---
const pathname = new URL(Astro.request.url).pathname;

const navItems = [
 {
 name: 'Repertorio',
 href: '/repertorio',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`
 },
 {
 name: 'Programación',
 href: '/programacion',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>`
 },
 {
 name: 'Equipo',
 href: '/equipo',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
 },
 {
 name: 'Herramientas',
 href: '/herramientas',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="12" x2="12" y1="18" y2="22"/></svg>`
 },
 {
 name: 'Perfil',
 href: '/perfil',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 20.662V19a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v1.662"/></svg>`
 }
];

// Helper to determine exact or path-based active states natively on server
const isActive = (href) => {
 if (href === '/') return pathname === '/';
 return pathname.startsWith(href);
};
---

<nav class="fixed bottom-0 w-full z-50 bg-white/85 backdrop-blur-xl border-t border-neutral-200 pb-safe shadow-[0_-4px_20px_-10px_rgba(0,0,0,0.1)]">
 <div class="max-w-md mx-auto grid grid-cols-5 px-2">
 {navItems.map((item) => {
 const active = isActive(item.href);
 return (
 <a 
 href={item.href} 
 id={`nav-item-${item.name.toLowerCase()}`}
 class={`flex flex-col items-center justify-center py-3 px-1 transition-all duration-300 relative ${active ? 'text-blue-600 ' : 'text-neutral-500 hover:text-neutral-900 :text-neutral-700'}`}
 >
 {item.name === 'Perfil' && (
 <span id="nav-badge-perfil" class="absolute top-2 right-4 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-white hidden z-10 transition-opacity"></span>
 )}
 {active && (
 <span class="absolute top-0 left-1/2 -translate-x-1/2 w-8 h-1 bg-blue-600 rounded-b-full"></span>
 )}
 <div 
 class={`w-6 h-6 mb-1 transition-transform duration-300 ${active ? 'scale-110' : 'scale-100'}`}
 set:html={item.icon}
 />
 <span class={`text-[10px] font-medium tracking-wide ${active ? 'font-bold' : ''}`}>
 {item.name}
 </span>
 </a>
 )
 })}
 </div>
</nav>

<style>
 /* Support for mobile safe areas (iOS notches/bars) */
 .pb-safe {
 padding-bottom: env(safe-area-inset-bottom);
 }
</style>

<script>
 import { supabase } from '../lib/supabase';

 document.addEventListener('DOMContentLoaded', async () => {
 const badge = document.getElementById('nav-badge-perfil');
 if (!badge) return;

 // 1. Get current logged in user
 const { data: { session } } = await supabase.auth.getSession();
 if (!session?.user) return;

 const userId = session.user.id;

 // 2. Fetch initial unread notifications count
 const { count, error } = await supabase
 .from('notificaciones')
 .select('*', { count: 'exact', head: true })
 .eq('perfil_id', userId)
 .eq('leido', false);

 if (!error && count && count > 0) {
 badge.classList.remove('hidden');
 }

 // 3. Subscribe to Realtime PostgreSQL events for this specific user
 const channel = supabase.channel('notificaciones-badge')
 .on(
 'postgres_changes',
 {
 event: 'INSERT',
 schema: 'public',
 table: 'notificaciones',
 filter: `perfil_id=eq.${userId}`
 },
 (payload) => {
 // Turn on badge when new notification arrives
 badge.classList.remove('hidden');
 }
 )
 .on(
 'postgres_changes',
 {
 event: 'UPDATE',
 schema: 'public',
 table: 'notificaciones',
 filter: `perfil_id=eq.${userId}`
 },
 async () => {
 // If a notification was updated (e.g. marked as read), re-check the count
 const { count } = await supabase
 .from('notificaciones')
 .select('*', { count: 'exact', head: true })
 .eq('perfil_id', userId)
 .eq('leido', false);
 
 if (count === 0) {
 badge.classList.add('hidden');
 }
 }
 )
 .subscribe();
 });
</script>
