---
import { supabase } from '../lib/supabase';
import MotionNavIcon from './react/MotionNavIcon.jsx';

const pathname = new URL(Astro.request.url).pathname;

// 1. SSR Auth Check for Layout Stability
let isAdmin = false;
const tokenCookie = Astro.cookies.get('sb-access-token');

if (tokenCookie) {
  const { data: { user } } = await supabase.auth.getUser(tokenCookie.value);
  if (user) {
    const { data: profile } = await supabase.from('perfiles').select('is_admin').eq('id', user.id).single();
    if (profile?.is_admin) {
      isAdmin = true;
    }
  }
}

const navItems = [
 {
 name: 'Inicio',
 href: '/',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`
 },
 {
 name: 'Repertorio',
 href: '/repertorio',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`
 },
 {
 name: 'Programaci\u00F3n',
 href: '/programacion',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>`
 },
 {
 name: 'Equipo',
 href: '/equipo',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
 adminOnly: true
 },
 {
 name: 'Herramientas',
 href: '/herramientas',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="12" x2="12" y1="18" y2="22"/></svg>`
 },
 {
 name: 'Configuraci\u00F3n',
 href: '/configuracion',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33h.01a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.01a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.01a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
 adminOnly: true
 },
 {
 name: 'Perfil',
 href: '/perfil',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 20.662V19a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v1.662"/></svg>`
 }
];

// Helper to determine exact or path-based active states natively on server
const isActive = (href) => {
 if (href === '/') return pathname === '/';
 return pathname.startsWith(href);
};

const visibleNavItems = navItems.filter((item) => !item.adminOnly || isAdmin);
const navGridStyle = `grid-template-columns: repeat(${visibleNavItems.length}, minmax(0, 1fr));`;
---

<nav transition:persist transition:animate="none" class="fixed bottom-0 w-full z-50 bg-surface/85 backdrop-blur-xl border-t border-border pt-1 pb-safe shadow-[0_-4px_20px_-10px_rgba(0,0,0,0.1)]">
 <div class="mx-auto grid w-full max-w-none px-2 md:max-w-xl" style={navGridStyle}>
 {visibleNavItems.map((item) => {
 const active = isActive(item.href);
 return (
 <a 
 href={item.href} 
 id={`nav-item-${item.name.toLowerCase()}`}
 data-nav-link="true"
 data-nav-href={item.href}
 data-astro-prefetch="hover"
 class={`nav-link flex min-w-0 flex-col items-center justify-center gap-0.5 py-3 px-1 transition-all duration-300 relative ${active ? 'text-brand ' : 'text-content-muted hover:text-content'}`}
 >
 {item.name === 'Perfil' && (
 <span id="nav-badge-perfil" class="absolute top-2 right-4 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-surface hidden z-10 transition-opacity"></span>
 )}
 <span data-nav-active-indicator class={`absolute top-0 left-1/2 -translate-x-1/2 w-8 h-1 bg-brand rounded-b-full ${active ? '' : 'hidden'}`}></span>
 <MotionNavIcon key={`nav-icon-${item.href}`} icon={item.icon} active={active} client:load />
  <span data-nav-label class={`block w-full truncate text-center text-[10px] font-medium tracking-wide ${active ? 'font-bold' : ''}`}>
  {item.name}
  </span>
 </a>
 )
 })}
 </div>
</nav>

<style>
 /* Support for mobile safe areas (iOS notches/bars) */
 .pb-safe {
 padding-bottom: calc(env(safe-area-inset-bottom) + 0.75rem);
 }

 .nav-link {
  will-change: transform, opacity;
  transform: translateZ(0);
  transition: transform 220ms cubic-bezier(0.42, 0, 0.58, 1), opacity 220ms cubic-bezier(0.42, 0, 0.58, 1);
 }

 .nav-link.nav-link-pressed {
  transform: translateZ(0) scale(0.93);
 }

 .nav-link.nav-link-loading [data-nav-label] {
  opacity: 0.88;
 }

 .nav-link.nav-link-loading [data-nav-icon] {
  animation: nav-icon-breathe 0.9s ease-in-out infinite;
 }

 @keyframes nav-icon-breathe {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
 }
</style>

<script>
 import { supabase } from '../lib/supabase';

 const initBottomNav = async () => {
 const navLinks = Array.from(document.querySelectorAll('a[data-nav-link="true"]'));
 if (!navLinks.length) return;

 const triggerHaptic = () => {
 try {
 if (typeof window !== 'undefined' && window.navigator?.vibrate) {
 window.navigator.vibrate(50);
 }
 } catch {
 // no-op
 }
 };

 const prefetchedHrefs = window.__REDIL_PREFETCHED_HREFS__ || new Set();
 window.__REDIL_PREFETCHED_HREFS__ = prefetchedHrefs;

 const supportsPrefetch = (() => {
 try {
 return Boolean(document.createElement('link').relList?.supports?.('prefetch'));
 } catch {
 return false;
 }
 })();

 const syncActiveState = () => {
 const currentPath = window.location.pathname;
 navLinks.forEach((link) => {
 const href = link.dataset.navHref || link.getAttribute('href') || '';
 if (!href) return;
 const active = href === '/' ? currentPath === '/' : currentPath.startsWith(href);

 link.classList.toggle('text-brand', active);
 link.classList.toggle('text-content-muted', !active);
 link.classList.toggle('hover:text-content', !active);

 const indicator = link.querySelector('[data-nav-active-indicator]');
 if (indicator) indicator.classList.toggle('hidden', !active);

 const label = link.querySelector('[data-nav-label]');
 if (label) label.classList.toggle('font-bold', active);
 });
 };

 const clearLoadingState = () => {
 navLinks.forEach((link) => {
 link.classList.remove('nav-link-loading');
 link.dataset.navLoading = 'false';
 });
 if (window.__REDIL_NAV_LOADING__?.stop) {
 window.__REDIL_NAV_LOADING__.stop();
 }
 };

 const setLoadingState = (targetLink) => {
 clearLoadingState();
 targetLink.classList.add('nav-link-loading');
 targetLink.dataset.navLoading = 'true';
 if (window.__REDIL_NAV_LOADING__?.start) {
 window.__REDIL_NAV_LOADING__.start();
 }
 };

 const prefetchRoute = (href) => {
 if (!href) return;

 let targetUrl;
 try {
 targetUrl = new URL(href, window.location.origin);
 } catch {
 return;
 }

 if (targetUrl.origin !== window.location.origin) return;
 if (targetUrl.pathname === window.location.pathname && targetUrl.search === window.location.search) return;
 if (prefetchedHrefs.has(targetUrl.href)) return;
 prefetchedHrefs.add(targetUrl.href);

 if (supportsPrefetch) {
 const link = document.createElement('link');
 link.rel = 'prefetch';
 link.as = 'document';
 link.href = targetUrl.href;
 document.head.appendChild(link);
 return;
 }

 fetch(targetUrl.href, { credentials: 'same-origin' }).catch(() => {
 // no-op
 });
 };

 navLinks.forEach((link) => {
 if (link.dataset.prefetchBound === 'true') return;
 const href = link.getAttribute('href') || '';
 if (!href) return;
 link.addEventListener('pointerenter', () => prefetchRoute(href), { passive: true });
 link.addEventListener('touchstart', () => prefetchRoute(href), { passive: true });
 link.addEventListener('pointerdown', () => {
 triggerHaptic();
 link.classList.add('nav-link-pressed');
 window.setTimeout(() => {
 link.classList.remove('nav-link-pressed');
 }, 180);
 }, { passive: true });
 link.addEventListener('pointerup', () => link.classList.remove('nav-link-pressed'), { passive: true });
 link.addEventListener('pointercancel', () => link.classList.remove('nav-link-pressed'), { passive: true });
 link.addEventListener('click', () => {
 const targetHref = link.dataset.navHref || link.getAttribute('href') || '';
 if (!targetHref) return;
 let targetUrl;
 try {
 targetUrl = new URL(targetHref, window.location.origin);
 } catch {
 return;
 }
 const isSameRoute =
 targetUrl.pathname === window.location.pathname &&
 targetUrl.search === window.location.search &&
 targetUrl.hash === window.location.hash;
 if (isSameRoute) return;
 setLoadingState(link);
 }, { passive: true });
 link.dataset.prefetchBound = 'true';
 });

 if (!window.__REDIL_NAV_ACTIVE_SYNC_BOUND__) {
 document.addEventListener('astro:after-swap', () => {
 clearLoadingState();
 syncActiveState();
 });
 document.addEventListener('astro:page-load', () => {
 clearLoadingState();
 syncActiveState();
 });
 window.addEventListener('popstate', () => {
 clearLoadingState();
 syncActiveState();
 });
 window.__REDIL_NAV_ACTIVE_SYNC_BOUND__ = true;
 }

 syncActiveState();

 const badge = document.getElementById('nav-badge-perfil');
 if (!badge || window.__REDIL_NAV_BADGE_BOUND__) return;
 window.__REDIL_NAV_BADGE_BOUND__ = true;

 const { data: { session } } = await supabase.auth.getSession();
 if (!session?.user) return;

 const userId = session.user.id;

 const { count, error } = await supabase
 .from('notificaciones')
 .select('*', { count: 'exact', head: true })
 .eq('perfil_id', userId)
 .eq('leido', false);

 if (!error && count && count > 0) {
 badge.classList.remove('hidden');
 }

 supabase.channel('notificaciones-badge')
 .on(
 'postgres_changes',
 {
 event: 'INSERT',
 schema: 'public',
 table: 'notificaciones',
 filter: `perfil_id=eq.${userId}`
 },
 () => {
 badge.classList.remove('hidden');
 }
 )
 .on(
 'postgres_changes',
 {
 event: 'UPDATE',
 schema: 'public',
 table: 'notificaciones',
 filter: `perfil_id=eq.${userId}`
 },
 async () => {
 const { count: unreadCount } = await supabase
 .from('notificaciones')
 .select('*', { count: 'exact', head: true })
 .eq('perfil_id', userId)
 .eq('leido', false);
 
 if (unreadCount === 0) {
 badge.classList.add('hidden');
 }
 }
 )
 .subscribe();
 };

 if (document.readyState === 'loading') {
 document.addEventListener('DOMContentLoaded', () => { initBottomNav(); }, { once: true });
 } else {
 initBottomNav();
 }
</script>


