---
const pathname = new URL(Astro.request.url).pathname;
const user = Astro.locals.user;
const perfil = Astro.locals.perfil;
const isAdmin = Boolean(user && perfil?.is_admin);

const navItems = [
 {
 name: 'Inicio',
 href: '/',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`
 },
 {
 name: 'Repertorio',
 href: '/repertorio',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`
 },
 {
 name: 'Programaci\u00F3n',
 href: '/programacion',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>`
 },
 {
 name: 'Equipo',
 href: '/equipo',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
 adminOnly: true
 },
 {
 name: 'Herramientas',
 href: '/herramientas',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="12" x2="12" y1="18" y2="22"/></svg>`
 },
 {
 name: 'Configuraci\u00F3n',
 href: '/configuracion',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33h.01a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.01a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.01a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
 adminOnly: true
 },
 {
 name: 'Perfil',
 href: '/perfil',
 icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 20.662V19a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v1.662"/></svg>`
 }
];

// Helper to determine exact or path-based active states natively on server
const isActive = (href: string) => {
 if (href === '/') return pathname === '/';
 return pathname.startsWith(href);
};

const visibleNavItems = navItems.filter((item) => !item.adminOnly || isAdmin);
const navGridStyle = `grid-template-columns: repeat(${visibleNavItems.length}, minmax(0, 1fr));`;
---

<nav data-bottom-nav="true" transition:persist transition:animate="none" class="bottom-nav-shell fixed bottom-0 w-full z-50 bg-surface/85 backdrop-blur-xl border-t border-border pt-1 pb-safe shadow-[0_-4px_20px_-10px_rgba(0,0,0,0.1)]">
 <div class="mx-auto grid w-full max-w-none px-2 md:max-w-xl" style={navGridStyle}>
 {visibleNavItems.map((item) => {
 const active = isActive(item.href);
 return (
 <a 
 href={item.href} 
 id={`nav-item-${item.name.toLowerCase()}`}
 data-nav-link="true"
 data-nav-href={item.href}
 data-astro-prefetch="hover"
 class={`nav-link ${active ? 'is-active text-brand ' : 'text-content-muted hover:text-content'} flex min-w-0 flex-col items-center justify-center gap-0.5 py-3 px-1 transition-all duration-300 relative`}
 >
 <span data-nav-active-indicator class={`absolute top-0 left-1/2 -translate-x-1/2 w-8 h-1 bg-brand rounded-b-full ${active ? '' : 'hidden'}`}></span>
 <span data-nav-icon class="nav-icon mb-1 flex h-6 w-6 origin-center items-center justify-center" set:html={item.icon}></span>
  <span data-nav-label class={`block w-full truncate text-center text-[10px] font-medium tracking-wide ${active ? 'font-bold' : ''}`}>
  {item.name}
  </span>
 </a>
 )
 })}
 </div>
</nav>

<style>
 /* Support for mobile safe areas (iOS notches/bars) */
 .pb-safe {
 padding-bottom: calc(env(safe-area-inset-bottom) + 0.75rem);
 }

 .bottom-nav-shell {
  isolation: isolate;
  overflow: hidden;
  background:
   linear-gradient(180deg, rgba(255,255,255,0.54), rgba(255,255,255,0.34));
  border-top-color: rgba(255,255,255,0.36);
  box-shadow:
   0 -18px 46px rgba(15,23,42,0.16),
   0 -1px 0 rgba(15,23,42,0.06),
   inset 0 1px 0 rgba(255,255,255,0.68),
   inset 0 -1px 0 rgba(255,255,255,0.24);
  transform: translate3d(0, 0, 0);
  opacity: 1;
  -webkit-backdrop-filter: blur(24px) saturate(2);
  backdrop-filter: blur(24px) saturate(2);
  will-change: transform, opacity;
  transition:
   transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
   opacity 700ms cubic-bezier(0.22, 1, 0.36, 1);
 }

 .bottom-nav-shell::before,
 .bottom-nav-shell::after {
  content: "";
  position: absolute;
  inset-inline: 0;
  pointer-events: none;
  z-index: 0;
 }

 .bottom-nav-shell::before {
  top: 0;
  height: 58%;
  background:
   linear-gradient(180deg, rgba(255,255,255,0.46), rgba(255,255,255,0.06) 58%, transparent);
  opacity: 0.82;
 }

 .bottom-nav-shell::after {
  bottom: 0;
  height: 72%;
  background:
   radial-gradient(120% 86% at 50% 100%, rgba(255,255,255,0.22), transparent 64%);
  opacity: 0.64;
 }

 .bottom-nav-shell > * {
  position: relative;
  z-index: 1;
 }

 :global(.dark) .bottom-nav-shell {
  background:
   linear-gradient(180deg, rgba(24,24,27,0.62), rgba(9,9,11,0.48));
  border-top-color: rgba(255,255,255,0.15);
  box-shadow:
   0 -22px 60px rgba(0,0,0,0.46),
   0 -1px 0 rgba(255,255,255,0.08),
   inset 0 1px 0 rgba(255,255,255,0.16),
   inset 0 -1px 0 rgba(255,255,255,0.04);
 }

 :global(.dark) .bottom-nav-shell::before {
  background:
   linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0.03) 58%, transparent);
  opacity: 0.84;
 }

 :global(.dark) .bottom-nav-shell::after {
  background:
   radial-gradient(120% 86% at 50% 100%, rgba(59,130,246,0.16), transparent 66%);
  opacity: 0.66;
 }

 @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
  .bottom-nav-shell {
   background: rgba(255,255,255,0.92);
  }

  :global(.dark) .bottom-nav-shell {
   background: rgba(9,9,11,0.92);
  }
 }

 .bottom-nav-shell.is-hidden {
  transform: translate3d(0, calc(100% + env(safe-area-inset-bottom) + 1.25rem), 0);
  opacity: 0;
  pointer-events: none;
 }

 :global(html[data-bottom-nav-hidden='true'] nav[data-bottom-nav='true']) {
  transform: translate3d(0, calc(100% + env(safe-area-inset-bottom) + 1.25rem), 0) !important;
  opacity: 0 !important;
  pointer-events: none !important;
 }

 .nav-link {
  will-change: transform, opacity;
  transform: translateZ(0);
  transition: transform 220ms cubic-bezier(0.42, 0, 0.58, 1), opacity 220ms cubic-bezier(0.42, 0, 0.58, 1);
 }

 .nav-icon {
  transform: translateY(0) scale(1);
  transition:
   transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
   opacity 220ms ease;
  will-change: transform;
 }

 .nav-link.is-active .nav-icon {
  transform: translateY(-1px) scale(1.13);
 }

 .nav-link.nav-link-pressed {
  transform: translateZ(0) scale(0.93);
 }

 .nav-link.nav-link-pressed .nav-icon {
  transform: translateY(1px) scale(0.8);
 }

 .nav-link.nav-link-loading [data-nav-label] {
  opacity: 0.88;
 }

 .nav-link.nav-link-loading [data-nav-icon] {
  animation: nav-icon-breathe 0.9s ease-in-out infinite;
 }

 @keyframes nav-icon-breathe {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
 }

 @media (prefers-reduced-motion: reduce) {
  .bottom-nav-shell {
   transition-duration: 1ms;
  }

  .nav-icon,
  .nav-link.nav-link-pressed .nav-icon,
  .nav-link.is-active .nav-icon {
   transition: transform 80ms linear;
  }

  .nav-link.is-active .nav-icon {
   transform: scale(1.08);
  }

  .nav-link.nav-link-pressed .nav-icon {
   transform: scale(0.96);
  }
 }
</style>

<script>
 const initBottomNav = async () => {
 const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('a[data-nav-link="true"]'));
 const bottomNav = document.querySelector<HTMLElement>('nav[data-bottom-nav="true"]');
 if (!navLinks.length || !bottomNav) return;

 const triggerHaptic = () => {
 try {
 if (typeof window !== 'undefined' && window.navigator?.vibrate) {
 window.navigator.vibrate(50);
 }
 } catch {
 // no-op
 }
 };

 const prefetchedHrefs: Set<string> = window.__REDIL_PREFETCHED_HREFS__ || new Set<string>();
 window.__REDIL_PREFETCHED_HREFS__ = prefetchedHrefs;

 const supportsPrefetch = (() => {
 try {
 return Boolean(document.createElement('link').relList?.supports?.('prefetch'));
 } catch {
 return false;
 }
 })();

 const syncActiveState = () => {
 const currentPath = window.location.pathname;
 navLinks.forEach((link) => {
 const href = link.dataset.navHref || link.getAttribute('href') || '';
 if (!href) return;
 const active = href === '/' ? currentPath === '/' : currentPath.startsWith(href);

 link.classList.toggle('is-active', active);
 link.classList.toggle('text-brand', active);
 link.classList.toggle('text-content-muted', !active);
 link.classList.toggle('hover:text-content', !active);

 const indicator = link.querySelector('[data-nav-active-indicator]');
 if (indicator) indicator.classList.toggle('hidden', !active);

 const label = link.querySelector('[data-nav-label]');
 if (label) label.classList.toggle('font-bold', active);
 });
 };

 const setBottomNavHiddenState = (hidden: boolean) => {
 const nav = document.querySelector('nav[data-bottom-nav="true"]');
 document.documentElement.dataset.bottomNavHidden = hidden ? 'true' : 'false';
 if (nav) nav.classList.toggle('is-hidden', hidden);
 window.__REDIL_BOTTOM_NAV_HIDDEN__ = hidden;
 };

 const showBottomNav = () => {
 setBottomNavHiddenState(false);
 };

 if (!window.__REDIL_BOTTOM_NAV_SCROLL_BOUND__) {
 let lastWindowScrollY = Math.max(window.scrollY, 0);
 const scrollPositions = new WeakMap<Element, number>();
 let ticking = false;

 const getScrollTarget = (event: Event): Window | Element => {
 const target = event?.target;
 if (
 target instanceof Element &&
 target !== document.documentElement &&
 target !== document.body &&
 target.scrollHeight - target.clientHeight > 1
 ) {
 return target;
 }
 return window;
 };

 const getCurrentScrollY = (scrollTarget: Window | Element) => {
 if (scrollTarget instanceof Element) return Math.max(scrollTarget.scrollTop, 0);
 return Math.max(window.scrollY, 0);
 };

 const getLastScrollY = (scrollTarget: Window | Element) => {
 if (scrollTarget instanceof Element) return scrollPositions.get(scrollTarget) ?? 0;
 return lastWindowScrollY;
 };

 const setLastScrollY = (scrollTarget: Window | Element, currentScrollY: number) => {
 if (scrollTarget instanceof Element) scrollPositions.set(scrollTarget, currentScrollY);
 else lastWindowScrollY = currentScrollY;
 };

 const handleScroll = (event: Event) => {
 if (ticking) return;
 ticking = true;

 window.requestAnimationFrame(() => {
 const scrollTarget = getScrollTarget(event);
 const currentScrollY = getCurrentScrollY(scrollTarget);
 const lastScrollY = getLastScrollY(scrollTarget);
 const diff = currentScrollY - lastScrollY;
 const activeElement = document.activeElement;
 const nav = document.querySelector('nav[data-bottom-nav="true"]');
 const navFocused = Boolean(activeElement && nav?.contains(activeElement));

 if (currentScrollY <= 80 || navFocused) {
 setBottomNavHiddenState(false);
 setLastScrollY(scrollTarget, currentScrollY);
 ticking = false;
 return;
 }

 if (Math.abs(diff) >= 8) {
 if (diff > 0 && currentScrollY > 120) {
 setBottomNavHiddenState(true);
 } else if (diff < 0) {
 setBottomNavHiddenState(false);
 }

 setLastScrollY(scrollTarget, currentScrollY);
 }

 ticking = false;
 });
 };

 const scrollListenerTargets = new WeakSet<Element>();
 let scrollBindingScheduled = false;
 let scrollContainerObserver: MutationObserver | null = null;
 let observedScrollObserverBody: HTMLElement | null = null;
 const scrollContainerSelector = [
 '[data-bottom-nav-scroll-root]',
 '[id$="scroll-root"]',
 '[class*="overflow-y-auto"]',
 '[class*="overflow-y-scroll"]',
 '[class*="overflow-auto"]',
 'main'
 ].join(',');

 const isVerticalScrollContainer = (element: Element) => {
 if (!(element instanceof Element)) return false;
 if (element === document.documentElement || element === document.body) return false;
 if (element.scrollHeight - element.clientHeight <= 1) return false;
 const style = window.getComputedStyle(element);
 return /(auto|scroll|overlay)/.test(style.overflowY);
 };

 const bindScrollTarget = (element: Element) => {
 if (!isVerticalScrollContainer(element) || scrollListenerTargets.has(element)) return;
 element.addEventListener('scroll', handleScroll, { passive: true });
 scrollListenerTargets.add(element);
 };

 const bindScrollableContainers = () => {
 document.querySelectorAll<Element>(scrollContainerSelector).forEach(bindScrollTarget);
 };

 const scheduleScrollableContainerBinding = () => {
 if (scrollBindingScheduled) return;
 scrollBindingScheduled = true;
 window.requestAnimationFrame(() => {
 scrollBindingScheduled = false;
 bindScrollableContainers();
 });
 window.setTimeout(bindScrollableContainers, 450);
 window.setTimeout(bindScrollableContainers, 1200);
 };

 const observeScrollableContainerMounts = () => {
 if (!('MutationObserver' in window) || observedScrollObserverBody === document.body) return;
 if (scrollContainerObserver) scrollContainerObserver.disconnect();
 observedScrollObserverBody = document.body;
 scrollContainerObserver = new MutationObserver((mutations) => {
 const hasAddedElements = mutations.some((mutation) =>
 Array.from(mutation.addedNodes).some((node) => node instanceof Element)
 );
 if (hasAddedElements) scheduleScrollableContainerBinding();
 });
 scrollContainerObserver.observe(document.body, { childList: true, subtree: true });
 };

 window.addEventListener('scroll', handleScroll, { passive: true });
 document.addEventListener('scroll', handleScroll, { passive: true, capture: true });
 observeScrollableContainerMounts();
 scheduleScrollableContainerBinding();
 window.addEventListener('focusin', () => {
 const nav = document.querySelector('nav[data-bottom-nav="true"]');
 if (nav?.contains(document.activeElement)) setBottomNavHiddenState(false);
 });
 document.addEventListener('astro:before-swap', () => setBottomNavHiddenState(false));
 document.addEventListener('astro:after-swap', () => {
 lastWindowScrollY = Math.max(window.scrollY, 0);
 setBottomNavHiddenState(false);
 observeScrollableContainerMounts();
 scheduleScrollableContainerBinding();
 });
 document.addEventListener('astro:page-load', () => {
 lastWindowScrollY = Math.max(window.scrollY, 0);
 setBottomNavHiddenState(false);
 observeScrollableContainerMounts();
 scheduleScrollableContainerBinding();
 });
 window.addEventListener('resize', scheduleScrollableContainerBinding, { passive: true });

 window.__REDIL_BOTTOM_NAV_SCROLL_BOUND__ = true;
 }

 const clearLoadingState = () => {
 navLinks.forEach((link) => {
 link.classList.remove('nav-link-loading');
 link.dataset.navLoading = 'false';
 });
 if (window.__REDIL_NAV_LOADING__?.stop) {
 window.__REDIL_NAV_LOADING__.stop();
 }
 };

 const setLoadingState = (targetLink: HTMLAnchorElement) => {
 clearLoadingState();
 targetLink.classList.add('nav-link-loading');
 targetLink.dataset.navLoading = 'true';
 if (window.__REDIL_NAV_LOADING__?.start) {
 window.__REDIL_NAV_LOADING__.start();
 }
 };

 const prefetchRoute = (href: string) => {
 if (!href) return;

 let targetUrl;
 try {
 targetUrl = new URL(href, window.location.origin);
 } catch {
 return;
 }

 if (targetUrl.origin !== window.location.origin) return;
 if (targetUrl.pathname === window.location.pathname && targetUrl.search === window.location.search) return;
 if (prefetchedHrefs.has(targetUrl.href)) return;
 prefetchedHrefs.add(targetUrl.href);

 if (supportsPrefetch) {
 const link = document.createElement('link');
 link.rel = 'prefetch';
 link.as = 'document';
 link.href = targetUrl.href;
 document.head.appendChild(link);
 return;
 }

 fetch(targetUrl.href, { credentials: 'same-origin' }).catch(() => {
 // no-op
 });
 };

 navLinks.forEach((link) => {
 if (link.dataset.prefetchBound === 'true') return;
 const href = link.getAttribute('href') || '';
 if (!href) return;
 link.addEventListener('pointerenter', () => prefetchRoute(href), { passive: true });
 link.addEventListener('touchstart', () => prefetchRoute(href), { passive: true });
 link.addEventListener('pointerdown', () => {
 showBottomNav();
 triggerHaptic();
 link.classList.add('nav-link-pressed');
 window.setTimeout(() => {
 link.classList.remove('nav-link-pressed');
 }, 180);
 }, { passive: true });
 link.addEventListener('pointerup', () => link.classList.remove('nav-link-pressed'), { passive: true });
 link.addEventListener('pointercancel', () => link.classList.remove('nav-link-pressed'), { passive: true });
 link.addEventListener('click', () => {
 const targetHref = link.dataset.navHref || link.getAttribute('href') || '';
 if (!targetHref) return;
 let targetUrl;
 try {
 targetUrl = new URL(targetHref, window.location.origin);
 } catch {
 return;
 }
 const isSameRoute =
 targetUrl.pathname === window.location.pathname &&
 targetUrl.search === window.location.search &&
 targetUrl.hash === window.location.hash;
 if (isSameRoute) return;
 setLoadingState(link);
 }, { passive: true });
 link.dataset.prefetchBound = 'true';
 });

 if (!window.__REDIL_NAV_ACTIVE_SYNC_BOUND__) {
 document.addEventListener('astro:after-swap', () => {
 clearLoadingState();
 syncActiveState();
 });
 document.addEventListener('astro:page-load', () => {
 clearLoadingState();
 syncActiveState();
 });
 window.addEventListener('popstate', () => {
 clearLoadingState();
 syncActiveState();
 });
 window.__REDIL_NAV_ACTIVE_SYNC_BOUND__ = true;
 }

 syncActiveState();

 };

 if (document.readyState === 'loading') {
 document.addEventListener('DOMContentLoaded', () => { initBottomNav(); }, { once: true });
 } else {
 initBottomNav();
 }
</script>
