                <span id="mp3Duration" class="w-12 text-xs font-semibold tabular-nums text-white/58">00:00</span>
              </div>

              <div class="mt-4 grid grid-cols-[auto_1fr_auto] items-center gap-2">
                <button id="btnMp3Back5" type="button" class="h-11 rounded-full bg-white/8 px-3.5 text-sm font-bold text-white transition-colors hover:bg-white/14" aria-label="Retroceder 5 segundos">-5s</button>
                <button id="btnMp3PlayPause" type="button" class="inline-flex h-11 w-full items-center justify-center gap-2 rounded-full bg-white text-[#111113] shadow-lg transition-colors hover:bg-white/88" aria-label="Reproducir">
                  <svg id="mp3PlayIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M8 5v14l11-7z"></path></svg>
                  <span id="mp3PlayLabel" class="text-sm font-semibold tracking-wide">Reproducir</span>
                </button>
                <button id="btnMp3Forward5" type="button" class="h-11 rounded-full bg-white/8 px-3.5 text-sm font-bold text-white transition-colors hover:bg-white/14" aria-label="Adelantar 5 segundos">+5s</button>
              </div>

              <div class="mt-3 flex items-center gap-3">
                <button id="btnMp3Mute" type="button" class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white/8 text-white/74 transition-colors hover:bg-white/14 hover:text-white" aria-label="Silenciar">
                  <svg id="mp3VolumeIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H3v6h3l5 4V5Z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M18.36 5.64a9 9 0 0 1 0 12.73"/></svg>
                </button>
                <input id="mp3Volume" type="range" min="0" max="1" step="0.01" value="0.85" class="mp3-volume-slider flex-1" aria-label="Volumen" />
              </div>

              <div class="mt-3 hidden flex-wrap items-center justify-between gap-2">
                <label class="inline-flex items-center gap-2 text-sm font-semibold text-content">
                  <input id="chkLoopRange" type="checkbox" class="h-4 w-4 rounded border-border accent-action" />
                  Loop A/B
                </label>
                <button id="btnClearLoopRange" type="button" class="rounded-xl border border-border bg-surface px-3 py-1.5 text-xs font-bold text-content transition-colors hover:bg-background">Limpiar</button>
              </div>
              <p id="mp3LoopInfo" class="mt-2 hidden text-xs text-content-muted">[A] 00:00 - [B] 00:00</p>
              <p id="mp3Status" class="mt-3 hidden text-xs leading-tight text-white/52">Cargando audio...</p>
            </div>

            <div class="mt-4 hidden rounded-2xl border border-border bg-background/60 p-3">
              <div class="grid grid-cols-3 gap-2">
                <button id="btnMp3PrevSection" type="button" class="h-10 rounded-xl border border-border bg-surface text-xs font-black text-content transition-colors hover:bg-background">Anterior</button>
                <button id="btnMp3LoopSection" type="button" class="h-10 rounded-xl border border-brand/25 bg-brand/10 text-xs font-black text-brand transition-colors hover:bg-brand/15">Loop seccion</button>
                <button id="btnMp3NextSection" type="button" class="h-10 rounded-xl border border-border bg-surface text-xs font-black text-content transition-colors hover:bg-background">Siguiente</button>
              </div>
              <div id="mp3SectionStrip" class="mt-3 flex max-h-44 flex-col gap-1.5 overflow-y-auto pr-1"></div>
            </div>
          </section>

          <section class="order-1 min-h-0 flex-1 p-4 pb-2 md:p-6 md:pb-3">
            <div class="sr-only mb-3 flex items-center justify-between gap-3">
              <div class="min-w-0">
                <p class="text-[10px] font-black uppercase tracking-[0.24em] text-content-muted">Karaoke</p>
                <h4 id="mp3ActiveSectionTitle" class="truncate text-base font-black text-content">Sin secciones</h4>
              </div>
              <div class="inline-flex shrink-0 rounded-xl border border-border bg-background p-1">
                <button id="btnMp3ModeLyrics" type="button" class="mp3-mode-btn is-active h-8 rounded-lg px-3 text-xs font-black">Letra</button>
                <button id="btnMp3ModeMap" type="button" class="mp3-mode-btn h-8 rounded-lg px-3 text-xs font-black">Mapa</button>
              </div>
            </div>
            <div id="mp3KaraokePanel" class="h-full min-h-[24rem] overflow-y-auto rounded-2xl border border-transparent bg-transparent p-1 md:min-h-0 md:p-3">
              <div id="mp3KaraokeEmpty" class="grid h-full place-items-center text-center text-sm text-white/50">Esta cancion todavia no tiene letra sincronizable.</div>
              <div id="mp3KaraokeLyrics" class="hidden space-y-2"></div>
              <div id="mp3KaraokeMap" class="hidden space-y-2"></div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { audioSessionService } from '../services/AudioSessionService';
  import {
    buildPlaybackSourceCandidates,
    extractDriveFileId,
    shouldPreferNativeBackgroundPlayback,
  } from '../lib/audio-playback.js';

  (() => {
    if (window.__REDIL_PRO_PLAYER_READY__) return;
    window.__REDIL_PRO_PLAYER_READY__ = true;

    const MODAL_PREMIUM_MS = 300;

    const modal = document.getElementById('mp3PlayerModal');
    const backdrop = document.getElementById('mp3PlayerBackdrop');
    const panel = document.getElementById('mp3PlayerPanel');
    const mini = document.getElementById('mp3MiniPlayer');
    const audio = document.getElementById('mp3Audio');

    const titleEl = document.getElementById('mp3Title');
    const artistEl = document.getElementById('mp3Artist');
    const miniTitleEl = document.getElementById('mp3MiniTitle');
    const miniArtistEl = document.getElementById('mp3MiniArtist');
    const miniTimeEl = document.getElementById('mp3MiniTime');
    const miniProgressEl = document.getElementById('mp3MiniProgress');
    const artworkEl = document.getElementById('mp3Artwork');
    const miniArtworkEl = document.getElementById('mp3MiniArtwork');
    const artworkFallbackEl = document.getElementById('mp3ArtworkFallback');
    const miniArtworkFallbackEl = document.getElementById('mp3MiniArtworkFallback');
    const liveIndicatorEl = document.getElementById('mp3LiveIndicator');
    const statusEl = document.getElementById('mp3Status');

    const btnClose = document.getElementById('btnMp3Close');
    const btnCollapse = document.getElementById('btnMp3Collapse');
    const btnMiniClose = document.getElementById('btnMp3MiniClose');
    const btnExpand = document.getElementById('btnMp3Expand');
    const btnExpandIcon = document.getElementById('btnMp3MiniExpandIcon');
    const btnPlay = document.getElementById('btnMp3PlayPause');
    const btnMiniPlay = document.getElementById('btnMp3MiniPlay');
    const btnMute = document.getElementById('btnMp3Mute');
    const btnMiniMute = document.getElementById('btnMp3MiniMute');
    const btnBack5 = document.getElementById('btnMp3Back5');
    const btnForward5 = document.getElementById('btnMp3Forward5');
    const playIcon = document.getElementById('mp3PlayIcon');
    const miniPlayIcon = document.getElementById('mp3MiniPlayIcon');
    const volumeIcon = document.getElementById('mp3VolumeIcon');
    const miniVolumeIcon = document.getElementById('mp3MiniVolumeIcon');
    const playLabel = document.getElementById('mp3PlayLabel');

    const timelineWrap = document.getElementById('mp3TimelineWrap');
    const waveformCanvas = document.getElementById('mp3Waveform');
    const seek = document.getElementById('mp3Seek');
    const volume = document.getElementById('mp3Volume');
    const miniVolume = document.getElementById('mp3MiniVolume');
    const currentEl = document.getElementById('mp3CurrentTime');
    const durationEl = document.getElementById('mp3Duration');

    const chkLoop = document.getElementById('chkLoopRange');
    const loopInfo = document.getElementById('mp3LoopInfo');
    const loopBracket = document.getElementById('mp3LoopBracket');
    const loopFill = document.getElementById('mp3LoopRangeFill');
    const handleA = document.getElementById('mp3LoopHandleA');
    const handleB = document.getElementById('mp3LoopHandleB');
    const btnClearLoop = document.getElementById('btnClearLoopRange');
    const btnPrevSection = document.getElementById('btnMp3PrevSection');
    const btnNextSection = document.getElementById('btnMp3NextSection');
    const btnLoopSection = document.getElementById('btnMp3LoopSection');
    const sectionStrip = document.getElementById('mp3SectionStrip');
    const activeSectionTitle = document.getElementById('mp3ActiveSectionTitle');
    const karaokeEmpty = document.getElementById('mp3KaraokeEmpty');
    const karaokePanel = document.getElementById('mp3KaraokePanel');
    const karaokeLyrics = document.getElementById('mp3KaraokeLyrics');
    const karaokeMap = document.getElementById('mp3KaraokeMap');
    const btnModeLyrics = document.getElementById('btnMp3ModeLyrics');
    const btnModeMap = document.getElementById('btnMp3ModeMap');

    if (
      !modal || !backdrop || !panel || !mini || !audio || !titleEl || !artistEl ||
      !miniTitleEl || !miniArtistEl || !miniTimeEl || !miniProgressEl ||
      !artworkEl || !miniArtworkEl || !artworkFallbackEl || !miniArtworkFallbackEl ||
      !liveIndicatorEl || !statusEl ||
      !btnClose || !btnCollapse || !btnMiniClose || !btnExpand || !btnExpandIcon ||
      !btnPlay || !btnMiniPlay || !btnMute || !btnMiniMute || !btnBack5 ||
      !btnForward5 || !playIcon || !miniPlayIcon || !volumeIcon || !miniVolumeIcon ||
      !playLabel || !timelineWrap || !waveformCanvas || !seek || !volume ||
      !miniVolume || !currentEl || !durationEl || !chkLoop || !loopInfo || !loopBracket ||
      !loopFill || !handleA || !handleB || !btnClearLoop || !btnPrevSection ||
      !btnNextSection || !btnLoopSection || !sectionStrip || !activeSectionTitle ||
      !karaokeEmpty || !karaokePanel || !karaokeLyrics || !karaokeMap || !btnModeLyrics || !btnModeMap
    ) {
      return;
    }

    const prefersNativeBackgroundPlayback = shouldPreferNativeBackgroundPlayback();
    const useWaveformAnalyser = false;

    audioSessionService.install();
    audioSessionService.registerPrimaryAudio(
      'pro-player-global',
      {
        audioElement: audio,
        onPlay: async () => {
          await setupWaveform().catch(() => {});
          if (waveCtx && waveCtx.state === 'suspended') await waveCtx.resume();
          await audio.play();
        },
        onPause: () => audio.pause(),
      },
      10
    );

    let totalDuration = 0;
    let loopStartSec = 0;
    let loopEndSec = 0;
    let isSeekingAudio = false;
    let draggingLoopHandle = null;

    let sourceCandidates = [];
    let sourceIndex = 0;
    let requestedPlay = false;
    let activeSectionIndex = -1;
    let activeCueIndex = -1;
    let currentSections = [];
    let lyricSections = [];
    let lyricCues = [];
    let karaokeMode = 'lyrics';
    let closingPlayer = false;
    let lastVolume = Number(window.localStorage?.getItem('redil:pro-player-volume') || 0.85);
    let artworkRequestId = 0;

    let waveRaf = 0;
    let waveCtx = null;
    let waveSource = null;
    let waveAnalyser = null;
    let waveData = null;
    let lockedScrollY = 0;

    const formatTime = (seconds) => {
      if (!Number.isFinite(seconds) || seconds < 0) return '00:00';
      const total = Math.floor(seconds);
      const min = Math.floor(total / 60);
      const sec = total % 60;
      return `${String(min).padStart(2, '0')}:${String(sec).padStart(2, '0')}`;
    };

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const normalizeLabel = (value = '') => String(value || '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, ' ')
      .trim();

    const buildSourceCandidates = (rawUrl) => buildPlaybackSourceCandidates(rawUrl, { origin: window.location.origin });

    const stripChordProLine = (line = '') => String(line || '')
      .replace(/\{[^}]*\}/g, '')
      .replace(/\[[^\]]+\]/g, '')
      .replace(/\s+/g, ' ')
      .trim();

    const isChordLikeToken = (value = '') => /^[A-G](?:#|b)?(?:m|maj|min|dim|aug|sus|add)?\d*(?:\/[A-G](?:#|b)?)?$/i.test(String(value || '').trim());

    const isSectionHeading = (value = '') => {
      const label = String(value || '').split('|')[0].trim();
      if (!label) return false;
      const key = normalizeLabel(label);
      if (/^(intro|verso|pre coro|precoro|coro|interludio|puente|solo|final|outro|tag|entrada|salida)(\s+\d+)?$/.test(key)) return true;
      if (/\s/.test(label) && !label.split(/\s+/).every(isChordLikeToken)) return true;
      return !isChordLikeToken(label) && !/^[A-G](?:#|b)?$/i.test(label);
    };

    const parseChordProSections = (rawChordpro = '') => {
      const source = String(rawChordpro || '').replace(/\r\n/g, '\n');
      if (!source.trim()) return [];

      const sections = [];
      let current = { name: 'Letra', lines: [] };
      const pushCurrent = () => {
        if (current.name !== 'Letra' || current.lines.some(Boolean)) {
          sections.push({ ...current, lines: current.lines.filter(Boolean) });
        }
      };

      source.split('\n').forEach((rawLine) => {
        const line = rawLine.trim();
        if (!line) return;

        const sectionDirective =
          line.match(/^\{(?:section|s|comment|c):\s*([^}]+)\}$/i) ||
          line.match(/^\{start_of_([^}:]+)(?::\s*([^}]+))?\}$/i);

        if (sectionDirective) {
          pushCurrent();
          current = {
            name: (sectionDirective[2] || sectionDirective[1] || 'Seccion').replace(/_/g, ' '),
            lines: [],
          };
          return;
        }

        if (/^\{(?:title|t|subtitle|artist|key|tempo|end_of_|eoc|eov)/i.test(line)) return;

        const bracketHeading = line.match(/^\[([^\]]+)\]\s*$/);
        if (bracketHeading && isSectionHeading(bracketHeading[1])) {
          pushCurrent();
          current = {
            name: bracketHeading[1].split('|')[0].trim() || 'Seccion',
            lines: [],
          };
          return;
        }

        const lyric = stripChordProLine(line);
        if (lyric) current.lines.push(lyric);
      });

      pushCurrent();
      return sections;
    };

    const normalizeSectionMarkers = (markers = [], duration = 0) => {
      if (!Array.isArray(markers)) return [];
      const normalized = markers
        .map((marker, index) => {
          const start = Number(marker?.startSec ?? marker?.start_sec ?? marker?.time ?? marker?.seconds);
          if (!Number.isFinite(start) || start < 0) return null;
          return {
            id: marker?.id || `section-${index}`,
            label: String(marker?.sectionName || marker?.name || marker?.label || marker?.title || `Seccion ${index + 1}`).trim() || `Seccion ${index + 1}`,
            startSec: start,
            endSec: Number.isFinite(Number(marker?.endSec ?? marker?.end_sec)) ? Number(marker?.endSec ?? marker?.end_sec) : null,
            lyricIndex: -1,
          };
        })
        .filter(Boolean)
        .sort((a, b) => a.startSec - b.startSec);

      return normalized.map((marker, index) => ({
        ...marker,
        endSec: Number.isFinite(marker.endSec) && marker.endSec > marker.startSec
          ? marker.endSec
          : (normalized[index + 1]?.startSec ?? duration ?? 0),
      }));
    };

    const baseSectionLabel = (value = '') => normalizeLabel(String(value || '').split('|')[0])
      .replace(/\b\d+\b/g, '')
      .replace(/\s+/g, ' ')
      .trim();

    const attachLyricsToSections = (sections, lyrics) => {
      const usedLyrics = new Set();
      return sections.map((section, index) => {
        const sectionKey = normalizeLabel(section.label);
        const sectionBase = baseSectionLabel(section.label);
        let lyricIndex = lyrics.findIndex((lyric, candidateIndex) => (
          !usedLyrics.has(candidateIndex) && normalizeLabel(lyric.name) === sectionKey
        ));
        if (lyricIndex === -1) {
          lyricIndex = lyrics.findIndex((lyric, candidateIndex) => (
            !usedLyrics.has(candidateIndex) && baseSectionLabel(lyric.name) === sectionBase
          ));
        }
        if (lyricIndex === -1 && lyrics[index]) lyricIndex = index;
        if (lyricIndex !== -1) usedLyrics.add(lyricIndex);
        return { ...section, lyricIndex };
      });
    };

    const buildLyricCues = (sections, lyrics, duration = 0) => {
      const cues = [];
      const pushLines = (lines, startSec, endSec, sectionIndex = -1) => {
        const cleanLines = (lines || []).map((line) => String(line || '').trim()).filter(Boolean);
        if (!cleanLines.length) return;
        const safeStart = Number.isFinite(startSec) ? Math.max(0, startSec) : 0;
        const fallbackEnd = Number.isFinite(duration) && duration > safeStart ? duration : safeStart + cleanLines.length * 4;
        const safeEnd = Number.isFinite(endSec) && endSec > safeStart ? endSec : fallbackEnd;
        const span = Math.max(cleanLines.length * 1.8, safeEnd - safeStart);
        cleanLines.forEach((line, lineIndex) => {
          const cueStart = safeStart + (span * lineIndex) / cleanLines.length;
          const cueEnd = safeStart + (span * (lineIndex + 1)) / cleanLines.length;
          cues.push({
            text: line,
            startSec: cueStart,
            endSec: cueEnd,
            sectionIndex,
          });
        });
      };

      if (sections.length) {
        sections.forEach((section, sectionIndex) => {
          const lyric = lyrics[section.lyricIndex] || null;
          pushLines(lyric?.lines || [], section.startSec, section.endSec, sectionIndex);
        });
      } else {
        const allLines = lyrics.flatMap((section) => section.lines || []);
        pushLines(allLines, 0, duration, -1);
      }

      return cues.sort((a, b) => a.startSec - b.startSec);
    };

    const setSource = (index) => {
      const nextUrl = sourceCandidates[index] || '';
      if (!nextUrl) return false;
      audio.src = nextUrl;
      audio.load();
      return true;
    };

    const tryNextSource = (autoPlay = false) => {
      if (sourceIndex + 1 >= sourceCandidates.length) return false;
      sourceIndex += 1;
      const ok = setSource(sourceIndex);
      if (!ok) return false;
      statusEl.textContent = `Probando fuente alterna (${sourceIndex + 1}/${sourceCandidates.length})...`;
      if (autoPlay) void audio.play().catch(() => {});
      return true;
    };

    const setArtworkFallback = (title = '', artist = '') => {
      artworkEl.classList.add('hidden');
      miniArtworkEl.classList.add('hidden');
      artworkEl.removeAttribute('src');
      miniArtworkEl.removeAttribute('src');
      artworkEl.alt = '';
      miniArtworkEl.alt = '';
      artworkFallbackEl.classList.remove('hidden');
      miniArtworkFallbackEl.classList.remove('hidden');
      artworkFallbackEl.setAttribute('aria-label', `${title || 'Cancion'} ${artist || ''}`.trim());
      miniArtworkFallbackEl.setAttribute('aria-label', `${title || 'Cancion'} ${artist || ''}`.trim());
    };

    const setArtworkImage = (src, title, artist) => {
      const artworkSrc = String(src || '').trim();
      if (!artworkSrc) {
        setArtworkFallback(title, artist);
        return;
      }

      artworkEl.alt = `Portada de ${title || 'cancion'}${artist ? ` - ${artist}` : ''}`;
      miniArtworkEl.alt = artworkEl.alt;
      artworkEl.onload = () => {
        artworkEl.classList.remove('hidden');
        artworkFallbackEl.classList.add('hidden');
      };
      miniArtworkEl.onload = () => {
        miniArtworkEl.classList.remove('hidden');
        miniArtworkFallbackEl.classList.add('hidden');
      };
      artworkEl.onerror = () => setArtworkFallback(title, artist);
      miniArtworkEl.onerror = () => setArtworkFallback(title, artist);
      artworkEl.src = artworkSrc;
      miniArtworkEl.src = artworkSrc;
    };

    const toArtworkSrc = (rawUrl = '') => {
      const cleanUrl = String(rawUrl || '').trim();
      if (!cleanUrl) return '';
      const fileId = extractDriveFileId(cleanUrl);
      return fileId ? `https://drive.google.com/thumbnail?id=${fileId}&sz=w512` : cleanUrl;
    };

    const toEmbeddedCoverApiUrl = (rawUrl = '') => {
      const cleanUrl = String(rawUrl || '').trim();
      if (!cleanUrl) return '';
      return `${window.location.origin}/api/mp3-cover-art?src=${encodeURIComponent(cleanUrl)}`;
    };

    const setArtworkFromSource = (rawUrl, title, artist, artworkUrl = '') => {
      const requestId = artworkRequestId + 1;
      artworkRequestId = requestId;
      const explicitArtwork = toArtworkSrc(artworkUrl);
      if (explicitArtwork) {
        setArtworkImage(explicitArtwork, title, artist);
        return;
      }

      setArtworkFallback(title, artist);
      if (requestId === artworkRequestId) setArtworkImage(toEmbeddedCoverApiUrl(rawUrl), title, artist);
    };

    const stopWaveform = () => {
      if (waveRaf) {
        cancelAnimationFrame(waveRaf);
        waveRaf = 0;
      }
    };

    const setupWaveform = async () => {
      if (!useWaveformAnalyser || prefersNativeBackgroundPlayback) return;
      if (waveAnalyser && waveData) return;
      const AudioCtx = window.AudioContext || window.webkitAudioContext;
      if (!AudioCtx) return;

      try {
        waveCtx = waveCtx || new AudioCtx();
        if (!waveSource) waveSource = waveCtx.createMediaElementSource(audio);
        waveAnalyser = waveAnalyser || waveCtx.createAnalyser();
        waveAnalyser.fftSize = 1024;
        waveData = new Uint8Array(waveAnalyser.fftSize);

        try { waveSource.disconnect(); } catch {}
        try { waveAnalyser.disconnect(); } catch {}
        waveSource.connect(waveAnalyser);
        waveAnalyser.connect(waveCtx.destination);
      } catch {
        waveAnalyser = null;
        waveData = null;
      }
    };

    const drawWaveformFrame = () => {
      if (!waveAnalyser || !waveData) return;
      const rect = waveformCanvas.getBoundingClientRect();
      if (!rect.width || !rect.height) return;
      const dpr = window.devicePixelRatio || 1;
      const targetW = Math.floor(rect.width * dpr);
      const targetH = Math.floor(rect.height * dpr);
      if (waveformCanvas.width !== targetW || waveformCanvas.height !== targetH) {
        waveformCanvas.width = targetW;
        waveformCanvas.height = targetH;
      }

      const ctx = waveformCanvas.getContext('2d');
      if (!ctx) return;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, rect.width, rect.height);

      waveAnalyser.getByteTimeDomainData(waveData);
      const midY = rect.height / 2;
      const amp = rect.height * 0.34;
      const step = rect.width / (waveData.length - 1);
      ctx.lineWidth = 1.25;
      ctx.strokeStyle = audio.paused ? 'rgba(96,165,250,0.35)' : 'rgba(16,185,129,0.74)';
      ctx.beginPath();
      for (let i = 0; i < waveData.length; i += 1) {
        const x = i * step;
        const y = midY + ((waveData[i] - 128) / 128) * amp;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.stroke();
    };

    const runWaveform = () => {
      stopWaveform();
      const tick = () => {
        drawWaveformFrame();
        if (!audio.paused && !audio.ended) waveRaf = requestAnimationFrame(tick);
        else waveRaf = 0;
      };
      tick();
    };

    const syncPlaybackWaveform = () => {
      if (waveAnalyser) drawWaveformFrame();
    };

    const setLiveIndicatorState = (isPlaying) => {
      liveIndicatorEl.classList.toggle('mp3-live-on', isPlaying);
    };

    const renderPlayIcon = (isPlaying) => {
      const html = isPlaying
        ? '<path d="M8 5h3v14H8zM13 5h3v14h-3z"></path>'
        : '<path d="M8 5v14l11-7z"></path>';
      playIcon.innerHTML = html;
      miniPlayIcon.innerHTML = html;
    };

    const setPlayButtonState = (isPlaying) => {
      modal.classList.toggle('mp3-playing', isPlaying);
      mini.classList.toggle('mp3-playing', isPlaying);
      setLiveIndicatorState(isPlaying);
      renderPlayIcon(isPlaying);

      playLabel.textContent = isPlaying ? 'Pausar' : 'Reproducir';
      btnPlay.setAttribute('aria-label', isPlaying ? 'Pausar' : 'Reproducir');
      btnMiniPlay.setAttribute('aria-label', isPlaying ? 'Pausar' : 'Reproducir');

      if (isPlaying) runWaveform();
      else drawWaveformFrame();
    };

    const renderVolumeIcon = () => {
      const muted = audio.muted || audio.volume <= 0.01;
      const html = muted
        ? '<path d="M11 5 6 9H3v6h3l5 4V5Z"/><path d="m16 9 5 5"/><path d="m21 9-5 5"/>'
        : '<path d="M11 5 6 9H3v6h3l5 4V5Z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M18.36 5.64a9 9 0 0 1 0 12.73"/>';
      volumeIcon.innerHTML = html;
      miniVolumeIcon.innerHTML = html;
      btnMute.setAttribute('aria-label', muted ? 'Activar volumen' : 'Silenciar');
      btnMiniMute.setAttribute('aria-label', muted ? 'Activar volumen' : 'Silenciar');
    };

    const syncVolumeInputs = () => {
      const visibleValue = audio.muted ? 0 : audio.volume;
      volume.value = String(visibleValue);
      miniVolume.value = String(visibleValue);
      renderVolumeIcon();
    };

    const setVolume = (value, { remember = true } = {}) => {
      const next = clamp(Number(value), 0, 1);
      audio.volume = next;
      audio.muted = next <= 0.01;
      if (next > 0.01) lastVolume = next;
      if (remember) {
        try { window.localStorage?.setItem('redil:pro-player-volume', String(lastVolume)); } catch {}
      }
      syncVolumeInputs();
    };

    const toggleMute = () => {
      if (audio.muted || audio.volume <= 0.01) {
        setVolume(lastVolume > 0.01 ? lastVolume : 0.85);
      } else {
        audio.muted = true;
        syncVolumeInputs();
      }
    };

    const lockBackgroundScroll = () => {
      if (document.body.dataset.proPlayerModalOpen === 'true') return;
      lockedScrollY = window.scrollY || window.pageYOffset || 0;
      document.body.dataset.proPlayerModalOpen = 'true';
      document.body.style.position = 'fixed';
      document.body.style.top = `-${lockedScrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.width = '100%';
      document.body.style.overflow = 'hidden';
      document.documentElement.style.overflow = 'hidden';
    };

    const unlockBackgroundScroll = () => {
      if (document.body.dataset.proPlayerModalOpen !== 'true') return;
      delete document.body.dataset.proPlayerModalOpen;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.width = '';
      document.body.style.overflow = '';
      document.documentElement.style.overflow = '';
      window.scrollTo({ top: lockedScrollY, behavior: 'auto' });
    };

    const showMini = () => {
      mini.classList.remove('hidden');
    };

    const openExpanded = () => {
      mini.classList.add('hidden');
      lockBackgroundScroll();
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      backdrop.classList.add('opacity-0');
      panel.classList.add('opacity-0', 'translate-y-[6rem]', 'scale-[0.985]');
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          backdrop.classList.remove('opacity-0');
          panel.classList.remove('opacity-0', 'translate-y-[6rem]', 'scale-[0.985]');
        });
      });
    };

    const collapseExpanded = (onAfterClose = () => {}) => {
      if (modal.classList.contains('hidden')) {
        onAfterClose();
        return;
      }
      backdrop.classList.add('opacity-0');
      panel.classList.add('opacity-0', 'translate-y-[6rem]', 'scale-[0.985]');
      window.setTimeout(() => {
        modal.classList.add('hidden');
        modal.setAttribute('aria-hidden', 'true');
        unlockBackgroundScroll();
        if (!closingPlayer && sourceCandidates.length > 0) {
          showMini();
        }
        onAfterClose();
      }, MODAL_PREMIUM_MS);
    };

    const setLoopUiVisibility = () => {
      loopBracket.classList.toggle('hidden', !chkLoop.checked);
      btnLoopSection.classList.toggle('is-active', chkLoop.checked && activeSectionIndex >= 0);
    };

    const syncLoopUi = () => {
      const safeDuration = totalDuration || 1;
      const startPct = clamp((loopStartSec / safeDuration) * 100, 0, 100);
      const endPct = clamp((loopEndSec / safeDuration) * 100, 0, 100);

      loopInfo.textContent = `[A] ${formatTime(loopStartSec)} - [B] ${formatTime(loopEndSec)}`;
      loopFill.style.left = `${startPct}%`;
      loopFill.style.width = `${Math.max(0, endPct - startPct)}%`;
      handleA.style.left = `${startPct}%`;
      handleB.style.left = `${endPct}%`;
    };

    const resetLoopRange = () => {
      loopStartSec = 0;
      loopEndSec = totalDuration;
      syncLoopUi();
      syncPlaybackWaveform();
    };

    const secondsFromPointer = (clientX) => {
      const rect = timelineWrap.getBoundingClientRect();
      if (!rect.width || !totalDuration) return 0;
      return clamp((clientX - rect.left) / rect.width, 0, 1) * totalDuration;
    };

    const updateLoopHandlePosition = (which, clientX) => {
      if (!totalDuration) return;
      const nextSec = secondsFromPointer(clientX);
      if (which === 'A') loopStartSec = clamp(nextSec, 0, Math.max(0, loopEndSec - 0.1));
      else loopEndSec = clamp(nextSec, Math.min(totalDuration, loopStartSec + 0.1), totalDuration);

      const current = Number.isFinite(audio.currentTime) ? audio.currentTime : 0;
      if (which === 'A' && loopStartSec > current) {
        audio.currentTime = loopStartSec;
        if (!isSeekingAudio) seek.value = String(loopStartSec);
        currentEl.textContent = formatTime(loopStartSec);
      } else if (which === 'B' && loopEndSec < current) {
        const loopSafeStart = clamp(loopStartSec, 0, totalDuration);
        audio.currentTime = loopSafeStart;
        if (!isSeekingAudio) seek.value = String(loopSafeStart);
        currentEl.textContent = formatTime(loopSafeStart);
      }
      syncLoopUi();
      syncPlaybackWaveform();
    };

    const renderSections = () => {
      sectionStrip.innerHTML = '';
      karaokeLyrics.innerHTML = '';
      karaokeMap.innerHTML = '';

      const hasSections = currentSections.length > 0;
      const hasLyrics = lyricCues.length > 0 || lyricSections.some((section) => section.lines?.length);
      karaokeEmpty.classList.toggle('hidden', hasLyrics);
      karaokeLyrics.classList.toggle('hidden', karaokeMode !== 'lyrics' || !hasLyrics);
      karaokeMap.classList.toggle('hidden', karaokeMode !== 'map' || !hasSections);

      btnPrevSection.disabled = !hasSections;
      btnNextSection.disabled = !hasSections;
      btnLoopSection.disabled = !hasSections;

      if (!hasSections) {
        activeSectionTitle.textContent = hasLyrics ? 'Letra disponible' : 'Sin secciones';
        if (hasLyrics) {
          const fallbackLines = lyricCues.length
            ? lyricCues
            : lyricSections.flatMap((section) => (section.lines || []).map((line) => ({ text: line, sectionIndex: -1 })));
          fallbackLines.forEach((cue, index) => {
            const line = document.createElement('p');
            line.className = 'mp3-lyric-line';
            line.dataset.cueIndex = String(index);
            line.textContent = cue.text || '';
            karaokeLyrics.appendChild(line);
          });
        }
        syncActiveCue(true);
        return;
      }

      currentSections.forEach((section, index) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'mp3-section-btn';
        button.dataset.sectionIndex = String(index);
        button.innerHTML = `
          <span class="min-w-0 truncate">${escapeHtml(section.label)}</span>
          <span class="shrink-0 tabular-nums text-content-muted">${formatTime(section.startSec)}</span>
        `;
        button.addEventListener('click', () => seekToSection(index));
        sectionStrip.appendChild(button);

        const mapButton = document.createElement('button');
        mapButton.type = 'button';
        mapButton.className = 'mp3-map-row';
        mapButton.dataset.sectionIndex = String(index);
        mapButton.innerHTML = `
          <span class="truncate font-black">${escapeHtml(section.label)}</span>
          <span class="shrink-0 tabular-nums text-content-muted">${formatTime(section.startSec)}</span>
        `;
        mapButton.addEventListener('click', () => seekToSection(index));
        karaokeMap.appendChild(mapButton);
      });

      lyricCues.forEach((cue, index) => {
        const line = document.createElement('p');
        line.className = 'mp3-lyric-line';
        line.dataset.cueIndex = String(index);
        line.dataset.sectionIndex = String(cue.sectionIndex ?? -1);
        line.textContent = cue.text || '';
        karaokeLyrics.appendChild(line);
      });

      syncActiveSection(true);
      syncActiveCue(true);
    };

    const escapeHtml = (value = '') => String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const setKaraokeMode = (mode) => {
      karaokeMode = mode === 'map' ? 'map' : 'lyrics';
      btnModeLyrics.classList.toggle('is-active', karaokeMode === 'lyrics');
      btnModeMap.classList.toggle('is-active', karaokeMode === 'map');
      renderSections();
    };

    const seekToSection = (index) => {
      const section = currentSections[index];
      if (!section) return;
      audio.currentTime = section.startSec;
      syncPlaybackMetrics();
      syncActiveSection(true);
      if (audio.paused && requestedPlay) void audio.play().catch(() => {});
    };

    const loopActiveSection = () => {
      const section = currentSections[activeSectionIndex];
      if (!section) return;
      loopStartSec = section.startSec;
      loopEndSec = Number.isFinite(section.endSec) && section.endSec > section.startSec
        ? section.endSec
        : totalDuration;
      chkLoop.checked = true;
      setLoopUiVisibility();
      syncLoopUi();
      audio.currentTime = loopStartSec;
      syncPlaybackMetrics();
    };

    const syncActiveSection = (forceScroll = false) => {
      if (!currentSections.length) return;
      const current = Number.isFinite(audio.currentTime) ? audio.currentTime : 0;
      const nextIndex = currentSections.findIndex((section, index) => {
        const nextStart = currentSections[index + 1]?.startSec ?? Number.POSITIVE_INFINITY;
        const end = Number.isFinite(section.endSec) && section.endSec > section.startSec ? section.endSec : nextStart;
        return current >= section.startSec && current < end;
      });
      const safeIndex = nextIndex === -1
        ? (current < currentSections[0].startSec ? 0 : currentSections.length - 1)
        : nextIndex;
      if (safeIndex === -1 || (!forceScroll && safeIndex === activeSectionIndex)) return;
      activeSectionIndex = safeIndex;
      const active = currentSections[activeSectionIndex];
      activeSectionTitle.textContent = active?.label || 'Seccion actual';

      [...sectionStrip.querySelectorAll('[data-section-index]'), ...karaokeMap.querySelectorAll('[data-section-index]')]
        .forEach((node) => {
          node.classList.toggle('is-active', Number(node.dataset.sectionIndex) === activeSectionIndex);
        });

      const activeButton = sectionStrip.querySelector(`[data-section-index="${activeSectionIndex}"]`);
      if (activeButton && (forceScroll || !modal.classList.contains('hidden'))) {
        activeButton.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      }
      setLoopUiVisibility();
    };

    const syncActiveCue = (forceScroll = false) => {
      if (!lyricCues.length) return;
      const current = Number.isFinite(audio.currentTime) ? audio.currentTime : 0;
      const nextIndex = lyricCues.findIndex((cue, index) => {
        const nextStart = lyricCues[index + 1]?.startSec ?? Number.POSITIVE_INFINITY;
        const end = Number.isFinite(cue.endSec) && cue.endSec > cue.startSec ? cue.endSec : nextStart;
        return current >= cue.startSec && current < end;
      });
      const safeIndex = nextIndex === -1
        ? (current < lyricCues[0].startSec ? 0 : lyricCues.length - 1)
        : nextIndex;
      if (safeIndex === -1 || (!forceScroll && safeIndex === activeCueIndex)) return;
      activeCueIndex = safeIndex;

      karaokeLyrics.querySelectorAll('[data-cue-index]').forEach((node) => {
        const index = Number(node.dataset.cueIndex);
        node.classList.toggle('is-active', index === activeCueIndex);
        node.classList.toggle('is-past', index < activeCueIndex);
        node.classList.toggle('is-near', Math.abs(index - activeCueIndex) === 1);
      });

      const activeLyric = karaokeLyrics.querySelector(`[data-cue-index="${activeCueIndex}"]`);
      if (activeLyric && (forceScroll || !modal.classList.contains('hidden'))) {
        const lyricRect = activeLyric.getBoundingClientRect();
        const panelRect = karaokePanel.getBoundingClientRect();
        const targetTop = karaokePanel.scrollTop + lyricRect.top - panelRect.top - (karaokePanel.clientHeight * 0.34);
        karaokePanel.scrollTo({
          top: Math.max(0, targetTop),
          behavior: forceScroll ? 'auto' : 'smooth',
        });
      }
    };

    const syncPlaybackMetrics = () => {
      const current = Number.isFinite(audio.currentTime) ? audio.currentTime : 0;
      const duration = Number.isFinite(totalDuration) && totalDuration > 0
        ? totalDuration
        : (Number.isFinite(audio.duration) ? audio.duration : 0);
      if (!isSeekingAudio) seek.value = String(current);
      currentEl.textContent = formatTime(current);
      durationEl.textContent = formatTime(duration);
      miniTimeEl.textContent = `${formatTime(current)} / ${formatTime(duration)}`;
      const progress = duration > 0 ? clamp((current / duration) * 100, 0, 100) : 0;
      miniProgressEl.style.width = `${progress}%`;
    };

    const onLoopPointerMove = (event) => {
      if (!draggingLoopHandle || !chkLoop.checked) return;
      event.preventDefault();
      updateLoopHandlePosition(draggingLoopHandle, event.clientX);
    };

    const onLoopPointerUp = () => {
      draggingLoopHandle = null;
      window.removeEventListener('pointermove', onLoopPointerMove);
      window.removeEventListener('pointerup', onLoopPointerUp);
    };

    const startLoopDrag = (which, event) => {
      if (!chkLoop.checked) return;
      draggingLoopHandle = which;
      updateLoopHandlePosition(which, event.clientX);
      window.addEventListener('pointermove', onLoopPointerMove, { passive: false });
      window.addEventListener('pointerup', onLoopPointerUp);
    };

    const closePlayer = () => {
      closingPlayer = true;
      audio.pause();
      audio.removeAttribute('src');
      audio.load();
      audioSessionService.resetMetadata();
      sourceCandidates = [];
      sourceIndex = 0;
      requestedPlay = false;
      activeSectionIndex = -1;
      activeCueIndex = -1;
      currentSections = [];
      lyricSections = [];
      lyricCues = [];
      artworkRequestId += 1;
      mini.classList.add('hidden');
      setArtworkFallback();
      setPlayButtonState(false);
      stopWaveform();
      collapseExpanded(() => {
        mini.classList.add('hidden');
        closingPlayer = false;
      });
    };

    const openPlayer = async ({
      url,
      title = 'Cancion',
      artist = 'Artista no especificado',
      autoPlay = true,
      chordpro = '',
      sectionMarkers = [],
      artworkUrl = '',
      expand = false,
    }) => {
      const playableCandidates = buildSourceCandidates(url);
      if (!playableCandidates.length) return;

      sourceCandidates = playableCandidates;
      sourceIndex = 0;
      requestedPlay = false;
      activeSectionIndex = -1;
      activeCueIndex = -1;

      titleEl.textContent = title || 'Cancion';
      miniTitleEl.textContent = title || 'Cancion';
      artistEl.textContent = String(artist || '').trim() || 'Artista no especificado';
      miniArtistEl.textContent = String(artist || '').trim() || 'Artista no especificado';
      setArtworkFromSource(url, title, artist || '', artworkUrl);
      audioSessionService.setMetadata({
        title: title || 'Cancion',
        artist: String(artist || '').trim() || 'Artista no especificado',
      });

      statusEl.textContent = 'Cargando audio...';
      setPlayButtonState(false);
      seek.value = '0';
      currentEl.textContent = '00:00';
      durationEl.textContent = '00:00';
      miniTimeEl.textContent = '00:00 / 00:00';
      miniProgressEl.style.width = '0%';

      totalDuration = 0;
      chkLoop.checked = false;
      setLoopUiVisibility();
      syncPlaybackWaveform();

      lyricSections = parseChordProSections(chordpro);
      currentSections = attachLyricsToSections(normalizeSectionMarkers(sectionMarkers, 0), lyricSections);
      lyricCues = buildLyricCues(currentSections, lyricSections, 0);
      renderSections();

      showMini();
      if (expand) openExpanded();
      else collapseExpanded();
      setSource(0);

      if (!autoPlay) return;
      requestedPlay = true;
      try {
        await setupWaveform();
        if (waveCtx && waveCtx.state === 'suspended') await waveCtx.resume();
        await audio.play();
      } catch (error) {
        if (error instanceof DOMException && error.name === 'NotAllowedError') {
          statusEl.textContent = 'Autoplay bloqueado. Toca Reproducir nuevamente.';
        } else {
          statusEl.textContent = 'No se pudo iniciar el audio. Intentalo de nuevo.';
        }
      }
    };

    const togglePlayback = async () => {
      try {
        if (audio.paused) {
          requestedPlay = true;
          await setupWaveform();
          if (waveCtx && waveCtx.state === 'suspended') await waveCtx.resume();
          await audio.play();
        } else {
          requestedPlay = false;
          audio.pause();
        }
      } catch (error) {
        if (error instanceof DOMException && error.name === 'NotAllowedError') {
          statusEl.textContent = 'El navegador bloqueo la reproduccion. Toca Reproducir nuevamente.';
          return;
        }
        if (error instanceof DOMException && error.name === 'NotSupportedError') {
          if (tryNextSource(true)) return;
          requestedPlay = false;
          statusEl.textContent = 'El enlace no se pudo reproducir. Revisa formato o permisos del MP3.';
          return;
        }
        requestedPlay = false;
        statusEl.textContent = 'No se pudo iniciar el audio. Intentalo de nuevo.';
      }
    };

    window.__REDIL_PRO_PLAYER__ = {
      open: (payload) => openPlayer({ ...payload, autoPlay: payload?.autoPlay !== false }),
      close: closePlayer,
      expand: openExpanded,
    };

    window.addEventListener('play-pro-audio', (event) => {
      const detail = event?.detail || {};
      if (!detail.url) return;
      void openPlayer({
        url: detail.url,
        title: detail.title,
        artist: detail.artist,
        autoPlay: detail.autoPlay !== false,
        chordpro: detail.chordpro || '',
        sectionMarkers: Array.isArray(detail.sectionMarkers) ? detail.sectionMarkers : [],
        artworkUrl: detail.artworkUrl || '',
        expand: detail.expand === true,
      });
    });

    audio.addEventListener('loadedmetadata', () => {
      totalDuration = Number.isFinite(audio.duration) ? audio.duration : 0;
      seek.min = '0';
      seek.max = String(totalDuration || 1);
      currentSections = attachLyricsToSections(normalizeSectionMarkers(currentSections, totalDuration), lyricSections);
      lyricCues = buildLyricCues(currentSections, lyricSections, totalDuration);
      activeCueIndex = -1;
      renderSections();
      resetLoopRange();
      syncPlaybackMetrics();
      statusEl.textContent = '';
      void setupWaveform().then(() => drawWaveformFrame());
    });

    audio.addEventListener('timeupdate', () => {
      syncPlaybackMetrics();
      syncPlaybackWaveform();
      syncActiveSection();
      syncActiveCue();

      if (chkLoop.checked && loopEndSec > loopStartSec + 0.15 && audio.currentTime >= loopEndSec) {
        audio.currentTime = loopStartSec;
        syncPlaybackMetrics();
        syncPlaybackWaveform();
        syncActiveCue(true);
      }
    });

    audio.addEventListener('play', () => {
      requestedPlay = true;
      setPlayButtonState(true);
    });

    audio.addEventListener('pause', () => setPlayButtonState(false));
    audio.addEventListener('ended', () => {
      requestedPlay = false;
      setPlayButtonState(false);
    });

    audio.addEventListener('error', () => {
      if (tryNextSource(requestedPlay)) return;
      requestedPlay = false;
      statusEl.textContent = 'El enlace no se pudo reproducir. Verifica permisos o formato del archivo.';
    });

    btnPlay.addEventListener('click', togglePlayback);
    btnMiniPlay.addEventListener('click', togglePlayback);
    btnMute.addEventListener('click', toggleMute);
    btnMiniMute.addEventListener('click', toggleMute);
    volume.addEventListener('input', () => setVolume(volume.value));
    miniVolume.addEventListener('input', () => setVolume(miniVolume.value));
    btnExpand.addEventListener('click', openExpanded);
    btnExpandIcon.addEventListener('click', openExpanded);
    btnCollapse.addEventListener('click', () => collapseExpanded());
    btnClose.addEventListener('click', closePlayer);
    btnMiniClose.addEventListener('click', closePlayer);
    backdrop.addEventListener('click', () => collapseExpanded());

    seek.addEventListener('input', () => {
      isSeekingAudio = true;
      currentEl.textContent = formatTime(Number(seek.value || 0));
    });
    seek.addEventListener('change', () => {
      audio.currentTime = Number(seek.value || 0);
      syncPlaybackMetrics();
      syncActiveSection(true);
      syncActiveCue(true);
      isSeekingAudio = false;
    });

    chkLoop.addEventListener('change', () => {
      setLoopUiVisibility();
      syncLoopUi();
    });
    btnClearLoop.addEventListener('click', () => {
      chkLoop.checked = false;
      setLoopUiVisibility();
      resetLoopRange();
    });
    handleA.addEventListener('pointerdown', (event) => startLoopDrag('A', event));
    handleB.addEventListener('pointerdown', (event) => startLoopDrag('B', event));

    btnBack5.addEventListener('click', () => {
      if (!Number.isFinite(audio.currentTime)) return;
      audio.currentTime = Math.max(0, (audio.currentTime || 0) - 5);
      syncPlaybackMetrics();
      syncActiveSection();
      syncActiveCue(true);
      syncPlaybackWaveform();
    });
    btnForward5.addEventListener('click', () => {
      const maxDuration = Number.isFinite(totalDuration) && totalDuration > 0 ? totalDuration : Number.isFinite(audio.duration) ? audio.duration : 0;
      if (!maxDuration) return;
      audio.currentTime = Math.min(maxDuration, (audio.currentTime || 0) + 5);
      syncPlaybackMetrics();
      syncActiveSection();
      syncActiveCue(true);
      syncPlaybackWaveform();
    });
    btnPrevSection.addEventListener('click', () => seekToSection(Math.max(0, activeSectionIndex - 1)));
    btnNextSection.addEventListener('click', () => seekToSection(Math.min(currentSections.length - 1, activeSectionIndex + 1)));
    btnLoopSection.addEventListener('click', loopActiveSection);
    btnModeLyrics.addEventListener('click', () => setKaraokeMode('lyrics'));
    btnModeMap.addEventListener('click', () => setKaraokeMode('map'));

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      if (!modal.classList.contains('hidden')) {
        collapseExpanded();
      }
    });

    setVolume(Number.isFinite(lastVolume) ? lastVolume : 0.85, { remember: false });
  })();
</script>

