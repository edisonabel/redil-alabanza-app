        </div>
      </div>
      <button id="btnMp3Expand" type="button" class="min-w-0 text-left" aria-label="Expandir reproductor">
        <span id="mp3MiniTitle" class="block truncate text-sm font-black leading-tight">Cancion</span>
        <span class="mt-0.5 flex items-center gap-2 text-[11px] font-semibold text-white/58">
          <span id="mp3MiniArtist" class="truncate">Artista</span>
          <span class="shrink-0 text-white/35">/</span>
          <span id="mp3MiniTime" class="shrink-0 tabular-nums">00:00</span>
        </span>
      </button>
      <div class="flex items-center gap-1">
        <div class="hidden items-center gap-1.5 sm:flex">
          <button id="btnMp3MiniMute" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white/74 transition-colors hover:bg-white/10 hover:text-white" aria-label="Silenciar">
            <svg id="mp3MiniVolumeIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H3v6h3l5 4V5Z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M18.36 5.64a9 9 0 0 1 0 12.73"/></svg>
          </button>
          <input id="mp3MiniVolume" type="range" min="0" max="1" step="0.01" value="0.85" class="mp3-volume-slider w-20" aria-label="Volumen mini reproductor" />
        </div>
        <button id="btnMp3MiniExpandIcon" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white/74 transition-colors hover:bg-white/10 hover:text-white" aria-label="Abrir panel">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 15 6-6 6 6"/></svg>
        </button>
        <button id="btnMp3MiniClose" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-full text-white/74 transition-colors hover:bg-white/10 hover:text-white" aria-label="Cerrar reproductor">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mp3PlayerModal" class="fixed inset-0 z-[320] hidden overscroll-contain" aria-hidden="true">
    <div id="mp3PlayerBackdrop" class="absolute inset-0 bg-black/74 backdrop-blur-3xl opacity-0 transition-opacity duration-500"></div>
    <div class="relative z-10 flex h-full w-full items-end justify-center px-2 pb-[calc(env(safe-area-inset-bottom)+0.5rem)] pt-2 md:items-stretch md:justify-end md:p-4">
      <div id="mp3PlayerPanel" class="flex h-[calc(100dvh-env(safe-area-inset-bottom)-1rem)] max-h-[calc(100dvh-env(safe-area-inset-bottom)-1rem)] w-full max-w-5xl translate-y-[6rem] scale-[0.985] flex-col overflow-hidden rounded-[1.8rem] border border-white/14 bg-[#17171b]/90 text-white opacity-0 shadow-[0_28px_90px_rgba(0,0,0,0.68)] outline outline-1 outline-white/5 backdrop-blur-3xl transition-[opacity,transform] duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] will-change-transform md:h-full md:max-h-none md:w-[min(58rem,calc(100vw-2rem))]">
        <div class="flex items-start justify-between gap-3 border-b border-white/8 bg-white/[0.06] p-4 backdrop-blur-2xl md:p-5">
          <div class="min-w-0 flex items-center gap-3">
            <div class="relative h-14 w-14 shrink-0 overflow-hidden rounded-2xl border border-white/14 bg-black/24 shadow-[0_12px_34px_rgba(0,0,0,0.36)]">
              <img id="mp3Artwork" src="" alt="" class="hidden h-full w-full object-cover" />
              <div id="mp3ArtworkFallback" class="grid h-full w-full place-items-center text-content-muted" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
              </div>
            </div>
            <div class="min-w-0">
              <h3 id="mp3Title" class="truncate text-lg font-black leading-tight md:text-xl">Cancion</h3>
              <p id="mp3Artist" class="truncate text-sm text-white/58">Artista</p>
              <div class="mt-1.5 h-1.5 w-12 overflow-hidden rounded-full bg-white/12">
                <span id="mp3LiveIndicator" class="block h-full w-2 rounded-full bg-action transition-all duration-300"></span>
              </div>
            </div>
          </div>
          <div class="flex shrink-0 items-center gap-2">
            <button id="btnMp3Collapse" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/8 text-white/74 transition-colors hover:bg-white/14 hover:text-white" aria-label="Minimizar reproductor">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <button id="btnMp3Close" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/8 text-white/74 transition-colors hover:bg-white/14 hover:text-white" aria-label="Cerrar reproductor">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
            </button>
          </div>
        </div>

        <audio id="mp3Audio" class="hidden" preload="auto" playsinline webkit-playsinline="true"></audio>

        <div class="relative flex min-h-0 flex-1 flex-col overflow-hidden">
          <section class="order-2 shrink-0 border-t border-white/10 bg-black/34 p-3 backdrop-blur-3xl md:p-4">
            <div class="mx-auto max-w-3xl rounded-[1.6rem] border border-white/14 bg-white/[0.105] p-3 shadow-[0_20px_60px_rgba(0,0,0,0.38)] backdrop-blur-3xl md:p-4">
              <div class="flex items-center gap-3">
                <span id="mp3CurrentTime" class="w-12 text-right text-xs font-semibold tabular-nums text-white/58">00:00</span>
                <div id="mp3TimelineWrap" class="relative flex h-9 flex-1 items-center">
                  <canvas id="mp3Waveform" class="pointer-events-none absolute inset-x-0 top-1/2 h-8 w-full -translate-y-1/2 opacity-80"></canvas>
                  <input id="mp3Seek" type="range" min="0" max="100" value="0" class="w-full accent-action" />
                  <div id="mp3LoopBracket" class="pointer-events-none absolute inset-x-0 top-1/2 hidden h-2 -translate-y-1/2">
                    <div id="mp3LoopRangeFill" class="absolute top-0 h-2 rounded-full bg-brand/35"></div>
                    <button id="mp3LoopHandleA" type="button" class="mp3-loop-handle pointer-events-auto absolute top-1/2 -translate-x-1/2 -translate-y-1/2" aria-label="Bracket A"><span class="mp3-loop-stick"></span></button>
                    <button id="mp3LoopHandleB" type="button" class="mp3-loop-handle pointer-events-auto absolute top-1/2 -translate-x-1/2 -translate-y-1/2" aria-label="Bracket B"><span class="mp3-loop-stick"></span></button>
                  </div>
