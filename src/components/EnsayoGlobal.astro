---
import EnsayoGlobalIsland from './react/EnsayoGlobalIsland.jsx';
---

<div id="ensayo-global-mount" transition:persist>
  <EnsayoGlobalIsland client:only="react" />
</div>

<script>
  // Singleton guard: only register listener once across SPA navigations
  if (!window.__REDIL_ENSAYO_GLOBAL_READY__) {
    window.__REDIL_ENSAYO_GLOBAL_READY__ = true;

    document.addEventListener(
      'click',
      (event) => {
        const btn = (event.target as Element).closest('.btn-open-ensayo');
        if (!btn) return;
        event.preventDefault();
        event.stopPropagation();

        const el = btn as HTMLElement;
        const songId = el.dataset.id || '';

        // If this song has a persisted multitrack session, bypass the compact
        // rehearsal view and send the user straight to Live Director so the
        // multitrack engine applies automatically.
        const hasMultitrack = el.dataset.hasMultitrack === '1';
        if (hasMultitrack && songId) {
          const target = `/herramientas/live-director-preview?song=${encodeURIComponent(songId)}`;
          window.location.href = target;
          return;
        }

        // Prefer global registry (lightweight) over data attributes (heavy)
        const reg = (window as any).__REDIL_SONG_REGISTRY__?.[songId];
        const chordpro = reg?.c || el.dataset.chordpro || '';
        let sectionMarkers: any[] = reg?.m || [];
        if (!sectionMarkers.length) {
          try { sectionMarkers = JSON.parse(el.dataset.sectionMarkers || '[]'); } catch {}
        }

        const song = {
          id:        songId,
          title:     el.dataset.title  || '',
          artist:    el.dataset.artist || '',
          key:       el.dataset.key    || '',
          bpm:       Number(el.dataset.bpm) || 0,
          mp3:       el.dataset.mp3    || '',
          chordpro,
          linkVoces: el.dataset.voces  || '',
          linkYoutube: el.dataset.youtube || '',
          sectionMarkers,
        };

        window.dispatchEvent(
          new CustomEvent('open-ensayo-compacto', { detail: { song } }),
        );
      },
      true, // capture phase so it fires before card's own click handler
    );
  }
</script>
