<div id="globalVocesModalRoot" transition:persist transition:animate="none">
  <div id="vocesModal" class="fixed inset-0 z-[132] hidden" aria-hidden="true">
    <div id="vocesBackdrop" class="absolute inset-0 bg-black/60 backdrop-blur-xl opacity-0 transition-opacity duration-[900ms] [transition-timing-function:cubic-bezier(0.2,0.8,0.2,1)]"></div>
    <div class="relative z-10 w-full min-h-[100dvh] flex items-start justify-center p-3 pt-[max(env(safe-area-inset-top),1.5rem)] md:items-center md:p-5 overflow-y-auto">
      <div id="vocesPanel" class="w-full max-w-lg my-auto md:my-0 opacity-0 translate-y-4 transition-all duration-300 ease-out">
        <div class="overflow-hidden rounded-[2rem] border border-zinc-200/80 bg-[radial-gradient(circle_at_top,_rgba(59,130,246,0.12),_transparent_50%),linear-gradient(180deg,_rgba(255,255,255,0.98),_rgba(244,244,245,0.96))] shadow-[0_24px_80px_rgba(15,23,42,0.12)] dark:border-white/10 dark:bg-[radial-gradient(circle_at_top,_rgba(59,130,246,0.18),_transparent_45%),linear-gradient(180deg,_rgba(9,9,11,0.98),_rgba(15,23,42,0.94))] dark:shadow-[0_28px_80px_rgba(2,6,23,0.6)]">
          <div class="px-4 pt-3.5 pb-2 md:px-6 md:pt-5 md:pb-3">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-[10px] font-black uppercase tracking-[0.28em] text-zinc-500 dark:text-zinc-400 leading-none">Voces</p>
                <h3 id="vocesTitle" class="mt-0.5 text-lg md:text-2xl font-black tracking-tight leading-tight text-zinc-950 dark:text-zinc-50 truncate">Recursos de voz</h3>
                <p id="vocesArtist" class="text-[13px] font-medium leading-tight text-zinc-500 dark:text-zinc-400 truncate">Selecciona una pista</p>
              </div>
              <button id="btnVocesClose" type="button" class="shrink-0 flex h-11 w-11 items-center justify-center rounded-2xl border border-zinc-200 bg-white text-zinc-600 shadow-sm transition-colors hover:bg-zinc-100 hover:text-zinc-900 dark:border-white/10 dark:bg-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50" aria-label="Cerrar modal de voces">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6l12 12M18 6l-12 12"/></svg>
              </button>
            </div>
          </div>

          <div class="px-4 pb-4 md:px-6 md:pb-6">
            <div class="rounded-2xl border border-zinc-200/90 bg-zinc-50/80 p-3 sm:p-4 dark:border-white/[0.07] dark:bg-zinc-900/60">
              <div id="vocesOptions" class="grid grid-cols-1 sm:grid-cols-2 gap-1.5 sm:gap-2"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  type VoiceEntry = { label: string; url: string; [key: string]: unknown };
  type VoiceDatasetResult = { type: string; entries: VoiceEntry[]; legacyUrl: string };

  (() => {
    const alreadyInit = Boolean(window.__REDIL_VOCES_MODAL_READY__);
    if (alreadyInit) {
      if (!window.__REDIL_VOCES_MODAL__) {
        console.warn('[VocesModal] Guard hit but API missing — skipping (DOM already persisted)');
      }
      return;
    }
    window.__REDIL_VOCES_MODAL_READY__ = true;

    const MODAL_PREMIUM_MS = 900;
    let vocesLockedScrollY = 0;

    const getRefs = () => ({
      vocesModal: document.getElementById('vocesModal'),
      vocesBackdrop: document.getElementById('vocesBackdrop'),
      vocesPanel: document.getElementById('vocesPanel'),
      vocesTitle: document.getElementById('vocesTitle'),
      vocesArtist: document.getElementById('vocesArtist'),
      vocesOptions: document.getElementById('vocesOptions'),
    });

    const animateModalOpen = (modal: HTMLElement | null, backdrop: HTMLElement | null, panel: HTMLElement | null) => {
      if (!modal || !backdrop || !panel) return;
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      backdrop.classList.add('opacity-0');
      panel.classList.add('opacity-0', 'translate-y-4');

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          backdrop.classList.remove('opacity-0');
          panel.classList.remove('opacity-0', 'translate-y-4');
        });
      });
    };

    const animateModalClose = (modal: HTMLElement | null, backdrop: HTMLElement | null, panel: HTMLElement | null, onAfterClose: () => void = () => {}) => {
      if (!modal || !backdrop || !panel || modal.classList.contains('hidden')) {
        onAfterClose();
        return;
      }

      backdrop.classList.add('opacity-0');
      panel.classList.add('opacity-0', 'translate-y-4');
      window.setTimeout(() => {
        modal.classList.add('hidden');
        modal.setAttribute('aria-hidden', 'true');
        onAfterClose();
      }, MODAL_PREMIUM_MS);
    };

    const normalizeExternalUrl = (rawUrl: unknown) => {
      if (!rawUrl) return '';
      let normalized = String(rawUrl).trim();
      if (!normalized) return '';

      if (normalized.startsWith('www.')) {
        normalized = `https://${normalized}`;
      } else if (normalized.startsWith('//')) {
        normalized = `https:${normalized}`;
      } else if (/^\/(uc|open|file)\b/i.test(normalized)) {
        normalized = `https://drive.google.com${normalized}`;
      }

      try {
        const parsed = new URL(normalized, window.location.origin);
        return parsed.href;
      } catch {
        return '';
      }
    };

    const lockBackgroundScroll = () => {
      if (document.body.dataset.vocesModalOpen === 'true') return;
      vocesLockedScrollY = window.scrollY || window.pageYOffset || 0;
      document.body.dataset.vocesModalOpen = 'true';
      document.body.style.position = 'fixed';
      document.body.style.top = `-${vocesLockedScrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.width = '100%';
      document.body.style.overflow = 'hidden';
      document.documentElement.style.overflow = 'hidden';
    };

    const unlockBackgroundScroll = () => {
      if (document.body.dataset.vocesModalOpen !== 'true') return;
      delete document.body.dataset.vocesModalOpen;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.width = '';
      document.body.style.overflow = '';
      document.documentElement.style.overflow = '';
      window.scrollTo({ top: vocesLockedScrollY, behavior: 'auto' });
    };

    const dispatchProPlayerEvent = (payload: Record<string, any>) => {
      const url = String(payload?.url || '').trim();
      if (!url) return;
      window.dispatchEvent(new CustomEvent('play-pro-audio', { detail: payload }));
    };

    const getVoiceColor = (label: string) => {
      const text = (label || '').toLowerCase();
      if (text.includes('guia') || text.includes('guía') || text.includes('principal')) return '#2563EB';
      if (text.includes('tercera')) return '#16A34A';
      if (text.includes('quinta')) return '#CA8A04';
      if (text.includes('todas') || text.includes('tres voces')) return '#9333EA';
      if (text.includes('pista') || text.includes('instru')) return '#0891B2';
      return '#64748B';
    };

    const VOICE_LABEL_ORDER = ['Voz guía', 'Tercera voz', 'Quinta voz', 'Todas las voces', 'Pista'];
    const normalizeVoiceText = (value = '') => String(value || '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase();

    const normalizeVoiceLabel = (value = '') => {
      const normalized = normalizeVoiceText(value);
      if (normalized.includes('guia') || normalized.includes('principal') || normalized.includes('lead')) return 'Voz guía';
      if (normalized.includes('tercera') || /\b3(?:ra|ro)?\b/.test(normalized)) return 'Tercera voz';
      if (normalized.includes('quinta') || /\b5(?:ta|to)?\b/.test(normalized)) return 'Quinta voz';
      if (normalized.includes('todas') || normalized.includes('tres voces') || normalized.includes('full')) return 'Todas las voces';
      if (normalized.includes('pista') || normalized.includes('instrumental') || normalized.includes('track')) return 'Pista';
      return 'Pista';
    };

    const sortVoiceEntries = (entries: any[] = []): VoiceEntry[] => (
      (Array.isArray(entries) ? entries : [])
        .map((entry, index) => ({ entry: { ...entry, label: normalizeVoiceLabel(entry?.label || entry?.name || '') }, index }))
        .sort((left, right) => {
          const leftOrder = VOICE_LABEL_ORDER.indexOf(left.entry.label);
          const rightOrder = VOICE_LABEL_ORDER.indexOf(right.entry.label);
          return (leftOrder === -1 ? 99 : leftOrder) - (rightOrder === -1 ? 99 : rightOrder) || left.index - right.index;
        })
        .map(({ entry }) => entry)
    );

    const mergeVoiceEntriesByUrl = (...entryGroups: any[][]): VoiceEntry[] => {
      const seenUrls = new Set<string>();
      const mergedEntries: VoiceEntry[] = [];

      entryGroups.flat().forEach((entry) => {
        if (!entry || typeof entry !== 'object') return;
        const url = normalizeExternalUrl(entry.url || '');
        if (!url || seenUrls.has(url)) return;
        seenUrls.add(url);
        mergedEntries.push({ ...entry, url });
      });

      return sortVoiceEntries(mergedEntries);
    };

    const closeVocesModal = (onAfterClose = () => {}) => {
      const { vocesModal, vocesBackdrop, vocesPanel } = getRefs();
      const runAfterClose = () => {
        if (typeof onAfterClose === 'function') onAfterClose();
      };
      if (!vocesModal || vocesModal.classList.contains('hidden')) {
        runAfterClose();
        return;
      }
      animateModalClose(vocesModal, vocesBackdrop, vocesPanel, () => {
        unlockBackgroundScroll();
        runAfterClose();
      });
    };

    const playAudio = (rawUrl: unknown, voiceName = '') => {
      const normalized = normalizeExternalUrl(rawUrl);
      if (!normalized) return;

      const { vocesTitle, vocesArtist } = getRefs();
      const modalSongTitle = vocesTitle?.textContent?.trim() || 'Recursos de voz';
      const modalSongArtist = vocesArtist?.textContent?.trim() || '';
      const finalTitle = voiceName ? `${modalSongTitle} · ${voiceName}` : modalSongTitle;

      closeVocesModal(() => {
        const voiceColor = getVoiceColor(voiceName);
        dispatchProPlayerEvent({
          url: normalized,
          title: finalTitle,
          artist: voiceName || modalSongArtist,
          subtitle: modalSongArtist,
          mediaKind: 'voice',
          voiceName,
          voiceColor,
          isDirectPlayable: true,
          autoPlay: true,
        });
      });
    };

    const openVocesModal = (title: string, artist: string, entries: any[], legacyUrl = '') => {
      const { vocesModal, vocesBackdrop, vocesPanel, vocesTitle, vocesArtist, vocesOptions } = getRefs();
      if (!vocesModal || !vocesBackdrop || !vocesPanel || !vocesOptions || !vocesTitle || !vocesArtist) return;

      vocesTitle.textContent = title || 'Recursos de voz';
      vocesArtist.textContent = String(artist || '').trim() || 'Selecciona una pista';
      vocesOptions.innerHTML = '';

      if (legacyUrl && !(Array.isArray(entries) && entries.length > 0)) {
        const safeLegacyUrl = normalizeExternalUrl(legacyUrl);
        const legacyCard = document.createElement('div');
        legacyCard.className = 'col-span-full rounded-2xl border border-zinc-200 bg-white p-4 dark:border-white/10 dark:bg-zinc-800/60';
        legacyCard.innerHTML = `
          <p class="text-sm font-black text-zinc-950 dark:text-zinc-50">Pistas no disponibles a\u00fan</p>
          <p class="mt-1 text-xs font-medium text-zinc-500 dark:text-zinc-400">Esta canci\u00f3n a\u00fan usa el formato legacy.</p>
        `;

        if (safeLegacyUrl) {
          const link = document.createElement('a');
          link.href = safeLegacyUrl;
          link.target = '_blank';
          link.rel = 'noopener noreferrer';
          link.className = 'mt-3 inline-flex h-10 items-center justify-center rounded-2xl border border-zinc-200 bg-zinc-50 px-4 text-sm font-black text-zinc-700 shadow-sm transition-colors hover:bg-zinc-100 dark:border-white/10 dark:bg-zinc-900 dark:text-zinc-200 dark:hover:bg-zinc-800';
          link.textContent = 'Abrir carpeta de Drive';
          legacyCard.appendChild(link);
        }

        vocesOptions.appendChild(legacyCard);
        lockBackgroundScroll();
        animateModalOpen(vocesModal, vocesBackdrop, vocesPanel);
        return;
      }

      const validEntries = (Array.isArray(entries) ? entries : [])
        .map((entry, index) => {
          const labelRaw = entry?.label || entry?.nombre || entry?.name || 'Pista';
          const label = normalizeVoiceLabel(String(labelRaw).trim() || `Pista ${index + 1}`);
          const url = normalizeExternalUrl(typeof entry?.url === 'string' ? entry.url : '');
          if (!url) return null;
          return { label, url };
        })
        .filter((entry): entry is VoiceEntry => entry !== null);
      const orderedEntries = sortVoiceEntries(validEntries);

      if (!orderedEntries.length) {
        const emptyCard = document.createElement('div');
        emptyCard.className = 'col-span-full rounded-2xl border border-zinc-200 bg-white p-4 dark:border-white/10 dark:bg-zinc-800/60';
        emptyCard.innerHTML = `
          <p class="text-sm font-black text-zinc-950 dark:text-zinc-50">Pistas no disponibles a\u00fan</p>
          <p class="mt-1 text-xs font-medium text-zinc-500 dark:text-zinc-400">No encontramos pistas v\u00e1lidas para reproducir.</p>
        `;
        vocesOptions.appendChild(emptyCard);
        lockBackgroundScroll();
        animateModalOpen(vocesModal, vocesBackdrop, vocesPanel);
        return;
      }

      orderedEntries.forEach((entry, index) => {
        const button = document.createElement('button');
        const labelText = entry.label || `Pista ${index + 1}`;
        const color = getVoiceColor(labelText);
        button.type = 'button';
        button.dataset.url = entry.url;
        button.dataset.voice = labelText;
        button.className =
          'group grid grid-cols-[auto_1fr_auto] items-center gap-2.5 w-full rounded-xl border border-zinc-200 bg-white px-3 py-2.5 text-left shadow-sm transition-all hover:border-zinc-300 hover:shadow-md hover:scale-[1.01] active:scale-[0.99] dark:border-white/10 dark:bg-zinc-800/80 dark:hover:border-white/20 dark:hover:bg-zinc-800';

        const swatch = document.createElement('span');
        swatch.className = 'h-8 w-8 rounded-lg flex items-center justify-center shrink-0';
        swatch.style.background = color;
        swatch.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>';

        const labelNode = document.createElement('span');
        labelNode.className = 'truncate text-sm font-black text-zinc-950 dark:text-zinc-50';
        labelNode.textContent = labelText;

        const right = document.createElement('span');
        right.className = 'text-[11px] font-bold uppercase tracking-[0.16em] text-zinc-400 group-hover:text-zinc-600 dark:text-zinc-500 dark:group-hover:text-zinc-300 transition-colors shrink-0';
        right.textContent = 'Play';

        button.appendChild(swatch);
        button.appendChild(labelNode);
        button.appendChild(right);

        button.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          const url = button.dataset.url || '';
          const voice = button.dataset.voice || '';
          playAudio(url, voice);
        });
        vocesOptions.appendChild(button);
      });

      if (legacyUrl) {
        const safeLegacyUrl = normalizeExternalUrl(legacyUrl);
        if (safeLegacyUrl) {
          const legacyCard = document.createElement('a');
          legacyCard.href = safeLegacyUrl;
          legacyCard.target = '_blank';
          legacyCard.rel = 'noopener noreferrer';
          legacyCard.className = 'col-span-full mt-1 inline-flex h-10 items-center justify-center rounded-xl border border-zinc-200 bg-zinc-50 px-3 text-xs font-black uppercase tracking-[0.12em] text-zinc-500 transition-colors hover:bg-zinc-100 hover:text-zinc-800 dark:border-white/10 dark:bg-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-200';
          legacyCard.textContent = 'Abrir link viejo';
          vocesOptions.appendChild(legacyCard);
        }
      }

      lockBackgroundScroll();
      animateModalOpen(vocesModal, vocesBackdrop, vocesPanel);
    };

    const parseDatasetVoces = (rawVoces: unknown): VoiceDatasetResult | null => {
      const value = String(rawVoces || '').trim();
      if (!value || value === 'null') return null;

      const audioFilePattern = /\.(mp3|wav|m4a|aac|ogg|flac|mp4|mpeg|mpga|webm)(\?.*)?$/i;
      const toVoiceEntry = (candidate: any, index = 0, forcedLabel = ''): VoiceEntry | null => {
        if (typeof candidate === 'string') {
          const url = normalizeExternalUrl(candidate);
          if (!url) return null;
          return { label: normalizeVoiceLabel(forcedLabel || `Voz ${index + 1}`), url };
        }

        if (!candidate || typeof candidate !== 'object') return null;

        const url = normalizeExternalUrl(candidate.url || candidate.link || candidate.href || candidate.src || candidate.audio || '');
        if (!url) return null;

        const labelRaw = forcedLabel || candidate.label || candidate.nombre || candidate.name || candidate.title || candidate.voice || '';
        return {
          label: normalizeVoiceLabel(String(labelRaw || `Voz ${index + 1}`).trim() || `Voz ${index + 1}`),
          url,
        };
      };

      if (value.includes('\n')) {
        const entries = value
          .split('\n')
          .map((line, index) => {
            const trimmed = String(line || '').trim();
            if (!trimmed) return null;
            const [labelPart, ...urlParts] = trimmed.includes('|') ? trimmed.split('|') : [`Voz ${index + 1}`, trimmed];
            return toVoiceEntry(urlParts.join('|').trim(), index, String(labelPart || '').trim());
          })
          .filter((entry): entry is VoiceEntry => entry !== null);

        if (entries.length > 0) {
          return { type: 'lines', entries: sortVoiceEntries(entries), legacyUrl: '' };
        }
      }

      if (value.startsWith('http') && !value.startsWith('[')) {
        const normalizedUrl = normalizeExternalUrl(value);
        if (audioFilePattern.test(normalizedUrl)) {
          return { type: 'audio', entries: [{ label: 'Voz guía', url: normalizedUrl }], legacyUrl: '' };
        }
        return { type: 'legacy', legacyUrl: normalizedUrl, entries: [] };
      }
      if (value.startsWith('[') || value.startsWith('{')) {
        try {
          const parsed = JSON.parse(value);
          if (Array.isArray(parsed)) {
            return { type: 'json', entries: sortVoiceEntries(parsed.map((entry, index) => toVoiceEntry(entry, index)).filter((entry): entry is VoiceEntry => entry !== null)), legacyUrl: '' };
          }
          if (parsed && typeof parsed === 'object') {
            const directEntry = Array.isArray(parsed.entries)
              ? null
              : toVoiceEntry(parsed, 0, parsed.label || parsed.nombre || parsed.name || parsed.title || 'Voz guía');
            const sourceEntries: Array<{ label: string; url: unknown }> = Array.isArray(parsed.entries)
              ? parsed.entries
              : Object.entries(parsed)
                .map(([key, candidate]) => (
                  ['legacyUrl', 'folder', 'drive'].includes(key) ? null : { label: key, url: candidate }
                ))
                .filter((entry): entry is { label: string; url: unknown } => entry !== null);
            const entries = directEntry
              ? [directEntry]
              : sourceEntries.map((entry: { label: string; url: unknown }, index: number) => toVoiceEntry(entry, index)).filter((entry: VoiceEntry | null): entry is VoiceEntry => entry !== null);
            const nestedLegacy = parseDatasetVoces(parsed.legacyUrl || parsed.folder || parsed.drive || '');
            const legacyUrl = nestedLegacy?.legacyUrl || normalizeExternalUrl(parsed.legacyUrl || parsed.folder || parsed.drive || '');
            return {
              type: 'json',
              entries: mergeVoiceEntriesByUrl(entries, nestedLegacy?.entries || []),
              legacyUrl,
            };
          }
          return null;
        } catch {
          return null;
        }
      }
      return null;
    };

    const handleDocumentClick = (event: MouseEvent) => {
      const target = event.target instanceof Element ? event.target : null;
      if (!target) return;

      const closeBtn = target.closest('#btnVocesClose');
      const backdrop = target.id === 'vocesBackdrop' ? target : target.closest('#vocesBackdrop');
      if (closeBtn || backdrop) {
        event.preventDefault();
        event.stopPropagation();
        closeVocesModal();
        return;
      }

      const vocesButton = target.closest('.btn-open-voces');
      if (!vocesButton) return;

      event.preventDefault();
      event.stopPropagation();

      const rawVoces = vocesButton.getAttribute('data-voces') || '';
      const songTitle = vocesButton.getAttribute('data-title') || vocesButton.getAttribute('data-cancion') || 'Recursos de voz';
      const songArtist = vocesButton.getAttribute('data-artist') || '';

      const parsed = parseDatasetVoces(rawVoces);
      if (!parsed) return;

      if (parsed.type === 'legacy') {
        openVocesModal(songTitle, songArtist, [], parsed.legacyUrl);
        return;
      }

      openVocesModal(songTitle, songArtist, parsed.entries || []);
    };

    const handleEscape = (event: KeyboardEvent) => {
      if (event.key !== 'Escape') return;
      const { vocesModal } = getRefs();
      if (!vocesModal || vocesModal.classList.contains('hidden')) return;
      closeVocesModal();
    };

    document.addEventListener('click', handleDocumentClick, true);
    document.addEventListener('keydown', handleEscape);

    window.addEventListener('open-voces-modal', (event) => {
      const detail = (event as CustomEvent<Record<string, any>>).detail || {};
      openVocesModal(detail.title || 'Recursos de voz', detail.artist || '', detail.entries || [], detail.legacyUrl || '');
    });

    document.addEventListener('astro:before-swap', () => {
      closeVocesModal();
    });

    window.__REDIL_VOCES_MODAL__ = {
      open: openVocesModal,
      close: closeVocesModal,
    };
  })();
</script>
