---
import '../styles/global.css';
import BottomNav from '../components/BottomNav.astro';
import ProPlayerGlobal from '../components/ProPlayerGlobal.astro';
import VocesModalGlobal from '../components/VocesModalGlobal.astro';
import EnsayoGlobal from '../components/EnsayoGlobal.astro';
import NotificationBell from '../components/react/NotificationBell.jsx';
import { getBrandingConfig, invalidarCacheBranding } from '../lib/branding';
import { ClientRouter } from 'astro:transitions';

const user = Astro.locals.user;
const perfil = Astro.locals.perfil;

const premiumPageTransition = {
  forwards: {
    old: {
      name: 'app-page-premium-out',
      duration: '900ms',
      easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)',
      fillMode: 'both',
    },
    new: {
      name: 'app-page-premium-in',
      duration: '900ms',
      easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)',
      fillMode: 'both',
    },
  },
  backwards: {
    old: {
      name: 'app-page-premium-out',
      duration: '900ms',
      easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)',
      fillMode: 'both',
    },
    new: {
      name: 'app-page-premium-in',
      duration: '900ms',
      easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)',
      fillMode: 'both',
    },
  },
};

const hexToRgbString = (hex) => {
  if (!hex || typeof hex !== 'string') return '';
  const value = hex.trim();

  if (!/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/.test(value)) {
    return value;
  }

  let r = 0;
  let g = 0;
  let b = 0;

  if (value.length === 4) {
    r = parseInt(value[1] + value[1], 16);
    g = parseInt(value[2] + value[2], 16);
    b = parseInt(value[3] + value[3], 16);
  } else {
    r = parseInt(value[1] + value[2], 16);
    g = parseInt(value[3] + value[4], 16);
    b = parseInt(value[5] + value[6], 16);
  }

  return `${r} ${g} ${b}`;
};

const pathname = new URL(Astro.request.url).pathname;
const isAdminRepertorioView = pathname === '/admin';
const isChordProPrintView = pathname === '/herramientas/chordpro-print';
const isLiveDirectorPreviewView = pathname === '/herramientas/live-director-preview';
const isAuthView = pathname === '/login' || pathname === '/reset-password';
const showBottomNav = !isAdminRepertorioView && !isChordProPrintView && !isLiveDirectorPreviewView && !isAuthView;
const showGlobalRuntimeIslands = !isAuthView;
const brandingAccessToken = Astro.cookies.get('sb-access-token')?.value || '';
const shouldBustBrandingCache =
  Astro.cookies.has('branding_cache_bust') ||
  Astro.request.headers.get('x-branding-bust') === '1' ||
  new URL(Astro.request.url).searchParams.get('branding_bust') === '1';

if (shouldBustBrandingCache) {
  invalidarCacheBranding();
  Astro.cookies.delete('branding_cache_bust', { path: '/' });
}

const brandingData = await getBrandingConfig({ accessToken: brandingAccessToken });
const themeColors = brandingData;
---
<!DOCTYPE html>
<html lang="es" data-branding-source={themeColors ? 'ssr' : 'default'} data-admin-route={isAdminRepertorioView ? 'true' : 'false'}>
<head>
 <meta charset="UTF-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
 <link rel="preload" href="/fonts/redil/adineuePRO-Regular.woff2" as="font" type="font/woff2" crossorigin />
 <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
 <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

 <script is:inline>
  (() => {
    window.__REDIL_BOOT_SPLASH_STARTED_AT__ = window.__REDIL_BOOT_SPLASH_STARTED_AT__ || Date.now();

    const syncStandaloneAppState = () => {
      const root = document.documentElement;
      const capacitorBridge = window.Capacitor;
      const isCapacitorNative =
        Boolean(capacitorBridge?.isNativePlatform?.()) ||
        capacitorBridge?.getPlatform?.() === 'ios' ||
        capacitorBridge?.getPlatform?.() === 'android';
      const isStandalone =
        isCapacitorNative ||
        window.matchMedia('(display-mode: standalone)').matches ||
        window.navigator.standalone === true;
      root.dataset.nativeApp = isCapacitorNative ? 'true' : 'false';
      root.dataset.standaloneApp = isStandalone ? 'true' : 'false';
      const bootSplashDismissed = root.dataset.bootSplashDismissed === 'true';
      root.classList.toggle('app-boot-active', isStandalone && !bootSplashDismissed);
    };

    window.__REDIL_SYNC_STANDALONE_APP_STATE__ = syncStandaloneAppState;
    syncStandaloneAppState();
    window.setTimeout(syncStandaloneAppState, 0);
    window.setTimeout(syncStandaloneAppState, 250);
    window.addEventListener('resize', syncStandaloneAppState);
    window.addEventListener('pageshow', syncStandaloneAppState);
    document.addEventListener('astro:page-load', syncStandaloneAppState);

    const originalAddEventListener = document.addEventListener.bind(document);
    document.addEventListener = function (type, listener, options) {
      if (type === 'DOMContentLoaded' && document.readyState !== 'loading') {
        queueMicrotask(() => {
          const event = new Event('DOMContentLoaded');
          if (typeof listener === 'function') {
            listener.call(document, event);
          } else if (listener && typeof listener.handleEvent === 'function') {
            listener.handleEvent(event);
          }
        });
        return;
      }

      return originalAddEventListener(type, listener, options);
    };
  })();
 </script>
 <ClientRouter />
  <script is:inline>
   (() => {
    try {
      const root = document.documentElement;
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

      const getStoredTheme = () => {
        try {
          const value = localStorage.getItem('theme');
          return value === 'dark' || value === 'light' ? value : null;
        } catch {
          return null;
        }
      };

      const emitThemeChanged = (isDark) => {
        window.dispatchEvent(new CustomEvent('redil:theme-changed', { detail: { isDark } }));
      };

      if (!window.__REDIL_THEME_MANAGER__) {
        const applyTheme = () => {
          const savedTheme = getStoredTheme();
          const isDark = savedTheme ? savedTheme === 'dark' : mediaQuery.matches;
          root.classList.toggle('dark', isDark);
          root.style.colorScheme = isDark ? 'dark' : 'light';
          return isDark;
        };

        const setTheme = (nextTheme) => {
          try {
            if (nextTheme === 'dark' || nextTheme === 'light') {
              localStorage.setItem('theme', nextTheme);
            } else {
              localStorage.removeItem('theme');
            }
          } catch {
            // no-op
          }
          const isDark = applyTheme();
          emitThemeChanged(isDark);
          return isDark;
        };

        const syncTheme = () => {
          const isDark = applyTheme();
          emitThemeChanged(isDark);
        };

        const syncWithSystem = () => {
          if (getStoredTheme()) return;
          syncTheme();
        };

        if (typeof mediaQuery.addEventListener === 'function') {
          mediaQuery.addEventListener('change', syncWithSystem);
        } else if (typeof mediaQuery.addListener === 'function') {
          mediaQuery.addListener(syncWithSystem);
        }

        document.addEventListener('astro:after-swap', syncTheme);
        document.addEventListener('astro:page-load', syncTheme);
        window.addEventListener('pageshow', syncTheme);
        window.addEventListener('storage', (event) => {
          if (event.key !== 'theme') return;
          syncTheme();
        });

        window.__REDIL_THEME_MANAGER__ = {
          applyTheme,
          setTheme,
          getStoredTheme,
        };
      }

      const isDark = window.__REDIL_THEME_MANAGER__.applyTheme();
      emitThemeChanged(isDark);

      const applyBrandingFallbackFromLocalStorage = () => {
        const brandingSource = document.documentElement.dataset.brandingSource || '';
        const ssrTrajoColores = getComputedStyle(document.documentElement)
          .getPropertyValue('--color-brand')
          .trim();
        const esDefaultHardcodeado = ssrTrajoColores === '20 184 166';
        const shouldUseLocalFallback =
          brandingSource !== 'ssr' && (!ssrTrajoColores || esDefaultHardcodeado);

        if (!shouldUseLocalFallback) {
          console.log('[Branding] SSR trajo branding válido, localStorage no interviene');
          return;
        }

        const rawBranding = localStorage.getItem('branding_config_cache_v1');
        if (!rawBranding) return;

        const isHexColor = (value) => /^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/.test(value || '');
        const hexToRgb = (hex) => {
          if (!isHexColor(hex)) return '';
          const value = hex.trim();
          let r = 0;
          let g = 0;
          let b = 0;
          if (value.length === 4) {
            r = parseInt(value[1] + value[1], 16);
            g = parseInt(value[2] + value[2], 16);
            b = parseInt(value[3] + value[3], 16);
          } else {
            r = parseInt(value[1] + value[2], 16);
            g = parseInt(value[3] + value[4], 16);
            b = parseInt(value[5] + value[6], 16);
          }
          return `${r} ${g} ${b}`;
        };

        const map = {
          brand: '--color-brand',
          action: '--color-action',
          danger: '--color-danger',
          success: '--color-success',
          warning: '--color-warning',
          info: '--color-info',
          accent: '--color-accent',
          neutral: '--color-neutral',
          overlay: '--color-overlay',
          rolDir: '--color-rol-dir',
          rolLet: '--color-rol-let',
          rolBan: '--color-rol-ban',
          rolVoc: '--color-rol-voc',
        };

        try {
          const parsed = JSON.parse(rawBranding);
          if (!parsed || typeof parsed !== 'object' || Object.keys(parsed).length === 0) {
            return;
          }

          Object.entries(map).forEach(([key, cssVar]) => {
            const value = parsed?.[key];
            const rgbValue = typeof value === 'string' ? hexToRgb(value) : '';
            if (rgbValue) {
              document.documentElement.style.setProperty(cssVar, rgbValue);
            }
          });

          if (!parsed?.action && parsed?.brand) {
            const brandAsAction = hexToRgb(parsed.brand);
            if (brandAsAction) {
              document.documentElement.style.setProperty('--color-action', brandAsAction);
            }
          }

          console.log('[Branding] Fallback: usando localStorage porque SSR no trajo branding válido');
        } catch (error) {
          console.warn('[Branding] localStorage corrupto, ignorando', error);
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', applyBrandingFallbackFromLocalStorage, { once: true });
      } else {
        applyBrandingFallbackFromLocalStorage();
      }

      document.addEventListener('astro:page-load', applyBrandingFallbackFromLocalStorage);
      document.addEventListener('astro:after-swap', applyBrandingFallbackFromLocalStorage);
    } catch {
      // no-op
    }
   })();
  </script>
 <link rel="icon" type="image/x-icon" href="/favicon.ico?v=20260403" />
 <link rel="shortcut icon" href="/favicon.ico?v=20260403" />
 <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=20260403" />
 <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=20260403" />
 <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg?v=20260403" />
 <meta name="generator" content={Astro.generator} />
 <title>Alabanza</title>
 <link rel="manifest" href="/manifest.webmanifest" />
 <meta name="mobile-web-app-capable" content="yes">
 <meta name="apple-mobile-web-app-capable" content="yes">
 <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
 <meta name="apple-mobile-web-app-title" content="App Alabanza">
 <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)" />
 <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
 
 <link rel="apple-touch-icon" href="/apple-touch-icon.png">
 <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
 <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png">
 
  <style is:global>
    :root {
      /* ðŸŽ¨ TOKENS DE SUPERFICIE Y TEXTO (MODO CLARO) */
      --bg-background: 248 250 252;
      --bg-surface: 255 255 255;
      --border-base: 226 232 240;
      --text-base: 15 23 42;
      --text-muted: 100 116 139;
    
      /* ðŸŽ¨ TOKENS SEMÁNTICOS DE LA APP (RGB puro) */
      --color-brand: 20 184 166;
      --color-action: 20 184 166;
      --color-danger: 239 68 68;
      --color-success: 34 197 94;
      --color-warning: 249 115 22;
      --color-info: 59 130 246;
      --color-accent: 236 72 153;

      /* ðŸŽ¨ TOKENS ESTRUCTURALES Y ROLES */
      --color-neutral: 100 116 139;
      --color-overlay: 10 10 12;
      --color-rol-dir: 139 92 246;
      --color-rol-let: 245 158 11;
      --color-rol-ban: 20 184 166;
      --color-rol-voc: 168 85 247;
    }
    
    /* ðŸŒ™ TOKENS DE MODO OSCURO (Activados por clase 'dark' en el DOM root) */
    html.dark {
      --bg-background: 9 9 11;
      --bg-surface: 24 24 27;
      --border-base: 63 63 70;
      --text-base: 250 250 250;
      --text-muted: 161 161 170;
      /* Los tokens semánticos no mutan para mantener contraste vibrante */
    }

    @media print {
      body, html { background-color: white !important; color: black !important; }
      .no-print, nav, header { display: none !important; }
      .print-only { display: block !important; }
      @page { margin: 2cm; }
    }

    .print-only { display: none; }
    .nav-link-active { color: rgb(var(--text-base)) !important; border-bottom-width: 2px !important; border-color: rgb(var(--color-brand)) !important; }
    .nav-link-inactive { color: rgb(var(--text-muted)) !important; border-color: transparent !important; }

    html,
    body {
      min-height: 100%;
      background-color: rgb(var(--bg-background));
    }

    html[data-standalone-app='true'].app-boot-active,
    html[data-standalone-app='true'].app-boot-active body {
      background-color: #020617;
    }

    html[data-standalone-app='true'].app-boot-active body {
      background-image: none;
      color-scheme: dark;
    }

    html[data-admin-route='true'],
    html[data-admin-route='true'] body,
    body[data-admin-route='true'] {
      height: 100dvh;
      overflow: hidden;
      overscroll-behavior: none;
    }

    body {
      min-height: 100dvh;
      /* Dot grid — premium texture (Linear/Vercel style) */
      background-image: radial-gradient(circle, rgba(0,0,0,0.055) 1px, transparent 1px);
      background-size: 22px 22px;
    }

    html.dark body {
      background-image: radial-gradient(circle, rgba(255,255,255,0.038) 1px, transparent 1px);
      background-size: 22px 22px;
    }

    @media print {
      body { background-image: none !important; }
    }

    #standalone-boot-splash {
      position: fixed;
      inset: 0;
      z-index: 80;
      display: none;
      align-items: center;
      justify-content: center;
      padding: clamp(1.5rem, 4vw, 2.5rem);
      background:
        radial-gradient(circle at top, rgba(59, 130, 246, 0.18), transparent 42%),
        linear-gradient(180deg, #030712 0%, #020617 100%);
      pointer-events: none;
    }

    html[data-standalone-app='true'].app-boot-active #standalone-boot-splash {
      display: flex;
      pointer-events: auto;
    }

    .standalone-boot-splash__card {
      display: flex;
      width: min(100%, 18rem);
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem 1rem;
      text-align: center;
    }

    .standalone-boot-splash__logo {
      width: min(100%, 13.5rem);
      height: auto;
      object-fit: contain;
      filter: drop-shadow(0 18px 30px rgba(59, 130, 246, 0.12));
    }

    .standalone-boot-splash__spinner {
      width: 1.75rem;
      height: 1.75rem;
      border-radius: 9999px;
      border: 2px solid rgba(255, 255, 255, 0.12);
      border-top-color: #60a5fa;
      animation: standalone-boot-splash-spin 0.78s linear infinite;
    }

    .standalone-boot-splash__label {
      color: rgba(255, 255, 255, 0.92);
      font-size: 0.94rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .standalone-boot-splash__hint {
      color: rgba(255, 255, 255, 0.58);
      font-size: 0.75rem;
      line-height: 1.4;
    }

    #layout-notification-bell {
      transition:
        opacity 0.18s ease,
        transform 0.18s ease,
        visibility 0.18s ease;
    }

    @media (max-width: 767px) {
      html[data-mobile-modal-open='true'] #layout-notification-bell {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translate3d(0, -0.4rem, 0) scale(0.96);
      }
    }

    @keyframes standalone-boot-splash-spin {
      to {
        transform: rotate(360deg);
      }
    }

    @keyframes app-page-premium-in {
      from {
        opacity: 0;
        transform: translate3d(0, 18px, 0);
      }
      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @keyframes app-page-premium-out {
      from {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
      to {
        opacity: 0;
        transform: translate3d(0, -18px, 0);
      }
    }

    [data-astro-transition-scope] {
      background-color: rgb(var(--bg-background));
      isolation: isolate;
    }

    @media (prefers-reduced-motion: reduce) {
      [data-astro-transition-scope] {
        animation: none !important;
        transform: none !important;
      }
    }
  </style>

  {themeColors && (
    <style is:global set:html={`
      :root {
        ${themeColors.brand ? `--color-brand: ${hexToRgbString(themeColors.brand)};` : ''}
        ${
          themeColors.action
            ? `--color-action: ${hexToRgbString(themeColors.action)};`
            : themeColors.brand
              ? `--color-action: ${hexToRgbString(themeColors.brand)};`
              : ''
        }
        ${themeColors.danger ? `--color-danger: ${hexToRgbString(themeColors.danger)};` : ''}
        ${themeColors.success ? `--color-success: ${hexToRgbString(themeColors.success)};` : ''}
        ${themeColors.warning ? `--color-warning: ${hexToRgbString(themeColors.warning)};` : ''}
        ${themeColors.info ? `--color-info: ${hexToRgbString(themeColors.info)};` : ''}
        ${themeColors.accent ? `--color-accent: ${hexToRgbString(themeColors.accent)};` : ''}
        ${themeColors.neutral ? `--color-neutral: ${hexToRgbString(themeColors.neutral)};` : ''}
        ${themeColors.overlay ? `--color-overlay: ${hexToRgbString(themeColors.overlay)};` : ''}
        ${themeColors.rolDir ? `--color-rol-dir: ${hexToRgbString(themeColors.rolDir)};` : ''}
        ${themeColors.rolLet ? `--color-rol-let: ${hexToRgbString(themeColors.rolLet)};` : ''}
        ${themeColors.rolBan ? `--color-rol-ban: ${hexToRgbString(themeColors.rolBan)};` : ''}
        ${themeColors.rolVoc ? `--color-rol-voc: ${hexToRgbString(themeColors.rolVoc)};` : ''}
      }
    `} />
  )}
</head>
<body transition:animate="none" data-admin-route={isAdminRepertorioView ? 'true' : 'false'} class="app-shell bg-background text-content min-h-screen min-h-[100dvh] w-full flex flex-col">
 <div id="standalone-boot-splash" aria-hidden="true">
  <div class="standalone-boot-splash__card">
   <img class="standalone-boot-splash__logo" src="/LOGO%20REDIL%20LIGHT.png" alt="Redil Alabanza" loading="eager" decoding="async" />
   <span class="standalone-boot-splash__spinner" aria-hidden="true"></span>
   <p class="standalone-boot-splash__label">Cargando app</p>
   <p class="standalone-boot-splash__hint">Preparando tu espacio de trabajo</p>
  </div>
 </div>
{pathname !== '/' && user && !isAdminRepertorioView && !isChordProPrintView && !isLiveDirectorPreviewView && (
  <div
   id="layout-notification-bell"
   class="fixed right-4 md:right-6 z-[61] pointer-events-none"
   style="top: calc(env(safe-area-inset-top) + 0.75rem);"
  >
   <div class="pointer-events-auto flex-shrink-0">
    <NotificationBell inline client:idle />
   </div>
  </div>
 )}
 <main
  transition:animate={premiumPageTransition}
  class={`app-safe-main relative isolate w-full flex-1 bg-background px-4 lg:px-8 xl:px-12 ${
    isAdminRepertorioView
      ? 'box-border flex min-h-0 h-[calc(100dvh-var(--app-safe-top-offset))] max-h-[calc(100dvh-var(--app-safe-top-offset))] flex-col overflow-x-clip overflow-y-hidden pb-[calc(env(safe-area-inset-bottom)+0.35rem)]'
      : 'min-h-screen min-h-[100dvh] overflow-x-clip pb-24'
  }`}
 >
 <!-- Contenedor principal (pb-24 evita choque visual con la barra flotante). -->
 <slot />
 </main>

 {showGlobalRuntimeIslands && <ProPlayerGlobal />}
 {showGlobalRuntimeIslands && <VocesModalGlobal />}
 {showGlobalRuntimeIslands && <EnsayoGlobal />}

 <!-- Barra de navegacion fija mobile-first -->
 {showBottomNav && <BottomNav />}

 <div id="global-nav-loading" class="hidden fixed inset-0 z-40 bg-background/86 backdrop-blur-sm" aria-hidden="true">
  <div class="absolute inset-0 flex items-center justify-center px-6">
   <div class="flex items-center gap-3 rounded-2xl border border-border bg-surface/95 px-4 py-3 shadow-2xl">
    <span class="h-4 w-4 rounded-full border-2 border-brand/30 border-t-brand animate-spin" aria-hidden="true"></span>
    <span class="text-sm font-semibold text-content">Cargando...</span>
   </div>
  </div>
 </div>

 {showGlobalRuntimeIslands && (
  <script>
   import { audioSessionService } from '../services/AudioSessionService';

   if (!window.__REDIL_AUDIO_SESSION_BOOTSTRAPPED__) {
     window.__REDIL_AUDIO_SESSION_BOOTSTRAPPED__ = true;
     audioSessionService.install();
   }
  </script>
 )}

 <script>
  import { Capacitor } from '@capacitor/core';

  if (!window.__REDIL_CAPACITOR_INTERNAL_NAV_INITIALIZED__) {
    window.__REDIL_CAPACITOR_INTERNAL_NAV_INITIALIZED__ = true;

    const isNativeApp = () => Capacitor.isNativePlatform();

    const toInternalPath = (rawUrl) => {
      if (!rawUrl || typeof rawUrl !== 'string') return null;
      if (/^(mailto:|tel:|sms:|blob:|data:|javascript:)/i.test(rawUrl)) return null;

      try {
        const url = new URL(rawUrl, window.location.href);
        if (url.origin !== window.location.origin) return null;
        return `${url.pathname}${url.search}${url.hash}`;
      } catch {
        return null;
      }
    };

    document.addEventListener(
      'click',
      (event) => {
        if (!isNativeApp()) return;
        const target = event.target instanceof Element ? event.target : null;
        const link = target?.closest?.('a[target="_blank"]');
        if (!link) return;

        const internalPath = toInternalPath(link.getAttribute('href') || '');
        if (!internalPath) return;

        event.preventDefault();
        event.stopPropagation();
        window.location.assign(internalPath);
      },
      true,
    );

    const nativeOpen = window.open?.bind(window);
    if (nativeOpen) {
      window.open = (rawUrl, target, features) => {
        if (isNativeApp() && (!target || target === '_blank')) {
          const internalPath = toInternalPath(String(rawUrl || ''));
          if (internalPath) {
            window.location.assign(internalPath);
            return window;
          }
        }

        return nativeOpen(rawUrl, target, features);
      };
    }
  }
 </script>

 <script>
  import { supabase } from '../lib/supabase';

  const COOKIE_MAX_AGE = 60 * 60 * 24 * 365;
  const AUTH_COOKIE_REGEX = /^(sb-|__Host-sb-|__Secure-sb-|supabase-)/i;

  const writeSessionCookies = (session) => {
    const secureFlag = window.location.protocol === 'https:' ? '; Secure' : '';
    if (!session?.access_token) return;

    document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=${COOKIE_MAX_AGE}; SameSite=Lax${secureFlag}`;
    if (session.refresh_token) {
      document.cookie = `sb-refresh-token=${session.refresh_token}; path=/; max-age=${COOKIE_MAX_AGE}; SameSite=Lax${secureFlag}`;
    }
  };

  const expireCookie = (name) => {
    if (!name) return;
    const secureFlag = window.location.protocol === 'https:' ? '; Secure' : '';
    document.cookie = `${name}=; path=/; max-age=0; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax${secureFlag}`;
    document.cookie = `${name}=; path=/; max-age=0; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=None${secureFlag}`;
  };

  const clearSessionCookies = () => {
    const names = new Set(['sb-access-token', 'sb-refresh-token']);
    const rawCookies = document.cookie ? document.cookie.split(';') : [];
    rawCookies.forEach((cookiePart) => {
      const [rawName] = cookiePart.trim().split('=');
      if (!rawName) return;
      if (AUTH_COOKIE_REGEX.test(rawName)) {
        names.add(rawName);
      }
    });

    names.forEach((name) => expireCookie(name));

    try {
      Object.keys(localStorage).forEach((key) => {
        if (AUTH_COOKIE_REGEX.test(key) || key.includes('supabase.auth.token')) {
          localStorage.removeItem(key);
        }
      });
    } catch {
      // no-op
    }
  };

  window.__REDIL_AUTH_MANAGER__ = {
    clearSessionCookies,
  };

  const bootstrapSessionCookieSync = async () => {
    try {
      const { data } = await supabase.auth.getSession();
      if (data?.session) writeSessionCookies(data.session);
    } catch {
      // no-op
    }
  };

  bootstrapSessionCookieSync();

  supabase.auth.onAuthStateChange((event, session) => {
    if ((event === 'SIGNED_IN' || event === 'TOKEN_REFRESHED' || event === 'USER_UPDATED') && session) {
      writeSessionCookies(session);
      return;
    }

    if (event === 'INITIAL_SESSION' && session) {
      writeSessionCookies(session);
      return;
    }

    if (event === 'SIGNED_OUT') {
      clearSessionCookies();
      if (window.location.pathname !== '/login') {
        window.location.assign('/login');
      }
    }
 });
 </script>

 <script is:inline>
  (() => {
    if (window.__REDIL_MOBILE_MODAL_GUARD_INITIALIZED__) return;
    window.__REDIL_MOBILE_MODAL_GUARD_INITIALIZED__ = true;

    const root = document.documentElement;
    const modalSelector = [
      '[data-ui-modal="true"]:not([aria-hidden="true"])',
      '[aria-modal="true"]:not([aria-hidden="true"])',
      'dialog[open]',
    ].join(',');

    let observer = null;
    let rafId = 0;

    const syncModalState = () => {
      rafId = 0;
      const hasOpenModal = Boolean(document.querySelector(modalSelector));
      root.dataset.mobileModalOpen = hasOpenModal ? 'true' : 'false';
    };

    const scheduleSync = () => {
      if (rafId) return;
      rafId = window.requestAnimationFrame(syncModalState);
    };

    const startObserver = () => {
      if (!document.body) return;
      if (!observer) {
        observer = new MutationObserver(scheduleSync);
      }

      observer.observe(document.body, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ['aria-hidden', 'aria-modal', 'class', 'data-ui-modal', 'hidden', 'open', 'style'],
      });

      scheduleSync();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', startObserver, { once: true });
    } else {
      startObserver();
    }

    document.addEventListener('astro:after-swap', scheduleSync);
    document.addEventListener('astro:page-load', scheduleSync);
    window.addEventListener('pageshow', scheduleSync);
    window.addEventListener('resize', scheduleSync);
  })();
 </script>

 <script is:inline>
  (() => {
    if (window.__REDIL_BOOT_SPLASH_INITIALIZED__) return;
    window.__REDIL_BOOT_SPLASH_INITIALIZED__ = true;

    const root = document.documentElement;
    const syncStandaloneAppState = window.__REDIL_SYNC_STANDALONE_APP_STATE__ || (() => {});
    const MIN_BOOT_SPLASH_MS = 980;
    let dismissTimer = 0;

    const dismissSplash = () => {
      root.dataset.bootSplashDismissed = 'true';
      root.classList.remove('app-boot-active');
      syncStandaloneAppState();
    };

    const scheduleDismiss = () => {
      const isStandalone =
        root.dataset.standaloneApp === 'true' ||
        window.matchMedia('(display-mode: standalone)').matches ||
        window.navigator.standalone === true;

      if (!isStandalone) {
        dismissSplash();
        return;
      }

      window.clearTimeout(dismissTimer);
      const startedAt = window.__REDIL_BOOT_SPLASH_STARTED_AT__ || Date.now();
      const elapsed = Date.now() - startedAt;
      const wait = Math.max(0, MIN_BOOT_SPLASH_MS - elapsed);
      dismissTimer = window.setTimeout(dismissSplash, wait);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scheduleDismiss, { once: true });
    } else {
      scheduleDismiss();
    }

    document.addEventListener('astro:page-load', scheduleDismiss);
    window.addEventListener('pageshow', scheduleDismiss);
  })();
 </script>

 <script is:inline>
  (() => {
    if (window.__REDIL_NAV_LOADING_INITIALIZED__) return;
    window.__REDIL_NAV_LOADING_INITIALIZED__ = true;

    const state = {
      showTimer: 0,
      hideTimer: 0,
      visible: false,
      shownAt: 0,
    };

    const MIN_VISIBLE_MS = 220;
    const SHOW_DELAY_MS = 120;

    const getLoader = () => document.getElementById('global-nav-loading');

    const showLoader = () => {
      const loader = getLoader();
      if (!loader || state.visible) return;
      state.visible = true;
      state.shownAt = Date.now();
      loader.classList.remove('hidden');
      loader.setAttribute('aria-hidden', 'false');
    };

    const hideLoader = () => {
      const loader = getLoader();
      if (!loader) return;
      state.visible = false;
      loader.classList.add('hidden');
      loader.setAttribute('aria-hidden', 'true');
    };

    const start = () => {
      window.clearTimeout(state.showTimer);
      window.clearTimeout(state.hideTimer);
      state.showTimer = window.setTimeout(showLoader, SHOW_DELAY_MS);
    };

    const stop = () => {
      window.clearTimeout(state.showTimer);
      window.clearTimeout(state.hideTimer);
      if (!state.visible) {
        hideLoader();
        return;
      }
      const elapsed = Date.now() - state.shownAt;
      const wait = Math.max(0, MIN_VISIBLE_MS - elapsed);
      state.hideTimer = window.setTimeout(hideLoader, wait);
    };

    window.__REDIL_NAV_LOADING__ = { start, stop };

    document.addEventListener('astro:after-swap', stop);
    document.addEventListener('astro:page-load', stop);
    window.addEventListener('pageshow', stop);
  })();
 </script>

 <script is:inline>
  (() => {
    if (!('serviceWorker' in navigator)) return;
    if (window.__REDIL_MAIN_SW_SYNC__) return;
    const isLocalHost =
      window.location.hostname === 'localhost' ||
      window.location.hostname === '127.0.0.1';
    if (isLocalHost) return;
    window.__REDIL_MAIN_SW_SYNC__ = true;

    // Defer SW registration to after page is interactive
    const doRegister = () => {
      navigator.serviceWorker
        .register('/sw.js')
        .then((registration) => {
          registration.onupdatefound = () => {
            const installingWorker = registration.installing;
            if (!installingWorker) return;

            installingWorker.onstatechange = () => {
              if (
                installingWorker.state === 'installed' &&
                navigator.serviceWorker.controller
              ) {
                window.location.reload();
              }
            };
          };
        })
        .catch((error) => {
          console.warn('SW main registration sync failed', error);
        });
    };

    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(doRegister);
    } else {
      setTimeout(doRegister, 2000);
    }
  })();
 </script>
