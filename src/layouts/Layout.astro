---
import '../styles/global.css';
import BottomNav from '../components/BottomNav.astro';
import ProPlayerGlobal from '../components/ProPlayerGlobal.astro';
import VocesModalGlobal from '../components/VocesModalGlobal.astro';
import NotificationBell from '../components/react/NotificationBell.jsx';
import { supabase } from '../lib/supabase';
import { ClientRouter } from 'astro:transitions';

const user = Astro.locals.user;
const perfil = Astro.locals.perfil;

const premiumPageTransition = {
  forwards: {
    old: {
      name: 'app-page-premium-out',
      duration: '900ms',
      easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)',
      fillMode: 'both',
    },
    new: {
      name: 'app-page-premium-in',
      duration: '900ms',
      easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)',
      fillMode: 'both',
    },
  },
  backwards: {
    old: {
      name: 'app-page-premium-out',
      duration: '900ms',
      easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)',
      fillMode: 'both',
    },
    new: {
      name: 'app-page-premium-in',
      duration: '900ms',
      easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)',
      fillMode: 'both',
    },
  },
};

const hexToRgbString = (hex) => {
  if (!hex || typeof hex !== 'string') return '';
  const value = hex.trim();

  if (!/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/.test(value)) {
    return value;
  }

  let r = 0;
  let g = 0;
  let b = 0;

  if (value.length === 4) {
    r = parseInt(value[1] + value[1], 16);
    g = parseInt(value[2] + value[2], 16);
    b = parseInt(value[3] + value[3], 16);
  } else {
    r = parseInt(value[1] + value[2], 16);
    g = parseInt(value[3] + value[4], 16);
    b = parseInt(value[5] + value[6], 16);
  }

  return `${r} ${g} ${b}`;
};

const BRANDING_TABLE_CANDIDATES = ['configuracion_app', 'configuracion', 'branding_config'];

const isTableNotFoundError = (error) => {
  if (!error) return false;
  const message = String(error.message || '').toLowerCase();
  return error.code === 'PGRST205' || message.includes('could not find the table');
};

let themeColors = null;
for (const table of BRANDING_TABLE_CANDIDATES) {
  const { data, error } = await supabase
    .from(table)
    .select('colores')
    .eq('id', 1)
    .limit(1);

  if (error) {
    if (isTableNotFoundError(error)) continue;
    continue;
  }

  themeColors = data?.[0]?.colores || null;
  break;
}

const pathname = new URL(Astro.request.url).pathname;
---
<!DOCTYPE html>
<html lang="es">
<head>
 <meta charset="UTF-8" />
 <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
 <script is:inline>
  (function nuclearCacheFlushV2() {
    const FLAG_KEY = "v2_cache_cleared";

    try {
      if (localStorage.getItem(FLAG_KEY) === "1") return;
    } catch (_) {
      return;
    }

    (async () => {
      try {
        // 1) Destruir todas las Cache Storage
        if ("caches" in window) {
          const cacheNames = await window.caches.keys();
          await Promise.all(cacheNames.map((name) => window.caches.delete(name)));
        }

        // 2) Matar todos los Service Workers
        if ("serviceWorker" in navigator) {
          const regs = await navigator.serviceWorker.getRegistrations();
          await Promise.all(regs.map((reg) => reg.unregister()));
        }

        // 3) Marcar como ejecutado (one-shot)
        localStorage.setItem(FLAG_KEY, "1");

        // 4) Recarga dura
        // reload(true) está deprecado en algunos navegadores, pero se mantiene por compat.
        window.location.reload(true);
      } catch (err) {
        console.error("[CACHE-NUCLEAR-FLUSH] Error:", err);
        // Evitar loop incluso si algo falla
        try {
          localStorage.setItem(FLAG_KEY, "1");
        } catch (_) {}
        window.location.reload();
      }
    })();
  })();
</script>
  <script is:inline>
  (() => {
    const isLocalHost =
      window.location.hostname === 'localhost' ||
      window.location.hostname === '127.0.0.1';
    if (!isLocalHost) return;

    if ('serviceWorker' in navigator) {
      navigator.serviceWorker
        .getRegistrations()
        .then((registrations) => Promise.all(registrations.map((registration) => registration.unregister())))
        .catch(() => {});
    }

    if ('caches' in window) {
      caches
        .keys()
        .then((keys) => Promise.all(keys.map((key) => caches.delete(key))))
        .catch(() => {});
    }
  })();
 </script>
 <script is:inline>
  (() => {
    const originalAddEventListener = document.addEventListener.bind(document);
    document.addEventListener = function (type, listener, options) {
      if (type === 'DOMContentLoaded' && document.readyState !== 'loading') {
        queueMicrotask(() => {
          const event = new Event('DOMContentLoaded');
          if (typeof listener === 'function') {
            listener.call(document, event);
          } else if (listener && typeof listener.handleEvent === 'function') {
            listener.handleEvent(event);
          }
        });
        return;
      }

      return originalAddEventListener(type, listener, options);
    };
  })();
 </script>
 <ClientRouter />
  <script is:inline>
   (() => {
    try {
      const root = document.documentElement;
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

      const getStoredTheme = () => {
        try {
          const value = localStorage.getItem('theme');
          return value === 'dark' || value === 'light' ? value : null;
        } catch {
          return null;
        }
      };

      const emitThemeChanged = (isDark) => {
        window.dispatchEvent(new CustomEvent('redil:theme-changed', { detail: { isDark } }));
      };

      if (!window.__REDIL_THEME_MANAGER__) {
        const applyTheme = () => {
          const savedTheme = getStoredTheme();
          const isDark = savedTheme ? savedTheme === 'dark' : mediaQuery.matches;
          root.classList.toggle('dark', isDark);
          root.style.colorScheme = isDark ? 'dark' : 'light';
          return isDark;
        };

        const setTheme = (nextTheme) => {
          try {
            if (nextTheme === 'dark' || nextTheme === 'light') {
              localStorage.setItem('theme', nextTheme);
            } else {
              localStorage.removeItem('theme');
            }
          } catch {
            // no-op
          }
          const isDark = applyTheme();
          emitThemeChanged(isDark);
          return isDark;
        };

        const syncTheme = () => {
          const isDark = applyTheme();
          emitThemeChanged(isDark);
        };

        const syncWithSystem = () => {
          if (getStoredTheme()) return;
          syncTheme();
        };

        if (typeof mediaQuery.addEventListener === 'function') {
          mediaQuery.addEventListener('change', syncWithSystem);
        } else if (typeof mediaQuery.addListener === 'function') {
          mediaQuery.addListener(syncWithSystem);
        }

        document.addEventListener('astro:after-swap', syncTheme);
        document.addEventListener('astro:page-load', syncTheme);
        window.addEventListener('pageshow', syncTheme);
        window.addEventListener('storage', (event) => {
          if (event.key !== 'theme') return;
          syncTheme();
        });

        window.__REDIL_THEME_MANAGER__ = {
          applyTheme,
          setTheme,
          getStoredTheme,
        };
      }

      const isDark = window.__REDIL_THEME_MANAGER__.applyTheme();
      emitThemeChanged(isDark);

      // Fallback global: si SSR no trae branding, usa cache local del panel.
      const rawBranding = localStorage.getItem('branding_config_cache_v1');
      if (rawBranding) {
        const isHexColor = (value) => /^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/.test(value || '');
        const hexToRgb = (hex) => {
          if (!isHexColor(hex)) return '';
          const value = hex.trim();
          let r = 0;
          let g = 0;
          let b = 0;
          if (value.length === 4) {
            r = parseInt(value[1] + value[1], 16);
            g = parseInt(value[2] + value[2], 16);
            b = parseInt(value[3] + value[3], 16);
          } else {
            r = parseInt(value[1] + value[2], 16);
            g = parseInt(value[3] + value[4], 16);
            b = parseInt(value[5] + value[6], 16);
          }
          return `${r} ${g} ${b}`;
        };

        const map = {
          brand: '--color-brand',
          action: '--color-action',
          danger: '--color-danger',
          success: '--color-success',
          warning: '--color-warning',
          info: '--color-info',
          accent: '--color-accent',
          neutral: '--color-neutral',
          overlay: '--color-overlay',
          rolDir: '--color-rol-dir',
          rolLet: '--color-rol-let',
          rolBan: '--color-rol-ban',
          rolVoc: '--color-rol-voc',
        };

        const parsed = JSON.parse(rawBranding);
        Object.entries(map).forEach(([key, cssVar]) => {
          const value = parsed?.[key];
          const rgbValue = typeof value === 'string' ? hexToRgb(value) : '';
          if (rgbValue) {
            document.documentElement.style.setProperty(cssVar, rgbValue);
          }
        });

        if (!parsed?.action && parsed?.brand) {
          const brandAsAction = hexToRgb(parsed.brand);
          if (brandAsAction) {
            document.documentElement.style.setProperty('--color-action', brandAsAction);
          }
        }
      }
    } catch {
      // no-op
    }
   })();
  </script>
 <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
 <meta name="generator" content={Astro.generator} />
 <title>Alabanza</title>
 <link rel="manifest" href="/manifest.webmanifest" />
 <meta name="mobile-web-app-capable" content="yes">
 <meta name="apple-mobile-web-app-capable" content="yes">
 <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
 <meta name="apple-mobile-web-app-title" content="App Alabanza">
 <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)" />
 <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
 
 <link rel="apple-touch-icon" href="/apple-touch-icon.png">
 <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
 <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png">
 
  <style is:global>
    :root {
      /* ðŸŽ¨ TOKENS DE SUPERFICIE Y TEXTO (MODO CLARO) */
      --bg-background: 248 250 252;
      --bg-surface: 255 255 255;
      --border-base: 226 232 240;
      --text-base: 15 23 42;
      --text-muted: 100 116 139;
    
      /* ðŸŽ¨ TOKENS SEMÁNTICOS DE LA APP (RGB puro) */
      --color-brand: 20 184 166;
      --color-action: 20 184 166;
      --color-danger: 239 68 68;
      --color-success: 34 197 94;
      --color-warning: 249 115 22;
      --color-info: 59 130 246;
      --color-accent: 236 72 153;

      /* ðŸŽ¨ TOKENS ESTRUCTURALES Y ROLES */
      --color-neutral: 100 116 139;
      --color-overlay: 10 10 12;
      --color-rol-dir: 139 92 246;
      --color-rol-let: 245 158 11;
      --color-rol-ban: 20 184 166;
      --color-rol-voc: 168 85 247;
    }
    
    /* ðŸŒ™ TOKENS DE MODO OSCURO (Activados por clase 'dark' en el DOM root) */
    html.dark {
      --bg-background: 9 9 11;
      --bg-surface: 24 24 27;
      --border-base: 63 63 70;
      --text-base: 250 250 250;
      --text-muted: 161 161 170;
      /* Los tokens semánticos no mutan para mantener contraste vibrante */
    }

    @media print {
      body, html { background-color: white !important; color: black !important; }
      .no-print, nav, header { display: none !important; }
      .print-only { display: block !important; }
      @page { margin: 2cm; }
    }

    .print-only { display: none; }
    .nav-link-active { color: rgb(var(--text-base)) !important; border-bottom-width: 2px !important; border-color: rgb(var(--color-brand)) !important; }
    .nav-link-inactive { color: rgb(var(--text-muted)) !important; border-color: transparent !important; }

    html,
    body {
      min-height: 100%;
      background-color: rgb(var(--bg-background));
    }

    body {
      min-height: 100dvh;
    }

    @keyframes app-page-premium-in {
      from {
        opacity: 0;
        transform: translate3d(0, 18px, 0);
      }
      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @keyframes app-page-premium-out {
      from {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
      to {
        opacity: 0;
        transform: translate3d(0, -18px, 0);
      }
    }

    [data-astro-transition-scope] {
      background-color: rgb(var(--bg-background));
      isolation: isolate;
    }

    @media (prefers-reduced-motion: reduce) {
      [data-astro-transition-scope] {
        animation: none !important;
        transform: none !important;
      }
    }
  </style>

  {themeColors && (
    <style is:global set:html={`
      :root {
        ${themeColors.brand ? `--color-brand: ${hexToRgbString(themeColors.brand)};` : ''}
        ${
          themeColors.action
            ? `--color-action: ${hexToRgbString(themeColors.action)};`
            : themeColors.brand
              ? `--color-action: ${hexToRgbString(themeColors.brand)};`
              : ''
        }
        ${themeColors.danger ? `--color-danger: ${hexToRgbString(themeColors.danger)};` : ''}
        ${themeColors.success ? `--color-success: ${hexToRgbString(themeColors.success)};` : ''}
        ${themeColors.warning ? `--color-warning: ${hexToRgbString(themeColors.warning)};` : ''}
        ${themeColors.info ? `--color-info: ${hexToRgbString(themeColors.info)};` : ''}
        ${themeColors.accent ? `--color-accent: ${hexToRgbString(themeColors.accent)};` : ''}
        ${themeColors.neutral ? `--color-neutral: ${hexToRgbString(themeColors.neutral)};` : ''}
        ${themeColors.overlay ? `--color-overlay: ${hexToRgbString(themeColors.overlay)};` : ''}
        ${themeColors.rolDir ? `--color-rol-dir: ${hexToRgbString(themeColors.rolDir)};` : ''}
        ${themeColors.rolLet ? `--color-rol-let: ${hexToRgbString(themeColors.rolLet)};` : ''}
        ${themeColors.rolBan ? `--color-rol-ban: ${hexToRgbString(themeColors.rolBan)};` : ''}
        ${themeColors.rolVoc ? `--color-rol-voc: ${hexToRgbString(themeColors.rolVoc)};` : ''}
      }
    `} />
  )}
</head>
<body transition:animate="none" class="bg-background text-content min-h-screen min-h-[100dvh] w-full flex flex-col">
 {pathname !== '/' && user && (
  <div class="relative z-[61] flex w-full justify-end px-4 md:px-6" style="padding-top: calc(env(safe-area-inset-top) + 0.75rem);">
   <NotificationBell inline client:load />
  </div>
 )}
 <main
  transition:animate={premiumPageTransition}
  class="relative isolate overflow-x-clip w-full min-h-screen min-h-[100dvh] flex-1 bg-background pb-24 px-4 lg:px-8 xl:px-12"
 >
 <!-- Contenedor principal (pb-24 evita choque visual con la barra flotante). -->
 <slot />
 </main>

 <ProPlayerGlobal />
 <VocesModalGlobal />

 <!-- Barra de navegacion fija mobile-first -->
 <BottomNav />

 <div id="global-nav-loading" class="hidden fixed inset-0 z-40 bg-background/86 backdrop-blur-sm" aria-hidden="true">
  <div class="absolute inset-0 flex items-center justify-center px-6">
   <div class="flex items-center gap-3 rounded-2xl border border-border bg-surface/95 px-4 py-3 shadow-2xl">
    <span class="h-4 w-4 rounded-full border-2 border-brand/30 border-t-brand animate-spin" aria-hidden="true"></span>
    <span class="text-sm font-semibold text-content">Cargando...</span>
   </div>
  </div>
 </div>

 <script>
  import { supabase } from '../lib/supabase';

  const COOKIE_MAX_AGE = 60 * 60 * 24 * 365;
  const AUTH_COOKIE_REGEX = /^(sb-|__Host-sb-|__Secure-sb-|supabase-)/i;

  const writeSessionCookies = (session) => {
    const secureFlag = window.location.protocol === 'https:' ? '; Secure' : '';
    if (!session?.access_token) return;

    document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=${COOKIE_MAX_AGE}; SameSite=Lax${secureFlag}`;
    if (session.refresh_token) {
      document.cookie = `sb-refresh-token=${session.refresh_token}; path=/; max-age=${COOKIE_MAX_AGE}; SameSite=Lax${secureFlag}`;
    }
  };

  const expireCookie = (name) => {
    if (!name) return;
    const secureFlag = window.location.protocol === 'https:' ? '; Secure' : '';
    document.cookie = `${name}=; path=/; max-age=0; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax${secureFlag}`;
    document.cookie = `${name}=; path=/; max-age=0; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=None${secureFlag}`;
  };

  const clearSessionCookies = () => {
    const names = new Set(['sb-access-token', 'sb-refresh-token']);
    const rawCookies = document.cookie ? document.cookie.split(';') : [];
    rawCookies.forEach((cookiePart) => {
      const [rawName] = cookiePart.trim().split('=');
      if (!rawName) return;
      if (AUTH_COOKIE_REGEX.test(rawName)) {
        names.add(rawName);
      }
    });

    names.forEach((name) => expireCookie(name));

    try {
      Object.keys(localStorage).forEach((key) => {
        if (AUTH_COOKIE_REGEX.test(key) || key.includes('supabase.auth.token')) {
          localStorage.removeItem(key);
        }
      });
    } catch {
      // no-op
    }
  };

  window.__REDIL_AUTH_MANAGER__ = {
    clearSessionCookies,
  };

  const bootstrapSessionCookieSync = async () => {
    try {
      const { data } = await supabase.auth.getSession();
      if (data?.session) writeSessionCookies(data.session);
    } catch {
      // no-op
    }
  };

  bootstrapSessionCookieSync();

  supabase.auth.onAuthStateChange((_event, session) => {
    if (session) writeSessionCookies(session);
    else clearSessionCookies();
  });
 </script>

 <script is:inline>
  (() => {
    if (window.__REDIL_NAV_LOADING_INITIALIZED__) return;
    window.__REDIL_NAV_LOADING_INITIALIZED__ = true;

    const state = {
      showTimer: 0,
      hideTimer: 0,
      visible: false,
      shownAt: 0,
    };

    const MIN_VISIBLE_MS = 220;
    const SHOW_DELAY_MS = 120;

    const getLoader = () => document.getElementById('global-nav-loading');

    const showLoader = () => {
      const loader = getLoader();
      if (!loader || state.visible) return;
      state.visible = true;
      state.shownAt = Date.now();
      loader.classList.remove('hidden');
      loader.setAttribute('aria-hidden', 'false');
    };

    const hideLoader = () => {
      const loader = getLoader();
      if (!loader) return;
      state.visible = false;
      loader.classList.add('hidden');
      loader.setAttribute('aria-hidden', 'true');
    };

    const start = () => {
      window.clearTimeout(state.showTimer);
      window.clearTimeout(state.hideTimer);
      state.showTimer = window.setTimeout(showLoader, SHOW_DELAY_MS);
    };

    const stop = () => {
      window.clearTimeout(state.showTimer);
      window.clearTimeout(state.hideTimer);
      if (!state.visible) {
        hideLoader();
        return;
      }
      const elapsed = Date.now() - state.shownAt;
      const wait = Math.max(0, MIN_VISIBLE_MS - elapsed);
      state.hideTimer = window.setTimeout(hideLoader, wait);
    };

    window.__REDIL_NAV_LOADING__ = { start, stop };

    document.addEventListener('astro:after-swap', stop);
    document.addEventListener('astro:page-load', stop);
    window.addEventListener('pageshow', stop);
  })();
 </script>
</body>
</html>
