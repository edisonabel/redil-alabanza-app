---
import Layout from '../../layouts/Layout.astro';
import StemConverterTool from '../../components/react/StemConverterTool';
---

<Layout title="Conversor de Stems | Redil Alabanza">
  <main class="min-h-screen pt-4 md:pt-8">
    <div class="mx-auto mb-6 w-full max-w-6xl px-4">
      <a href="/herramientas" class="inline-flex items-center text-content-muted hover:text-content transition-colors mb-6 pb-2 w-max">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 mr-2"><path d="m15 18-6-6 6-6"/></svg>
        Volver a Herramientas
      </a>

      <header class="max-w-3xl">
        <div class="page-title-row mb-3">
          <span class="page-title-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          </span>
          <h1 class="page-title text-[2rem] md:text-[3rem]">Conversor de Stems</h1>
        </div>
        <p class="page-subtitle text-sm md:text-lg">
          Arrastra stems, convierte a M4A 256 kbps / 48 kHz y descarga.
        </p>
      </header>
    </div>

    <StemConverterTool client:only="react" />
  </main>
</Layout>
