 const formAusencia = document.getElementById('form-ausencia') as HTMLFormElement;
 const btnSaveAusencia = document.getElementById('btn-save-ausencia') as HTMLButtonElement;
 const inputInicio = document.getElementById('ausencia-inicio') as HTMLInputElement;
 const inputFin = document.getElementById('ausencia-fin') as HTMLInputElement;
 const inputMotivo = document.getElementById('ausencia-motivo') as HTMLInputElement;
 const absenceDateFormatter = new Intl.DateTimeFormat('en-CA', {
 timeZone: 'America/Bogota',
 year: 'numeric',
 month: '2-digit',
 day: '2-digit',
 });
 const addDaysToDateOnly = (dateOnly: string, amount: number) => {
 const anchor = new Date(`${dateOnly}T12:00:00Z`);
 anchor.setUTCDate(anchor.getUTCDate() + amount);
 return anchor.toISOString().slice(0, 10);
 };
 const absenceMinStartDate = addDaysToDateOnly(absenceDateFormatter.format(new Date()), 7);
 const syncAbsenceDateConstraints = ({ forceResetEnd = false } = {}) => {
 const nextMinEndDate = inputInicio?.value && inputInicio.value > absenceMinStartDate
 ? inputInicio.value
 : absenceMinStartDate;
 if (inputInicio) inputInicio.min = absenceMinStartDate;
 if (inputFin) inputFin.min = nextMinEndDate;
 if (inputFin && (forceResetEnd || !inputFin.value || inputFin.value < nextMinEndDate)) {
 inputFin.value = nextMinEndDate;
 }
 };

 syncAbsenceDateConstraints({ forceResetEnd: true });
 on(inputInicio, 'input', () => syncAbsenceDateConstraints({ forceResetEnd: true }));
 on(inputInicio, 'change', () => syncAbsenceDateConstraints({ forceResetEnd: true }));

 on(formAusencia, 'submit', async (e: Event) => {
 e.preventDefault();
 if (!inputInicio.value || !inputFin.value) return;

 const originalBtnText = btnSaveAusencia.textContent;
 btnSaveAusencia.textContent = 'Guardando...';
 btnSaveAusencia.disabled = true;

 try {
 const auth = await getStableAuth();
 const userId = currentUserId || auth.user?.id;
 if (!userId) throw new Error("No session");

 const response = await fetch('/api/absences', {
 method: 'POST',
 credentials: 'same-origin',
 headers: {
 'content-type': 'application/json'
 },
 body: JSON.stringify({
 fecha_inicio: inputInicio.value,
 fecha_fin: inputFin.value,
 motivo: inputMotivo.value || null
 })
 });
 const payload = await response.json().catch(() => ({}));
 if (!response.ok || payload?.ok === false) {
 throw new Error(payload?.error || 'No se pudo registrar la ausencia.');
 }

 const result = payload?.result || {};
 const summaryMessages = ['Ausencia registrada correctamente.'];
 const removedAssignments = Number(result?.removedAssignments || 0);
 const leadersNotified = Number(result?.leadersNotified || 0);
 const eventsWithoutLeader = Number(result?.eventsWithoutLeader || 0);

 if (removedAssignments > 0) {
 const label = removedAssignments === 1 ? 'servicio' : 'servicios';
 summaryMessages.push(`Te retiramos de ${removedAssignments} ${label}.`);
 }

 if (leadersNotified > 0) {
 const label = leadersNotified === 1 ? 'lider' : 'lideres';
 summaryMessages.push(`Avisamos a ${leadersNotified} ${label}.`);
 }

 if (eventsWithoutLeader > 0) {
 const label = eventsWithoutLeader === 1 ? 'servicio' : 'servicios';
 summaryMessages.push(`Hay ${eventsWithoutLeader} ${label} sin liderazgo asignado para avisar.`);
 }

 alert(summaryMessages.join(' '));
 
 // Recargar pÃ¡gina para actualizar lista
 window.location.reload();
} catch (err) {
 console.error('Error insertando ausencia:', err);
 alert(err instanceof Error ? err.message : 'Hubo un error al registrar la ausencia. Verifica las fechas.');
 btnSaveAusencia.textContent = originalBtnText;
 btnSaveAusencia.disabled = false;
 }
 });

