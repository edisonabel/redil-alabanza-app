 const clearClientAuthState = () => {
 try {
 if (window.__REDIL_AUTH_MANAGER__?.clearSessionCookies) {
 window.__REDIL_AUTH_MANAGER__.clearSessionCookies();
 return;
 }
 } catch {
 // no-op
 }

 const secureDeleteFlag = window.location.protocol === 'https:' ? '; Secure' : '';
 const localNames = new Set(['sb-access-token', 'sb-refresh-token']);
 const rawCookies = document.cookie ? document.cookie.split(';') : [];
 rawCookies.forEach((cookiePart) => {
 const [rawName] = cookiePart.trim().split('=');
 if (!rawName) return;
 if (/^(sb-|__Host-sb-|__Secure-sb-|supabase-)/i.test(rawName)) {
 localNames.add(rawName);
 }
 });

 localNames.forEach((name) => {
 document.cookie = `${name}=; path=/; max-age=0; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax${secureDeleteFlag}`;
 document.cookie = `${name}=; path=/; max-age=0; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=None${secureDeleteFlag}`;
 });
 };

 const btnLogout = document.getElementById('btn-logout');
 on(btnLogout, 'click', async () => {
