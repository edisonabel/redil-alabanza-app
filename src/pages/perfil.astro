 canChangeAvatar = isAllowed;
 syncAvatarControls();
 };

 const setAvatarProcessingState = (isBusy: boolean) => {
 isPreparingAvatar = isBusy;
 syncAvatarControls();
 };

 const supportsCanvasMimeType = (mimeType: string): Promise<boolean> => {
 return new Promise((resolve) => {
 const testCanvas = document.createElement('canvas');
 testCanvas.width = 1;
 testCanvas.height = 1;
 testCanvas.toBlob((blob) => resolve(Boolean(blob && blob.type === mimeType)), mimeType, 0.6);
 });
 };

 syncAvatarControls();

