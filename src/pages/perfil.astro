 }

 (window as any)._initialTonalidad = vocalVal;
 (window as any)._initialCumpleanos = cumpleanosVal;
 (window as any)._initialTelefono = telefonoVal;
 btnSaveDatos.classList.add('hidden');
 
 // Alerta nativa simple
 alert('Datos guardados exitosamente');
 } catch (error) {
 console.error("Error al actualizar datos:", error);
 alert('No se pudo guardar la información.');
 } finally {
 btnSaveDatos.innerHTML = originalBtnHtml;
 btnSaveDatos.disabled = false;
 }
 });
 }
 
 // Expose delete function to window context for the innerHTML buttons
 (window as any)._deleteAusencia = async (id: string) => {
 if (!confirm('\u00BFEst\u00E1s seguro de eliminar este bloqueo de fechas?')) return;
 
 const row = document.querySelector(`[data-ausencia-id="${id}"]`) as HTMLElement;
 if(row) row.style.opacity = '0.5';

 try {
 const { error } = await supabase
 .from('ausencias')
 .delete()
 .eq('id', id);

 if (error) throw error;
 row?.remove();
 
 // If it was the last one, fetch again to show empty state
 if (document.querySelectorAll('[data-ausencia-id]').length === 0) {
 fetchData();
 }

 } catch (err) {
 console.error('Error eliminando ausencia:', err);
 alert("Error eliminando registro.");
 if(row) row.style.opacity = '1';
 }
 }

 };

 if ((window as any).__perfilPageLoadHandler) {
 document.removeEventListener('astro:page-load', (window as any).__perfilPageLoadHandler);
 }

 if ((window as any).__perfilAfterSwapHandler) {
 document.removeEventListener('astro:after-swap', (window as any).__perfilAfterSwapHandler);
 }

 const onPerfilAfterSwap = () => {
 cleanupPerfilRuntime();
 };

 (window as any).__perfilPageLoadHandler = initPerfilPage;
 (window as any).__perfilAfterSwapHandler = onPerfilAfterSwap;
 document.addEventListener('astro:page-load', initPerfilPage);
 document.addEventListener('astro:after-swap', onPerfilAfterSwap);
</script>



