---
import Layout from '../layouts/Layout.astro';
import OnboardingRoot from '../components/onboarding/OnboardingRoot';
import BotonNotificaciones from '../components/react/BotonNotificaciones.jsx';

const userId = Astro.locals.user?.id ?? null;
---

<Layout title="Mi Perfil - Redil">
 <header class="w-full flex items-center justify-between py-6 px-4 md:px-8 mb-4 border-b border-border ">
 <div>
 <div class="page-title-row">
 <span class="page-title-icon" aria-hidden="true">
 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"></circle><path d="M4 20a8 8 0 0 1 16 0"></path></svg>
 </span>
 <h1 class="page-title text-[2.1rem] md:text-[3.5rem]">Mi Perfil</h1>
 </div>
 <p class="page-subtitle text-sm">Gestiona tus datos, foto de perfil y fechas indisponibles.</p>
 </div>
 </header>

 <main class="w-full max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
 <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
 
 {/* Lado Izquierdo: Avatar y Roles (Fase 1 y 2) */}
 <div class="col-span-1 flex flex-col items-center" data-tour="perfil-photo">
 <div class="relative group w-32 h-32 mb-4">
 {/* Avatar dinÃ¡mico */}
 <div id="avatar-container" class="w-full h-full rounded-full bg-neutral/20 border-4 border-white flex items-center justify-center font-black text-4xl shadow-md overflow-hidden text-content-muted">
 <!-- Injected by JS -->
 <svg class="w-8 h-8 animate-pulse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
 </div>
 
 <button id="btn-change-avatar" class="absolute bottom-0 right-0 p-2.5 rounded-full bg-surface shadow-lg border border-border text-content-muted hover:text-action dark:hover:text-action transition-colors z-10" title="Cambiar Foto" disabled>
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" class="shrink-0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/><path d="m16 9-4 4-2-2"/></svg>
 </button>
 <!-- Input oculto para el file picker -->
 <input type="file" id="avatar-input" accept="image/*" class="hidden" />
 </div>

 <h2 id="ui-user-name" class="text-xl font-bold text-content text-center mb-1 h-7 min-w-[120px] bg-neutral/20 animate-pulse rounded mx-auto flex items-center justify-center"></h2>
 <p id="ui-user-email" class="text-sm text-content-muted text-center mb-4 h-5 min-w-[160px] bg-neutral/20 animate-pulse rounded mx-auto flex items-center justify-center"></p>

 <div id="ui-roles-container" class="flex flex-wrap items-center justify-center gap-2 mb-6 w-full min-h-[30px]">
 <div class="h-6 w-16 bg-neutral/20 animate-pulse rounded"></div>
 <div class="h-6 w-20 bg-neutral/20 animate-pulse rounded"></div>
 </div>
 </div>

 {/* Lado Derecho: Datos y Ajustes */}
 <div class="col-span-1 md:col-span-2 space-y-8">
 
 {/* Panel de Datos Personales */}
 <section class="bg-surface rounded-2xl p-6 border border-border shadow-sm">
 <h3 class="text-lg font-bold text-content mb-4 flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-action"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
 Datos Personales
 </h3>
 
 <form id="form-datos-personales" class="grid grid-cols-1 md:grid-cols-2 gap-4">
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-content-muted uppercase tracking-wide">Nombre Completo</label>
 <input type="text" id="input-nombre" disabled class="w-full bg-background border border-border text-content rounded-xl px-4 py-2 text-sm opacity-70 cursor-not-allowed" placeholder="Cargando..." />
 </div>
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-content-muted uppercase tracking-wide">Correo de Acceso</label>
 <input type="email" id="input-correo" disabled class="w-full bg-background border border-border text-content rounded-xl px-4 py-2 text-sm opacity-70 cursor-not-allowed" placeholder="Cargando..." />
 </div>
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-content-muted uppercase tracking-wide">Registro Vocal</label>
 <select id="tonalidad-select" disabled class="w-full min-w-0 bg-surface border border-border text-content rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-action focus:outline-none transition-shadow">
 <option value="">Seleccionar Perfil Vocal...</option>
 <option value="Soprano">Soprano</option>
 <option value="Contralto">Contralto</option>
 <option value="Tenor">Tenor</option>
 <option value="Bar&iacute;tono">Bar&iacute;tono / Bajo</option>
 </select>
 </div>
<div class="space-y-1.5" data-tour="perfil-birthday">
<label class="text-xs font-bold text-content-muted uppercase tracking-wide">Fecha de nacimiento</label>
<input type="date" id="input-cumpleanos" required disabled class="w-full min-w-0 bg-surface border border-border text-content rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-action focus:outline-none transition-shadow" />
<p class="text-sm text-gray-500">Esto es para recordar tu cumpleaños</p>
</div>
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-content-muted uppercase tracking-wide">Tel&eacute;fono / WhatsApp</label>
 <input type="tel" id="input-telefono" disabled class="w-full bg-surface border border-border text-content rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-action focus:outline-none transition-shadow" placeholder="Ej: +123456789" />
 </div>
 <div class="md:col-span-2 flex justify-end mt-2">
 <button type="submit" id="btn-save-datos" class="hidden px-5 py-2.5 bg-action hover:bg-action/80 text-white font-bold text-sm rounded-xl transition-colors shadow-sm flex items-center gap-2">
 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
 </svg>
 Guardar Datos
 </button>
 </div>
 </form>
 </section>

 {/* PANEL FASE 3: Sistema de Disponibilidad (Ausencias) */}
 <section class="bg-surface rounded-2xl p-6 border border-border shadow-sm mt-8" data-tour="perfil-availability">
 <h3 class="text-lg font-bold text-content mb-4 flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
 Mis Ausencias / Fechas Bloqueadas
 </h3>
 <p class="text-xs text-content-muted mb-4">Registra los dias en los que no estaras disponible. Debes bloquear con minimo 7 dias de anticipacion.</p>

 <form id="form-ausencia" class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8 bg-background p-4 rounded-xl border border-border opacity-50 pointer-events-none transition-opacity">
 <div class="space-y-1.5">
 <label class="text-[10px] font-bold text-content-muted uppercase tracking-wide">Fecha Inicio</label>
 <input type="date" id="ausencia-inicio" required class="w-full min-w-0 bg-surface border border-border text-content rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:outline-none" />
 </div>
 <div class="space-y-1.5">
 <label class="text-[10px] font-bold text-content-muted uppercase tracking-wide">Fecha Fin</label>
 <input type="date" id="ausencia-fin" required class="w-full min-w-0 bg-surface border border-border text-content rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:outline-none" />
 </div>
 <div class="space-y-1.5 md:col-span-2">
 <label class="text-[10px] font-bold text-content-muted uppercase tracking-wide">Motivo (Opcional)</label>
 <div class="flex gap-2">
 <input type="text" id="ausencia-motivo" placeholder="Ej. Viaje familiar, Trabajo..." class="flex-1 bg-surface border border-border text-content rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:outline-none" />
 <button type="submit" id="btn-save-ausencia" class="px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white font-bold text-sm rounded-lg shadow-md shadow-orange-500/20 transition-all shrink-0">Registrar</button>
 </div>
 </div>
 </form>
 <p class="text-[11px] text-content-muted mb-6">Si ya estabas asignado en ese rango, el sistema te retirara automaticamente y avisara al liderazgo del servicio para buscar reemplazo.</p>

 <div class="space-y-3" id="ausencias-list">
 <div class="py-6 text-center border-2 border-dashed border-border rounded-xl">
 <p class="text-xs font-bold text-content-muted">Cargando ausencias...</p>
 </div>
 </div>
 </section>

 {/* PANEL FASE 4: Seguirdad */}
 <section class="bg-surface rounded-2xl p-6 border border-border shadow-sm mt-8">
 <h3 class="text-lg font-bold text-content mb-4 flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-action"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
 Seguridad
 </h3>
 <div class="mb-5">
 <BotonNotificaciones client:load userId={userId} />
 </div>
 
 <div class="flex flex-col sm:flex-row gap-4 mt-6">
 <button id="btn-change-password" class="flex-1 py-3 px-4 rounded-xl border border-border bg-surface text-neutral-700 font-ui-strong text-sm hover:bg-background :bg-neutral-700 transition-colors flex items-center justify-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
 Cambiar Contrase&ntilde;a
 </button>
 <button id="btn-logout" class="flex-1 py-3 px-4 rounded-xl bg-red-500/10 text-red-600 font-ui-strong text-sm hover:bg-red-500/20 transition-colors flex items-center justify-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
 Cerrar Sesi&oacute;n
 </button>
 </div>
 </section>
 </div>
 </main>

 <OnboardingRoot client:load page="perfil" userId={userId} />

 {/* Modal para Recortar Foto */}
 <div id="cropper-modal" class="fixed inset-0 z-50 bg-black/80 hidden items-center justify-center p-4 backdrop-blur-sm transition-opacity opacity-0 duration-300">
 <div id="cropper-content" class="bg-surface rounded-2xl w-full max-w-lg overflow-hidden shadow-2xl scale-95 transition-transform duration-300">
 <div class="px-6 py-4 border-b border-border flex justify-between items-center">
 <h3 class="text-lg font-bold text-content ">Ajustar Foto de Perfil</h3>
 <button id="btn-close-cropper" class="text-content-muted hover:text-content-muted :text-neutral-200 transition-colors">
 <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
 </button>
 </div>
 
 <div class="px-6 py-4 bg-blue-50 text-blue-900 border-b border-blue-200 dark:bg-blue-900/40 dark:text-blue-100 dark:border-blue-800 flex items-start gap-3">
 <div class="mt-0.5 text-blue-700 dark:text-blue-200 shrink-0">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
 </div>
 <div class="space-y-1">
 <p class="text-sm font-bold leading-snug">Usa una foto de cerca (Retrato)</p>
 <p class="text-sm leading-snug text-blue-900 dark:text-blue-100">Ampl&iacute;a la imagen hasta que <strong class="text-blue-700 dark:text-white">tu rostro llene el c&iacute;rculo</strong>. No uses fotos de cuerpo entero ni grupales.</p>
 </div>
 </div>

 <div class="p-6 bg-background aspect-square flex items-center justify-center relative">
 <div class="w-full h-full max-h-[60vh] relative z-10">
 <img id="cropper-image" src="" alt="Imagen a recortar" class="max-w-full hidden" />
 </div>
 </div>
 <div class="px-6 py-4 border-t border-border flex justify-end gap-3 bg-background ">
 <button id="btn-cancel-cropper" class="px-5 py-2.5 rounded-xl font-bold text-sm text-content-muted hover:bg-neutral/20 :bg-neutral-800 transition-colors">Cancelar</button>
 <button id="btn-save-cropper" class="px-5 py-2.5 rounded-xl font-ui-strong text-sm bg-action hover:bg-action/80 text-white shadow-md transition-all flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
 Guardar Foto
 </button>
 </div>
 </div>
 </div>
</Layout>

<div id="avatar-lock-modal" class="fixed inset-0 z-[55] hidden items-center justify-center bg-black/60 p-4 backdrop-blur-sm opacity-0 transition-opacity duration-300">
 <div id="avatar-lock-content" class="w-full max-w-md rounded-[28px] border border-sky-200/80 bg-white shadow-2xl shadow-sky-950/10 transition-transform duration-300 scale-95 dark:border-sky-800/50 dark:bg-surface dark:shadow-black/40">
 <div class="flex items-center justify-between border-b border-border px-6 py-5">
 <div class="flex items-center gap-3">
 <div class="rounded-2xl bg-sky-100 p-2.5 text-sky-700 dark:bg-sky-900/60 dark:text-sky-200">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
 <path d="M12 3a9 9 0 1 0 9 9"></path>
 <path d="M12 7v5l3 3"></path>
 </svg>
 </div>
 <div>
 <h3 class="text-lg font-bold text-content">Cambio de foto de perfil</h3>
 <p class="text-sm text-content-muted">Informacion importante</p>
 </div>
 </div>
 <button id="btn-close-avatar-lock" class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-border bg-surface text-content-muted transition-colors hover:text-content hover:bg-background" type="button" aria-label="Cerrar aviso">
 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
 </button>
 </div>

 <div class="space-y-4 px-6 py-6">
 <p class="rounded-3xl border border-sky-200/80 bg-gradient-to-br from-sky-50 via-white to-amber-50 px-5 py-5 text-sm leading-7 text-slate-700 shadow-sm shadow-sky-100/70 dark:border-sky-800/50 dark:from-sky-950/40 dark:via-surface dark:to-amber-950/10 dark:text-slate-200 dark:shadow-none">
 <strong class="font-bold text-slate-900 dark:text-slate-50">&iexcl;Hola, Dios te bendiga!</strong>
 Para poder <strong class="font-semibold text-slate-900 dark:text-slate-50">identificarte f&aacute;cilmente en el calendario y en las asignaciones</strong>, hemos actualizado tu foto de perfil con una donde
 <strong class="font-semibold text-slate-900 dark:text-slate-50">se ve tu rostro claramente</strong>.
 Si prefieres usar una distinta, <strong class="font-semibold text-slate-900 dark:text-slate-50">&iexcl;no hay problema!</strong>
 Solo env&iacute;ale
 <strong class="font-semibold text-slate-900 dark:text-slate-50">una foto clara de tu rostro al administrador</strong>
 y con gusto la cambiaremos.
 <strong class="font-semibold text-slate-900 dark:text-slate-50">&iexcl;Un abrazo y gracias por tu comprensi&oacute;n!</strong>
 </p>
 </div>

 <div class="flex justify-end border-t border-border px-6 py-5">
 <button id="btn-confirm-avatar-lock" type="button" class="inline-flex min-h-[48px] items-center justify-center rounded-2xl bg-action px-5 py-3 text-sm font-bold text-white shadow-sm transition-colors hover:bg-action/85">
 Entendido
 </button>
 </div>
 </div>
</div>

<!-- Estilos para forzar el recorte circular de Cropperjs -->
<style is:global>
 .cropper-view-box,
 .cropper-face {
 border-radius: 50%;
 }
</style>

<!-- Script de Cropperjs vÃ­a CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" integrity="sha512-hvNR0F/e2J7zPPfLC9auFe3/SE0yG4aJCOd/qxew74NN7eyiSKjr7xJJMu1Jy2wf7FXITpWS1E/RY8yzuXN7VA==" crossorigin="anonymous" />
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js" integrity="sha512-9KkIqdfN7ipEW6B6k+Aq20PV31bjODg4AA52W+tYtAE0jE0kMx49bjJ3FgvS56wzmyfMUHbQ4Km2b7l9+Y/+Eg==" crossorigin="anonymous"></script>

<script>
 import { supabase, uploadAvatarAtomic } from '../lib/supabase';
 import { getSafeImageForCropper } from '../utils/safeImageProcessor';

 const revokePerfilSafeCropperUrl = () => {
 const safeUrl = (window as any).__perfilSafeCropperUrl as string | null | undefined;
 if (!safeUrl) return;
 URL.revokeObjectURL(safeUrl);
 (window as any).__perfilSafeCropperUrl = null;
 };

 const cleanupPerfilRuntime = () => {
 const abortController = (window as any).__perfilListenersAbort as AbortController | undefined;
 if (abortController) {
 abortController.abort();
 (window as any).__perfilListenersAbort = null;
 }

 const cropperInstance = (window as any)._cropperInstance;
 if (cropperInstance) {
 try {
 cropperInstance.destroy();
 } catch {
 // no-op
 }
 (window as any)._cropperInstance = null;
 }
 revokePerfilSafeCropperUrl();
 };

 const initPerfilPage = async () => {
 cleanupPerfilRuntime();
 const listenersAbort = new AbortController();
 const signal = listenersAbort.signal;
 (window as any).__perfilListenersAbort = listenersAbort;

 const on = (
 target: EventTarget | null | undefined,
 eventName: string,
 handler: EventListenerOrEventListenerObject,
 options: AddEventListenerOptions = {},
 ) => {
 if (!target || typeof (target as EventTarget).addEventListener !== 'function') return;
 (target as EventTarget).addEventListener(eventName, handler, { ...options, signal });
 };

 // Init global vars
 let currentUserId = null;
 let currentAvatarUrl: string | null = null;

 const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
 const getCookieValue = (name) => {
 try {
 const cookiePart = document.cookie
 .split(';')
 .map((chunk) => chunk.trim())
 .find((chunk) => chunk.startsWith(`${name}=`));
 if (!cookiePart) return '';
 return decodeURIComponent(cookiePart.substring(name.length + 1));
 } catch {
 return '';
 }
 };

 const getStableAuth = async () => {
 let lastError = null;

 for (let attempt = 0; attempt < 5; attempt += 1) {
 try {
 const { data: { session }, error } = await supabase.auth.getSession();
 if (session?.user) {
 return { session, user: session.user, error: null };
 }
 if (error) lastError = error;
 } catch (error) {
 lastError = error;
 }
 await wait(120);
 }

 const tokenFromCookie = getCookieValue('sb-access-token');
 if (tokenFromCookie) {
 try {
 const { data: { user }, error } = await supabase.auth.getUser(tokenFromCookie);
 if (user) return { session: null, user, error: null };
 if (error) lastError = error;
 } catch (error) {
 lastError = error;
 }
 }

 try {
 const { data: { user }, error } = await supabase.auth.getUser();
 if (user) return { session: null, user, error: null };
 if (error) lastError = error;
 } catch (error) {
 lastError = error;
 }

 return { session: null, user: null, error: lastError };
 };
 
 const avatarContainer = document.getElementById('avatar-container');
 const uiUserName = document.getElementById('ui-user-name');
 const uiUserEmail = document.getElementById('ui-user-email');
 const uiRolesContainer = document.getElementById('ui-roles-container');
 const inputNombre = document.getElementById('input-nombre') as HTMLInputElement;
 const inputCorreo = document.getElementById('input-correo') as HTMLInputElement;
 
 const formDatosPersonales = document.getElementById('form-datos-personales') as HTMLFormElement;
 const selectTonalidad = document.getElementById('tonalidad-select') as HTMLSelectElement;
 const inputCumpleanos = document.getElementById('input-cumpleanos') as HTMLInputElement;
 const inputTelefono = document.getElementById('input-telefono') as HTMLInputElement;
 const btnSaveDatos = document.getElementById('btn-save-datos') as HTMLButtonElement;
 
 

 // ==========================================
 // LÃ³gica de Cropper y Upload de Foto de Perfil
 // ==========================================
 const btnChangeAvatar = document.getElementById('btn-change-avatar') as HTMLButtonElement | null;
 const avatarInput = document.getElementById('avatar-input') as HTMLInputElement;
 const cropperModal = document.getElementById('cropper-modal');
 const cropperContent = document.getElementById('cropper-content');
 const cropperImage = document.getElementById('cropper-image') as HTMLImageElement;
 const btnCloseCropper = document.getElementById('btn-close-cropper');
 const btnCancelCropper = document.getElementById('btn-cancel-cropper');
 const btnSaveCropper = document.getElementById('btn-save-cropper') as HTMLButtonElement;
 const avatarLockModal = document.getElementById('avatar-lock-modal');
 const avatarLockContent = document.getElementById('avatar-lock-content');
 const btnCloseAvatarLock = document.getElementById('btn-close-avatar-lock');
 const btnConfirmAvatarLock = document.getElementById('btn-confirm-avatar-lock');
 
const avatarPreview = document.getElementById('avatar-preview') as HTMLImageElement;
const avatarPreviewText = document.getElementById('avatar-preview-text');
 let canChangeAvatar = false;
 let isPreparingAvatar = false;

 const syncAvatarControls = () => {
 if (btnChangeAvatar) {
 btnChangeAvatar.disabled = !canChangeAvatar || isPreparingAvatar;
 btnChangeAvatar.classList.toggle('opacity-70', isPreparingAvatar);
 btnChangeAvatar.setAttribute('aria-busy', isPreparingAvatar ? 'true' : 'false');
 }
 if (avatarInput) {
 avatarInput.disabled = !canChangeAvatar || isPreparingAvatar;
 }
 };

