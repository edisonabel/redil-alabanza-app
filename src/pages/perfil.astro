 revokePerfilSafeCropperUrl();
 (window as any).__perfilSafeCropperUrl = safeImageUrl;

 if (cropperImage) {
 const waitForImageLoad = new Promise<void>((resolve, reject) => {
 const cleanupImageListeners = () => {
 cropperImage.onload = null;
 cropperImage.onerror = null;
 };

 cropperImage.onload = () => {
 cleanupImageListeners();
 resolve();
 };

 cropperImage.onerror = () => {
 cleanupImageListeners();
 reject(new Error('No se pudo preparar la imagen para el recorte.'));
 };
 });

 cropperImage.src = safeImageUrl;
 cropperImage.classList.remove('hidden');
 if (!cropperImage.complete) {
 await waitForImageLoad;
 }
 openCropperModal();
 }
