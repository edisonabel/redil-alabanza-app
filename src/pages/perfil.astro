---
import Layout from '../layouts/Layout.astro';
import OnboardingRoot from '../components/onboarding/OnboardingRoot';
import BotonNotificaciones from '../components/react/BotonNotificaciones.jsx';

const userId = Astro.locals.user?.id ?? null;
---

<Layout title="Mi Perfil - Redil">
 <header class="w-full flex items-center justify-between py-6 px-4 md:px-8 mb-4 border-b border-border ">
 <div>
 <div class="page-title-row">
 <span class="page-title-icon" aria-hidden="true">
 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"></circle><path d="M4 20a8 8 0 0 1 16 0"></path></svg>
 </span>
 <h1 class="page-title text-[2.1rem] md:text-[3.5rem]">Mi Perfil</h1>
 </div>
 <p class="page-subtitle text-sm">Gestiona tus datos, foto de perfil y fechas indisponibles.</p>
 </div>
 </header>

 <main class="w-full max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
 <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
 
 {/* Lado Izquierdo: Avatar y Roles (Fase 1 y 2) */}
 <div class="col-span-1 flex flex-col items-center" data-tour="perfil-photo">
 <div class="relative group w-32 h-32 mb-4">
 {/* Avatar dinÃ¡mico */}
 <div id="avatar-container" class="w-full h-full rounded-full bg-neutral/20 border-4 border-white flex items-center justify-center font-black text-4xl shadow-md overflow-hidden text-content-muted">
 <!-- Injected by JS -->
 <svg class="w-8 h-8 animate-pulse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
 </div>
 
 <button id="btn-change-avatar" class="absolute bottom-0 right-0 p-2.5 rounded-full bg-surface shadow-lg border border-border text-content-muted hover:text-action dark:hover:text-action transition-colors z-10" title="Cambiar Foto" disabled>
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" class="shrink-0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/><path d="m16 9-4 4-2-2"/></svg>
 </button>
 <!-- Input oculto para el file picker -->
 <input type="file" id="avatar-input" accept="image/*" class="hidden" />
 </div>
 
 <h2 id="ui-user-name" class="text-xl font-bold text-content text-center mb-1 h-7 min-w-[120px] bg-neutral/20 animate-pulse rounded mx-auto flex items-center justify-center"></h2>
 <p id="ui-user-email" class="text-sm text-content-muted text-center mb-4 h-5 min-w-[160px] bg-neutral/20 animate-pulse rounded mx-auto flex items-center justify-center"></p>

 <div id="ui-roles-container" class="flex flex-wrap items-center justify-center gap-2 mb-6 w-full min-h-[30px]">
 <div class="h-6 w-16 bg-neutral/20 animate-pulse rounded"></div>
 <div class="h-6 w-20 bg-neutral/20 animate-pulse rounded"></div>
 </div>
 </div>

 {/* Lado Derecho: Datos y Ajustes */}
 <div class="col-span-1 md:col-span-2 space-y-8">
 
 {/* Panel de Datos Personales */}
 <section class="bg-surface rounded-2xl p-6 border border-border shadow-sm">
 <h3 class="text-lg font-bold text-content mb-4 flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-action"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
 Datos Personales
 </h3>
 
 <form id="form-datos-personales" class="grid grid-cols-1 md:grid-cols-2 gap-4">
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-content-muted uppercase tracking-wide">Nombre Completo</label>
 <input type="text" id="input-nombre" disabled class="w-full bg-background border border-border text-content rounded-xl px-4 py-2 text-sm opacity-70 cursor-not-allowed" placeholder="Cargando..." />
 </div>
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-content-muted uppercase tracking-wide">Correo de Acceso</label>
 <input type="email" id="input-correo" disabled class="w-full bg-background border border-border text-content rounded-xl px-4 py-2 text-sm opacity-70 cursor-not-allowed" placeholder="Cargando..." />
 </div>
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-content-muted uppercase tracking-wide">Registro Vocal</label>
 <select id="tonalidad-select" disabled class="w-full min-w-0 bg-surface border border-border text-content rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-action focus:outline-none transition-shadow">
 <option value="">Seleccionar Perfil Vocal...</option>
 <option value="Soprano">Soprano</option>
 <option value="Contralto">Contralto</option>
 <option value="Tenor">Tenor</option>
 <option value="Bar&iacute;tono">Bar&iacute;tono / Bajo</option>
 </select>
 </div>
<div class="space-y-1.5" data-tour="perfil-birthday">
<label class="text-xs font-bold text-content-muted uppercase tracking-wide">Fecha de nacimiento</label>
<input type="date" id="input-cumpleanos" required disabled class="w-full min-w-0 bg-surface border border-border text-content rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-action focus:outline-none transition-shadow" />
<p class="text-sm text-gray-500">Esto es para recordar tu cumpleaños</p>
</div>
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-content-muted uppercase tracking-wide">Tel&eacute;fono / WhatsApp</label>
 <input type="tel" id="input-telefono" disabled class="w-full bg-surface border border-border text-content rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-action focus:outline-none transition-shadow" placeholder="Ej: +123456789" />
 </div>
 <div class="md:col-span-2 flex justify-end mt-2">
 <button type="submit" id="btn-save-datos" class="hidden px-5 py-2.5 bg-action hover:bg-action/80 text-white font-bold text-sm rounded-xl transition-colors shadow-sm flex items-center gap-2">
 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
 </svg>
 Guardar Datos
 </button>
 </div>
 </form>
 </section>

 {/* PANEL FASE 3: Sistema de Disponibilidad (Ausencias) */}
 <section class="bg-surface rounded-2xl p-6 border border-border shadow-sm mt-8" data-tour="perfil-availability">
 <h3 class="text-lg font-bold text-content mb-4 flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
 Mis Ausencias / Fechas Bloqueadas
 </h3>
 <p class="text-xs text-content-muted mb-6">Informa a tu l&iacute;der de alabanza los d&iacute;as que no estar&aacute;s disponible (viajes, trabajo, etc.).</p>

 <form id="form-ausencia" class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8 bg-background p-4 rounded-xl border border-border opacity-50 pointer-events-none transition-opacity">
 <div class="space-y-1.5">
 <label class="text-[10px] font-bold text-content-muted uppercase tracking-wide">Fecha Inicio</label>
 <input type="date" id="ausencia-inicio" required class="w-full min-w-0 bg-surface border border-border text-content rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:outline-none" />
 </div>
 <div class="space-y-1.5">
 <label class="text-[10px] font-bold text-content-muted uppercase tracking-wide">Fecha Fin</label>
 <input type="date" id="ausencia-fin" required class="w-full min-w-0 bg-surface border border-border text-content rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:outline-none" />
 </div>
 <div class="space-y-1.5 md:col-span-2">
 <label class="text-[10px] font-bold text-content-muted uppercase tracking-wide">Motivo (Opcional)</label>
 <div class="flex gap-2">
 <input type="text" id="ausencia-motivo" placeholder="Ej. Viaje familiar, Trabajo..." class="flex-1 bg-surface border border-border text-content rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:outline-none" />
 <button type="submit" id="btn-save-ausencia" class="px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white font-bold text-sm rounded-lg shadow-md shadow-orange-500/20 transition-all shrink-0">Registrar</button>
 </div>
 </div>
 </form>

 <div class="space-y-3" id="ausencias-list">
 <div class="py-6 text-center border-2 border-dashed border-border rounded-xl">
 <p class="text-xs font-bold text-content-muted">Cargando ausencias...</p>
 </div>
 </div>
 </section>

 {/* PANEL FASE 4: Seguirdad */}
 <section class="bg-surface rounded-2xl p-6 border border-border shadow-sm mt-8">
 <h3 class="text-lg font-bold text-content mb-4 flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-action"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
 Seguridad
 </h3>
 <div class="mb-5">
 <BotonNotificaciones client:load userId={userId} />
 </div>
 
 <div class="flex flex-col sm:flex-row gap-4 mt-6">
 <button id="btn-change-password" class="flex-1 py-3 px-4 rounded-xl border border-border bg-surface text-neutral-700 font-ui-strong text-sm hover:bg-background :bg-neutral-700 transition-colors flex items-center justify-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
 Cambiar Contrase&ntilde;a
 </button>
 <button id="btn-logout" class="flex-1 py-3 px-4 rounded-xl bg-red-500/10 text-red-600 font-ui-strong text-sm hover:bg-red-500/20 transition-colors flex items-center justify-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
 Cerrar Sesi&oacute;n
 </button>
 </div>
 </section>
 </div>
 </main>

 <OnboardingRoot client:load page="perfil" />

 {/* Modal para Recortar Foto */}
 <div id="cropper-modal" class="fixed inset-0 z-50 bg-black/80 hidden items-center justify-center p-4 backdrop-blur-sm transition-opacity opacity-0 duration-300">
 <div id="cropper-content" class="bg-surface rounded-2xl w-full max-w-lg overflow-hidden shadow-2xl scale-95 transition-transform duration-300">
 <div class="px-6 py-4 border-b border-border flex justify-between items-center">
 <h3 class="text-lg font-bold text-content ">Ajustar Foto de Perfil</h3>
 <button id="btn-close-cropper" class="text-content-muted hover:text-content-muted :text-neutral-200 transition-colors">
 <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
 </button>
 </div>
 
 <div class="px-6 py-4 bg-blue-50 text-blue-900 border-b border-blue-200 dark:bg-blue-900/40 dark:text-blue-100 dark:border-blue-800 flex items-start gap-3">
 <div class="mt-0.5 text-blue-700 dark:text-blue-200 shrink-0">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
 </div>
 <div class="space-y-1">
 <p class="text-sm font-bold leading-snug">Usa una foto de cerca (Retrato)</p>
 <p class="text-sm leading-snug text-blue-900 dark:text-blue-100">Ampl&iacute;a la imagen hasta que <strong class="text-blue-700 dark:text-white">tu rostro llene el c&iacute;rculo</strong>. No uses fotos de cuerpo entero ni grupales.</p>
 </div>
 </div>

 <div class="p-6 bg-background aspect-square flex items-center justify-center relative">
 <div class="w-full h-full max-h-[60vh] relative z-10">
 <img id="cropper-image" src="" alt="Imagen a recortar" class="max-w-full hidden" />
 </div>
 </div>
 <div class="px-6 py-4 border-t border-border flex justify-end gap-3 bg-background ">
 <button id="btn-cancel-cropper" class="px-5 py-2.5 rounded-xl font-bold text-sm text-content-muted hover:bg-neutral/20 :bg-neutral-800 transition-colors">Cancelar</button>
 <button id="btn-save-cropper" class="px-5 py-2.5 rounded-xl font-ui-strong text-sm bg-action hover:bg-action/80 text-white shadow-md transition-all flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
 Guardar Foto
 </button>
 </div>
 </div>
 </div>
</Layout>

<!-- Estilos para forzar el recorte circular de Cropperjs -->
<style is:global>
 .cropper-view-box,
 .cropper-face {
 border-radius: 50%;
 }
</style>

<!-- Script de Cropperjs vÃ­a CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" integrity="sha512-hvNR0F/e2J7zPPfLC9auFe3/SE0yG4aJCOd/qxew74NN7eyiSKjr7xJJMu1Jy2wf7FXITpWS1E/RY8yzuXN7VA==" crossorigin="anonymous" />
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js" integrity="sha512-9KkIqdfN7ipEW6B6k+Aq20PV31bjODg4AA52W+tYtAE0jE0kMx49bjJ3FgvS56wzmyfMUHbQ4Km2b7l9+Y/+Eg==" crossorigin="anonymous"></script>

<script>
 import { supabase } from '../lib/supabase';

 const cleanupPerfilRuntime = () => {
 const abortController = (window as any).__perfilListenersAbort as AbortController | undefined;
 if (abortController) {
 abortController.abort();
 (window as any).__perfilListenersAbort = null;
 }

 const cropperInstance = (window as any)._cropperInstance;
 if (cropperInstance) {
 try {
 cropperInstance.destroy();
 } catch {
 // no-op
 }
 (window as any)._cropperInstance = null;
 }
 };

 const initPerfilPage = async () => {
 cleanupPerfilRuntime();
 const listenersAbort = new AbortController();
 const signal = listenersAbort.signal;
 (window as any).__perfilListenersAbort = listenersAbort;

 const on = (
 target: EventTarget | null | undefined,
 eventName: string,
 handler: EventListenerOrEventListenerObject,
 options: AddEventListenerOptions = {},
 ) => {
 if (!target || typeof (target as EventTarget).addEventListener !== 'function') return;
 (target as EventTarget).addEventListener(eventName, handler, { ...options, signal });
 };

 // Init global vars
 let currentUserId = null;

 const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
 const getCookieValue = (name) => {
 try {
 const cookiePart = document.cookie
 .split(';')
 .map((chunk) => chunk.trim())
 .find((chunk) => chunk.startsWith(`${name}=`));
 if (!cookiePart) return '';
 return decodeURIComponent(cookiePart.substring(name.length + 1));
 } catch {
 return '';
 }
 };

 const getStableAuth = async () => {
 let lastError = null;

 for (let attempt = 0; attempt < 5; attempt += 1) {
 try {
 const { data: { session }, error } = await supabase.auth.getSession();
 if (session?.user) {
 return { session, user: session.user, error: null };
 }
 if (error) lastError = error;
 } catch (error) {
 lastError = error;
 }
 await wait(120);
 }

 const tokenFromCookie = getCookieValue('sb-access-token');
 if (tokenFromCookie) {
 try {
 const { data: { user }, error } = await supabase.auth.getUser(tokenFromCookie);
 if (user) return { session: null, user, error: null };
 if (error) lastError = error;
 } catch (error) {
 lastError = error;
 }
 }

 try {
 const { data: { user }, error } = await supabase.auth.getUser();
 if (user) return { session: null, user, error: null };
 if (error) lastError = error;
 } catch (error) {
 lastError = error;
 }

 return { session: null, user: null, error: lastError };
 };
 
 const avatarContainer = document.getElementById('avatar-container');
 const uiUserName = document.getElementById('ui-user-name');
 const uiUserEmail = document.getElementById('ui-user-email');
 const uiRolesContainer = document.getElementById('ui-roles-container');
 const inputNombre = document.getElementById('input-nombre') as HTMLInputElement;
 const inputCorreo = document.getElementById('input-correo') as HTMLInputElement;
 
 const formDatosPersonales = document.getElementById('form-datos-personales') as HTMLFormElement;
 const selectTonalidad = document.getElementById('tonalidad-select') as HTMLSelectElement;
 const inputCumpleanos = document.getElementById('input-cumpleanos') as HTMLInputElement;
 const inputTelefono = document.getElementById('input-telefono') as HTMLInputElement;
 const btnSaveDatos = document.getElementById('btn-save-datos') as HTMLButtonElement;
 
 

 // ==========================================
 // LÃ³gica de Cropper y Upload de Foto de Perfil
 // ==========================================
 const btnChangeAvatar = document.getElementById('btn-change-avatar');
 const avatarInput = document.getElementById('avatar-input') as HTMLInputElement;
 const cropperModal = document.getElementById('cropper-modal');
 const cropperContent = document.getElementById('cropper-content');
 const cropperImage = document.getElementById('cropper-image') as HTMLImageElement;
 const btnCloseCropper = document.getElementById('btn-close-cropper');
 const btnCancelCropper = document.getElementById('btn-cancel-cropper');
 const btnSaveCropper = document.getElementById('btn-save-cropper') as HTMLButtonElement;
 
 const avatarPreview = document.getElementById('avatar-preview') as HTMLImageElement;
 const avatarPreviewText = document.getElementById('avatar-preview-text');

 let cropper: any = (window as any)._cropperInstance || null;
 if (cropper) {
 try {
 cropper.destroy();
 } catch {
 // no-op
 }
 cropper = null;
 (window as any)._cropperInstance = null;
 }

 // Abrir selector de archivos
 on(btnChangeAvatar, 'click', () => {
 avatarInput?.click();
 });

 // Cuando el usuario selecciona una imagen
 on(avatarInput, 'change', (e: Event) => {
 const file = (e.target as HTMLInputElement).files?.[0];
 if (file) {
 const reader = new FileReader();
 reader.onload = (event) => {
 if (cropperImage && event.target?.result) {
 cropperImage.src = event.target.result as string;
 cropperImage.classList.remove('hidden');
 openCropperModal();
 }
 };
 reader.readAsDataURL(file);
 }
 // Reset input so the same file can be selected again if needed
 avatarInput.value = '';
 });

 const openCropperModal = () => {
 if (!cropperImage) return;
 
 cropperModal?.classList.remove('hidden');
 cropperModal?.classList.add('flex');
 
 // Timeout para permitir que el modal se muestre antes de inicializar cropper y animar
 setTimeout(() => {
 cropperModal?.classList.remove('opacity-0');
 cropperContent?.classList.remove('scale-95');
 
 if (cropper) {
 cropper.destroy();
 }
 
 // Initialize Cropper via CDN (window.Cropper)
 const CropperJS = (window as any).Cropper;
 if(CropperJS) {
 cropper = new CropperJS(cropperImage, {
 aspectRatio: 1,
 viewMode: 1,
 dragMode: 'move',
 autoCropArea: 1,
 restore: false,
 guides: false,
 center: false,
 highlight: false,
 cropBoxMovable: true,
 cropBoxResizable: true,
 toggleDragModeOnDblclick: false,
 });
 (window as any)._cropperInstance = cropper;
 } else {
 alert('Error cargando herramienta de recorte. Intente recargar la página.');
 closeCropperModal();
 }
 }, 10);
 };

 const closeCropperModal = () => {
 cropperModal?.classList.add('opacity-0');
 cropperContent?.classList.add('scale-95');
 
 setTimeout(() => {
 cropperModal?.classList.add('hidden');
 cropperModal?.classList.remove('flex');
 if (cropper) {
 cropper.destroy();
 cropper = null;
 (window as any)._cropperInstance = null;
 }
 if (cropperImage) {
 cropperImage.src = '';
 cropperImage.classList.add('hidden');
 }
 }, 300);
 };

 on(btnCloseCropper, 'click', closeCropperModal);
 on(btnCancelCropper, 'click', closeCropperModal);
 
 // Cerrar al hacer clic fuera
 on(cropperModal, 'click', (e: Event) => {
 if (e.target === cropperModal) closeCropperModal();
 });

 // Guardar recorte y subir a Supabase
 on(btnSaveCropper, 'click', async () => {
 if (!cropper) return;
 
 const originalText = btnSaveCropper.innerHTML;
 btnSaveCropper.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Subiendo...';
 btnSaveCropper.disabled = true;

 try {
 // Generar blob webp de 400x400
 const canvas = cropper.getCroppedCanvas({
 width: 400,
 height: 400,
 imageSmoothingEnabled: true,
 imageSmoothingQuality: 'high',
 });

 const blob = await new Promise<Blob | null>((resolve) => {
 canvas.toBlob((b) => resolve(b), 'image/webp', 0.9);
 });

 if (!blob) throw new Error("No se pudo generar el recorte de la imagen.");

 const auth = await getStableAuth();
 const userId = currentUserId || auth.user?.id;
 if (!userId) throw new Error("No session");

 // Upload a Supabase Storage (bucket: avatars)
 const fileName = `${userId}-${Date.now()}.webp`; // Para bust de cachÃ©
 const { data: uploadData, error: uploadError } = await supabase
 .storage
 .from('avatars')
 .upload(fileName, blob, {
 cacheControl: '3600',
 upsert: true,
 contentType: 'image/webp'
 });

 if (uploadError) throw uploadError;

 // Obtener URL PÃºblica
 const { data: { publicUrl } } = supabase
 .storage
 .from('avatars')
 .getPublicUrl(fileName);

 // Actualizar tabla perfiles
 const { error: updateError } = await supabase
 .from('perfiles')
 .update({ avatar_url: publicUrl })
 .eq('id', userId);

 if (updateError) throw updateError;

 // Actualizar DOM visualmente
 const avatarContainerToUpdate = document.getElementById('avatar-container');
 if (avatarContainerToUpdate) {
 avatarContainerToUpdate.innerHTML = `<img src="${publicUrl}" alt="Avatar" class="w-full h-full object-cover" id="avatar-preview" />`;
 }

 closeCropperModal();
 btnSaveCropper.innerHTML = originalText;
 btnSaveCropper.disabled = false;

 } catch (err) {
 console.error("Error al subir avatar:", err);
 alert("Error al subir imagen. Revisa que el Storage (bucket 'avatars') exista en Supabase.");
 btnSaveCropper.innerHTML = originalText;
 btnSaveCropper.disabled = false;
 }
 });
 // ==========================================
 // LÃ³gica FASE 3: Ausencias
 // ==========================================
 const formAusencia = document.getElementById('form-ausencia') as HTMLFormElement;
 const btnSaveAusencia = document.getElementById('btn-save-ausencia') as HTMLButtonElement;
 const inputInicio = document.getElementById('ausencia-inicio') as HTMLInputElement;
 const inputFin = document.getElementById('ausencia-fin') as HTMLInputElement;
 const inputMotivo = document.getElementById('ausencia-motivo') as HTMLInputElement;

 on(formAusencia, 'submit', async (e: Event) => {
 e.preventDefault();
 if (!inputInicio.value || !inputFin.value) return;

 const originalBtnText = btnSaveAusencia.textContent;
 btnSaveAusencia.textContent = 'Guardando...';
 btnSaveAusencia.disabled = true;

 try {
 const auth = await getStableAuth();
 const userId = currentUserId || auth.user?.id;
 if (!userId) throw new Error("No session");

 const { error } = await supabase
 .from('ausencias')
 .insert({
 perfil_id: userId,
 fecha_inicio: inputInicio.value,
 fecha_fin: inputFin.value,
 motivo: inputMotivo.value || null
 });

 if (error) throw error;
 
 // Recargar pÃ¡gina para actualizar lista
 window.location.reload();
 } catch (err) {
 console.error('Error insertando ausencia:', err);
 alert("Hubo un error al registrar la ausencia. Verifica las fechas.");
 btnSaveAusencia.textContent = originalBtnText;
 btnSaveAusencia.disabled = false;
 }
 });

 // Borrar Ausencia
 document.querySelectorAll('.btn-delete-ausencia').forEach((btn) => {
 on(btn, 'click', async (e: Event) => {
 const button = e.currentTarget as HTMLButtonElement;
 const id = button.getAttribute('data-id');
 if (!id) return;
 
 if (!confirm('\u00BFEst\u00E1s seguro de eliminar este bloqueo de fechas?')) return;
 
 button.disabled = true;
 button.classList.add('opacity-50');

 try {
 const { error } = await supabase
 .from('ausencias')
 .delete()
 .eq('id', id);

 if (error) throw error;
 
 // Remover del DOM visualmente
 const row = document.querySelector(`[data-ausencia-id="${id}"]`);
 row?.remove();

 } catch (err) {
 console.error('Error eliminando ausencia:', err);
 alert("Error eliminando registro.");
 button.disabled = false;
 button.classList.remove('opacity-50');
 }
 });
 });

 // ==========================================
 // Lógica FASE 4: Seguridad
 // ==========================================
 const clearClientAuthState = () => {
 try {
 if (window.__REDIL_AUTH_MANAGER__?.clearSessionCookies) {
 window.__REDIL_AUTH_MANAGER__.clearSessionCookies();
 return;
 }
 } catch {
 // no-op
 }

 const secureDeleteFlag = window.location.protocol === 'https:' ? '; Secure' : '';
 const localNames = new Set(['sb-access-token', 'sb-refresh-token']);
 const rawCookies = document.cookie ? document.cookie.split(';') : [];
 rawCookies.forEach((cookiePart) => {
 const [rawName] = cookiePart.trim().split('=');
 if (!rawName) return;
 if (/^(sb-|__Host-sb-|__Secure-sb-|supabase-)/i.test(rawName)) {
 localNames.add(rawName);
 }
 });

 localNames.forEach((name) => {
 document.cookie = `${name}=; path=/; max-age=0; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax${secureDeleteFlag}`;
 document.cookie = `${name}=; path=/; max-age=0; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=None${secureDeleteFlag}`;
 });
 };

 const btnLogout = document.getElementById('btn-logout');
 on(btnLogout, 'click', async () => {
 if (!confirm('\u00BFSeguro que deseas cerrar la sesi\u00F3n?')) return;

 try {
 const { error } = await supabase.auth.signOut({ scope: 'global' });
 if (error) throw error;
 } catch (logoutError) {
 console.error('Logout Error (supabase):', logoutError);
 } finally {
 clearClientAuthState();
 try {
 await fetch('/api/auth/logout', {
 method: 'POST',
 credentials: 'include',
 headers: {
 'cache-control': 'no-store',
 },
 });
 } catch (cookieError) {
 console.error('Logout Error (cookie endpoint):', cookieError);
 }
 window.location.replace('/login');
 }
 });

 const btnChangePassword = document.getElementById('btn-change-password');
 on(btnChangePassword, 'click', async () => {
 alert('Se ha enviado un correo con instrucciones a tu email. (Por implementar enlace backend)');
 // Implement Supabase Password Reset Email trigger here
 });

 // ==========================================
 // CLIENT-SIDE DATA FETCHING
 // ==========================================
 const fetchData = async () => {
 const { user, error: sessionError } = await getStableAuth();

 if (!user || sessionError) {
 /* window.location.href = '/login'; Movido a Middleware */
 console.warn('Perfil: sesión no disponible en cliente', sessionError);
 return;
 }

 currentUserId = user.id;
 const email = user.email;
 
 if (inputCorreo) inputCorreo.value = email || '';
 if (uiUserEmail) uiUserEmail.innerHTML = email || '';

 // 1. Fetch Perfil
 const { data: perfilData, error: perfilError } = await supabase
 .from('perfiles')
 .select('id, nombre, avatar_url, tonalidad_voz, fecha_nacimiento, telefono')
 .eq('id', currentUserId)
 .single();

 if (!perfilError && perfilData) {
 if (inputNombre) inputNombre.value = perfilData.nombre;
 
 if (uiUserName) {
 uiUserName.classList.remove('bg-neutral/20', 'animate-pulse', 'h-7', 'min-w-[120px]', 'flex', 'items-center', 'justify-center');
 uiUserName.innerHTML = perfilData.nombre;
 }
 
 if (uiUserEmail) {
 uiUserEmail.classList.remove('bg-neutral/20', 'animate-pulse', 'h-5', 'min-w-[160px]', 'flex', 'items-center', 'justify-center');
 uiUserEmail.innerHTML = email || '';
 }

 // Set vocal key and birthday
 if(selectTonalidad) {
 selectTonalidad.disabled = false;
 if (perfilData.tonalidad_voz) {
 selectTonalidad.value = perfilData.tonalidad_voz;
 (window as any)._initialTonalidad = perfilData.tonalidad_voz;
 }
 }
 if (inputCumpleanos) {
 inputCumpleanos.disabled = false;
 if (perfilData.fecha_nacimiento) {
 inputCumpleanos.value = perfilData.fecha_nacimiento;
 (window as any)._initialCumpleanos = perfilData.fecha_nacimiento;
 }
 }
 if (inputTelefono) {
 inputTelefono.disabled = false;
 if (perfilData.telefono) {
 inputTelefono.value = perfilData.telefono;
 (window as any)._initialTelefono = perfilData.telefono;
 }
 }
 if(avatarContainer) {
 if (perfilData.avatar_url) {
 avatarContainer.innerHTML = `<img src="${perfilData.avatar_url}" alt="${perfilData.nombre}" class="w-full h-full object-cover" id="avatar-preview" />`;
 } else {
 const initials = perfilData.nombre.split(' ').map((n: string) => n[0]).join('').substring(0,2).toUpperCase();
 avatarContainer.innerHTML = `<span id="avatar-preview-text" class="text-brand">${initials}</span>`;
 avatarContainer.classList.add('bg-brand/10');
 }
 }
 }

 // Enable avatar button and form
 btnChangeAvatar?.removeAttribute('disabled');
 formAusencia?.classList.remove('opacity-50', 'pointer-events-none');

 // 2. Fetch Roles
 const { data: rolesData, error: rolesError } = await supabase
 .from('perfil_roles')
 .select(`roles (nombre)`)
 .eq('perfil_id', currentUserId);

 if (uiRolesContainer && !rolesError) {
 const userRoles = rolesData ? rolesData.map((r: any) => r.roles?.nombre).filter(Boolean) : [];
 uiRolesContainer.innerHTML = '';
 
 if (userRoles.length === 0) {
 uiRolesContainer.innerHTML = '<span class="text-xs text-content-muted italic">Sin roles asignados</span>';
 } else {
 userRoles.forEach((rol: string) => {
 uiRolesContainer.innerHTML += `<span class="px-2.5 py-1 text-xs font-bold uppercase tracking-wider rounded-md bg-background border border-border text-content-muted shadow-sm">${rol}</span>`;
 });
 }
 }

 // 3. Fetch Ausencias
 const ausenciasListEl = document.getElementById('ausencias-list');
 const { data: ausenciasData, error: ausenciasError } = await supabase
 .from('ausencias')
 .select('*')
 .eq('perfil_id', currentUserId)
 .gte('fecha_fin', new Date().toISOString().split('T')[0])
 .order('fecha_inicio', { ascending: true });

 if (ausenciasListEl && !ausenciasError) {
 const futureAusencias = ausenciasData || [];
 ausenciasListEl.innerHTML = '';
 
 if (futureAusencias.length === 0) {
 ausenciasListEl.innerHTML = `
 <div class="py-6 text-center border-2 border-dashed border-border rounded-xl">
 <p class="text-xs font-bold text-content-muted">No tienes ausencias registradas.</p>
 </div>
 `;
 } else {
 futureAusencias.forEach((aus: any) => {
 const inicio = new Date(aus.fecha_inicio).toLocaleDateString('es', { day: 'numeric', month: 'short', timeZone: 'UTC' });
 const fin = new Date(aus.fecha_fin).toLocaleDateString('es', { day: 'numeric', month: 'short', timeZone: 'UTC' });
 const motivoHtml = aus.motivo ? `<p class="text-xs text-content-muted">${aus.motivo}</p>` : '';
 
 // We recreate the HTML for each item
 const div = document.createElement('div');
 div.className = "flex items-center justify-between p-3 rounded-lg border border-neutral-100 bg-background group shrink-0 transition-opacity";
 div.setAttribute('data-ausencia-id', aus.id);
 div.innerHTML = `
 <div>
 <p class="text-sm font-bold text-content ">
 ${inicio} <span class="text-content-muted mx-1">-</span> ${fin}
 </p>
 ${motivoHtml}
 </div>
 <button type="button" class="p-2 rounded-lg text-content-muted hover:text-red-500 hover:bg-red-50 :bg-red-950/30 transition-colors" title="Eliminar" onclick="window._deleteAusencia('${aus.id}')">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
 </button>
 `;
 ausenciasListEl.appendChild(div);
 });
 }
 }
 };

 // Initialize fetch
 fetchData();

 // -------------------------------------------------------------------------
 // Manejar envÃ­o de Formulario de Datos Personales
 // -------------------------------------------------------------------------

 if (selectTonalidad && inputCumpleanos && inputTelefono && btnSaveDatos) {
 const checkChanges = () => {
 const btnHtml = btnSaveDatos.innerHTML;
 if(btnHtml.includes('Guardando')) return; // ignore during save

 const tVal = selectTonalidad.value || '';
 const cVal = inputCumpleanos.value || '';
 const phoneVal = inputTelefono.value || '';
 const initT = (window as any)._initialTonalidad || '';
 const initC = (window as any)._initialCumpleanos || '';
 const initPhone = (window as any)._initialTelefono || '';
 
 if (tVal !== initT || cVal !== initC || phoneVal !== initPhone) {
 btnSaveDatos.classList.remove('hidden');
 } else {
 btnSaveDatos.classList.add('hidden');
 }
 };
 on(selectTonalidad, 'input', checkChanges);
 on(inputCumpleanos, 'input', checkChanges);
 on(inputTelefono, 'input', checkChanges);
 }

 if (formDatosPersonales && btnSaveDatos) {
 on(formDatosPersonales, 'submit', async (e: Event) => {
 e.preventDefault();
 const vocalVal = selectTonalidad.value;
 const cumpleanosVal = inputCumpleanos.value;
 const telefonoVal = inputTelefono.value;

 const originalBtnHtml = btnSaveDatos.innerHTML;
 btnSaveDatos.innerHTML = '<span class="flex items-center gap-2"><div class="w-4 h-4 rounded-full border-2 border-white/20 border-t-white animate-spin"></div> Guardando...</span>';
 btnSaveDatos.disabled = true;

 try {
 const auth = await getStableAuth();
 const userId = currentUserId || auth.user?.id;
 if (!userId) throw new Error('No hay sesión activa');

 const updates = {
 tonalidad_voz: vocalVal || null,
 fecha_nacimiento: cumpleanosVal || null,
 telefono: telefonoVal || null,
 updated_at: new Date().toISOString()
 };

 const { error } = await supabase
 .from('perfiles')
 .update(updates)
 .eq('id', userId);

 if (error) throw error;

 (window as any)._initialTonalidad = vocalVal;
 (window as any)._initialCumpleanos = cumpleanosVal;
 (window as any)._initialTelefono = telefonoVal;
 btnSaveDatos.classList.add('hidden');
 
 // Alerta nativa simple
 alert('Datos guardados exitosamente');
 } catch (error) {
 console.error("Error al actualizar datos:", error);
 alert('No se pudo guardar la información.');
 } finally {
 btnSaveDatos.innerHTML = originalBtnHtml;
 btnSaveDatos.disabled = false;
 }
 });
 }
 
 // Expose delete function to window context for the innerHTML buttons
 (window as any)._deleteAusencia = async (id: string) => {
 if (!confirm('\u00BFEst\u00E1s seguro de eliminar este bloqueo de fechas?')) return;
 
 const row = document.querySelector(`[data-ausencia-id="${id}"]`) as HTMLElement;
 if(row) row.style.opacity = '0.5';

 try {
 const { error } = await supabase
 .from('ausencias')
 .delete()
 .eq('id', id);

 if (error) throw error;
 row?.remove();
 
 // If it was the last one, fetch again to show empty state
 if (document.querySelectorAll('[data-ausencia-id]').length === 0) {
 fetchData();
 }

 } catch (err) {
 console.error('Error eliminando ausencia:', err);
 alert("Error eliminando registro.");
 if(row) row.style.opacity = '1';
 }
 }

 };

 if ((window as any).__perfilPageLoadHandler) {
 document.removeEventListener('astro:page-load', (window as any).__perfilPageLoadHandler);
 }

 if ((window as any).__perfilAfterSwapHandler) {
 document.removeEventListener('astro:after-swap', (window as any).__perfilAfterSwapHandler);
 }

 const onPerfilAfterSwap = () => {
 cleanupPerfilRuntime();
 };

 (window as any).__perfilPageLoadHandler = initPerfilPage;
 (window as any).__perfilAfterSwapHandler = onPerfilAfterSwap;
 document.addEventListener('astro:page-load', initPerfilPage);
 document.addEventListener('astro:after-swap', onPerfilAfterSwap);
</script>



