---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mi Perfil - Redil">
 <header class="w-full flex items-center justify-between py-6 px-4 md:px-8 mb-4 border-b border-neutral-200 ">
 <div>
 <h1 class="text-2xl font-bold text-neutral-900 tracking-tight">Mi Perfil</h1>
 <p class="text-sm text-neutral-500 ">Gestiona tus datos, foto de perfil y fechas indisponibles.</p>
 </div>
 </header>

 <main class="w-full max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
 <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
 
 {/* Lado Izquierdo: Avatar y Roles (Fase 1 y 2) */}
 <div class="col-span-1 flex flex-col items-center">
 <div class="relative group w-32 h-32 mb-4">
 {/* Avatar dinámico */}
 <div id="avatar-container" class="w-full h-full rounded-full bg-neutral-200 border-4 border-white flex items-center justify-center font-black text-4xl shadow-md overflow-hidden text-neutral-400">
 <!-- Injected by JS -->
 <svg class="w-8 h-8 animate-pulse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
 </div>
 
 <button id="btn-change-avatar" class="absolute bottom-0 right-0 p-2.5 rounded-full bg-white shadow-lg border border-neutral-200 text-neutral-600 hover:text-emerald-500 :text-emerald-400 transition-colors z-10" title="Cambiar Foto" disabled>
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" class="shrink-0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/><path d="m16 9-4 4-2-2"/></svg>
 </button>
 <!-- Input oculto para el file picker -->
 <input type="file" id="avatar-input" accept="image/*" class="hidden" />
 </div>
 
 <h2 id="ui-user-name" class="text-xl font-bold text-neutral-900 text-center mb-1 h-7 min-w-[120px] bg-neutral-200 animate-pulse rounded mx-auto flex items-center justify-center"></h2>
 <p id="ui-user-email" class="text-sm text-neutral-500 text-center mb-4 h-5 min-w-[160px] bg-neutral-200 animate-pulse rounded mx-auto flex items-center justify-center"></p>

 <div id="ui-roles-container" class="flex flex-wrap items-center justify-center gap-2 mb-6 w-full min-h-[30px]">
 <div class="h-6 w-16 bg-neutral-200 animate-pulse rounded"></div>
 <div class="h-6 w-20 bg-neutral-200 animate-pulse rounded"></div>
 </div>
 </div>

 {/* Lado Derecho: Datos y Ajustes */}
 <div class="col-span-1 md:col-span-2 space-y-8">
 
 {/* Panel de Datos Personales */}
 <section class="bg-white rounded-2xl p-6 border border-neutral-200 shadow-sm">
 <h3 class="text-lg font-bold text-neutral-900 mb-4 flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
 Datos Personales
 </h3>
 
 <form id="form-datos-personales" class="grid grid-cols-1 md:grid-cols-2 gap-4">
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-neutral-500 uppercase tracking-wide">Nombre Completo</label>
 <input type="text" id="input-nombre" disabled class="w-full bg-neutral-50 border border-neutral-200 text-neutral-900 rounded-xl px-4 py-2 text-sm opacity-70 cursor-not-allowed" placeholder="Cargando..." />
 </div>
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-neutral-500 uppercase tracking-wide">Correo de Acceso</label>
 <input type="email" id="input-correo" disabled class="w-full bg-neutral-50 border border-neutral-200 text-neutral-900 rounded-xl px-4 py-2 text-sm opacity-70 cursor-not-allowed" placeholder="Cargando..." />
 </div>
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-neutral-500 uppercase tracking-wide">Registro Vocal</label>
 <select id="tonalidad-select" disabled class="w-full bg-white border border-neutral-200 text-neutral-900 rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:outline-none transition-shadow">
 <option value="">Seleccionar Perfil Vocal...</option>
 <option value="Soprano">Soprano</option>
 <option value="Contralto">Contralto</option>
 <option value="Tenor">Tenor</option>
 <option value="Barítono">Barítono / Bajo</option>
 </select>
 </div>
 <div class="space-y-1.5">
 <label class="text-xs font-bold text-neutral-500 uppercase tracking-wide">Cumpleaños</label>
 <input type="date" id="input-cumpleanos" disabled class="w-full bg-white border border-neutral-200 text-neutral-900 rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:outline-none transition-shadow" />
 </div>
 <div class="md:col-span-2 flex justify-end mt-2">
 <button type="submit" id="btn-save-datos" class="hidden px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-sm rounded-xl transition-colors shadow-sm flex items-center gap-2">
 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
 </svg>
 Guardar Datos
 </button>
 </div>
 </form>
 </section>

 {/* PANEL FASE 3: Sistema de Disponibilidad (Ausencias) */}
 <section class="bg-white rounded-2xl p-6 border border-neutral-200 shadow-sm mt-8">
 <h3 class="text-lg font-bold text-neutral-900 mb-4 flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
 Mis Ausencias / Fechas Bloqueadas
 </h3>
 <p class="text-xs text-neutral-500 mb-6">Informa a tu líder de alabanza los días que no estarás disponible (viajes, trabajo, etc.).</p>

 <form id="form-ausencia" class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8 bg-neutral-50 p-4 rounded-xl border border-neutral-200 opacity-50 pointer-events-none transition-opacity">
 <div class="space-y-1.5">
 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-wide">Fecha Inicio</label>
 <input type="date" id="ausencia-inicio" required class="w-full bg-white border border-neutral-200 text-neutral-900 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:outline-none" />
 </div>
 <div class="space-y-1.5">
 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-wide">Fecha Fin</label>
 <input type="date" id="ausencia-fin" required class="w-full bg-white border border-neutral-200 text-neutral-900 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:outline-none" />
 </div>
 <div class="space-y-1.5 md:col-span-2">
 <label class="text-[10px] font-bold text-neutral-500 uppercase tracking-wide">Motivo (Opcional)</label>
 <div class="flex gap-2">
 <input type="text" id="ausencia-motivo" placeholder="Ej. Viaje familiar, Trabajo..." class="flex-1 bg-white border border-neutral-200 text-neutral-900 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:outline-none" />
 <button type="submit" id="btn-save-ausencia" class="px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white font-bold text-sm rounded-lg shadow-md shadow-orange-500/20 transition-all shrink-0">Registrar</button>
 </div>
 </div>
 </form>

 <div class="space-y-3" id="ausencias-list">
 <div class="py-6 text-center border-2 border-dashed border-neutral-200 rounded-xl">
 <p class="text-xs font-bold text-neutral-400">Cargando ausencias...</p>
 </div>
 </div>
 </section>

 {/* PANEL FASE 4: Seguirdad */}
 <section class="bg-white rounded-2xl p-6 border border-neutral-200 shadow-sm mt-8">
 <h3 class="text-lg font-bold text-neutral-900 mb-4 flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
 Seguridad
 </h3>
 
 <div class="flex flex-col sm:flex-row gap-4 mt-6">
 <button id="btn-change-password" class="flex-1 py-3 px-4 rounded-xl border border-neutral-200 bg-white text-neutral-700 font-bold text-sm hover:bg-neutral-50 :bg-neutral-700 transition-colors flex items-center justify-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
 Cambiar Contraseña
 </button>
 <button id="btn-logout" class="flex-1 py-3 px-4 rounded-xl bg-red-500/10 text-red-600 font-bold text-sm hover:bg-red-500/20 transition-colors flex items-center justify-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
 Cerrar Sesión
 </button>
 </div>
 </section>
 </div>
 </main>

 {/* Modal para Recortar Foto */}
 <div id="cropper-modal" class="fixed inset-0 z-50 bg-black/80 hidden items-center justify-center p-4 backdrop-blur-sm transition-opacity opacity-0 duration-300">
 <div id="cropper-content" class="bg-white rounded-2xl w-full max-w-lg overflow-hidden shadow-2xl scale-95 transition-transform duration-300">
 <div class="px-6 py-4 border-b border-neutral-200 flex justify-between items-center">
 <h3 class="text-lg font-bold text-neutral-900 ">Ajustar Foto de Perfil</h3>
 <button id="btn-close-cropper" class="text-neutral-400 hover:text-neutral-600 :text-neutral-200 transition-colors">
 <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
 </button>
 </div>
 <div class="p-6 bg-neutral-100 aspect-square flex items-center justify-center">
 <div class="w-full h-full max-h-[60vh]">
 <img id="cropper-image" src="" alt="Imagen a recortar" class="max-w-full hidden" />
 </div>
 </div>
 <div class="px-6 py-4 border-t border-neutral-200 flex justify-end gap-3 bg-neutral-50 ">
 <button id="btn-cancel-cropper" class="px-5 py-2.5 rounded-xl font-bold text-sm text-neutral-600 hover:bg-neutral-200 :bg-neutral-800 transition-colors">Cancelar</button>
 <button id="btn-save-cropper" class="px-5 py-2.5 rounded-xl font-bold text-sm bg-emerald-500 hover:bg-emerald-600 text-white shadow-md shadow-emerald-500/20 transition-all flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
 Guardar Foto
 </button>
 </div>
 </div>
 </div>
</Layout>

<!-- Estilos para forzar el recorte circular de Cropperjs -->
<style is:global>
 .cropper-view-box,
 .cropper-face {
 border-radius: 50%;
 }
</style>

<!-- Script de Cropperjs vía CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" integrity="sha512-hvNR0F/e2J7zPPfLC9auFe3/SE0yG4aJCOd/qxew74NN7eyiSKjr7xJJMu1Jy2wf7FXITpWS1E/RY8yzuXN7VA==" crossorigin="anonymous" />
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js" integrity="sha512-9KkIqdfN7ipEW6B6k+Aq20PV31bjODg4AA52W+tYtAE0jE0kMx49bjJ3FgvS56wzmyfMUHbQ4Km2b7l9+Y/+Eg==" crossorigin="anonymous"></script>

<script>
 import { supabase } from '../lib/supabase';

 document.addEventListener('DOMContentLoaded', async () => {
 // Init global vars
 let currentUserId = null;
 
 const avatarContainer = document.getElementById('avatar-container');
 const uiUserName = document.getElementById('ui-user-name');
 const uiUserEmail = document.getElementById('ui-user-email');
 const uiRolesContainer = document.getElementById('ui-roles-container');
 const inputNombre = document.getElementById('input-nombre') as HTMLInputElement;
 const inputCorreo = document.getElementById('input-correo') as HTMLInputElement;
 
 

 // ==========================================
 // Lógica de Cropper y Upload de Foto de Perfil
 // ==========================================
 const btnChangeAvatar = document.getElementById('btn-change-avatar');
 const avatarInput = document.getElementById('avatar-input') as HTMLInputElement;
 const cropperModal = document.getElementById('cropper-modal');
 const cropperContent = document.getElementById('cropper-content');
 const cropperImage = document.getElementById('cropper-image') as HTMLImageElement;
 const btnCloseCropper = document.getElementById('btn-close-cropper');
 const btnCancelCropper = document.getElementById('btn-cancel-cropper');
 const btnSaveCropper = document.getElementById('btn-save-cropper') as HTMLButtonElement;
 
 const avatarPreview = document.getElementById('avatar-preview') as HTMLImageElement;
 const avatarPreviewText = document.getElementById('avatar-preview-text');

 let cropper: any = null;

 // Abrir selector de archivos
 btnChangeAvatar?.addEventListener('click', () => {
 avatarInput?.click();
 });

 // Cuando el usuario selecciona una imagen
 avatarInput?.addEventListener('change', (e) => {
 const file = (e.target as HTMLInputElement).files?.[0];
 if (file) {
 const reader = new FileReader();
 reader.onload = (event) => {
 if (cropperImage && event.target?.result) {
 cropperImage.src = event.target.result as string;
 cropperImage.classList.remove('hidden');
 openCropperModal();
 }
 };
 reader.readAsDataURL(file);
 }
 // Reset input so the same file can be selected again if needed
 avatarInput.value = '';
 });

 const openCropperModal = () => {
 if (!cropperImage) return;
 
 cropperModal?.classList.remove('hidden');
 cropperModal?.classList.add('flex');
 
 // Timeout para permitir que el modal se muestre antes de inicializar cropper y animar
 setTimeout(() => {
 cropperModal?.classList.remove('opacity-0');
 cropperContent?.classList.remove('scale-95');
 
 if (cropper) {
 cropper.destroy();
 }
 
 // Initialize Cropper via CDN (window.Cropper)
 const CropperJS = (window as any).Cropper;
 if(CropperJS) {
 cropper = new CropperJS(cropperImage, {
 aspectRatio: 1,
 viewMode: 1,
 dragMode: 'move',
 autoCropArea: 1,
 restore: false,
 guides: false,
 center: false,
 highlight: false,
 cropBoxMovable: true,
 cropBoxResizable: true,
 toggleDragModeOnDblclick: false,
 });
 } else {
 alert('Error cargando herramienta de recorte. Intente recargar la página.');
 closeCropperModal();
 }
 }, 10);
 };

 const closeCropperModal = () => {
 cropperModal?.classList.add('opacity-0');
 cropperContent?.classList.add('scale-95');
 
 setTimeout(() => {
 cropperModal?.classList.add('hidden');
 cropperModal?.classList.remove('flex');
 if (cropper) {
 cropper.destroy();
 cropper = null;
 }
 if (cropperImage) {
 cropperImage.src = '';
 cropperImage.classList.add('hidden');
 }
 }, 300);
 };

 btnCloseCropper?.addEventListener('click', closeCropperModal);
 btnCancelCropper?.addEventListener('click', closeCropperModal);
 
 // Cerrar al hacer clic fuera
 cropperModal?.addEventListener('click', (e) => {
 if (e.target === cropperModal) closeCropperModal();
 });

 // Guardar recorte y subir a Supabase
 btnSaveCropper?.addEventListener('click', async () => {
 if (!cropper) return;
 
 const originalText = btnSaveCropper.innerHTML;
 btnSaveCropper.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Subiendo...';
 btnSaveCropper.disabled = true;

 try {
 // Generar blob webp de 400x400
 const canvas = cropper.getCroppedCanvas({
 width: 400,
 height: 400,
 imageSmoothingEnabled: true,
 imageSmoothingQuality: 'high',
 });

 const blob = await new Promise<Blob | null>((resolve) => {
 canvas.toBlob((b) => resolve(b), 'image/webp', 0.9);
 });

 if (!blob) throw new Error("No se pudo generar el recorte de la imagen.");

 const { data: { session } } = await supabase.auth.getSession();
 if(!session) throw new Error("No session");
 const userId = session.user.id;

 // Upload a Supabase Storage (bucket: avatars)
 const fileName = `${userId}-${Date.now()}.webp`; // Para bust de caché
 const { data: uploadData, error: uploadError } = await supabase
 .storage
 .from('avatars')
 .upload(fileName, blob, {
 cacheControl: '3600',
 upsert: true,
 contentType: 'image/webp'
 });

 if (uploadError) throw uploadError;

 // Obtener URL Pública
 const { data: { publicUrl } } = supabase
 .storage
 .from('avatars')
 .getPublicUrl(fileName);

 // Actualizar tabla perfiles
 const { error: updateError } = await supabase
 .from('perfiles')
 .update({ avatar_url: publicUrl })
 .eq('id', userId);

 if (updateError) throw updateError;

 // Actualizar DOM visualmente
 const avatarContainerToUpdate = document.getElementById('avatar-container');
 if (avatarContainerToUpdate) {
 avatarContainerToUpdate.innerHTML = `<img src="${publicUrl}" alt="Avatar" class="w-full h-full object-cover" id="avatar-preview" />`;
 }

 closeCropperModal();
 btnSaveCropper.innerHTML = originalText;
 btnSaveCropper.disabled = false;

 } catch (err) {
 console.error("Error al subir avatar:", err);
 alert("Error al subir imagen. Revisa que el Storage (bucket 'avatars') exista en Supabase.");
 btnSaveCropper.innerHTML = originalText;
 btnSaveCropper.disabled = false;
 }
 });
 // ==========================================
 // Lógica FASE 3: Ausencias
 // ==========================================
 const formAusencia = document.getElementById('form-ausencia') as HTMLFormElement;
 const btnSaveAusencia = document.getElementById('btn-save-ausencia') as HTMLButtonElement;
 const inputInicio = document.getElementById('ausencia-inicio') as HTMLInputElement;
 const inputFin = document.getElementById('ausencia-fin') as HTMLInputElement;
 const inputMotivo = document.getElementById('ausencia-motivo') as HTMLInputElement;

 formAusencia?.addEventListener('submit', async (e) => {
 e.preventDefault();
 if (!inputInicio.value || !inputFin.value) return;

 const originalBtnText = btnSaveAusencia.textContent;
 btnSaveAusencia.textContent = 'Guardando...';
 btnSaveAusencia.disabled = true;

 try {
 const { data: { session } } = await supabase.auth.getSession();
 if (!session) throw new Error("No session");

 const { error } = await supabase
 .from('ausencias')
 .insert({
 perfil_id: session.user.id,
 fecha_inicio: inputInicio.value,
 fecha_fin: inputFin.value,
 motivo: inputMotivo.value || null
 });

 if (error) throw error;
 
 // Recargar página para actualizar lista
 window.location.reload();
 } catch (err) {
 console.error('Error insertando ausencia:', err);
 alert("Hubo un error al registrar la ausencia. Verifica las fechas.");
 btnSaveAusencia.textContent = originalBtnText;
 btnSaveAusencia.disabled = false;
 }
 });

 // Borrar Ausencia
 document.querySelectorAll('.btn-delete-ausencia').forEach(btn => {
 btn.addEventListener('click', async (e) => {
 const button = e.currentTarget as HTMLButtonElement;
 const id = button.getAttribute('data-id');
 if (!id) return;
 
 if (!confirm('¿Estás seguro de eliminar este bloqueo de fechas?')) return;
 
 button.disabled = true;
 button.classList.add('opacity-50');

 try {
 const { error } = await supabase
 .from('ausencias')
 .delete()
 .eq('id', id);

 if (error) throw error;
 
 // Remover del DOM visualmente
 const row = document.querySelector(`[data-ausencia-id="${id}"]`);
 row?.remove();

 } catch (err) {
 console.error('Error eliminando ausencia:', err);
 alert("Error eliminando registro.");
 button.disabled = false;
 button.classList.remove('opacity-50');
 }
 });
 });

 // ==========================================
 // Lógica FASE 4: Seguridad
 // ==========================================
 const btnLogout = document.getElementById('btn-logout');
 btnLogout?.addEventListener('click', async () => {
 if(!confirm("¿Seguro que deseas cerrar la sesión?")) return;
 
 try {
 await supabase.auth.signOut();
 window.location.href = '/login';
 } catch(e) {
 console.error("Logout Error:", e);
 window.location.href = '/login';
 }
 });

 const btnChangePassword = document.getElementById('btn-change-password');
 btnChangePassword?.addEventListener('click', async () => {
 alert('Se ha enviado un correo con instrucciones a tu email. (Por implementar enlace backend)');
 // Implement Supabase Password Reset Email trigger here
 });

 // ==========================================
 // CLIENT-SIDE DATA FETCHING
 // ==========================================
 const fetchData = async () => {
 const { data: { session }, error: sessionError } = await supabase.auth.getSession();
 
 if (!session || sessionError) {
 window.location.href = '/login';
 return;
 }

 currentUserId = session.user.id;
 const email = session.user.email;
 
 if (inputCorreo) inputCorreo.value = email || '';
 if (uiUserEmail) uiUserEmail.innerHTML = email || '';

 // 1. Fetch Perfil
 const { data: perfilData, error: perfilError } = await supabase
 .from('perfiles')
 .select('id, nombre, avatar_url, tonalidad_voz')
 .eq('id', currentUserId)
 .single();

 if (!perfilError && perfilData) {
 if (inputNombre) inputNombre.value = perfilData.nombre;
 
 if (uiUserName) {
 uiUserName.classList.remove('bg-neutral-200', '', 'animate-pulse', 'h-7', 'min-w-[120px]', 'flex', 'items-center', 'justify-center');
 uiUserName.innerHTML = perfilData.nombre;
 }
 
 if (uiUserEmail) {
 uiUserEmail.classList.remove('bg-neutral-200', '', 'animate-pulse', 'h-5', 'min-w-[160px]', 'flex', 'items-center', 'justify-center');
 uiUserEmail.innerHTML = email || '';
 }

 // Set vocal key and birthday
 if(selectTonalidad) {
 selectTonalidad.disabled = false;
 if (perfilData.tonalidad_voz) {
 selectTonalidad.value = perfilData.tonalidad_voz;
 }
 }
 if (inputCumpleanos) {
 inputCumpleanos.disabled = false;
 if (perfilData.fecha_nacimiento) {
 inputCumpleanos.value = perfilData.fecha_nacimiento;
 }
 }
 if(avatarContainer) {
 if (perfilData.avatar_url) {
 avatarContainer.innerHTML = `<img src="${perfilData.avatar_url}" alt="${perfilData.nombre}" class="w-full h-full object-cover" id="avatar-preview" />`;
 } else {
 const initials = perfilData.nombre.split(' ').map((n: string) => n[0]).join('').substring(0,2).toUpperCase();
 avatarContainer.innerHTML = `<span id="avatar-preview-text" class="text-blue-700 ">${initials}</span>`;
 avatarContainer.classList.add('bg-blue-100', '');
 }
 }
 }

 // Enable avatar button and form
 btnChangeAvatar?.removeAttribute('disabled');
 formAusencia?.classList.remove('opacity-50', 'pointer-events-none');

 // 2. Fetch Roles
 const { data: rolesData, error: rolesError } = await supabase
 .from('perfil_roles')
 .select(`roles (nombre)`)
 .eq('perfil_id', currentUserId);

 if (uiRolesContainer && !rolesError) {
 const userRoles = rolesData ? rolesData.map((r: any) => r.roles?.nombre).filter(Boolean) : [];
 uiRolesContainer.innerHTML = '';
 
 if (userRoles.length === 0) {
 uiRolesContainer.innerHTML = '<span class="text-xs text-neutral-400 italic">Sin roles asignados</span>';
 } else {
 userRoles.forEach((rol: string) => {
 uiRolesContainer.innerHTML += `<span class="px-2.5 py-1 text-xs font-bold uppercase tracking-wider rounded-md bg-neutral-100 border border-neutral-200 text-neutral-600 shadow-sm">${rol}</span>`;
 });
 }
 }

 // 3. Fetch Ausencias
 const ausenciasListEl = document.getElementById('ausencias-list');
 const { data: ausenciasData, error: ausenciasError } = await supabase
 .from('ausencias')
 .select('*')
 .eq('perfil_id', currentUserId)
 .gte('fecha_fin', new Date().toISOString().split('T')[0])
 .order('fecha_inicio', { ascending: true });

 if (ausenciasListEl && !ausenciasError) {
 const futureAusencias = ausenciasData || [];
 ausenciasListEl.innerHTML = '';
 
 if (futureAusencias.length === 0) {
 ausenciasListEl.innerHTML = `
 <div class="py-6 text-center border-2 border-dashed border-neutral-200 rounded-xl">
 <p class="text-xs font-bold text-neutral-400">No tienes ausencias registradas.</p>
 </div>
 `;
 } else {
 futureAusencias.forEach((aus: any) => {
 const inicio = new Date(aus.fecha_inicio).toLocaleDateString('es', { day: 'numeric', month: 'short', timeZone: 'UTC' });
 const fin = new Date(aus.fecha_fin).toLocaleDateString('es', { day: 'numeric', month: 'short', timeZone: 'UTC' });
 const motivoHtml = aus.motivo ? `<p class="text-xs text-neutral-500">${aus.motivo}</p>` : '';
 
 // We recreate the HTML for each item
 const div = document.createElement('div');
 div.className = "flex items-center justify-between p-3 rounded-lg border border-neutral-100 bg-neutral-50 group shrink-0 transition-opacity";
 div.setAttribute('data-ausencia-id', aus.id);
 div.innerHTML = `
 <div>
 <p class="text-sm font-bold text-neutral-900 ">
 ${inicio} <span class="text-neutral-400 mx-1">→</span> ${fin}
 </p>
 ${motivoHtml}
 </div>
 <button type="button" class="p-2 rounded-lg text-neutral-400 hover:text-red-500 hover:bg-red-50 :bg-red-950/30 transition-colors" title="Eliminar" onclick="window._deleteAusencia('${aus.id}')">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
 </button>
 `;
 ausenciasListEl.appendChild(div);
 });
 }
 }
 };

 // Initialize fetch
 fetchData();

 // -------------------------------------------------------------------------
 // Manejar envío de Formulario de Datos Personales
 // -------------------------------------------------------------------------
 const formDatosPersonales = document.getElementById('form-datos-personales') as HTMLFormElement;
 const selectTonalidad = document.getElementById('tonalidad-select') as HTMLSelectElement;
 const inputCumpleanos = document.getElementById('input-cumpleanos') as HTMLInputElement;
 const btnSaveDatos = document.getElementById('btn-save-datos') as HTMLButtonElement;

 if (selectTonalidad && inputCumpleanos && btnSaveDatos) {
 const checkChanges = () => {
 const btnHtml = btnSaveDatos.innerHTML;
 if(btnHtml.includes('Guardando')) return; // ignore during save

 const tVal = selectTonalidad.value || '';
 const cVal = inputCumpleanos.value || '';
 const initT = (window as any)._initialTonalidad || '';
 const initC = (window as any)._initialCumpleanos || '';
 
 if (tVal !== initT || cVal !== initC) {
 btnSaveDatos.classList.remove('hidden');
 } else {
 btnSaveDatos.classList.add('hidden');
 }
 };
 selectTonalidad.addEventListener('change', checkChanges);
 inputCumpleanos.addEventListener('change', checkChanges);
 }

 if (formDatosPersonales && btnSaveDatos) {
 formDatosPersonales.addEventListener('submit', async (e) => {
 e.preventDefault();
 const vocalVal = selectTonalidad.value;
 const cumpleanosVal = inputCumpleanos.value;

 const originalBtnHtml = btnSaveDatos.innerHTML;
 btnSaveDatos.innerHTML = '<span class="flex items-center gap-2"><div class="w-4 h-4 rounded-full border-2 border-white/20 border-t-white animate-spin"></div> Guardando...</span>';
 btnSaveDatos.disabled = true;

 try {
 const { data: { session } } = await supabase.auth.getSession();
 if (!session) throw new Error("No hay sesión activa");

 const updates = {
 tonalidad_voz: vocalVal || null,
 fecha_nacimiento: cumpleanosVal || null,
 updated_at: new Date().toISOString()
 };

 const { error } = await supabase
 .from('perfiles')
 .update(updates)
 .eq('id', session.user.id);

 if (error) throw error;

 (window as any)._initialTonalidad = vocalVal;
 (window as any)._initialCumpleanos = cumpleanosVal;
 btnSaveDatos.classList.add('hidden');
 
 // Alerta nativa simple
 alert('Datos guardados exitosamente');
 } catch (error) {
 console.error("Error al actualizar datos:", error);
 alert("No se pudo guardar la información.");
 } finally {
 btnSaveDatos.innerHTML = originalBtnHtml;
 btnSaveDatos.disabled = false;
 }
 });
 }
 
 // Expose delete function to window context for the innerHTML buttons
 (window as any)._deleteAusencia = async (id: string) => {
 if (!confirm('¿Estás seguro de eliminar este bloqueo de fechas?')) return;
 
 const row = document.querySelector(`[data-ausencia-id="${id}"]`) as HTMLElement;
 if(row) row.style.opacity = '0.5';

 try {
 const { error } = await supabase
 .from('ausencias')
 .delete()
 .eq('id', id);

 if (error) throw error;
 row?.remove();
 
 // If it was the last one, fetch again to show empty state
 if (document.querySelectorAll('[data-ausencia-id]').length === 0) {
 fetchData();
 }

 } catch (err) {
 console.error('Error eliminando ausencia:', err);
 alert("Error eliminando registro.");
 if(row) row.style.opacity = '1';
 }
 }

 });
</script>
