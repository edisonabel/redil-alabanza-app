 try {
 const { error } = await supabase.auth.signOut({ scope: 'global' });
 if (error) throw error;
 } catch (logoutError) {
 console.error('Logout Error (supabase):', logoutError);
 } finally {
 clearClientAuthState();
 try {
 await fetch('/api/auth/logout', {
 method: 'POST',
 credentials: 'include',
 headers: {
 'cache-control': 'no-store',
 },
 });
 } catch (cookieError) {
 console.error('Logout Error (cookie endpoint):', cookieError);
 }
 window.location.replace('/login');
 }
 });

