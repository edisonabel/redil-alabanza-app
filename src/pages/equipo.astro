<Layout title="Gestion de Equipo - Redil">
 <!-- Navbar base similar to other tools for consistency -->
 <header class="w-full flex items-center justify-between py-6 px-4 md:px-8 mb-4 border-b border-border ">
 <div class="flex items-center gap-4">
 <a href="/programacion" class="text-content-muted hover:text-content :text-white transition-colors">
 <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
 <path d="m15 18-6-6 6-6"/>
 </svg>
 </a>
 <div>
 <div class="page-title-row">
 <span class="page-title-icon" aria-hidden="true">
 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
 </span>
