 </div>
 </div>
 <!-- L3 -->
 <div>
 <div class="flex items-center justify-between mb-3"><span class="text-[10px] font-bold text-brand uppercase tracking-widest">Banda y Voces</span><div class="h-px flex-1 bg-teal-200 ml-3"></div></div>
 <div class="grid grid-cols-2 sm:grid-cols-3 gap-2" id="tb-n3-slots"></div>
 </div>
 </div>
 </div>
 </div>
 
 <!-- Footer Form -->
 <div class="px-5 sm:px-6 py-4 bg-background border-t border-neutral-100 sticky bottom-0 z-10 flex gap-3 pb-8 sm:pb-4">
 <button type="submit" id="btn-tb-submit" class="flex-1 bg-neutral-900 text-white py-3 rounded-xl font-bold hover:bg-neutral-800 :bg-background transition-colors shadow-sm relative overflow-hidden flex justify-center items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
 <svg id="tb-spinner" class="animate-spin -ml-1 mr-2 h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
 <span id="tb-submit-text">Guardar Equipo</span>
 </button>
 </div>
 </form>
 </div>
 </div>
 
 <!-- MODAL DETALLES DEL EQUIPO -->
 <div id="modal-detalles-equipo" class="fixed inset-0 z-[120] flex items-center justify-center bg-black/50 backdrop-blur-sm hidden">
 <div class="absolute inset-0" id="backdrop-detalles-equipo"></div>
 <div class="relative w-full max-w-2xl bg-background rounded-t-3xl sm:rounded-3xl shadow-2xl overflow-hidden transition-transform translate-y-full flex flex-col max-h-[90vh] m-auto" id="panel-detalles-equipo">
 <!-- Header -->
 <div class="px-6 py-5 border-b border-border bg-surface flex justify-between items-center z-10 sticky top-0">
 <div class="flex items-center gap-3">
 <div id="detalle-letra-circle" class="w-10 h-10 rounded-full bg-neutral/20 text-content-muted flex items-center justify-center font-bold text-lg shadow-sm shrink-0">
 -
 </div>
 <div>
 <h3 class="text-xl font-black text-content leading-none tracking-tight" id="detalle-nombre">Nombre Equipo</h3>
 <p class="text-xs text-content-muted font-bold uppercase tracking-widest mt-1">ConfiguraciÃ³n Base</p>
 </div>
 </div>
 <button type="button" id="btn-close-detalles" class="p-2 -mr-2 bg-background text-content-muted hover:text-content :text-white rounded-full transition-colors">
 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
 </button>
 </div>
 
 <!-- Body estructurado -->
 <div class="p-6 overflow-y-auto custom-scrollbar flex-1 flex flex-col gap-6">
 <!-- DirecciÃ³n -->
 <div>
 <div class="flex items-center justify-between mb-3">
 <span class="text-xs font-bold text-violet-600 uppercase tracking-widest flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"/><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M12 2v2"/><path d="M12 22v-2"/><path d="m17 20.66-1-1.73"/><path d="M11 10.27 7 3.34"/><path d="m20.66 17-1.73-1"/><path d="m3.34 7 1.73 1"/><path d="M14 12h8"/><path d="M2 12h2"/><path d="m20.66 7-1.73 1"/><path d="m3.34 17 1.73-1"/><path d="m17 3.34-1 1.73"/><path d="m11 13.73-4 6.93"/></svg> DirecciÃ³n</span>
 <div class="h-px flex-1 bg-violet-200 ml-3"></div>
 </div>
 <div class="grid grid-cols-2 gap-2" id="detalle-direccion">
 <!-- Slots Inyectados -->
 </div>
 </div>
 
 <!-- Letras -->
 <div class="bg-amber-50/50 p-4 rounded-2xl border border-amber-100 ">
 <div class="flex items-center justify-between mb-3">
 <span class="text-xs font-bold text-amber-600 uppercase tracking-widest flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg> Letras</span>
 <div class="h-px flex-1 bg-amber-200 ml-3"></div>
 </div>
 <div class="flex flex-col gap-2" id="detalle-letras">
 <!-- Slots Inyectados -->
 </div>
 </div>
 
 <!-- Banda y Voces -->
 <div>
 <div class="flex items-center justify-between mb-3">
 <span class="text-xs font-bold text-brand uppercase tracking-widest flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg> Banda y Voces</span>
 <div class="h-px flex-1 bg-teal-200 ml-3"></div>
 </div>
 <div class="grid grid-cols-2 gap-2" id="detalle-banda">
 <!-- Slots Inyectados -->
 </div>
 </div>
 </div>
 </div>
 </div>
 
 <!-- MODAL CONFIRMACIÃ“N BORRAR EQUIPO -->
 <div id="modal-confirm-delete" class="fixed inset-0 z-[200] flex items-center justify-center bg-black/60 backdrop-blur-sm hidden">
 <div class="relative bg-surface rounded-2xl shadow-2xl max-w-sm w-full mx-4 p-6 flex flex-col gap-4">
 <div class="flex items-center gap-3">
 <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-500"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
 </div>
 <div>
 <h3 class="font-bold text-content text-base">Eliminar Equipo</h3>
 <p class="text-xs text-content-muted" id="confirm-delete-msg">Â¿Seguro que deseas eliminar este equipo?</p>
 </div>
 </div>
 <p class="text-xs text-content-muted bg-background rounded-lg p-3 border border-border ">Los integrantes del equipo se perderÃ¡n. Los eventos de domingos anteriores NO se afectan.</p>
 <div class="flex gap-3">
 <button id="confirm-delete-cancel" type="button" class="flex-1 py-2.5 px-4 rounded-xl border border-border text-neutral-700 font-semibold text-sm hover:bg-background :bg-neutral-800 transition-colors">Cancelar</button>
 <button id="confirm-delete-ok" type="button" class="flex-1 py-2.5 px-4 rounded-xl bg-red-500 hover:bg-red-600 text-white font-bold text-sm transition-colors flex items-center justify-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
 Eliminar
 </button>
 </div>
 </div>
 </div>

 <!-- MODAL PICKER REUTILIZADO PARA EVENTOS Y BUILDER -->
 <div id="picker-modal" class="fixed inset-0 z-[110] flex items-center justify-center bg-neutral-900/40 backdrop-blur-sm" style="display:none">
 <div class="absolute inset-0" id="picker-backdrop"></div>
 <!-- Picker Panel -->
 <div class="relative bg-background w-full sm:max-w-md rounded-3xl shadow-2xl flex flex-col max-h-[85vh] mx-4" id="picker-panel">
 <div class="px-5 py-4 border-b border-border flex justify-between items-center bg-surface rounded-t-3xl sm:rounded-t-3xl shadow-sm z-10">
