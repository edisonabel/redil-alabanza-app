 <div class="relative bg-surface w-full md:w-full md:max-w-md rounded-t-3xl md:rounded-3xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh] transition-transform translate-y-full sm:translate-y-4 sm:scale-95 sm:opacity-0" id="modal-roles-panel">
 <!-- Header -->
 <div class="px-6 py-5 border-b border-neutral-100 flex justify-between items-center bg-surface/50 backdrop-blur-md sticky top-0 z-10">
 <h3 class="text-xl font-bold text-content " id="modal-roles-title">Editar Roles</h3>
 <button type="button" id="btn-close-modal-roles" class="p-2 -mr-2 text-content-muted hover:text-neutral-700 :text-neutral-200 hover:bg-background :bg-neutral-800 rounded-full transition-colors">
 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
 </button>
 </div>
 
 <!-- Body -->
 <div class="p-6 overflow-y-auto flex-1 custom-scrollbar">
 <p class="text-xs font-bold uppercase tracking-widest text-content-muted mb-4">MÃºltiples Asignaciones Permitidas</p>
 <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="modal-roles-container">
 <!-- InyecciÃ³n dinÃ¡mica de Toggles -->
 </div>
 </div>
 <!-- Footer -->
 <div class="px-6 py-4 bg-background border-t border-neutral-100 flex gap-3">
 <button type="button" id="btn-roles-submit" class="flex-1 bg-neutral-900 text-white py-3 rounded-xl font-bold hover:bg-neutral-800 transition-colors shadow-sm">
 Guardar Cambios
 </button>
 </div>
 </div>
 </div>

 <!-- MODAL CONSTRUCTOR DE PLANTILLAS (Team Builder) -->
 <div id="modal-team-builder" class="fixed inset-0 z-[80] hidden items-end sm:items-center justify-center">
 <!-- Backdrop -->
 <div class="absolute inset-0 bg-neutral-900/40 backdrop-blur-sm transition-opacity opacity-0" id="tb-backdrop"></div>
 
 <!-- Panel -->
 <div class="relative bg-surface w-full sm:w-[90vw] md:w-[600px] shrink-0 rounded-t-3xl sm:rounded-3xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh] transition-transform translate-y-full sm:translate-y-4 sm:scale-95 sm:opacity-0" id="tb-panel">
 <!-- Header -->
 <div class="px-5 sm:px-6 py-4 sm:py-5 border-b border-neutral-100 flex justify-between items-center bg-surface/50 backdrop-blur-md sticky top-0 z-10">
 <div>
