 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="opacity-80" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
 Crear Equipo
 </button>
 </div>
 </header>
 
 <!-- BotÃ³n Flotante Mobile para Plantillas -->
 <button id="fab-team-builder" class="md:hidden fixed bottom-6 right-6 w-14 h-14 bg-gradient-to-r from-neutral-900 to-neutral-800 text-white rounded-full flex items-center justify-center shadow-lg hover:shadow-xl hover:scale-105 active:scale-95 transition-all z-40">
 <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
 </button>

 <!-- BotÃ³n Flotante para AÃ±adir MÃºsico -->
 <button id="fab-add-musico" class="fixed bottom-32 right-4 md:bottom-32 md:right-8 bg-blue-500 hover:bg-blue-400 text-white w-14 h-14 md:w-auto md:px-6 rounded-full shadow-2xl flex items-center justify-center gap-2 transition-transform hover:scale-105 z-40 group">
 <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-90 transition-transform duration-300"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
 <span class="hidden md:block font-bold text-base">AÃ±adir MÃºsico</span>
 </button>

 <main id="equipo-page-root" class="w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
 <!-- SECCIÃ“N MIS EQUIPOS -->
 <div class="mb-8 hidden" id="seccion-plantillas">
 <div class="flex items-center justify-between mb-4">
 <h2 class="text-xs font-bold text-content-muted uppercase tracking-widest flex items-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-blue-500" stroke="currentColor" stroke-width="2.5"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>
 Mis Equipos
 </h2>
 </div>
 <div class="relative w-full">
 <!-- Pista visual scroll derecho -->
 <div class="absolute right-0 top-0 bottom-0 w-12 bg-gradient-to-l from-neutral-50 [#0a0a0a] to-transparent pointer-events-none z-10 hidden md:block" id="scroll-hint-right"></div>
 
 <div id="plantillas-grid" class="flex gap-4 overflow-x-auto pb-4 custom-scrollbar snap-x relative z-0">
 <!-- Se inyectan cards -->
 </div>
 </div>
 </div>

 <div id="loading-state" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 animate-pulse mt-4">
 <!-- Skeleton Cards -->
 {Array(6).fill('').map(() => (
 <div class="bg-surface border border-border rounded-2xl p-6 shadow-sm">
 <div class="flex items-center gap-4 mb-4">
 <div class="w-12 h-12 bg-neutral/20 rounded-full"></div>
 <div class="space-y-2 flex-1">
 <div class="h-4 bg-neutral/20 rounded w-3/4"></div>
 <div class="h-3 bg-neutral/20 rounded w-1/2"></div>
 </div>
 </div>
 <div class="h-10 bg-neutral/20 rounded w-full mb-2"></div>
 <div class="h-10 bg-neutral/20 rounded w-full"></div>
 </div>
 ))}
 </div>

 <div id="equipo-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 hidden">
 <!-- Los perfiles se inyectarÃ¡n aquÃ­ -->
 </div>

 <div id="empty-state" class="hidden flex flex-col items-center justify-center py-20 text-center">
 <div class="w-20 h-20 bg-background rounded-full flex items-center justify-center mb-6">
 <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-content-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
 <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
 <circle cx="9" cy="7" r="4"/>
 <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
 <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
 </svg>
 </div>
 <h3 class="text-xl font-bold text-content mb-2">No hay mÃºsicos registrados</h3>
 <p class="text-content-muted max-w-md">Ejecuta el script SQL de inicializaciÃ³n en Supabase para registrar a los mÃºsicos y sus roles.</p>
 </div>
 
 <!-- Observer Sentinel -->
 <div id="scroll-sentinel" class="w-full h-10 mt-8 flex justify-center items-center opacity-0 transition-opacity">
 <svg class="animate-spin h-6 w-6 text-content-muted" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
 <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
 <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
 </svg>
 </div>

 <!-- MODAL GLOBAL DE EDICIÃ“N DE ROLES (In-Place) -->
 <div id="modal-roles-global" class="fixed inset-0 z-[100] hidden items-end sm:items-center justify-center">
 <!-- Backdrop -->
 <div class="absolute inset-0 bg-neutral-900/40 backdrop-blur-sm transition-opacity opacity-0" id="modal-roles-backdrop"></div>
 
