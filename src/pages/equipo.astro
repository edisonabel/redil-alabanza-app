 <div class="w-full sm:w-28 space-y-2 shrink-0">
 <label for="tb-letra" class="block text-xs uppercase tracking-wider font-bold text-content-muted ">Letra</label>
 <div class="relative">
 <select id="tb-letra" required class="appearance-none w-full bg-background border border-border text-content text-lg rounded-xl focus:ring-2 focus:ring-blue-500 :ring-brand focus:border-transparent outline-none transition-all px-4 py-3 cursor-pointer font-bold font-mono text-center">
 <option value="A" selected>A</option>
 <option value="B">B</option>
