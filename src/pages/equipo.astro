 // Picker Inyectado
 const modalPicker = document.getElementById('picker-modal');
 window.openTbPicker = async (rolId, rolName) => {
 document.getElementById('picker-role-name').textContent = rolName;
 modalPicker!.style.display = 'flex';
 void modalPicker?.offsetWidth; 
 
 const list = document.getElementById('picker-list');
 const spinner = document.getElementById('picker-spinner');
 list.innerHTML = '';
 spinner?.classList.remove('hidden');

 // ===== POOL DE VOCES: buscar soprano + tenor juntos =====
 const isVozPool = rolId === '_voz_pool';
 let perfilesRol: any[] = [];
 let fetchError: any = null;
 
 if (isVozPool) {
 const vozRoles = window.appStateRoles.filter((r:any) => ['voz_soprano', 'voz_tenor'].includes(r.codigo));
 const vozRoleIds = vozRoles.map((r:any) => r.id);
 if (vozRoleIds.length > 0) {
 const { data, error } = await supabase
 .from('perfil_roles')
 .select('rol_id, perfiles!inner ( * )')
 .in('rol_id', vozRoleIds);
 fetchError = error;
 const seen = new Set();
 (data || []).forEach((pr:any) => {
 if (!seen.has(pr.perfiles.id)) {
 seen.add(pr.perfiles.id);
 perfilesRol.push({ ...pr, _realRolId: pr.rol_id });
 }
 });
 }
 } else {
 const { data, error } = await supabase.from('perfil_roles').select('perfiles!inner ( * )').eq('rol_id', rolId);
 fetchError = error;
 perfilesRol = data || [];
 }
 
 spinner?.classList.add('hidden');
 
 if (fetchError || perfilesRol.length === 0) {
 list.innerHTML = `<p class="text-neutral-500 font-bold p-4 text-center">Nadie tiene este rol. Asignalo a alguien primero en la base.</p>`;
 return;
 }

 const vozRolesIds = window.appStateRoles
 .filter((r:any) => ['voz_soprano', 'voz_tenor'].includes(r.codigo))
 .map((r:any) => r.id);
 const vozCount = window.tbState.assignments.filter((a:any) => vozRolesIds.includes(a.rol_id)).length;

 perfilesRol.forEach((pr:any) => {
 const p = pr.perfiles;
 const realRolId = pr._realRolId || rolId;
 const initials = p.nombre.split(' ').map((n:any)=>n[0]).join('').substring(0,2).toUpperCase();
 const avatarUI = p.avatar_url 
 ? `<img src="${p.avatar_url}" alt="${p.nombre}" class="w-10 h-10 shrink-0 rounded-full object-cover">`
 : `<div class="w-10 h-10 shrink-0 rounded-full bg-neutral-200 text-neutral-600 flex items-center justify-center font-bold text-xs">${initials}</div>`;

 const isSelected = isVozPool
 ? window.tbState.assignments.some((a:any) => a.perfil_id === p.id && vozRolesIds.includes(a.rol_id))
 : window.tbState.assignments.some((a:any) => a.perfil_id === p.id && a.rol_id === rolId);
 
 const isDisabled = isVozPool && !isSelected && vozCount >= 4;
 
 const btn = document.createElement('button');
 btn.type = 'button';
 btn.disabled = isDisabled;
 btn.className = `w-full text-left bg-white border ${isSelected ? 'border-teal-500 ring-1 ring-teal-500' : isDisabled ? 'border-neutral-200 opacity-40 cursor-not-allowed' : 'border-neutral-200 hover:border-blue-500 :border-teal-500'} rounded-xl p-3 flex items-center gap-3 transition-all group`;
 btn.innerHTML = `
 ${avatarUI}
 <div class="flex-1 min-w-0">
 <p class="font-bold text-neutral-900 truncate">${p.nombre}</p>
 ${isVozPool ? `<p class="text-[10px] text-neutral-400 uppercase tracking-wide font-semibold">${window.appStateRoles.find((r:any)=>r.id===realRolId)?.nombre || 'Voz'}</p>` : ''}
 </div>
 ${isSelected 
 ? `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-teal-500 shrink-0" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
 : isDisabled ? `<span class="text-[10px] text-neutral-400 font-bold">LLENO</span>`
 : `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-neutral-300 group-hover:text-blue-500 shrink-0" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`}
 `;
 
 btn.onclick = () => {
 if (isDisabled || isSelected) { modalPicker!.style.display = 'none'; renderTbSlots(); return; }
 const saveRolId = isVozPool ? realRolId : rolId;
 window.tbState.assignments.push({ rol_id: saveRolId, perfil_id: p.id, perfil_nombre: p.nombre, avatar_url: p.avatar_url });
 modalPicker!.style.display = 'none';
 renderTbSlots();
 };
 list.appendChild(btn);
 });
 };
 
 document.getElementById('picker-close')?.addEventListener('click', () => {
 modalPicker!.style.display = 'none';
 });

 document.getElementById('picker-backdrop')?.addEventListener('click', () => {
 modalPicker!.style.display = 'none';
 });

 // Submit Form Team Builder Database Save
 formTb?.addEventListener('submit', async (e) => {
 e.preventDefault();
 if (window.tbState.assignments.length === 0) {
 alert('Agrega al menos a 1 músico a la plantilla.');
 return;
 }

 const btnSubmit = document.getElementById('btn-tb-submit') as HTMLButtonElement;
 const spinner = document.getElementById('tb-spinner');
 const submitText = document.getElementById('tb-submit-text');
 const nombrePlan = (document.getElementById('tb-nombre') as HTMLInputElement).value;
 const latraE = (document.getElementById('tb-letra') as HTMLSelectElement).value;

 btnSubmit.disabled = true;
 spinner?.classList.remove('hidden');
 submitText.textContent = 'Guardando...';

 try {
 // 1. Insert Equipos
 const { data: equipoRes, error: equipoErr } = await supabase
 .from('equipos')
 .insert([{ nombre: nombrePlan, letra: latraE }])
 .select()
 .single();
 
 if (equipoErr) throw equipoErr;

 // 2. Insert Equipo_Integrantes list
 const insertPayload = window.tbState.assignments.map((a:any) => ({
 equipo_id: equipoRes.id,
 perfil_id: a.perfil_id,
 rol_maestro: a.rol_id
 }));

 const { error: intsErr } = await supabase.from('equipo_integrantes').insert(insertPayload);
 if (intsErr) throw intsErr;

 // Inject into memory team loop list
 window.appStateTeamMembers.push(...insertPayload);

 // Update in memory on current page directly without reloading!
 equiposMaster.unshift({ id: equipoRes.id, nombre: nombrePlan, created_at: equipoRes.created_at, letra: latraE });
 window.renderPlantillasGlobally();

 // Success => Cierro y Aviso
 toggleTbModal(false);
 setTimeout(() => alert('Equipo Guardado Exitósamente.'), 350);
 
 } catch (err) {
 console.error('Error insertando equipo:', err);
 alert('Error Crítico: ' + (err.message || 'No se pudo guardar el equipo'));
 } finally {
 btnSubmit.disabled = false;
 spinner?.classList.add('hidden');
 submitText.textContent = 'Guardar Equipo';
 }
 });

 } catch (err) {
 console.error('❌ Error Crítico cargando equipo:', err.message || err);
 
 // Destruir Infinite Loader
 loadingState?.classList.add('hidden');
 
 // Construir UI de Error Fatal
 const errorDisplay = document.createElement('div');
 errorDisplay.className = 'w-full p-6 bg-red-50 border border-red-200 rounded-xl text-center';
 errorDisplay.innerHTML = `
 <h3 class="text-lg font-bold text-red-700 mb-2">Error de Sincronización</h3>
 <code class="text-sm text-red-600 block max-w-xl mx-auto break-all">${err.message || 'Error desconocido parseando Supabase'}</code>
 `;
 document.querySelector('main').appendChild(errorDisplay);
 }

 });
</script>
