 </div>
 </div>
 <div class="space-y-2 flex-1 min-w-0">
 <label for="tb-nombre" class="block text-xs uppercase tracking-wider font-bold text-content-muted ">Nombre del Equipo</label>
 <input type="text" id="tb-nombre" required class="w-full bg-background border border-border text-content text-lg rounded-xl focus:ring-2 focus:ring-blue-500 :ring-brand focus:border-transparent outline-none transition-all px-4 py-3 placeholder:text-content-muted" placeholder="Ej: Banda Dominical" autocomplete="off">
 </div>
 </div>

 <hr class="border-neutral-100 ">

 <!-- Grilla Similar a Programacion.astro -->
 <div class="space-y-4">
 <h4 class="text-sm font-bold text-content flex justify-between items-center">
 DefiniciÃ³n de Integrantes
 <span class="text-xs font-normal text-content-muted bg-background px-2 py-0.5 rounded-full" id="tb-counter-label">0 Asignados</span>
 </h4>
 
 <div class="bg-background rounded-2xl p-4 sm:p-5 border border-neutral-100 ">
 <!-- L1 L2 -->
 <div class="grid grid-cols-2 gap-4 mb-5">
 <div class="flex flex-col">
 <div class="flex items-center justify-between mb-3"><span class="text-[10px] font-bold text-violet-600 uppercase tracking-widest">DirecciÃ³n</span><div class="h-px flex-1 bg-violet-200 ml-2"></div></div>
 <div class="grid grid-cols-1 gap-2" id="tb-n1-slots"></div>
 </div>
 <div class="flex flex-col">
 <div class="flex items-center justify-between mb-3 w-full"><span class="text-[10px] font-bold text-amber-600 uppercase tracking-widest">Letras</span><div class="h-px flex-1 bg-amber-200 ml-2"></div></div>
