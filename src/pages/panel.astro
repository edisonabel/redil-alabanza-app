}).length;

const buildSongUsageRanking = ({ events = [], limit = 10 }: { events?: AnyRecord[]; limit?: number } = {}): AnyRecord[] => {
  const usageByServiceSong = new Map<string, AnyRecord>();
  const repeatWindowMs = 60 * 24 * 60 * 60 * 1000;

  const getRepeatAlert = (history: AnyRecord[] = []) => {
    const sortedAsc = history
      .map((item) => ({ ...item, date: new Date(item.dateIso) }))
      .filter((item) => !Number.isNaN(item.date.getTime()))
      .sort((a, b) => a.date.getTime() - b.date.getTime());

    let bestWindow: AnyRecord | null = null;
    for (let startIndex = 0; startIndex < sortedAsc.length; startIndex += 1) {
      const start = sortedAsc[startIndex];
      const inWindow = sortedAsc.filter((item) => item.date.getTime() >= start.date.getTime() && item.date.getTime() - start.date.getTime() <= repeatWindowMs);
      if (!bestWindow || inWindow.length > bestWindow.items.length) {
        bestWindow = { start, end: inWindow[inWindow.length - 1], items: inWindow };
      }
    }

    if (!bestWindow || bestWindow.items.length < 3) return null;

    return {
      label: `${bestWindow.items.length} usos en 60 dias`,
      detail: `Entre ${formatCountLabel(bestWindow.items.length, 'servicio')} del ${formatDateKey(bestWindow.start.date)} al ${formatDateKey(bestWindow.end.date)}.`,
      count: bestWindow.items.length,
      from: bestWindow.start.dateIso,
      to: bestWindow.end.dateIso,
    };
  };

  events.forEach((evento) => {
    const eventDate = new Date(evento?.dateIso || '');
    if (Number.isNaN(eventDate.getTime())) return;

    // Cada cancion cuenta una sola vez por servicio aunque este duplicada en la playlist.
    const uniqueServiceSongIds = new Set<string>((evento?.setlistSongIds || []).map((songId: unknown) => String(songId || '')));
    uniqueServiceSongIds.forEach((songId) => {
      const key = String(songId || '');
      if (!key || !activeSongIds.has(key)) return;

      const current = usageByServiceSong.get(key) || {
        song_id: key,
        id: key,
        title: safeText(cancionesById.get(key)?.titulo, 'Cancion sin titulo'),
        artist: safeText(cancionesById.get(key)?.cantante, 'Sin cantante'),
        usage_count: 0,
        count: 0,
        last_used_at: null,
        history: [],
      };

      current.usage_count += 1;
      current.count = current.usage_count;
      current.history.push({
        eventId: evento.id,
        serviceTitle: evento.title,
        dateIso: evento.dateIso,
        href: evento.programacionHref,
      });
      if (!current.last_used_at || eventDate > new Date(current.last_used_at)) {
        current.last_used_at = evento.dateIso;
      }
      usageByServiceSong.set(key, current);
    });
  });

  return [...usageByServiceSong.values()]
    .sort((a, b) => (b.usage_count - a.usage_count) || a.title.localeCompare(b.title, 'es'))
    .slice(0, limit)
    .map((item, index, ranking): AnyRecord => ({
      ...item,
      history: (item.history || []).sort((a: AnyRecord, b: AnyRecord) => new Date(b.dateIso).getTime() - new Date(a.dateIso).getTime()),
      repeatAlert: getRepeatAlert(item.history || []),
      rank: index + 1,
      max_count: ranking[0]?.usage_count || item.usage_count || 1,
    }));
};

const currentYearUsageEvents = operationalEvents.filter((evento) => {
  const eventDate = new Date(evento.dateIso);
  return !Number.isNaN(eventDate.getTime())
    && eventDate >= currentYearStart
    && eventDate <= now
    && isRealizedService(evento);
});
const topSongsCurrentYear = buildSongUsageRanking({ events: currentYearUsageEvents, limit: 10 });
const currentYearRepeatWatch = buildSongUsageRanking({ events: currentYearUsageEvents, limit: canciones.length })
  .filter((song) => song.repeatAlert != null)
  .sort((a, b) => (b.repeatAlert.count - a.repeatAlert.count) || (b.usage_count - a.usage_count) || a.title.localeCompare(b.title, 'es'))
  .slice(0, 8);
const currentYearUsedSongIds = getUniqueSongIdsForEvents(currentYearUsageEvents);

const profileRolesByProfileId = new Map<string, AnyRecord[]>();
perfilRoles.forEach((entry) => {
