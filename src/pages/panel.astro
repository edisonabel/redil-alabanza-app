const roleMembersByRoleId = new Map<string, AnyRecord[]>();
perfilRoles.forEach((entry) => {
  const roleId = String(entry?.rol_id || '');
  const profile = perfilesById.get(String(entry?.perfil_id || ''));
  if (!roleId || !profile) return;
  const bucket = roleMembersByRoleId.get(roleId) || [];
  bucket.push({
    id: String(profile.id),
    name: safeText(profile.nombre, 'Sin nombre'),
