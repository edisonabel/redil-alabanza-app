---
import Layout from '../layouts/Layout.astro';
import PanelControl from '../components/react/PanelControl.jsx';
import { createClient } from '@supabase/supabase-js';
import { buildEventHeadline } from '../lib/event-display.js';
import { isPredicadorColumnMissingError, withPredicadorFallbackRows } from '../lib/predicador-compat.js';
import { getSupabaseServerEnv } from '../lib/server/supabase-env.js';

const user = Astro.locals.user;
const perfilBase = Astro.locals.perfil;
const accessToken = Astro.locals.accessToken || Astro.cookies.get('sb-access-token')?.value || '';

if (!user || !accessToken) {
  return Astro.redirect('/login');
}

const { supabaseUrl, supabaseAnonKey } = getSupabaseServerEnv();

const supabaseSSR = createClient(supabaseUrl, supabaseAnonKey, {
  global: {
    headers: {
      Authorization: `Bearer ${accessToken}`,
    },
  },
  auth: {
    persistSession: false,
    autoRefreshToken: false,
  },
});

const now = new Date();
const currentYear = now.getFullYear();
const currentYearStart = new Date(currentYear, 0, 1);
const operationFloor = new Date(now.getTime() - 12 * 60 * 60 * 1000);
const upcomingWindowEnd = new Date(now);
upcomingWindowEnd.setDate(upcomingWindowEnd.getDate() + 45);
const fetchPastFloor = new Date(now);
fetchPastFloor.setDate(fetchPastFloor.getDate() - 365);
if (currentYearStart < fetchPastFloor) {
  fetchPastFloor.setTime(currentYearStart.getTime());
}
const fetchFutureLimit = new Date(now);
fetchFutureLimit.setDate(fetchFutureLimit.getDate() + 120);
const upcomingAbsenceFloor = new Date(now);
upcomingAbsenceFloor.setDate(upcomingAbsenceFloor.getDate() - 7);
const panelPeriods: PanelPeriod[] = [
  { id: 'proximos_45', label: 'Proximos 45 dias', mode: 'future', days: 45 },
  { id: 'ultimos_30', label: 'Ultimos 30 dias', mode: 'past', days: 30 },
  { id: 'ultimos_90', label: 'Ultimos 90 dias', mode: 'past', days: 90 },
  { id: 'ultimos_365', label: 'Ultimos 12 meses', mode: 'past', days: 365 },
];

type AnyRecord = Record<string, any>;
type PanelPeriod = { id: string; label: string; mode: 'future' | 'past'; days: number };

const hasText = (value: unknown): value is string => typeof value === 'string' && value.trim() !== '';
const safeText = (value: unknown, fallback = '') => (hasText(value) ? value.trim() : fallback);
const normalizeFold = (value: unknown) =>
  String(value || '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .trim()
    .toLowerCase();
const clamp = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));

const pluralizeSpanish = (singular: string) => {
  if (singular.endsWith('cion')) return `${singular.slice(0, -3)}iones`;
  return `${singular}s`;
};
const formatCountLabel = (count: number, singular: string, plural = pluralizeSpanish(singular)) => `${count} ${count === 1 ? singular : plural}`;

const isServiceStateExcludedFromUsage = (value: unknown) => {
  const text = normalizeFold(value);
  return text.includes('borrador') || text.includes('cancel') || text.includes('eliminad');
};

const isRealizedService = (evento: AnyRecord) => {
  const eventDate = new Date(evento?.dateIso || evento?.fecha_hora || '');
  if (Number.isNaN(eventDate.getTime())) return false;
  return eventDate <= now && !isServiceStateExcludedFromUsage(evento?.rawStatus || evento?.estado);
};

const formatDateKey = (dateValue: string | Date | null | undefined) => {
  if (!dateValue) return null;
  const safeDate = dateValue instanceof Date ? dateValue : new Date(dateValue);
  if (Number.isNaN(safeDate.getTime())) return null;
  return safeDate.toISOString().slice(0, 10);
};

const toDateStart = (value: string | null | undefined) => {
  if (!value) return null;
  const safe = new Date(`${value}T00:00:00`);
  return Number.isNaN(safe.getTime()) ? null : safe;
};

const toDateEnd = (value: string | null | undefined) => {
  if (!value) return null;
  const safe = new Date(`${value}T23:59:59`);
  return Number.isNaN(safe.getTime()) ? null : safe;
};

const inAbsenceRange = (eventDate: Date, absence: AnyRecord) => {
  const start = toDateStart(absence?.fecha_inicio);
  const end = toDateEnd(absence?.fecha_fin || absence?.fecha_inicio);
  if (!start || !end || !(eventDate instanceof Date) || Number.isNaN(eventDate.getTime())) return false;
  return eventDate >= start && eventDate <= end;
};

const getSongVoiceLabel = (voiceValue: unknown) => {
  const text = normalizeFold(voiceValue);
  if (!text) return 'Sin definir';
  const hasMale = ['hombre', 'masculino', 'male', 'tenor'].some((alias) => text.includes(alias));
  const hasFemale = ['mujer', 'femenino', 'female', 'soprano', 'alto', 'contralto'].some((alias) => text.includes(alias));
  if ((hasMale && hasFemale) || text.includes('mixto') || text.includes('mixta') || text.includes('dueto') || text.includes('duo')) {
    return 'Mixto';
  }
  if (hasMale) return 'Hombre';
  if (hasFemale) return 'Mujer';
  return safeText(voiceValue, 'Sin definir');
};

const getSongCategoryLabel = (categoryValue: unknown) => {
  const text = normalizeFold(categoryValue);
  if (!text) return 'Sin categoria';
  if (text.startsWith('rapid')) return 'Rapida';
  if (text.startsWith('lent')) return 'Lenta';
  if (text.startsWith('trans')) return 'Transicion';
  return safeText(categoryValue, 'Sin categoria');
};

const histogram = (items: AnyRecord[], getLabel: (item: AnyRecord) => unknown, { limit = 8 }: { limit?: number } = {}) => {
  const counts = new Map<string, number>();
  items.forEach((item) => {
    const label = safeText(getLabel(item), 'Sin definir');
    counts.set(label, (counts.get(label) || 0) + 1);
  });
  return [...counts.entries()]
    .map(([label, count]) => ({ label, count }))
    .sort((a, b) => (b.count - a.count) || a.label.localeCompare(b.label, 'es'))
    .slice(0, limit);
};

const resourceCoverageItem = (label: string, count: number, total: number, detail = '') => ({
  label,
  count,
  total,
  detail,
  percent: total > 0 ? Math.round((count / total) * 100) : 0,
});

const fetchSongs = async () => {
  const baseSelect = 'id, titulo, cantante, tonalidad, bpm, categoria, voz, tema, estado, mp3, voces, link_voces, link_secuencias, chordpro';
  const candidates: Array<{ select: string; warnings: string[]; normalize: (rows: AnyRecord[]) => AnyRecord[] }> = [
    {
      select: `${baseSelect}, section_markers, multitrack_session`,
      warnings: [],
      normalize: (rows) => rows,
    },
    {
      select: `${baseSelect}, section_markers`,
      warnings: ['Canciones: no se encontro multitrack_session, usando fallback sin detalle de secuencias completas.'],
      normalize: (rows) => rows.map((song) => ({ ...song, multitrack_session: null })),
    },
    {
      select: `${baseSelect}, multitrack_session`,
      warnings: ['Canciones: no se encontro section_markers, usando fallback sin markers.'],
      normalize: (rows) => rows.map((song) => ({ ...song, section_markers: [] })),
    },
    {
      select: baseSelect,
      warnings: [
        'Canciones: no se encontro section_markers, usando fallback sin markers.',
        'Canciones: no se encontro multitrack_session, usando fallback sin detalle de secuencias completas.',
      ],
      normalize: (rows) => rows.map((song) => ({ ...song, section_markers: [], multitrack_session: null })),
    },
  ];

  for (const candidate of candidates) {
    const response = await supabaseSSR.from('canciones').select(candidate.select).order('titulo');
    if (!response.error) {
      return {
        data: candidate.normalize(response.data || []),
        warnings: candidate.warnings,
      };
    }
  }

  const fallbackResp = await supabaseSSR.from('canciones').select(baseSelect).order('titulo');
  return {
    data: [],
    warnings: [`Canciones: ${fallbackResp.error?.message || 'No se pudieron consultar las canciones.'}`],
  };
};

const isAdmin = Boolean(perfilBase?.is_admin);

const buildEventosSelect = (includePredicador = true) => `
  id,
  fecha_hora,
  hora_fin,
  titulo,
  tema_predicacion,
  ${includePredicador ? 'predicador,' : ''}
  estado,
  asignaciones (
    perfil_id,
    rol_id,
    perfiles (id, nombre, avatar_url)
  )
`;

const buildEventosQuery = (includePredicador = true) => {
  let query = supabaseSSR
    .from('eventos')
    .select(buildEventosSelect(includePredicador))
    .gte('fecha_hora', fetchPastFloor.toISOString())
    .lte('fecha_hora', fetchFutureLimit.toISOString())
    .order('fecha_hora', { ascending: true });

  if (!isAdmin) {
    query = query.eq('estado', 'Publicado');
  }

  return query;
};

const [
  perfilesResp,
  rolesResp,
  perfilRolesResp,
  eventosResp,
  playlistsResp,
  playlistCancionesResp,
  ausenciasResp,
  songsBundle,
] = await Promise.all([
  supabaseSSR.from('perfiles').select('id, nombre, avatar_url, telefono, fecha_nacimiento').order('nombre'),
  supabaseSSR.from('roles').select('id, nombre, codigo').order('nombre'),
  supabaseSSR.from('perfil_roles').select('perfil_id, rol_id'),
  buildEventosQuery(true),
  supabaseSSR.from('playlists').select('id, evento_id, updated_at'),
  supabaseSSR.from('playlist_canciones').select('playlist_id, cancion_id, orden'),
  supabaseSSR
    .from('ausencias')
    .select('id, perfil_id, fecha_inicio, fecha_fin, motivo')
    .gte('fecha_fin', formatDateKey(upcomingAbsenceFloor) || formatDateKey(now))
    .order('fecha_inicio', { ascending: true }),
  fetchSongs(),
]);

const warnings: string[] = [];

if (perfilesResp.error) warnings.push(`Perfiles: ${perfilesResp.error.message}`);
if (rolesResp.error) warnings.push(`Roles: ${rolesResp.error.message}`);
if (perfilRolesResp.error) warnings.push(`Perfil roles: ${perfilRolesResp.error.message}`);
if (eventosResp.error) warnings.push(`Eventos: ${eventosResp.error.message}`);
if (playlistsResp.error) warnings.push(`Playlists: ${playlistsResp.error.message}`);
if (playlistCancionesResp.error) warnings.push(`Playlist canciones: ${playlistCancionesResp.error.message}`);
if (ausenciasResp.error) warnings.push(`Ausencias: ${ausenciasResp.error.message}`);
warnings.push(...(songsBundle.warnings || []));

const perfiles: AnyRecord[] = perfilesResp.data || [];
const roles: AnyRecord[] = rolesResp.data || [];
const perfilRoles: AnyRecord[] = perfilRolesResp.data || [];
let eventos: AnyRecord[] = withPredicadorFallbackRows(eventosResp.data || []);

if (isPredicadorColumnMissingError(eventosResp.error)) {
  const fallbackEventosResp = await buildEventosQuery(false);
  if (!fallbackEventosResp.error) {
    eventos = withPredicadorFallbackRows(fallbackEventosResp.data || []);
    const warningIndex = warnings.findIndex((warning) => warning === `Eventos: ${eventosResp.error?.message || ''}`);
    if (warningIndex >= 0) warnings.splice(warningIndex, 1);
    console.warn('Panel eventos query: usando fallback sin columna predicador.');
  } else {
    if (fallbackEventosResp.error) warnings.push(`Eventos fallback: ${fallbackEventosResp.error.message}`);
  }
}
const playlists: AnyRecord[] = playlistsResp.data || [];
const playlistCanciones: AnyRecord[] = playlistCancionesResp.data || [];
const ausencias: AnyRecord[] = ausenciasResp.data || [];
const cancionesRaw: AnyRecord[] = songsBundle.data || [];

const canciones = cancionesRaw.filter((song) => normalizeFold(song?.estado) !== 'archivada');
const perfilesById = new Map(perfiles.map((perfil) => [String(perfil.id), perfil]));
const rolesById = new Map(roles.map((rol) => [String(rol.id), rol]));
const cancionesById = new Map(canciones.map((song) => [String(song.id), song]));

const normalizeMultitrackSession = (rawValue: any) => {
  if (!rawValue) return null;

  let parsedValue = rawValue;
  if (typeof rawValue === 'string') {
    try {
      parsedValue = JSON.parse(rawValue);
    } catch {
      return null;
    }
  }

  if (!parsedValue || typeof parsedValue !== 'object') return null;

  const tracks = (Array.isArray(parsedValue.tracks) ? parsedValue.tracks : [])
    .map((track: AnyRecord) => ({
      id: safeText(track?.id),
      name: safeText(track?.name, 'Pista'),
      url: safeText(track?.url),
      enabled: track?.enabled !== false,
    }))
    .filter((track: AnyRecord) => track.id && track.name && track.url);

  if (!tracks.length) return null;

  return {
    mode: parsedValue.mode === 'folder' ? 'folder' : 'sequence',
    updatedAt: safeText(parsedValue.updatedAt),
    tracks,
  };
};

const getSongSequenceProfile = (song: AnyRecord) => {
  const session = normalizeMultitrackSession(song?.multitrack_session);
  const enabledTracks = (session?.tracks || []).filter((track: AnyRecord) => track.enabled !== false);
  const trackCount = enabledTracks.length;
  const hasExternalSequence = hasText(song?.link_secuencias);

  if (trackCount >= 4) {
    return {
      type: 'complete',
      label: 'Completa',
      trackCount,
      detail: `${trackCount} pistas separadas listas para Live Director.`,
    };
  }

  if (trackCount >= 2) {
    return {
      type: 'partial',
      label: 'Parcial',
      trackCount,
      detail: `${trackCount} pistas separadas; revisar si faltan bajo, bateria u otros stems.`,
    };
  }

  if (trackCount === 1 || hasExternalSequence) {
    return {
      type: 'simple',
      label: 'Una pista',
      trackCount: trackCount || 1,
      detail: trackCount === 1 ? 'Una pista cargada en Live Director.' : 'Link de secuencia sin stems separados.',
    };
  }

  return {
    type: 'missing',
    label: 'Sin secuencia',
    trackCount: 0,
    detail: 'Sin link de secuencia ni sesion multitrack cargada.',
  };
};

const sequenceProfileBySongId = new Map(
  canciones.map((song) => [String(song.id), getSongSequenceProfile(song)]),
);

const getSequenceProfileForSong = (song: AnyRecord) =>
  sequenceProfileBySongId.get(String(song?.id || '')) || getSongSequenceProfile(song);

const playlistsByEventId = new Map<string, AnyRecord>();
playlists.forEach((playlist) => {
  if (playlist?.evento_id) {
    playlistsByEventId.set(String(playlist.evento_id), playlist);
  }
});

const playlistSongsByPlaylistId = new Map<string, AnyRecord[]>();
const usageBySongId = new Map<string, number>();
playlistCanciones.forEach((item) => {
  const playlistId = String(item?.playlist_id || '');
  const songId = String(item?.cancion_id || '');
  if (!playlistId || !songId) return;
  const bucket = playlistSongsByPlaylistId.get(playlistId) || [];
  bucket.push(item);
  playlistSongsByPlaylistId.set(playlistId, bucket);
  usageBySongId.set(songId, (usageBySongId.get(songId) || 0) + 1);
});

const absencesByProfileId = new Map<string, AnyRecord[]>();
ausencias.forEach((absence) => {
  const profileId = String(absence?.perfil_id || '');
  if (!profileId) return;
  const bucket = absencesByProfileId.get(profileId) || [];
  bucket.push(absence);
  absencesByProfileId.set(profileId, bucket);
});

const directionRoleCodes = ['lider_alabanza', 'director_musical', 'talkback'];
const lyricsRoleCodes = ['encargado_letras', 'letra_y_notas', 'produccion_visual', 'letras'];

const operationalEvents: AnyRecord[] = eventos
  .map((evento) => {
    const eventDate = new Date(evento.fecha_hora);
    if (Number.isNaN(eventDate.getTime())) return null;

    const playlist = playlistsByEventId.get(String(evento.id)) || null;
    const playlistItems = playlist
      ? (playlistSongsByPlaylistId.get(String(playlist.id)) || []).slice().sort((a, b) => Number(a?.orden || 0) - Number(b?.orden || 0))
      : [];
    const setlistSongs = playlistItems
      .map((item) => cancionesById.get(String(item.cancion_id)))
      .filter((song): song is AnyRecord => song !== undefined);

    const roster = (Array.isArray(evento.asignaciones) ? evento.asignaciones : []).map((asig) => {
      const role = rolesById.get(String(asig?.rol_id || '')) || null;
      const profile = asig?.perfiles || perfilesById.get(String(asig?.perfil_id || '')) || null;
      return {
        perfil_id: String(asig?.perfil_id || profile?.id || ''),
        rol_id: String(asig?.rol_id || ''),
        role,
        profile,
      };
    });

    const roleCodes = roster.map((item) => item?.role?.codigo).filter(Boolean);
    const hasSetlist = setlistSongs.length > 0;
    const hasRoster = roster.length > 0;
    const hasDirection = roleCodes.some((code) => directionRoleCodes.includes(code));
    const hasLyrics = roleCodes.some((code) => lyricsRoleCodes.includes(code));
    const missingChordproSongs = setlistSongs.filter((song) => !hasText(song?.chordpro));
    const missingMp3Songs = setlistSongs.filter((song) => !hasText(song?.mp3));
    const conflictingAbsences = roster
      .map((item) => {
        const personAbsences = absencesByProfileId.get(String(item.perfil_id)) || [];
        const activeAbsence = personAbsences.find((absence) => inAbsenceRange(eventDate, absence));
        if (!activeAbsence || !item?.profile?.nombre) return null;
        return {
          profileId: item.perfil_id,
          profileName: item.profile.nombre,
          reason: safeText(activeAbsence?.motivo, 'Sin motivo'),
        };
      })
      .filter((item): item is NonNullable<typeof item> => item !== null)
      .reduce<AnyRecord[]>((unique, current) => {
        if (!unique.some((item) => item.profileId === current.profileId)) unique.push(current);
        return unique;
      }, []);

    const readinessChecks = [
      { key: 'setlist', label: 'Setlist cargada', ok: hasSetlist, detail: hasSetlist ? formatCountLabel(setlistSongs.length, 'cancion') : 'Sin playlist' },
      { key: 'roster', label: 'Equipo cargado', ok: hasRoster, detail: hasRoster ? formatCountLabel(roster.length, 'asignacion') : 'Sin roster' },
      { key: 'direction', label: 'Direccion cubierta', ok: hasDirection, detail: hasDirection ? 'Direccion presente' : 'Falta direccion' },
      { key: 'lyrics', label: 'Letras cubiertas', ok: hasLyrics, detail: hasLyrics ? 'Letras presentes' : 'Falta letras' },
      {
        key: 'chordpro',
        label: 'ChordPro listo',
        ok: hasSetlist && missingChordproSongs.length === 0,
        detail: hasSetlist ? `${setlistSongs.length - missingChordproSongs.length}/${setlistSongs.length}` : 'Sin setlist',
      },
      {
        key: 'mp3',
        label: 'MP3 listo',
        ok: hasSetlist && missingMp3Songs.length === 0,
        detail: hasSetlist ? `${setlistSongs.length - missingMp3Songs.length}/${setlistSongs.length}` : 'Sin setlist',
      },
    ];

    const readinessPassed = readinessChecks.filter((check) => check.ok).length;
    const readinessScore = Math.round((readinessPassed / readinessChecks.length) * 100);

    const alerts = [];
    if (!hasSetlist) alerts.push({ level: 'danger', title: 'Sin setlist', detail: 'Este servicio aun no tiene playlist cargada.' });
    if (!hasRoster) alerts.push({ level: 'danger', title: 'Sin roster', detail: 'Todavia no hay personal asignado.' });
    if (!hasDirection) alerts.push({ level: 'warning', title: 'Falta direccion', detail: 'No hay rol de direccion o talkback asignado.' });
    if (!hasLyrics) alerts.push({ level: 'warning', title: 'Falta letras', detail: 'No hay cobertura para letras o visuales.' });
    if (missingChordproSongs.length > 0) alerts.push({ level: 'warning', title: 'ChordPro pendiente', detail: `${missingChordproSongs.length} canciones sin guia de ensayo.` });
    if (missingMp3Songs.length > 0) alerts.push({ level: 'warning', title: 'MP3 pendiente', detail: `${missingMp3Songs.length} canciones sin audio base.` });
    if (conflictingAbsences.length > 0) alerts.push({ level: 'danger', title: 'Ausencias cruzadas', detail: `${conflictingAbsences.length} asignados con ausencia en esta fecha.` });

    let status = 'listo';
    if (!hasSetlist || !hasRoster || !hasDirection) {
      status = 'incompleto';
    } else if (alerts.length > 0) {
      status = 'riesgo';
    }

    const leaderName =
      roster.find((item) => item?.role?.codigo === 'lider_alabanza')?.profile?.nombre ||
      roster.find((item) => item?.role?.codigo === 'director_musical')?.profile?.nombre ||
      roster.find((item) => item?.role?.codigo === 'talkback')?.profile?.nombre ||
      '';

    return {
      id: String(evento.id),
      title: buildEventHeadline(evento, safeText(evento.titulo, 'Servicio')),
      eventTitle: safeText(evento.titulo, 'Evento'),
      dateIso: evento.fecha_hora,
      rawStatus: safeText(evento.estado),
      status,
      leaderName,
      playlistId: playlist?.id ? String(playlist.id) : '',
      setlistCount: setlistSongs.length,
      rosterCount: roster.length,
      readinessScore,
      readinessChecks,
      alerts,
      hasSetlist,
      hasRoster,
      hasDirection,
      hasLyrics,
      setlistSongIds: [...new Set(setlistSongs.map((song) => String(song.id)))],
      rosterMembers: roster
        .filter((item) => item.perfil_id)
        .map((item) => ({
          profileId: String(item.perfil_id),
          name: safeText(item?.profile?.nombre, 'Sin nombre'),
          avatarUrl: safeText(item?.profile?.avatar_url),
          roleId: String(item?.role?.id || item?.rol_id || ''),
          roleCode: safeText(item?.role?.codigo),
          roleName: safeText(item?.role?.nombre),
        })),
      missingChordproCount: missingChordproSongs.length,
      missingMp3Count: missingMp3Songs.length,
      conflictingAbsences,
      programacionHref: `/programacion?ver_evento=${evento.id}`,
      ensayoHref: setlistSongs.length > 0 ? `/ensayo/${evento.id}` : '',
      repertorioHref: `/repertorio?seleccionar_para=${evento.id}`,
    };
  })
  .filter((evento): evento is NonNullable<typeof evento> => evento !== null)
  .sort((a, b) => new Date(a.dateIso).getTime() - new Date(b.dateIso).getTime());

const activeSongIds = new Set(canciones.map((song) => String(song.id)));

const hasVoiceResource = (song: AnyRecord) => hasText(song?.link_voces) || hasText(song?.voces);
const hasSequenceResource = (song: AnyRecord) => getSequenceProfileForSong(song).type !== 'missing';
const hasCompleteSequenceResource = (song: AnyRecord) => getSequenceProfileForSong(song).type === 'complete';
const hasMarkers = (song: AnyRecord) => Array.isArray(song?.section_markers) && song.section_markers.length > 0;

const chordproReadyCount = canciones.filter((song) => hasText(song?.chordpro)).length;
const mp3ReadyCount = canciones.filter((song) => hasText(song?.mp3)).length;
const voicesReadyCount = canciones.filter((song) => hasVoiceResource(song)).length;
const sequencesReadyCount = canciones.filter((song) => hasSequenceResource(song)).length;
const completeSequencesReadyCount = canciones.filter((song) => hasCompleteSequenceResource(song)).length;
const markersReadyCount = canciones.filter((song) => hasMarkers(song)).length;
const baseResourceCoverage = [
  resourceCoverageItem('ChordPro', chordproReadyCount, canciones.length, 'Guia de acordes y letras para ensayo.'),
  resourceCoverageItem('MP3', mp3ReadyCount, canciones.length, 'Audio base disponible.'),
  resourceCoverageItem('Voces', voicesReadyCount, canciones.length, 'Guia o recurso vocal.'),
  resourceCoverageItem('Secuencias', sequencesReadyCount, canciones.length, `${completeSequencesReadyCount} completas con multitrack separado.`),
  resourceCoverageItem('Guia por secciones', markersReadyCount, canciones.length, 'Markers para navegar la cancion por partes en ensayo/Live Director.'),
];

const getUniqueSongIdsForEvents = (events: AnyRecord[]) => {
  const songIds = new Set<string>();
  events.forEach((evento) => {
    (evento?.setlistSongIds || []).forEach((songId: unknown) => {
      const key = String(songId || '');
      if (key && activeSongIds.has(key)) songIds.add(key);
    });
  });
  return songIds;
};

const upcomingRehearsalSongIds = getUniqueSongIdsForEvents(
  operationalEvents.filter((evento) => {
    const eventDate = new Date(evento.dateIso);
    return !Number.isNaN(eventDate.getTime())
