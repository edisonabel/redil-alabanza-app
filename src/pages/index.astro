---
import Layout from '../layouts/Layout.astro';
import DashboardInicio from '../components/react/DashboardInicio.jsx';
import { supabase } from '../lib/supabase';

// Redirect to login if no auth token is found
const tokenCookie = Astro.cookies.get('sb-access-token');
if (!tokenCookie) {
  return Astro.redirect('/login');
}

// Authenticate via SSR
const { data: { user }, error: authError } = await supabase.auth.getUser(tokenCookie.value);
if (authError || !user) {
  return Astro.redirect('/login');
}

// Get the user's profile details
const { data: perfil } = await supabase
  .from('perfiles')
  .select('nombre, avatar_url, is_admin')
  .eq('id', user.id)
  .single();

// Format today's date (mid-day to avoid timezone offset issues)
const hoy = new Date();
hoy.setHours(0, 0, 0, 0);
const hoyISO = hoy.toISOString();

// Fetch future assignments for this user
const { data: asignaciones, error: asignacionesError } = await supabase
  .from('asignaciones')
  .select(`
    rol_id,
    roles (nombre, codigo),
    eventos!inner (*)
  `)
  .eq('perfil_id', user.id)
  .gte('eventos.fecha_hora', hoyISO)
  .order('eventos.fecha_hora', { ascending: true });

if (asignacionesError) {
  console.error("Error fetching asignaciones:", asignacionesError);
}
---

<Layout title="Inicio | Redil Alabanza">
  <div class="h-[calc(100vh-80px)] overflow-y-auto bg-base w-full pt-4 md:pt-8 pb-32">
    <div class="max-w-[2000px] mx-auto w-full px-4 xl:px-8">
      <DashboardInicio client:load usuario={perfil} proximosServicios={asignaciones || []} />
    </div>
  </div>
</Layout>
