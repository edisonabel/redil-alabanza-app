---
import Layout from '../layouts/Layout.astro';
import DashboardInicio from '../components/react/DashboardInicio.jsx';
import DashboardShortcuts from '../components/react/DashboardShortcuts.jsx';
import ModalDetalle from '../components/react/ModalDetalle.jsx';
import OnboardingRoot from '../components/onboarding/OnboardingRoot';
import { supabase } from '../lib/supabase';
import { createClient } from '@supabase/supabase-js';
import { isPredicadorColumnMissingError, withPredicadorFallbackRows } from '../lib/predicador-compat.js';

const tokenCookie = Astro.cookies.get('sb-access-token');
if (!tokenCookie) {
  return Astro.redirect('/login');
}

const rawUrl = import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.SUPABASE_URL || '';
const supabaseUrl = rawUrl.replace(/\/$/, '');
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || import.meta.env.SUPABASE_ANON_KEY || '';

const supabaseSSR = createClient(supabaseUrl, supabaseAnonKey, {
  global: {
    headers: {
      Authorization: `Bearer ${tokenCookie.value}`
    }
  },
  auth: {
    persistSession: false,
    autoRefreshToken: false
  }
});

const { data: { user }, error: authError } = await supabase.auth.getUser(tokenCookie.value);
if (authError || !user) {
  return Astro.redirect('/login');
}

const [
  { data: perfil },
  { data: eventosEspecialesData, error: eventosEspecialesError },
  { data: perfilesCumplesData, error: perfilesCumplesError },
  { data: rolesCatalog, error: rolesError },
] = await Promise.all([
  supabaseSSR
    .from('perfiles')
    .select('id, nombre, avatar_url, is_admin, tour_completado')
    .eq('id', user.id)
    .single(),
  supabaseSSR
    .from('eventos_especiales')
    .select('id, titulo, descripcion, fecha, activo')
    .eq('activo', true)
    .order('fecha', { ascending: true })
    .limit(5),
  supabaseSSR
    .from('perfiles')
    .select('id, nombre, fecha_nacimiento, avatar_url')
    .not('fecha_nacimiento', 'is', null),
  supabaseSSR
    .from('roles')
    .select('id, nombre, codigo'),
]);

if (eventosEspecialesError) {
  console.error('Inicio eventos_especiales query error:', eventosEspecialesError);
}

if (perfilesCumplesError) {
  console.error('Inicio cumpleaneros query error:', perfilesCumplesError);
}

const hoy = new Date();
hoy.setHours(0, 0, 0, 0);
const mesActual = hoy.getMonth() + 1;
const cumpleanerosTodos = (perfilesCumplesData || [])
  .map((perfilCumple) => {
    const rawFecha = perfilCumple?.fecha_nacimiento;
    if (!rawFecha || typeof rawFecha !== 'string') return null;
    const [year, month, day] = rawFecha.split('-').map((v) => Number(v));
    if (!year || !month || !day) return null;
    const proximoCumple = new Date(hoy.getFullYear(), month - 1, day);
    if (proximoCumple < hoy) {
      proximoCumple.setFullYear(proximoCumple.getFullYear() + 1);
    }
    return {
      id: perfilCumple.id,
      nombre: perfilCumple.nombre || 'Músico',
      dia: day,
      nombre: perfilCumple.nombre || 'Musico',
      mes: month,
      avatar_url: perfilCumple.avatar_url || '',
      proximo_cumple_ts: proximoCumple.getTime()
    };
  })
  .filter(Boolean)
  .sort((a, b) => a.proximo_cumple_ts - b.proximo_cumple_ts);

const cumpleanerosMes = cumpleanerosTodos
  .filter((persona) => persona.mes === mesActual)
  .map((persona) => ({
    id: persona.id,
    nombre: persona.nombre || 'Musico',
    dia: persona.dia,
    mes: persona.mes,
    avatar_url: persona.avatar_url || ''
  }))
  .sort((a, b) => a.dia - b.dia);

// Keep a 12h tolerance like Programacion to avoid timezone edge-cases.
const fechaFiltroISO = new Date(Date.now() - 12 * 60 * 60 * 1000).toISOString();
const userEmail = user.email || null;

if (rolesError) {
  console.error('Inicio roles query error:', rolesError);
}

const rolesById = new Map((rolesCatalog || []).map((rol) => [rol.id, rol]));

const buildEventosSelect = (includePredicador = true) => `
  id,
  fecha_hora,
  hora_fin,
  titulo,
  tema_predicacion,
  ${includePredicador ? 'predicador,' : ''}
  estado,
  asignaciones (
    perfil_id,
    rol_id,
    perfiles (id, nombre, email, avatar_url)
  )
`;

const buildEventosQuery = (includePredicador = true) => {
  let query = supabaseSSR
    .from('eventos')
    .select(buildEventosSelect(includePredicador))
    .gte('fecha_hora', fechaFiltroISO)
    .order('fecha_hora', { ascending: true });

  if (!perfil?.is_admin) {
    query = query.eq('estado', 'Publicado');
  }

  return query;
};

let { data: eventosData, error: eventosError } = await buildEventosQuery(true);

if (isPredicadorColumnMissingError(eventosError)) {
  const fallbackResp = await buildEventosQuery(false);
  if (!fallbackResp.error) {
    eventosData = withPredicadorFallbackRows(fallbackResp.data || []);
    eventosError = null;
    console.warn('Inicio eventos query: usando fallback sin columna predicador.');
  } else {
    eventosData = fallbackResp.data;
    eventosError = fallbackResp.error;
  }
} else {
  eventosData = withPredicadorFallbackRows(eventosData || []);
}

if (eventosError) {
  console.error('Inicio eventos query error:', eventosError);
}

const eventoIds = (eventosData || []).map((evento) => evento.id).filter(Boolean);
const playlistByEvento = new Map();

if (eventoIds.length > 0) {
  const { data: playlistsData, error: playlistsError } = await supabaseSSR
    .from('playlists')
    .select('id, evento_id, playlist_canciones(id)')
    .in('evento_id', eventoIds);

  if (playlistsError) {
    console.error('Inicio playlists query error:', playlistsError);
  } else {
    for (const playlist of playlistsData || []) {
      const count = Array.isArray(playlist.playlist_canciones) ? playlist.playlist_canciones.length : 0;
      playlistByEvento.set(playlist.evento_id, {
        id: playlist.id,
        count
      });
    }
  }
}

const proximosServicios = (eventosData || [])
  .map((evento) => {
    const playlistMeta = playlistByEvento.get(evento.id) || null;
    const roster = Array.isArray(evento.asignaciones) ? evento.asignaciones : [];
    const misAsignaciones = roster.filter((asig) => {
      const perfilAsignado = asig?.perfiles;
      return asig?.perfil_id === user.id
        || perfilAsignado?.id === user.id
        || (userEmail && perfilAsignado?.email === userEmail);
    });

    if (misAsignaciones.length === 0) return null;

    const misRoles = [];
    const miRolCodigos = [];

    for (const miAsig of misAsignaciones) {
      const rol = rolesById.get(miAsig.rol_id);
      const rolNombre = rol?.nombre;
      const rolCodigo = rol?.codigo;

      if (rolNombre && !misRoles.includes(rolNombre)) {
        misRoles.push(rolNombre);
      }
      if (rolCodigo && !miRolCodigos.includes(rolCodigo)) {
        miRolCodigos.push(rolCodigo);
      }
    }

    const rosterConRoles = roster.map((asig) => ({
      ...asig,
      roles: rolesById.get(asig.rol_id) || null
    }));

    return {
      ...evento,
      asignaciones: rosterConRoles,
      mis_roles: misRoles.length > 0 ? misRoles : ['Miembro'],
      mi_rol_codigos: miRolCodigos,
      has_setlist: !!playlistMeta && playlistMeta.count > 0,
      setlist_count: playlistMeta?.count || 0,
      repertorio_href: `/programacion?ver_evento=${evento.id}&focus=repertorio`,
      crear_setlist_href: `/repertorio?seleccionar_para=${evento.id}`
    };
  })
  .filter(Boolean);


---

<Layout title="Inicio | Redil Alabanza">
  <script is:inline>
    window.openOnboarding = window.openOnboarding || function () {
      window.sessionStorage.setItem(
        'redil_onboarding_active_pages',
        JSON.stringify(['home', 'repertorio', 'programacion', 'perfil'])
      );
      window.__REDIL_OPEN_ONBOARDING_PENDING__ = true;
      window.dispatchEvent(new CustomEvent('redil:open-onboarding'));
    };
  </script>

  <div id="dashboard-scroll-root" class="h-[calc(100dvh-80px)] overflow-y-auto bg-background w-full pt-4 md:pt-8 pb-32 relative">
    <div class="pointer-events-none absolute inset-x-0 top-0 h-[420px] bg-[radial-gradient(ellipse_80%_50%_at_50%_-5%,rgba(59,130,246,0.06),transparent)] dark:bg-[radial-gradient(ellipse_80%_50%_at_50%_-5%,rgba(59,130,246,0.10),transparent)]"></div>
    <div class="relative max-w-[2000px] mx-auto w-full h-full px-3 sm:px-4 xl:px-8">
      <DashboardInicio
        client:idle
        usuario={perfil}
        proximosServicios={proximosServicios}
        eventosEspeciales={eventosEspecialesData || []}
        cumpleanerosMes={cumpleanerosMes || []}
        cumpleanerosTodos={cumpleanerosTodos || []}
      />
      <DashboardShortcuts client:idle userId={user.id} isAdmin={Boolean(perfil?.is_admin)} />
      <ModalDetalle client:only="react" initialRoles={rolesCatalog || []} sessionUser={user} isAdmin={Boolean(perfil?.is_admin)} />
    </div>
    </div>
  </div>

  <OnboardingRoot
    client:idle
    page="home"
    userId={user.id}
    onboardingCompleted={Boolean(perfil?.tour_completado)}
  />
</Layout>

