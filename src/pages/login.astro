---
import Layout from '../layouts/Layout.astro';
---

<Layout>
 <div class="max-w-md mx-auto mt-10 px-4 w-full">
 <div class="flex justify-center mb-5">
  <img src="/LOGO%20REDIL%20LIGHT.png" alt="Logo Redil" class="w-[96px] h-auto dark:hidden" />
  <img src="/LOGO%20REDIL.png" alt="Logo Redil" class="hidden w-[96px] h-auto dark:block" />
 </div>
 <div class="bg-surface border border-border rounded-2xl p-8 shadow-xl [0_0_30px_rgba(0,0,0,0.5)]">
 <h1 class="text-3xl font-extrabold text-content mb-2 text-center">Acceso al Sistema</h1>
 <p class="text-content-muted text-center mb-8">Ingresa tus credenciales para ver la agenda</p>

 <form id="login-form" class="flex flex-col gap-5">
 <!-- Pestañas (Tabs) -->
 <div class="flex p-1 bg-background rounded-xl mb-2">
 <button type="button" id="tab-login" class="flex-1 py-2 text-sm font-ui-strong rounded-lg bg-surface text-content shadow-sm transition-all">Iniciar Sesión</button>
 <button type="button" id="tab-register" class="flex-1 py-2 text-sm font-ui-strong rounded-lg text-content-muted hover:text-content transition-all">Registrarse</button>
 </div>
 
 <!-- Campos Exclusivos de Registro (Ocultos por defecto) -->
 <div id="register-fields" class="hidden flex-col gap-5">
 <div class="bg-blue-50 text-blue-900 border border-blue-200 rounded-xl px-4 py-4 dark:bg-blue-900/40 dark:text-blue-100 dark:border-blue-800 flex items-start gap-3">
 <div class="mt-0.5 text-blue-700 dark:text-blue-200 shrink-0">
 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
 </div>
 <div class="space-y-1">
 <p class="text-sm font-bold leading-snug">Usa una foto de cerca (Retrato)</p>
 <p class="text-sm leading-snug text-blue-900 dark:text-blue-100">Ampl&iacute;a la imagen hasta que <strong class="text-blue-700 dark:text-white">tu rostro llene el c&iacute;rculo</strong>. No uses fotos de cuerpo entero ni grupales.</p>
 </div>
 </div>
 <div>
 <label for="fullname" class="block text-sm font-semibold text-content mb-2">Nombre Completo <span class="text-red-500">*</span></label>
 <input type="text" id="fullname" class="w-full px-4 py-3 bg-background border border-border rounded-xl text-content focus:outline-none focus:ring-2 focus:ring-brand transition-all placeholder-content-muted" placeholder="Ej: Juan Pérez">
 </div>
<div>
<label for="telefono" class="block text-sm font-semibold text-content mb-2">Teléfono / WhatsApp <span class="text-red-500">*</span></label>
<input type="tel" id="telefono" class="w-full px-4 py-3 bg-background border border-border rounded-xl text-content focus:outline-none focus:ring-2 focus:ring-brand transition-all placeholder-content-muted" placeholder="Ej: +123456789">
</div>
<div>
<label for="fecha-nacimiento" class="block text-sm font-semibold text-content mb-2">Fecha de nacimiento <span class="text-red-500">*</span></label>
<input type="date" id="fecha-nacimiento" class="w-full px-4 py-3 bg-background border border-border rounded-xl text-content focus:outline-none focus:ring-2 focus:ring-brand transition-all" />
<p class="text-sm text-gray-500 mt-1.5">Esto es para recordar tu cumpleaños</p>
</div>
<div>
<label for="accesscode" class="block text-sm font-semibold text-content mb-2">Código de Acceso del Equipo <span class="text-red-500">*</span></label>
<input type="text" id="accesscode" class="w-full px-4 py-3 bg-background border border-border rounded-xl text-content focus:outline-none focus:ring-2 focus:ring-brand transition-all placeholder-content-muted font-mono tracking-widest uppercase" placeholder="Ej: CLAVE123">
<p class="text-[11px] text-content-muted mt-1.5 ml-1">Requerido para unirse a la plataforma.</p>
 </div>
 <div>
 <label class="block text-sm font-semibold text-content mb-2">Rol / Instrumento <span class="text-content-muted font-normal text-xs ml-1">(Puedes elegir varios)</span></label>
 <div id="register-roles-grid" class="grid grid-cols-2 gap-2 max-h-[140px] overflow-y-auto p-3 border border-border rounded-xl bg-background custom-scrollbar">
 <div class="col-span-2 text-center text-xs text-content-muted py-2 flex items-center justify-center gap-2"><div class="w-4 h-4 border-2 border-action border-t-transparent rounded-full animate-spin"></div>Cargando roles...</div>
 </div>
 </div>
 </div>

 <!-- Campos Comunes -->
 <div>
 <label for="email" class="block text-sm font-semibold text-content mb-2">Correo Electrónico <span class="text-red-500">*</span></label>
 <input type="email" id="email" required class="w-full px-4 py-3 bg-background border border-border rounded-xl text-content focus:outline-none focus:ring-2 focus:ring-brand transition-all placeholder-content-muted " placeholder="tu@correo.com">
 </div>
 
 <div>
 <label for="password" class="block text-sm font-semibold text-content mb-2">Contraseña <span class="text-red-500">*</span></label>
 <input type="password" id="password" required class="w-full px-4 py-3 bg-background border border-border rounded-xl text-content focus:outline-none focus:ring-2 focus:ring-brand transition-all placeholder-content-muted " placeholder="••••••••">
 <p class="text-[11px] text-content-muted mt-1.5 ml-1" id="password-hint">Mínimo 6 caracteres.</p>
 </div>
 
 <div class="flex items-center gap-2 mt-1">
 <input type="checkbox" id="remember-me" class="w-4 h-4 text-brand bg-background border-border rounded focus:ring-brand focus:ring-2 transition-colors cursor-pointer" checked>
 <label for="remember-me" class="text-sm text-content-muted cursor-pointer select-none">Mantener Sesión iniciada</label>
 </div>

 <div id="error-message" class="hidden text-red-600 text-sm font-medium bg-red-100 border border-red-300 p-3 rounded-xl text-center mt-2"></div>
 <div id="success-message" class="hidden text-success text-sm font-medium bg-success/10 border border-success/30 p-3 rounded-xl text-center mt-2"></div>

 <div class="flex flex-col gap-3 mt-2">
 <button type="submit" id="btn-submit" class="w-full py-4 bg-action hover:bg-action/80 text-white font-ui-strong rounded-xl active:scale-95 transition-all shadow-lg">
 Iniciar Sesión
 </button>
 </div>
 </form>
 </div>
 </div>
</Layout>

 <script>
 import { supabase } from '../lib/supabase';

 document.addEventListener('DOMContentLoaded', async () => {
  // Removido loop infinito de auto-sincronizaciÃ³n. El usuario debe hacer logout manual o login.

  const form = document.getElementById('login-form');
 const emailInput = document.getElementById('email') as HTMLInputElement;
const passwordInput = document.getElementById('password') as HTMLInputElement;
const fullnameInput = document.getElementById('fullname') as HTMLInputElement;
const telefonoInput = document.getElementById('telefono') as HTMLInputElement;
const fechaNacimientoInput = document.getElementById('fecha-nacimiento') as HTMLInputElement;
const accessCodeInput = document.getElementById('accesscode') as HTMLInputElement;
const rememberMeCheckbox = document.getElementById('remember-me') as HTMLInputElement;
 
 const errorMessage = document.getElementById('error-message');
 const successMessage = document.getElementById('success-message');
 const btnSubmit = document.getElementById('btn-submit');
 
 const tabLogin = document.getElementById('tab-login');
 const tabRegister = document.getElementById('tab-register');
 const registerFields = document.getElementById('register-fields');
 const passwordHint = document.getElementById('password-hint');
 const registerRolesGrid = document.getElementById('register-roles-grid');

 let isLoginMode = true;
 let rolesLoaded = false;

 const loadRoles = async () => {
 try {
 const { data, error } = await supabase.from('roles').select('id, nombre').order('nombre');
 if (error) throw error;
 if (data && registerRolesGrid) {
 registerRolesGrid.innerHTML = data.map(r => `
 <label class="flex items-center gap-2 p-2 rounded-lg border border-transparent hover:bg-surface hover:border-border transition-colors cursor-pointer text-sm text-content-muted">
 <input type="checkbox" name="register_role" value="${r.id}" class="w-4 h-4 text-brand rounded border-border focus:ring-brand cursor-pointer">
 <span class="truncate">${r.nombre}</span>
 </label>
 `).join('');
 }
 } catch (err) {
 console.error('Error cargando roles:', err);
 if (registerRolesGrid) registerRolesGrid.innerHTML = '<div class="col-span-2 text-center text-xs text-red-500 py-2">Error cargando roles</div>';
 }
 };

 // --- Tab Switching Logic ---
 const setLoginMode = () => {
 isLoginMode = true;
 tabLogin?.classList.add('bg-surface', 'text-content', 'shadow-sm');
 tabLogin?.classList.remove('text-content-muted', 'hover:text-content');
 
 tabRegister?.classList.remove('bg-surface', 'text-content', 'shadow-sm');
 tabRegister?.classList.add('text-content-muted', 'hover:text-content');

 registerFields?.classList.add('hidden');
 registerFields?.classList.remove('flex');
 passwordHint?.classList.add('hidden');
 
fullnameInput.required = false;
telefonoInput.required = false;
fechaNacimientoInput.required = false;
accessCodeInput.required = false;
accessCodeInput.value = ''; // limpiar por si acaso
 
 if (btnSubmit) btnSubmit.textContent = 'Iniciar Sesión';
 hideMessages();
 };

 const setRegisterMode = () => {
 isLoginMode = false;
 tabRegister?.classList.add('bg-surface', 'text-content', 'shadow-sm');
 tabRegister?.classList.remove('text-content-muted', 'hover:text-content');
 
 tabLogin?.classList.remove('bg-surface', 'text-content', 'shadow-sm');
 tabLogin?.classList.add('text-content-muted', 'hover:text-content');

 registerFields?.classList.remove('hidden');
 registerFields?.classList.add('flex');
 passwordHint?.classList.remove('hidden');

fullnameInput.required = true;
telefonoInput.required = true;
fechaNacimientoInput.required = true;
accessCodeInput.required = true;

 if (btnSubmit) btnSubmit.textContent = 'Crear Cuenta';
 hideMessages();

 if (!rolesLoaded) {
 rolesLoaded = true;
 loadRoles();
 }
 };

 tabLogin?.addEventListener('click', setLoginMode);
 tabRegister?.addEventListener('click', setRegisterMode);

 // --- UI Helpers ---
 const showError = (msg: string) => {
 if (errorMessage) {
 errorMessage.textContent = msg;
 errorMessage.classList.remove('hidden');
 if (successMessage) successMessage.classList.add('hidden');
 }
 };

 const showSuccess = (msg: string) => {
 if (successMessage) {
 successMessage.textContent = msg;
 successMessage.classList.remove('hidden');
 if (errorMessage) errorMessage.classList.add('hidden');
 }
 }

 const hideMessages = () => {
 if (errorMessage) errorMessage.classList.add('hidden');
 if (successMessage) successMessage.classList.add('hidden');
 };

 // --- Submit Logic ---
 form?.addEventListener('submit', async (e) => {
 e.preventDefault();
 hideMessages();
 
 const email = emailInput.value;
 const password = passwordInput.value;

 if (!email || !password) return;

 if(btnSubmit) {
 btnSubmit.innerHTML = '<span class="flex items-center justify-center gap-2"><div class="w-4 h-4 rounded-full border-2 border-white/20 border-t-white animate-spin"></div> Procesando...</span>';
 (btnSubmit as HTMLButtonElement).disabled = true;
 }

 try {
 if (isLoginMode) {
 // Logic for Login
 const { data, error } = await supabase.auth.signInWithPassword({
 email,
 password,
 });

 if (data.session) {
   try {
     const maxAge = 60 * 60 * 24 * 365; // 1 año
     const secureFlag = window.location.protocol === 'https:' ? '; Secure' : '';
     const firstLoginOnboardingKey = 'redil_onboarding_first_login_completed';
     const onboardingPagesKey = 'redil_onboarding_active_pages';
     
     // InyecciÃ³n robusta de cookies nativas para acceso del servidor (SSR)
     document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=${maxAge}; SameSite=Lax${secureFlag}`;
     document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; max-age=${maxAge}; SameSite=Lax${secureFlag}`;

     if (window.localStorage.getItem(firstLoginOnboardingKey) !== 'true') {
       window.localStorage.setItem(firstLoginOnboardingKey, 'true');
       window.sessionStorage.setItem(
         onboardingPagesKey,
         JSON.stringify(['home', 'repertorio', 'programacion', 'perfil'])
       );
     }
     
     // Retraso obligatorio para que el navegador guarde la cookie fÃ­sicamente
     setTimeout(() => {
       window.location.href = '/';
     }, 400);

   } catch (cookieError) {
     console.error("[Seguridad Login] Error crÃ­tico al inyectar cookie nativa:", cookieError);
     showError("Hubo un problema sincronizando tu Sesión de forma segura. Por favor, intenta usar otro navegador o borra el historial.");
     if (btnSubmit) {
       btnSubmit.innerHTML = 'Iniciar Sesión';
       (btnSubmit as HTMLButtonElement).disabled = false;
     }
   }
 }
 
 } else {
 // Logic for Registration
const fullName = fullnameInput.value;
const telefono = telefonoInput.value;
const fechaNacimiento = fechaNacimientoInput.value;
const accessCode = accessCodeInput.value?.trim().toUpperCase();

 // SECRET CODE VALIDATION
 const SECRET_CODE = 'REDIL2026';
 if (accessCode !== SECRET_CODE) {
  throw new Error("El Código de Acceso es incorrecto. Contacta a tu líder si no lo tienes.");
 }

if (!fullName || !telefono || !fechaNacimiento) throw new Error("Nombre, Teléfono y Fecha de nacimiento son obligatorios para el registro.");

 const selectedRoles = Array.from(document.querySelectorAll('input[name="register_role"]:checked')).map(cb => (cb as HTMLInputElement).value);

 const { data, error } = await supabase.auth.signUp({
 email,
 password,
 options: {
data: {
full_name: fullName,
telefono: telefono,
fecha_nacimiento: fechaNacimiento,
roles: selectedRoles
}
 }
 });

 if (error) throw error;
 showSuccess('Registro exitoso. Si el sistema te lo permite, ya puedes iniciar Sesión.');
 setLoginMode();
 // clear password & full name just for security
 passwordInput.value = '';
 }
 } catch(err: any) {
  showError(err.message || 'Ocurrió un error inesperado');
 } finally {
 if(btnSubmit) {
 btnSubmit.textContent = isLoginMode ? 'Iniciar Sesión' : 'Crear Cuenta';
 (btnSubmit as HTMLButtonElement).disabled = false;
 }
 }
 });

 });
</script>

