<style is:global>
  #login-cropper-modal .cropper-view-box,
  #login-cropper-modal .cropper-face {
    border-radius: 50%;
  }
</style>

<script is:inline>
  (function () {
    var cropperInstance = null;

    var modal = document.getElementById("login-cropper-modal");
    var content = document.getElementById("login-cropper-content");
    var cropperImage = document.getElementById("login-cropper-image");
    var btnClose = document.getElementById("login-btn-close-cropper");
    var btnCancel = document.getElementById("login-btn-cancel-cropper");
    var btnSave = document.getElementById("login-btn-save-cropper");

    function openCropper(file) {
      var objectUrl = URL.createObjectURL(file);
      cropperImage.src = objectUrl;
      cropperImage.classList.remove("hidden");
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      setTimeout(function () {
        modal.classList.remove("opacity-0");
        content.classList.remove("scale-95");
        if (cropperInstance) {
          cropperInstance.destroy();
        }
        var CropperJS = window.Cropper;
        if (CropperJS) {
          cropperInstance = new CropperJS(cropperImage, {
            aspectRatio: 1,
            viewMode: 1,
            dragMode: "move",
            autoCropArea: 1,
            restore: false,
            guides: false,
            center: false,
            highlight: false,
            cropBoxMovable: true,
            cropBoxResizable: true,
            toggleDragModeOnDblclick: false,
          });
        }
      }, 10);
    }

    function closeCropper() {
      modal.classList.add("opacity-0");
      content.classList.add("scale-95");
      setTimeout(function () {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        if (cropperInstance) {
          cropperInstance.destroy();
          cropperInstance = null;
        }
        if (cropperImage) {
          cropperImage.src = "";
          cropperImage.classList.add("hidden");
        }
      }, 300);
    }

    btnClose && btnClose.addEventListener("click", closeCropper);
    btnCancel && btnCancel.addEventListener("click", closeCropper);
    modal &&
      modal.addEventListener("click", function (e) {
        if (e.target === modal) closeCropper();
      });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !modal.classList.contains("hidden"))
        closeCropper();
    });

    btnSave &&
      btnSave.addEventListener("click", async function () {
        if (!cropperInstance) return;
        var originalHTML = btnSave.innerHTML;
        btnSave.innerHTML =
          '<svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Procesando...';
        btnSave.disabled = true;
        try {
          var canvas = cropperInstance.getCroppedCanvas({
            width: 400,
            height: 400,
            imageSmoothingEnabled: true,
            imageSmoothingQuality: "high",
          });
          // Intentar WebP, fallback a JPEG
          var mimeType = "image/webp";
          var ext = "webp";
          var testCanvas = document.createElement("canvas");
          testCanvas.width = 1;
          testCanvas.height = 1;
          var supportsWebP =
            testCanvas.toDataURL("image/webp").indexOf("data:image/webp") === 0;
          if (!supportsWebP) {
            mimeType = "image/jpeg";
            ext = "jpg";
          }
          var blob = await new Promise(function (resolve) {
            canvas.toBlob(resolve, mimeType, 0.9);
          });
          if (!blob) throw new Error("No se pudo generar el recorte.");
          var croppedFile = new File(
            [blob],
            "avatar_" + Date.now() + "." + ext,
            { type: mimeType },
          );
          // Disparar evento para que el script de login recoja el archivo
          document.dispatchEvent(
            new CustomEvent("avatar-cropped", {
              detail: { file: croppedFile },
            }),
          );
          closeCropper();
        } catch (err) {
          console.error("[Cropper]", err);
          alert("No se pudo procesar la foto. Intenta de nuevo.");
        } finally {
          btnSave.innerHTML = originalHTML;
          btnSave.disabled = false;
        }
      });

    // Exponer función para que el script de login abra el modal
    window.__loginOpenCropper = openCropper;
  })();
</script>
