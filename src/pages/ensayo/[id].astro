---
import '../../styles/global.css';
import { createClient } from '@supabase/supabase-js';
import EnsayoHub from '../../components/react/EnsayoHub.jsx';
import ProPlayerGlobal from '../../components/ProPlayerGlobal.astro';
import VocesModalGlobal from '../../components/VocesModalGlobal.astro';
import { getBrandingConfig } from '../../lib/branding';
import { buildEventHeadline, getEventThemeAndPreacher } from '../../lib/event-display.js';
import { buildEventDateSlug, isUuidLike, parseEventDateSlug } from '../../lib/event-slug.js';
import { isPredicadorColumnMissingError, withPredicadorFallbackRow } from '../../lib/predicador-compat.js';

const MOCK_CANCION_ENSAYO = {
  id: 'demo',
  title: 'Grande y Fuerte',
  artist: 'Miel San Marcos',
  key: 'Sol',
  originalKey: 'Sol',
  bpm: 76,
  mp3: '',
  sectionMarkers: [],
  duration: 298,
  sections: [
    {
      name: 'Intro',
      note: 'Pad y Piano',
      lines: [
        '[G]Oh oh oh [D/F#]oh oh [Em]oh [C]',
        '[G]Oh oh oh [D/F#]oh oh [Em]oh [C]',
      ],
    },
    {
      name: 'Verso 1',
      note: 'Entrada suave',
      lines: [
        '[G]Tu voz resuena [D/F#]fuerte en la ma\u00f1ana',
        '[C]Tu gloria llena todo [G]mi interior',
        '[G]Mi fe despierta [D/F#]cuando T\u00fa me llamas',
        '[C]Y canta el pueblo al [D]Rey de amor',
      ],
    },
    {
      name: 'Coro',
      lines: [
        '[G]Grande y fuerte [D]es nuestro Dios',
        '[Em]Digno por siempre [C]de adoraci\u00f3n',
        '[G]Toda la tierra [D]cantar\u00e1',
        '[Em]Cristo es mi roca, [C]mi salvaci\u00f3n',
      ],
    },
  ],
};

const SECTION_LABEL_RE = /^\s*\[([^\]]+)\]\s*(.*)$/;
const PURE_SECTION_HEADER_RE = /^\[([^\[\]]+)\]$/;
const CHORD_BODY_PATTERN = '[A-G](?:#|b)?(?:[a-z0-9+#°ø()\\-]*)?(?:\\/[A-G](?:#|b)?(?:[a-z0-9+#°ø()\\-]*)?)?';
const CHORD_TOKEN_RE = new RegExp(`^\\(?\\s*(\\[${CHORD_BODY_PATTERN}\\]\\s*)+\\)?\\s*$`, 'i');
const CHORD_SYMBOL_RE = new RegExp(`^${CHORD_BODY_PATTERN}$`, 'i');
const LEADING_CHORD_SECTION_RE = new RegExp(`^\\[(${CHORD_BODY_PATTERN})\\|`, 'i');
const BROKEN_INLINE_CHORD_RE = new RegExp(`\\[(${CHORD_BODY_PATTERN})\\s*\\|\\s*`, 'gi');

const { id = 'demo' } = Astro.params;
const routeId = String(id || 'demo').trim();
const routeIsDemo = routeId === 'demo';
const routeIsUuid = isUuidLike(routeId);
const tokenCookie = Astro.cookies.get('sb-access-token');
if (!tokenCookie) {
  return Astro.redirect('/login');
}

const rawUrl = import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.SUPABASE_URL || '';
const supabaseUrl = rawUrl.replace(/\/$/, '');
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || import.meta.env.SUPABASE_ANON_KEY || '';

const supabaseSSR = createClient(supabaseUrl, supabaseAnonKey, {
  global: {
    headers: {
      Authorization: `Bearer ${tokenCookie.value}`,
    },
  },
  auth: {
    persistSession: false,
    autoRefreshToken: false,
  },
});

const { data: userData, error: authError } = await supabaseSSR.auth.getUser(tokenCookie.value);
const user = userData?.user || null;
if (authError || !user) {
  return Astro.redirect('/login');
}

const hexToRgbString = (hex) => {
  if (!hex || typeof hex !== 'string') return '';
  const value = hex.trim();

  if (!/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/.test(value)) {
    return value;
  }

  let r = 0;
  let g = 0;
  let b = 0;

  if (value.length === 4) {
    r = parseInt(value[1] + value[1], 16);
    g = parseInt(value[2] + value[2], 16);
    b = parseInt(value[3] + value[3], 16);
  } else {
    r = parseInt(value[1] + value[2], 16);
    g = parseInt(value[3] + value[4], 16);
    b = parseInt(value[5] + value[6], 16);
  }

  return `${r} ${g} ${b}`;
};

const normalizeSectionName = (rawValue = '') => {
  const cleaned = String(rawValue).trim();
  if (!cleaned) return 'Secci\u00f3n';

  const normalized = cleaned.toLowerCase();
  if (normalized === 'soc' || normalized === 'start_of_chorus') return 'Coro';
  if (normalized === 'sov' || normalized === 'start_of_verse') return 'Verso';
  if (normalized === 'sob' || normalized === 'start_of_bridge') return 'Puente';
  if (normalized === 'soi' || normalized === 'start_of_intro') return 'Intro';
  if (normalized === 'interlude' || normalized === 'interludio' || normalized === 'instrumental' || normalized === 'instrumental 1' || normalized === 'instrumental 2' || normalized === 'solo instrumental' || normalized === 'start_of_interlude') return 'Interludio';
  if (normalized === 'sot' || normalized === 'start_of_tag') return 'Tag';
  if (normalized === 'eoc' || normalized === 'end_of_chorus') return '';
  if (normalized === 'eov' || normalized === 'end_of_verse') return '';
  if (normalized === 'eob' || normalized === 'end_of_bridge') return '';
  if (normalized === 'eoi' || normalized === 'end_of_intro') return '';
  if (normalized === 'eot' || normalized === 'end_of_tag') return '';

  return cleaned;
};

const isLikelySectionHeader = (rawHeader = '') => {
  const cleaned = String(rawHeader || '').trim();
  if (!cleaned) return false;

  if (CHORD_SYMBOL_RE.test(cleaned)) return false;

  const normalized = cleaned.toLowerCase();
  if ([
    'intro',
    'interlude',
    'interludio',
    'instrumental',
    'solo instrumental',
    'coro',
    'chorus',
    'pre coro',
    'pre-coro',
    'verse',
    'verso',
    'puente',
    'bridge',
    'tag',
    'outro',
    'final',
  ].some((label) => normalized.startsWith(label))) {
    return true;
  }

  return /\d/.test(cleaned);
};

const repararChordProCorrupto = (rawValue = '') => {
  if (!rawValue || typeof rawValue !== 'string') return '';

  return String(rawValue)
    .replace(/\r\n/g, '\n')
    .replace(/\r/g, '\n')
    .split('\n')
    .map((line) => {
      let fixedLine = line;

      if (LEADING_CHORD_SECTION_RE.test(fixedLine) || BROKEN_INLINE_CHORD_RE.test(fixedLine)) {
        fixedLine = fixedLine.replace(LEADING_CHORD_SECTION_RE, '[$1]');
        fixedLine = fixedLine.replace(BROKEN_INLINE_CHORD_RE, '[$1]');
        fixedLine = fixedLine.replace(/(?:\s*\|\s*)+\]+\s*$/, '');
      }

      BROKEN_INLINE_CHORD_RE.lastIndex = 0;
      return fixedLine;
    })
    .join('\n');
};

const createFallbackSong = ({
  songId = 'fallback',
  title = 'Setlist pendiente',
  artist = 'Redil Worship',
  key = '-',
  bpm = 0,
  message = 'Todav\u00eda no hay una gu\u00eda ChordPro disponible para esta canci\u00f3n.',
} = {}) => ({
  id: songId,
  title,
  artist,
  key,
  originalKey: key,
  bpm,
  mp3: '',
  sectionMarkers: [],
  duration: 160,
  sections: [
    {
      name: 'Ensayo',
      note: '',
      lines: [message],
    },
  ],
});

const estimateDuration = (sections = []) => {
  const totalLines = sections.reduce((acc, section) => acc + (section?.lines?.length || 0), 0);
  return Math.max(120, Math.min(480, totalLines * 7 + 36));
};

const parseChordProSections = (rawChordpro = '', fallbackTitle = 'Letra') => {
  const content = repararChordProCorrupto(String(rawChordpro || '')).replace(/\r\n/g, '\n').trim();
  if (!content) {
    return createFallbackSong({
      title: fallbackTitle,
      message: 'Todav\u00eda no hay una gu\u00eda ChordPro disponible para esta canci\u00f3n.',
    }).sections;
  }

  const sections = [];
  let currentSection = { name: 'Letra', note: '', lines: [] };

  const pushCurrentSection = () => {
    const sectionName = String(currentSection.name || '').trim();
    const shouldKeepEmptyNamedSection = sectionName && sectionName.toLowerCase() !== 'letra';
    if (currentSection.lines.length === 0 && !currentSection.note && !shouldKeepEmptyNamedSection) return;
    sections.push({
      name: sectionName || 'Letra',
      note: currentSection.note || '',
      lines: [...currentSection.lines],
    });
  };

  const parseSectionHeader = (rawHeader = '') => {
    const cleaned = String(rawHeader || '').trim();
    if (!cleaned) {
      return { name: 'Secci\u00f3n', note: '' };
    }

    const [rawName, ...rawNoteParts] = cleaned.split('|');
    return {
      name: normalizeSectionName(rawName.trim()) || 'Secci\u00f3n',
      note: rawNoteParts.join('|').trim(),
    };
  };

  for (const rawLine of content.split('\n')) {
    const line = rawLine.trimEnd();
    const trimmed = line.trim();

    if (!trimmed) {
      // Preservar líneas en blanco como boundary de frase para cue splitting.
      if (currentSection.lines.length > 0) {
        currentSection.lines.push('');
      }
      continue;
    }

    const inlineSectionMatch = trimmed.match(SECTION_LABEL_RE);
    if (inlineSectionMatch && isLikelySectionHeader(inlineSectionMatch[1])) {
      pushCurrentSection();
      const nextSection = parseSectionHeader(inlineSectionMatch[1]);
      const inlineRest = String(inlineSectionMatch[2] || '').trim();

      currentSection = {
        name: nextSection.name,
        note: nextSection.note,
        lines: [],
      };

      if (inlineRest) {
        if (CHORD_TOKEN_RE.test(inlineRest)) {
          currentSection.lines.push(inlineRest.replace(/\s{2,}/g, ' ').trim());
        } else {
          currentSection.note = currentSection.note
            ? `${currentSection.note} | ${inlineRest}`
            : inlineRest;
        }
      }
      continue;
    }

    const sectionLineMatch = trimmed.match(PURE_SECTION_HEADER_RE);
    if (sectionLineMatch && isLikelySectionHeader(sectionLineMatch[1])) {
      pushCurrentSection();
      const nextSection = parseSectionHeader(sectionLineMatch[1]);
      currentSection = {
        name: nextSection.name,
        note: nextSection.note,
        lines: [],
      };
      continue;
    }

    const directiveMatch = trimmed.match(/^\{([^}:]+)(?::\s*(.+))?\}$/);
    if (directiveMatch) {
      const rawDirectiveName = String(directiveMatch[1] || '').trim();
      const directiveKey = rawDirectiveName.toLowerCase();
      const directiveName = normalizeSectionName(rawDirectiveName);
      const directiveValue = directiveMatch[2]?.trim() || '';

      if (directiveKey === 'title' || directiveKey === 'artist' || directiveKey === 'subtitle' || directiveKey === 'key' || directiveKey === 'tempo' || directiveKey === 'bpm' || directiveKey === 'capo') {
        continue;
      }

      if (directiveKey === 'comment' || directiveKey === 'c') {
        if (!currentSection.note && directiveValue) {
          currentSection.note = directiveValue;
        } else if (directiveValue) {
          currentSection.lines.push(directiveValue);
        }
        continue;
      }

      if (directiveName) {
        pushCurrentSection();
        const nextSection = parseSectionHeader(directiveValue || directiveName);
        currentSection = {
          name: nextSection.name,
          note: nextSection.note,
          lines: [],
        };
      }
      continue;
    }

    currentSection.lines.push(line);
  }

  pushCurrentSection();

  if (sections.length === 0) {
    return createFallbackSong({
      title: fallbackTitle,
      message: 'Todav\u00eda no hay una gu\u00eda ChordPro disponible para esta canci\u00f3n.',
    }).sections;
  }

  return sections;
};

const readChordProContent = async (songRow) => {
  const rawChordpro = String(songRow?.chordpro || '').trim();
  if (!rawChordpro) return '';

  const looksLikeRemoteText =
    /^https?:\/\//i.test(rawChordpro) &&
    /\.(txt|pro|cho|chordpro)(\?.*)?$/i.test(rawChordpro);

  if (!looksLikeRemoteText) {
    return repararChordProCorrupto(rawChordpro);
  }

  try {
    const remoteResponse = await fetch(rawChordpro);
    if (!remoteResponse.ok) {
      console.error('Ensayo chordpro remote fetch failed:', remoteResponse.status, rawChordpro);
      return rawChordpro;
    }

    return repararChordProCorrupto((await remoteResponse.text()).trim() || rawChordpro);
  } catch (error) {
    console.error('Ensayo chordpro remote fetch error:', error);
    return repararChordProCorrupto(rawChordpro);
  }
};

const mergeMarkerNotesIntoSections = (sections = [], rawMarkers = []) => {
  const markers = Array.isArray(rawMarkers) ? rawMarkers.filter(Boolean) : [];
  if (markers.length === 0) return sections;

  const markerGroups = markers.reduce((acc, marker, index) => {
    const key = String(marker?.sectionName || marker?.name || '').trim().toLowerCase() || `marker-${index}`;
    if (!acc.has(key)) acc.set(key, []);
    acc.get(key).push(marker);
    return acc;
  }, new Map());

  const markerOccurrences = new Map();

  return sections.map((section, index) => {
    const existingSectionNote = String(section?.note || '').trim();
    if (existingSectionNote) return section;

    const normalizedSectionName = String(section?.name || '').trim().toLowerCase();
    const occurrence = markerOccurrences.get(normalizedSectionName) || 0;
    markerOccurrences.set(normalizedSectionName, occurrence + 1);

    const groupedMarkers = markerGroups.get(normalizedSectionName) || [];
    const markerByIndex = markers.find((marker) => Number(marker?.sectionIndex) === index);
    const markerByOccurrence = groupedMarkers[occurrence];
    const markerNote = String(markerByIndex?.note || markerByOccurrence?.note || '').trim();

    return markerNote ? { ...section, note: markerNote } : section;
  });
};

const buildSongFromRow = async (songRow, orderIndex = 0) => {
  const chordproContent = await readChordProContent(songRow);
  const rawSectionMarkers = Array.isArray(songRow?.section_markers) ? songRow.section_markers : [];
  const sections = mergeMarkerNotesIntoSections(
    parseChordProSections(chordproContent, songRow?.titulo || `Canci\u00f3n ${orderIndex + 1}`),
    rawSectionMarkers,
  );

  return {
    id: songRow?.id || `song-${orderIndex + 1}`,
    title: songRow?.titulo || `Canci\u00f3n ${orderIndex + 1}`,
    artist: songRow?.cantante || 'Redil Worship',
    key: songRow?.tonalidad || '-',
    originalKey: songRow?.tonalidad || '-',
    bpm: songRow?.bpm || 0,
    category: songRow?.categoria || '',
    voz: songRow?.voz || '',
    mp3: songRow?.mp3 || '',
    linkVoces: songRow?.voces || songRow?.link_voces || '',
    linkSecuencias: songRow?.link_secuencias || '',
    sectionMarkers: rawSectionMarkers,
    duration: estimateDuration(sections),
    sections,
  };
};

let eventData = null;
let playlistSongs = [];
let playlistDbId = null;
let rosterMembers = [];
let initialSongVoiceAssignments = {};

// ── Verificar si el usuario puede editar el setlist ──
let canEditSetlist = false;
if (user?.id) {
  const { data: perfilRoles } = await supabaseSSR
    .from('perfil_roles')
    .select('roles(codigo)')
    .eq('perfil_id', user.id);
  if (perfilRoles) {
    const rolCodes = perfilRoles.map(pr => pr.roles?.codigo).filter(Boolean);
    canEditSetlist = rolCodes.includes('lider_alabanza') || rolCodes.includes('talkback');
  }
}

const EVENT_SELECT_WITH_PREACHER = 'id, titulo, tema_predicacion, predicador, fecha_hora, hora_fin';
const EVENT_SELECT_BASE = 'id, titulo, tema_predicacion, fecha_hora, hora_fin';

const fetchEventBySlug = async (slugValue, includePredicador = true) => {
  const parsedSlug = parseEventDateSlug(slugValue);
  if (!parsedSlug) {
    return { data: null, error: null, multipleMatches: false };
  }

  const { data, error } = await supabaseSSR
    .from('eventos')
    .select(includePredicador ? EVENT_SELECT_WITH_PREACHER : EVENT_SELECT_BASE)
    .gte('fecha_hora', parsedSlug.startIso)
    .lt('fecha_hora', parsedSlug.endIso)
    .order('fecha_hora', { ascending: true })
    .limit(2);

  return {
    data: Array.isArray(data) ? data[0] || null : null,
    error,
    multipleMatches: Array.isArray(data) && data.length > 1,
  };
};

if (!routeIsDemo) {
  const fetchEventRow = async (includePredicador = true) => {
    if (routeIsUuid) {
      const { data, error } = await supabaseSSR
        .from('eventos')
        .select(includePredicador ? EVENT_SELECT_WITH_PREACHER : EVENT_SELECT_BASE)
        .eq('id', routeId)
        .maybeSingle();

      return { data, error, multipleMatches: false };
    }

    return fetchEventBySlug(routeId, includePredicador);
  };

  let { data: eventRow, error: eventError, multipleMatches } = await fetchEventRow(true);

  if (isPredicadorColumnMissingError(eventError)) {
    const fallbackEventResp = await fetchEventRow(false);
    if (!fallbackEventResp.error) {
      eventRow = withPredicadorFallbackRow(fallbackEventResp.data || null);
      eventError = null;
      multipleMatches = fallbackEventResp.multipleMatches;
      console.warn('Ensayo evento query: usando fallback sin columna predicador.');
    } else {
      eventRow = fallbackEventResp.data;
      eventError = fallbackEventResp.error;
      multipleMatches = fallbackEventResp.multipleMatches;
    }
  } else {
    eventRow = withPredicadorFallbackRow(eventRow || null);
  }

  if (eventError) {
    console.error('Ensayo evento query error:', eventError);
  }

  eventData = eventRow || null;

  if (multipleMatches) {
    console.warn('Ensayo slug query: multiple events found for slug, using first match.', routeId);
  }

  if (eventData?.id) {
    if (routeIsUuid) {
      const canonicalSlug = buildEventDateSlug(eventData.fecha_hora);

      if (canonicalSlug) {
        const canonicalLookup = await fetchEventBySlug(canonicalSlug, false);
        const canonicalEventId = String(canonicalLookup.data?.id || '').trim();

        if (!canonicalLookup.multipleMatches && canonicalEventId === String(eventData.id).trim()) {
          const redirectUrl = new URL(`/ensayo/${canonicalSlug}`, Astro.url);
          redirectUrl.search = Astro.url.search;
          return Astro.redirect(redirectUrl.toString());
        }
      }
    }

    const { data: rosterRows, error: rosterError } = await supabaseSSR
      .from('asignaciones')
      .select('perfil_id, roles(codigo, nombre), perfiles(id, nombre, email, avatar_url)')
      .eq('evento_id', eventData.id);

    if (rosterError) {
      console.error('Ensayo roster query error:', rosterError);
    } else if (Array.isArray(rosterRows)) {
      const rosterMap = new Map();

      rosterRows.forEach((row) => {
        const profileId = String(row?.perfil_id || row?.perfiles?.id || '').trim();
        if (!profileId) return;

        const roleCode = String(row?.roles?.codigo || '').trim();
        const roleName = String(row?.roles?.nombre || '').trim();
        const existing = rosterMap.get(profileId) || {
          id: profileId,
          name: String(row?.perfiles?.nombre || row?.perfiles?.email || 'Integrante').trim() || 'Integrante',
          email: String(row?.perfiles?.email || '').trim(),
          avatarUrl: String(row?.perfiles?.avatar_url || '').trim(),
          roleCodes: [],
          roleNames: [],
        };

        if (roleCode && !existing.roleCodes.includes(roleCode)) existing.roleCodes.push(roleCode);
        if (roleName && !existing.roleNames.includes(roleName)) existing.roleNames.push(roleName);
        rosterMap.set(profileId, existing);
      });

      const allMembers = Array.from(rosterMap.values()).map((member) => ({
        id: member.id,
        name: member.name,
        email: member.email,
        avatarUrl: member.avatarUrl,
        roleCodes: member.roleCodes,
        roleLabel: member.roleNames.join(', '),
      }));

      const voiceMembers = allMembers.filter((member) => (
        Array.isArray(member.roleCodes) &&
        member.roleCodes.some((code) => String(code || '').startsWith('voz_'))
      ));

      rosterMembers = (voiceMembers.length > 0 ? voiceMembers : allMembers)
        .sort((a, b) => a.name.localeCompare(b.name, 'es', { sensitivity: 'base' }));
    }

    const { data: playlistRow, error: playlistError } = await supabaseSSR
      .from('playlists')
      .select('id')
      .eq('evento_id', eventData.id)
      .maybeSingle();

    if (playlistError) {
      console.error('Ensayo playlist query error:', playlistError);
    }

    if (playlistRow?.id) {
      playlistDbId = playlistRow.id;
      const { data: voiceAssignmentsRow, error: voiceAssignmentsError } = await supabaseSSR
        .from('playlist_voice_assignments')
        .select('assignments')
        .eq('playlist_id', playlistRow.id)
        .maybeSingle();

      if (voiceAssignmentsError) {
        console.error('Ensayo playlist_voice_assignments query error:', voiceAssignmentsError);
      } else if (
        voiceAssignmentsRow?.assignments &&
        typeof voiceAssignmentsRow.assignments === 'object' &&
        !Array.isArray(voiceAssignmentsRow.assignments)
      ) {
        initialSongVoiceAssignments = voiceAssignmentsRow.assignments;
      }

      let playlistItems = [];
      let playlistItemsError = null;

      const playlistQueryWithMarkers = await supabaseSSR
        .from('playlist_canciones')
        .select('orden, cancion_id, canciones(id, titulo, cantante, tonalidad, bpm, categoria, voz, mp3, voces, link_voces, link_secuencias, chordpro, section_markers)')
        .eq('playlist_id', playlistRow.id)
        .order('orden', { ascending: true });

      if (playlistQueryWithMarkers.error) {
        const playlistQueryFallback = await supabaseSSR
          .from('playlist_canciones')
          .select('orden, cancion_id, canciones(id, titulo, cantante, tonalidad, bpm, categoria, voz, mp3, voces, link_voces, link_secuencias, chordpro)')
          .eq('playlist_id', playlistRow.id)
          .order('orden', { ascending: true });

        playlistItems = playlistQueryFallback.data || [];
        playlistItemsError = playlistQueryFallback.error;
      } else {
        playlistItems = playlistQueryWithMarkers.data || [];
      }

      if (playlistItemsError) {
        console.error('Ensayo playlist_canciones query error:', playlistItemsError);
      }

      const seenSongs = new Set();
      playlistSongs = await Promise.all((playlistItems || [])
        .filter((item) => {
          const songId = item?.cancion_id || item?.canciones?.id;
          if (!songId || seenSongs.has(songId)) return false;
          seenSongs.add(songId);
          return true;
        })
        .map((item, index) => buildSongFromRow(item.canciones, index)));
    }
  }
}

const rehearsalSongs =
  playlistSongs.length > 0
    ? playlistSongs
    : routeIsDemo
      ? [MOCK_CANCION_ENSAYO]
      : [
          createFallbackSong({
            songId: `fallback-${routeId}`,
            title: getEventThemeAndPreacher(eventData || {}, 'Setlist pendiente').theme || 'Setlist pendiente',
            message: eventData?.id
              ? 'Este servicio todav\u00eda no tiene canciones listas para el modo ensayo.'
              : 'No encontramos el evento solicitado o a\u00fan no tiene repertorio cargado.',
          }),
        ];

const initialSongId = Astro.url.searchParams.get('song') || null;
const monitorUrl = new URL(`/monitor/${routeId}`, Astro.url).toString();
const { theme: contextTheme, preacher: contextPreacher } = getEventThemeAndPreacher(eventData || {}, 'Modo Ensayo');
const contextTitle = contextTheme || 'Modo Ensayo';
const pageTitle = `${buildEventHeadline(eventData || {}, 'Modo Ensayo')} | Modo Ensayo`;
const pageDescription = eventData?.id
  ? `Vista de ensayo para ${buildEventHeadline(eventData || {}, contextTitle)}.`
  : 'Vista de ensayo enfocada para leer acordes y letras en vivo.';

const themeColors = await getBrandingConfig({ accessToken: tokenCookie.value });
const resolvedColorTokens = {
  brand: hexToRgbString(themeColors?.brand || '#14b8a6'),
  action: hexToRgbString(themeColors?.action || themeColors?.brand || '#14b8a6'),
  rehearsalAccent: hexToRgbString(themeColors?.info || '#3b82f6'),
  danger: hexToRgbString(themeColors?.danger || '#ef4444'),
  success: hexToRgbString(themeColors?.success || '#22c55e'),
  warning: hexToRgbString(themeColors?.warning || '#f59e0b'),
  info: hexToRgbString(themeColors?.info || '#3b82f6'),
  accent: hexToRgbString(themeColors?.accent || '#ec4899'),
  neutral: hexToRgbString(themeColors?.neutral || '#64748b'),
  overlay: hexToRgbString(themeColors?.overlay || '#0f172a'),
  rolDir: hexToRgbString(themeColors?.rolDir || '#8b5cf6'),
  rolLet: hexToRgbString(themeColors?.rolLet || '#f59e0b'),
  rolBan: hexToRgbString(themeColors?.rolBan || '#14b8a6'),
  rolVoc: hexToRgbString(themeColors?.rolVoc || '#a855f7'),
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={pageDescription} />
    <script is:inline>
      window.__REDIL_ENSAYO_LOADING_STARTED_AT__ = Date.now();
      document.documentElement.classList.add('ensayo-loading');
    </script>
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=20260403" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260403" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=20260403" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=20260403" />
    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg?v=20260403" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <title>{pageTitle}</title>
    <style
      is:global
      set:html={`
        :root {
          --bg-background: 248 250 252;
          --bg-surface: 255 255 255;
          --border-base: 226 232 240;
          --text-base: 15 23 42;
          --text-muted: 100 116 139;
          --color-brand: ${resolvedColorTokens.brand};
          --color-action: ${resolvedColorTokens.action};
          --ensayo-loading-accent: ${resolvedColorTokens.rehearsalAccent};
          --color-danger: ${resolvedColorTokens.danger};
          --color-success: ${resolvedColorTokens.success};
          --color-warning: ${resolvedColorTokens.warning};
          --color-info: ${resolvedColorTokens.info};
          --color-accent: ${resolvedColorTokens.accent};
          --color-neutral: ${resolvedColorTokens.neutral};
          --color-overlay: ${resolvedColorTokens.overlay};
          --color-rol-dir: ${resolvedColorTokens.rolDir};
          --color-rol-let: ${resolvedColorTokens.rolLet};
          --color-rol-ban: ${resolvedColorTokens.rolBan};
          --color-rol-voc: ${resolvedColorTokens.rolVoc};
        }

        .dark {
          --bg-background: 9 9 11;
          --bg-surface: 24 24 27;
          --border-base: 63 63 70;
          --text-base: 250 250 250;
          --text-muted: 161 161 170;
        }

        html,
        body {
          margin: 0;
          background: rgb(var(--bg-background));
        }

        #ensayo-page-loading {
          position: fixed;
          inset: 0;
          z-index: 90;
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 24px;
          background:
            radial-gradient(circle at top, rgba(var(--ensayo-loading-accent), 0.18), transparent 44%),
            linear-gradient(180deg, rgba(var(--bg-background), 0.96), rgba(var(--bg-background), 0.98));
          opacity: 0;
          visibility: hidden;
          pointer-events: none;
          transition: opacity 220ms ease, visibility 220ms ease;
          backdrop-filter: blur(12px);
        }

        .ensayo-loading #ensayo-page-loading {
          opacity: 1;
          visibility: visible;
          pointer-events: auto;
        }

        .ensayo-loading-card {
          width: min(100%, 420px);
          border-radius: 28px;
          border: 1px solid rgba(var(--border-base), 0.9);
          background:
            radial-gradient(circle at top, rgba(var(--ensayo-loading-accent), 0.16), transparent 48%),
            rgba(var(--bg-surface), 0.96);
          padding: 28px 24px;
          box-shadow: 0 28px 80px rgba(15, 23, 42, 0.14);
        }

        .ensayo-loading-chip {
          display: inline-flex;
          align-items: center;
          gap: 10px;
          padding: 10px 14px;
          border-radius: 999px;
          border: 1px solid rgba(var(--ensayo-loading-accent), 0.22);
          background: rgba(var(--ensayo-loading-accent), 0.1);
          color: rgba(var(--ensayo-loading-accent), 1);
          font-size: 12px;
          font-weight: 800;
          letter-spacing: 0.12em;
          text-transform: uppercase;
        }

        .ensayo-loading-chip img {
          width: 20px;
          height: 20px;
          border-radius: 6px;
        }

        .ensayo-loading-spinner {
          width: 44px;
          height: 44px;
          margin-top: 18px;
          border-radius: 999px;
          border: 3px solid rgba(var(--ensayo-loading-accent), 0.2);
          border-top-color: rgba(var(--ensayo-loading-accent), 1);
          animation: ensayo-loading-spin 0.9s linear infinite;
        }

        .ensayo-loading-title {
          margin: 18px 0 8px;
          font-size: clamp(1.45rem, 4vw, 2rem);
          line-height: 1.04;
          letter-spacing: -0.04em;
          font-weight: 900;
          color: rgb(var(--text-base));
        }

        .ensayo-loading-copy {
          margin: 0;
          color: rgb(var(--text-muted));
          line-height: 1.55;
        }

        .ensayo-loading-context {
          margin-top: 18px;
          padding-top: 14px;
          border-top: 1px solid rgba(var(--border-base), 0.85);
          color: rgb(var(--text-muted));
          font-size: 12px;
          line-height: 1.5;
        }

        .ensayo-loading-context strong {
          display: block;
          margin-bottom: 6px;
          color: rgb(var(--text-base));
          font-size: 11px;
          letter-spacing: 0.08em;
          text-transform: uppercase;
        }

        @keyframes ensayo-loading-spin {
          to {
            transform: rotate(360deg);
          }
        }
      `}
    />
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const isDark = storedTheme ? storedTheme === 'dark' : prefersDark;
          document.documentElement.classList.toggle('dark', isDark);
        } catch {
          // noop
        }
      })();
    </script>
  </head>
  <body class="min-h-screen overflow-hidden bg-white dark:bg-zinc-950">
    <div id="ensayo-page-loading" aria-hidden="true">
      <section class="ensayo-loading-card" aria-live="polite">
        <div class="ensayo-loading-chip">
          <img src="/icon-192.png" alt="" />
          <span>Modo Ensayo</span>
        </div>
        <div class="ensayo-loading-spinner" aria-hidden="true"></div>
        <h1 class="ensayo-loading-title">Abriendo ensayo...</h1>
        <p class="ensayo-loading-copy">Preparando setlist, acordes y recursos para esta vista.</p>
        <div class="ensayo-loading-context">
          <strong>Servicio</strong>
          {buildEventHeadline(eventData || {}, contextTitle)}
        </div>
      </section>
    </div>
    <EnsayoHub
      client:load
      playlist={rehearsalSongs}
      contextTitle={contextTitle}
      eventMeta={eventData ? { ...eventData, display_theme: contextTheme, display_preacher: contextPreacher } : null}
      initialSongId={initialSongId}
      monitorUrl={monitorUrl}
      playlistId={playlistDbId}
      canEdit={canEditSetlist}
      userId={user.id}
      rosterMembers={rosterMembers}
      initialSongVoiceAssignments={initialSongVoiceAssignments}
    />
    <ProPlayerGlobal />
    <VocesModalGlobal />
    <script is:inline>
      (() => {
        const finish = () => {
          const startedAt = window.__REDIL_ENSAYO_LOADING_STARTED_AT__ || Date.now();
          const elapsed = Date.now() - startedAt;
          const wait = Math.max(0, 180 - elapsed);

          window.setTimeout(() => {
            document.documentElement.classList.remove('ensayo-loading');
          }, wait);
        };

        if (document.readyState === 'complete' || document.readyState === 'interactive') {
          window.requestAnimationFrame(finish);
        } else {
          document.addEventListener('DOMContentLoaded', () => window.requestAnimationFrame(finish), { once: true });
        }

        window.addEventListener('pageshow', finish, { once: true });
      })();
    </script>
  </body>
</html>
