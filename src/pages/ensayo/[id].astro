    {
      name: 'Intro',
      note: 'Pad y Piano',
      lines: [
        '[G]Oh oh oh [D/F#]oh oh [Em]oh [C]',
        '[G]Oh oh oh [D/F#]oh oh [Em]oh [C]',
      ],
