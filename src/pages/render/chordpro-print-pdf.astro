---
import "../../styles/global.css";
import ChordProPdfDocument from "../../components/react/ChordProPdfDocument";
import { readChordProPdfPayloadToken } from "../../lib/chordproPdfPayloadStore";

export const prerender = false;

const token = Astro.url.searchParams.get("token")?.trim() || "";
const clientToken = Astro.url.searchParams.get("clientToken")?.trim() || "";
const autoPrint =
  Astro.url.searchParams.get("autoprint")?.trim() === "1" ||
  Astro.url.searchParams.get("autoprint")?.trim() === "true";
const payload = token ? await readChordProPdfPayloadToken(token) : null;

if (!payload && !clientToken) {
  Astro.response.status = 404;
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=816, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>{payload?.title ? `${payload.title} PDF` : "ChordPro PDF"}</title>
  </head>
  <body>
    {
      payload || clientToken ? (
        <ChordProPdfDocument
          client:load
          payload={payload}
          clientToken={clientToken}
          autoPrint={autoPrint}
        />
      ) : (
        <div class="pdf-error-state">
          <h1>No pudimos abrir esta hoja</h1>
          <p>Vuelve a intentarlo desde la ventana principal.</p>
        </div>
      )
    }
  </body>
</html>

<style is:global>
  @page {
    size: 8.5in 11in;
    margin: 0;
  }

  @font-face {
    font-family: "adineue";
    src: url("/fonts/redil/adineuePRO-Light.woff2") format("woff2");
    font-weight: 300;
    font-style: normal;
    font-display: block;
  }

  @font-face {
    font-family: "adineue";
    src: url("/fonts/redil/adineuePRO-Regular.woff2") format("woff2");
    font-weight: 400;
    font-style: normal;
    font-display: block;
  }

  @font-face {
    font-family: "adineue";
    src: url("/fonts/redil/adineuePRO-Bold.woff2") format("woff2");
    font-weight: 700;
    font-style: normal;
    font-display: block;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 8.5in;
    min-width: 8.5in;
    min-height: 11in;
    background: #ffffff;
    color: #000000;
    font-family: "adineue", "Segoe UI", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: geometricPrecision;
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
    overflow: hidden;
  }

  body {
    display: block;
  }

  .chordpro-print-action {
    top: max(1rem, env(safe-area-inset-top));
    right: max(1rem, env(safe-area-inset-right));
  }

  #chordpro-pdf-root,
  #chordpro-pdf-sheet {
    width: 8.5in;
    min-width: 8.5in;
    max-width: 8.5in;
  }

  #chordpro-pdf-sheet {
    height: 11in;
    min-height: 11in;
    max-height: 11in;
  }

  @media print {
    .chordpro-print-action {
      display: none !important;
    }

    html,
    body,
    #chordpro-pdf-root,
    #chordpro-pdf-sheet {
      width: 8.5in !important;
      min-width: 8.5in !important;
      max-width: 8.5in !important;
    }

    body,
    #chordpro-pdf-root,
    #chordpro-pdf-sheet {
      height: 11in !important;
      min-height: 11in !important;
      max-height: 11in !important;
      overflow: hidden !important;
    }
  }

  .pdf-error-state {
    min-height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-align: center;
    font-family: var(--font-ui, "Segoe UI", Arial, sans-serif);
  }
</style>
