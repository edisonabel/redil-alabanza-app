 function sortSongsSelectedFirst(songCards: Iterable<HTMLElement>) {
  if (isSelectionMode && !hasActiveSongFilters()) {
   return [...songCards].sort((a, b) => {
    const aId = String(a.getAttribute('data-id') || '');
    const bId = String(b.getAttribute('data-id') || '');
    const aSeleccionada = selectedSongs.includes(aId);
    const bSeleccionada = selectedSongs.includes(bId);
    if (aSeleccionada && !bSeleccionada) return -1;
    if (!aSeleccionada && bSeleccionada) return 1;
    const aIndex = Number(a.dataset.originalIndex || '0');
    const bIndex = Number(b.dataset.originalIndex || '0');
    return aIndex - bIndex;
   });
  }

  if (isSelectionMode) {
   return sortSongsByOriginalIndex(songCards);
  }

  // Modo normal: setlist songs go to top
  if (setlist.length > 0) {
   return [...songCards].sort((a, b) => {
    const aCancion = a.querySelector('.btn-add-setlist')?.getAttribute('data-cancion') || '';
    const bCancion = b.querySelector('.btn-add-setlist')?.getAttribute('data-cancion') || '';
    const aInSetlist = setlist.includes(aCancion);
    const bInSetlist = setlist.includes(bCancion);
    if (aInSetlist && !bInSetlist) return -1;
    if (!aInSetlist && bInSetlist) return 1;
    const aIndex = Number(a.dataset.originalIndex || '0');
    const bIndex = Number(b.dataset.originalIndex || '0');
    return aIndex - bIndex;
   });
  }

  return [...songCards];
 }

function applySongOrder(songCards: Iterable<HTMLElement>) {
  if (!gridCanciones) return;
  for (const card of songCards) gridCanciones.appendChild(card);
 }

