 const sentinel = document.getElementById('scroll-sentinel');
 const todasLasCanciones = Array.from(cards);
 let cancionesFiltradas = [...todasLasCanciones];
 let indiceActual = 0;
 const limite = 15;
 let isLoading = false;
 
 function cargarMasCanciones() {
 if (isLoading) return;
 isLoading = true;

 const fragmento = cancionesFiltradas.slice(indiceActual, indiceActual + limite);
 if (fragmento.length === 0) {
 if (sentinel) sentinel.style.display = 'none';
 isLoading = false;
 return;
 }
 
 fragmento.forEach(card => {
 card.classList.remove('cancion-oculta');
 card.style.display = ''; // Resetear el display modificado por el filtrado
 });
 indiceActual += limite;
 
 if (sentinel) {
 sentinel.style.display = (indiceActual >= cancionesFiltradas.length) ? 'none' : 'block';
 }

 requestAnimationFrame(() => {
 isLoading = false;
 if (sentinel && sentinel.style.display !== 'none') {
 const rect = sentinel.getBoundingClientRect();
 if (rect.top <= window.innerHeight + 150) {
 cargarMasCanciones();
 }
 }
 });
 }
 
 const observer = new IntersectionObserver((entries) => {
 if (entries[0].isIntersecting) cargarMasCanciones();
 }, { root: null, rootMargin: '150px', threshold: 0 });
 
 if (sentinel) observer.observe(sentinel);

const normalizeStr = (str) => str ? str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase() : '';

const matchVoz = (vozValue, vozFilter) => {
 const v = normalizeStr(vozValue);
 const f = normalizeStr(vozFilter);
 if (f === 'todas') return true;

 if (f === 'hombre y mujer') {
 const hasHombre = ['hombre', 'masculino', 'male', 'tenor'].some((alias) => v.includes(alias));
 const hasMujer = ['mujer', 'femenino', 'female', 'soprano', 'alto', 'contralto'].some((alias) => v.includes(alias));
 const hasDuetAlias = ['dueto', 'duo', 'mixta', 'mixto', 'mixed'].some((alias) => v.includes(alias));
 return (hasHombre && hasMujer) || hasDuetAlias;
 }

 if (f === 'hombre') {
 return ['hombre', 'masculino', 'male', 'tenor'].some((alias) => v.includes(alias));
 }

 if (f === 'mujer') {
 return ['mujer', 'femenino', 'female', 'soprano', 'alto', 'contralto'].some((alias) => v.includes(alias));
 }

 return v.includes(f);
};

 const formatTime = (seconds: number) => {
   if (!Number.isFinite(seconds) || seconds < 0) return '00:00';
   const total = Math.floor(seconds);
   const min = Math.floor(total / 60);
   const sec = total % 60;
   return `${String(min).padStart(2, '0')}:${String(sec).padStart(2, '0')}`;
 };

 const toPlayableMp3Url = (rawUrl: string) => {
   if (!rawUrl) return '';
   const normalized = rawUrl.trim();
   const isDrive =
     normalized.includes('drive.google.com') ||
     normalized.includes('docs.google.com') ||
     normalized.includes('drive.usercontent.google.com');

   if (!isDrive) return normalized;
   return `/api/mp3-proxy?src=${encodeURIComponent(normalized)}`;
 };

 let mp3TotalDuration = 0;
 let loopStartSec = 0;
 let loopEndSec = 0;
 let isSeekingAudio = false;
 let draggingLoopHandle: 'A' | 'B' | null = null;
 let mp3WaveRaf = 0;
 let mp3WaveCtx: AudioContext | null = null;
 let mp3WaveSource: MediaElementAudioSourceNode | null = null;
 let mp3WaveAnalyser: AnalyserNode | null = null;
 let mp3WaveData: Uint8Array | null = null;

 const clamp = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));

 const setLoopUiVisibility = () => {
   const active = !!chkLoopRange?.checked;
   mp3LoopBracket?.classList.toggle('hidden', !active);
 };

 const secondsFromPointer = (clientX: number) => {
   const rect = mp3TimelineWrap.getBoundingClientRect();
   if (!rect.width || !mp3TotalDuration) return 0;
   const ratio = clamp((clientX - rect.left) / rect.width, 0, 1);
   return ratio * mp3TotalDuration;
 };

 const syncLoopUi = () => {
   const safeDuration = mp3TotalDuration || 1;
   const startPct = clamp((loopStartSec / safeDuration) * 100, 0, 100);
   const endPct = clamp((loopEndSec / safeDuration) * 100, 0, 100);

   mp3LoopInfo.textContent = `[A] ${formatTime(loopStartSec)} - [B] ${formatTime(loopEndSec)}`;

   if (mp3LoopRangeFill) {
     mp3LoopRangeFill.style.left = `${startPct}%`;
     mp3LoopRangeFill.style.width = `${Math.max(0, endPct - startPct)}%`;
   }
   if (mp3LoopHandleA) mp3LoopHandleA.style.left = `${startPct}%`;
   if (mp3LoopHandleB) mp3LoopHandleB.style.left = `${endPct}%`;
  };

 const stopWaveform = () => {
   if (mp3WaveRaf) {
     cancelAnimationFrame(mp3WaveRaf);
     mp3WaveRaf = 0;
   }
 };

 const setupWaveform = async () => {
   if (mp3WaveAnalyser && mp3WaveData) return;
   const Ctx = window.AudioContext || (window as any).webkitAudioContext;
   if (!Ctx) return;

   mp3WaveCtx = mp3WaveCtx || new Ctx();
   if (!mp3WaveSource) {
     mp3WaveSource = mp3WaveCtx.createMediaElementSource(mp3Audio);
   }
   mp3WaveAnalyser = mp3WaveAnalyser || mp3WaveCtx.createAnalyser();
   mp3WaveAnalyser.fftSize = 1024;
   mp3WaveData = new Uint8Array(mp3WaveAnalyser.fftSize);

   try { mp3WaveSource.disconnect(); } catch {}
   try { mp3WaveAnalyser.disconnect(); } catch {}
   mp3WaveSource.connect(mp3WaveAnalyser);
   mp3WaveAnalyser.connect(mp3WaveCtx.destination);
 };

 const drawWaveformFrame = () => {
   if (!mp3Waveform || !mp3WaveAnalyser || !mp3WaveData) return;
   const rect = mp3Waveform.getBoundingClientRect();
   if (!rect.width || !rect.height) return;

   const dpr = window.devicePixelRatio || 1;
   const targetW = Math.floor(rect.width * dpr);
   const targetH = Math.floor(rect.height * dpr);
   if (mp3Waveform.width !== targetW || mp3Waveform.height !== targetH) {
     mp3Waveform.width = targetW;
     mp3Waveform.height = targetH;
   }

   const ctx = mp3Waveform.getContext('2d');
   if (!ctx) return;
   ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
   ctx.clearRect(0, 0, rect.width, rect.height);

   mp3WaveAnalyser.getByteTimeDomainData(mp3WaveData);
   const midY = rect.height / 2;
   const amp = rect.height * 0.34;
   const step = rect.width / (mp3WaveData.length - 1);

   ctx.lineWidth = 1.25;
   ctx.strokeStyle = mp3Audio.paused
     ? 'rgba(96, 165, 250, 0.35)'
     : 'rgba(110, 231, 183, 0.72)';
   ctx.beginPath();

   for (let i = 0; i < mp3WaveData.length; i += 1) {
     const x = i * step;
     const y = midY + ((mp3WaveData[i] - 128) / 128) * amp;
     if (i === 0) ctx.moveTo(x, y);
     else ctx.lineTo(x, y);
   }
   ctx.stroke();
 };

 const runWaveform = () => {
   stopWaveform();
   const tick = () => {
     drawWaveformFrame();
     if (!mp3Audio.paused && !mp3Audio.ended) {
       mp3WaveRaf = requestAnimationFrame(tick);
     } else {
       mp3WaveRaf = 0;
     }
   };
   tick();
 };

 const syncPlaybackWaveform = () => {
   if (!mp3WaveAnalyser) return;
   drawWaveformFrame();
 };

 const resetLoopRange = () => {
   loopStartSec = 0;
   loopEndSec = mp3TotalDuration;
   syncLoopUi();
   syncPlaybackWaveform();
  };

 const setPlayButtonState = (isPlaying: boolean) => {
   if (!btnMp3PlayPause || !mp3PlayIcon) return;
   mp3PlayerModal.classList.toggle('mp3-playing', isPlaying);
   if (isPlaying) {
     mp3PlayIcon.innerHTML = '<path d="M8 5h3v14H8zM13 5h3v14h-3z"></path>';
     btnMp3PlayPause.setAttribute('aria-label', 'Pausar');
     btnMp3PlayPause.title = 'Pausar';
   } else {
     mp3PlayIcon.innerHTML = '<path d="M8 5v14l11-7z"></path>';
     btnMp3PlayPause.setAttribute('aria-label', 'Reproducir');
     btnMp3PlayPause.title = 'Reproducir';
   }
   if (isPlaying) runWaveform();
   else drawWaveformFrame();
 };

 const closeMp3Modal = () => {
   mp3Audio.pause();
   mp3Audio.removeAttribute('src');
   mp3Audio.load();
   mp3PlayerModal.classList.add('hidden');
   setPlayButtonState(false);
   stopWaveform();
   };

 const openMp3Modal = (title: string, rawUrl: string, artist: string) => {
   const playableUrl = toPlayableMp3Url(rawUrl);
   if (!playableUrl) return;

   mp3Title.textContent = title || 'Canción';
   mp3Artist.textContent = artist?.trim() || 'Artista no especificado';
   mp3Status.textContent = 'Cargando audio...';
   setPlayButtonState(false);
   mp3Seek.value = '0';
   mp3CurrentTime.textContent = '00:00';
   mp3Duration.textContent = '00:00';
   chkLoopRange.checked = false;
   setLoopUiVisibility();
   syncPlaybackWaveform();
   mp3PlayerModal.classList.remove('hidden');

   mp3Audio.src = playableUrl;
   mp3Audio.load();
 };

 mp3Audio.addEventListener('loadedmetadata', () => {
   mp3TotalDuration = Number.isFinite(mp3Audio.duration) ? mp3Audio.duration : 0;
   mp3Seek.min = '0';
   mp3Seek.max = String(mp3TotalDuration || 1);
   mp3Duration.textContent = formatTime(mp3TotalDuration);
   resetLoopRange();
   mp3Status.textContent = 'Activa el loop y arrastra los brackets A/B sobre la barra.';
   void setupWaveform().then(() => drawWaveformFrame());
  });

  mp3Audio.addEventListener('timeupdate', () => {
    if (!isSeekingAudio) mp3Seek.value = String(mp3Audio.currentTime || 0);
    mp3CurrentTime.textContent = formatTime(mp3Audio.currentTime || 0);
   syncPlaybackWaveform();

    if (chkLoopRange.checked && loopEndSec > loopStartSec + 0.15 && mp3Audio.currentTime >= loopEndSec) {
      mp3Audio.currentTime = loopStartSec;
     syncPlaybackWaveform();
    }
  });

 mp3Audio.addEventListener('play', () => { setPlayButtonState(true); });
 mp3Audio.addEventListener('pause', () => { setPlayButtonState(false); });
 mp3Audio.addEventListener('ended', () => { setPlayButtonState(false); });
 mp3Audio.addEventListener('error', () => {
   mp3Status.textContent = 'No se pudo cargar el MP3. Verifica el enlace y permisos en Drive.';
 });

  btnMp3PlayPause?.addEventListener('click', async () => {
    try {
      if (mp3Audio.paused) {
        await setupWaveform();
        if (mp3WaveCtx?.state === 'suspended') await mp3WaveCtx.resume();
        await mp3Audio.play();
      } else {
        mp3Audio.pause();
      }
   } catch (error) {
     if (error instanceof DOMException && error.name === 'NotAllowedError') {
       mp3Status.textContent = 'El navegador bloqueó la reproducción. Toca Reproducir nuevamente.';
       return;
     }
     if (error instanceof DOMException && error.name === 'NotSupportedError') {
       mp3Status.textContent = 'El enlace no se pudo reproducir. Revisa el formato o permisos del MP3.';
       return;
     }
     mp3Status.textContent = 'No se pudo iniciar el audio. Inténtalo de nuevo.';
   }
 });

 mp3Seek?.addEventListener('input', () => {
   isSeekingAudio = true;
   mp3CurrentTime.textContent = formatTime(Number(mp3Seek.value || 0));
 });
 mp3Seek?.addEventListener('change', () => {
   mp3Audio.currentTime = Number(mp3Seek.value || 0);
   syncPlaybackWaveform();
   isSeekingAudio = false;
  });

 chkLoopRange?.addEventListener('change', () => {
   setLoopUiVisibility();
   syncLoopUi();
 });

 btnClearLoopRange?.addEventListener('click', () => {
   resetLoopRange();
  });

 const updateLoopHandlePosition = (which: 'A' | 'B', clientX: number) => {
   if (!mp3TotalDuration) return;
   const nextSec = secondsFromPointer(clientX);

   if (which === 'A') {
     loopStartSec = clamp(nextSec, 0, Math.max(0, loopEndSec - 0.1));
   } else {
     loopEndSec = clamp(nextSec, Math.min(mp3TotalDuration, loopStartSec + 0.1), mp3TotalDuration);
   }
   syncLoopUi();
 };

 const onLoopPointerMove = (event: PointerEvent) => {
   if (!draggingLoopHandle || !chkLoopRange.checked) return;
   event.preventDefault();
   updateLoopHandlePosition(draggingLoopHandle, event.clientX);
 };

 const onLoopPointerUp = () => {
   draggingLoopHandle = null;
   window.removeEventListener('pointermove', onLoopPointerMove);
   window.removeEventListener('pointerup', onLoopPointerUp);
 };

 const startLoopDrag = (which: 'A' | 'B', event: PointerEvent) => {
   if (!chkLoopRange.checked) return;
   draggingLoopHandle = which;
   updateLoopHandlePosition(which, event.clientX);
   window.addEventListener('pointermove', onLoopPointerMove, { passive: false });
   window.addEventListener('pointerup', onLoopPointerUp);
 };

 mp3LoopHandleA?.addEventListener('pointerdown', (event) => startLoopDrag('A', event));
 mp3LoopHandleB?.addEventListener('pointerdown', (event) => startLoopDrag('B', event));

 btnMp3Close?.addEventListener('click', closeMp3Modal);
 mp3PlayerBackdrop?.addEventListener('click', closeMp3Modal);
 document.addEventListener('keydown', (event) => {
   if (event.key === 'Escape' && !mp3PlayerModal.classList.contains('hidden')) {
     closeMp3Modal();
   }
 });

const matchCategoria = (categoriaValue, categoriaFilter) => {
 const c = normalizeStr(categoriaValue);
 const f = normalizeStr(categoriaFilter);
 if (f === 'todas') return true;

 if (f.startsWith('rapid')) return c.includes('rapid');
 if (f.startsWith('lent')) return c.includes('lent');
 if (f.startsWith('trans')) return c.includes('trans');

 return c.includes(f);
};

 function debounce(func, wait) {
 let timeout;
 return function(...args) {
 clearTimeout(timeout);
 timeout = setTimeout(() => func(...args), wait);
 };
 }

function filterCards() {
 const searchTerm = normalizeStr(searchInput.value).trim();
 const vozTerm = normalizeStr(filterVoz.value);
 const categoriaTerm = normalizeStr(filterCategoria.value);
 const temaTerm = normalizeStr(filterTema.value);

 todasLasCanciones.forEach(card => card.classList.add('cancion-oculta'));
 indiceActual = 0;

 cancionesFiltradas = todasLasCanciones.filter(card => {
 const titulo = normalizeStr(card.getAttribute('data-titulo') || '');
 const artista = normalizeStr(card.getAttribute('data-artista') || '');
 const voz = normalizeStr(card.getAttribute('data-voz') || '');
 const categoria = normalizeStr(card.getAttribute('data-categoria') || '');
 const tema = normalizeStr(card.getAttribute('data-tema') || '');

 const matchesSearch = titulo.includes(searchTerm) || artista.includes(searchTerm);
 const matchesVoz = matchVoz(voz, vozTerm);
 const matchesCategoria = matchCategoria(categoria, categoriaTerm);
 const matchesTema = temaTerm === 'todas' || tema.includes(temaTerm);

 return matchesSearch && matchesVoz && matchesCategoria && matchesTema;
 });

 todasLasCanciones.forEach(card => card.style.display = 'none');
 cargarMasCanciones();
 }

 const debouncedFilterCards = debounce(filterCards, 300);

 if(searchInput) searchInput.addEventListener('input', debouncedFilterCards);
 if(filterVoz) filterVoz.addEventListener('change', debouncedFilterCards);
 if(filterCategoria) filterCategoria.addEventListener('change', debouncedFilterCards);
 if(filterTema) filterTema.addEventListener('change', debouncedFilterCards);


 // ----- Metronomo Interactivo Logic -----
 let metronomoActivoDot: HTMLElement | null = null;
 let metronomoInterval: any = null;
 
 const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
 const audioCtx = new AudioContextClass();
 
 function playClick() {
 if (!audioCtx) return;
 if (audioCtx.state === 'suspended') audioCtx.resume();
 
 const osc = audioCtx.createOscillator();
 const gainNode = audioCtx.createGain();
 
 osc.connect(gainNode);
 gainNode.connect(audioCtx.destination);
 
 osc.type = 'sine';
 osc.frequency.setValueAtTime(800, audioCtx.currentTime);
 
 gainNode.gain.setValueAtTime(1, audioCtx.currentTime);
 gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
 
 osc.start(audioCtx.currentTime);
 osc.stop(audioCtx.currentTime + 0.1);
 }
 
 document.addEventListener('click', (e) => {
 const badge = (e.target as Element).closest('.badge-bpm');
 if (badge) {
 const bpmStr = badge.getAttribute('data-bpm');
 if (!bpmStr) return;
 
 const bpmVal = parseInt(bpmStr.replace(/[^0-9]/g, ''), 10);
 if (!bpmVal || bpmVal <= 0) return;
 
 const dot = badge.querySelector('.metronomo-dot') as HTMLElement;
 if (!dot) return;
 
 if (metronomoActivoDot && metronomoActivoDot !== dot) {
 metronomoActivoDot.classList.remove('beat-active');
 metronomoActivoDot.style.removeProperty('--bpm-duration');
 if (metronomoInterval) clearInterval(metronomoInterval);
 }
 
 if (dot.classList.contains('beat-active')) {
 dot.classList.remove('beat-active');
 dot.style.removeProperty('--bpm-duration');
 if (metronomoInterval) clearInterval(metronomoInterval);
 metronomoActivoDot = null;
 return;
 }
 
 const duracionSegundos = 60 / bpmVal;
 dot.style.setProperty('--bpm-duration', `${duracionSegundos}s`);
 dot.classList.add('beat-active');
 metronomoActivoDot = dot;
 
 playClick();
 metronomoInterval = setInterval(playClick, duracionSegundos * 1000);
 }
 });

 // ----- Reference Tone (Pitch Pipe) Logic -----
 const frecuencias: { [key: string]: number } = {
 'C': 261.63, 'C#': 277.18, 'D': 293.66, 'Eb': 311.13, 'E': 329.63, 
 'F': 349.23, 'F#': 369.99, 'G': 392.00, 'G#': 415.30, 'A': 440.00, 
 'Bb': 466.16, 'B': 493.88
 };
 
 document.addEventListener('click', (e) => {
 const badgeTono = (e.target as Element).closest('.badge-tono');
 if (badgeTono) {
 let tono = badgeTono.getAttribute('data-tono');
 if (!tono || tono.trim() === '-' || tono.trim() === '') return;
 
 tono = tono.replace(/m/g, '').trim();
 const frecuencia = frecuencias[tono];
 
 if (frecuencia && audioCtx) {
 if (audioCtx.state === 'suspended') audioCtx.resume();
 
 const oscPrincipal = audioCtx.createOscillator();
 oscPrincipal.type = 'triangle';
 oscPrincipal.frequency.value = frecuencia;
 
 const oscBrillo = audioCtx.createOscillator();
 oscBrillo.type = 'sine';
 oscBrillo.frequency.value = frecuencia * 2; 
 
 const gainNode = audioCtx.createGain();
 
 oscPrincipal.connect(gainNode);
 oscBrillo.connect(gainNode);
 gainNode.connect(audioCtx.destination);
 
 const now = audioCtx.currentTime;
 gainNode.gain.setValueAtTime(0, now);
 gainNode.gain.linearRampToValueAtTime(0.8, now + 0.02);
 gainNode.gain.exponentialRampToValueAtTime(0.1, now + 0.5);
 gainNode.gain.exponentialRampToValueAtTime(0.001, now + 3);
 
 oscPrincipal.start(now);
 oscBrillo.start(now);
 oscPrincipal.stop(now + 3);
 oscBrillo.stop(now + 3);
 }
 }
 });

 // Helper para Playlist modular
 function updatePlaylistCount() {
 if (playlistCountEl) playlistCountEl.textContent = selectedSongs.length.toString();
 }
 });
</script>

