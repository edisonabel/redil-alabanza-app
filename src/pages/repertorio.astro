  <BuscadorPredictivo idInput="searchInput" placeholder="Buscar canci&oacute;n o artista..." />
  </div>
 </div>
 </div>
 
 <div class="col-span-1">
 <label for="filterVoz" class="block text-xs md:text-sm font-medium text-content mb-1 md:mb-2">Voz</label>
 <select id="filterVoz" 
 class="w-full bg-surface border border-border text-content rounded-xl px-2 md:px-3 py-2 md:py-2.5 text-sm md:text-base focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors appearance-none">
