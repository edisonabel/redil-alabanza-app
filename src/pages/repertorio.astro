---
import Layout from '../layouts/Layout.astro';
import CardCancion from '../components/CardCancion.astro';
import BuscadorPredictivo from '../components/BuscadorPredictivo.astro';
import { supabase } from '../lib/supabase';

const SHEET_CSV_URL = 'https://docs.google.com/spreadsheets/d/1Fk4DgxWzizonrG_xB_DZN8wSqLSZY9myj7ROM7JLu-c/export?format=csv';

const normalizeToken = (value: string) =>
  (value || '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .trim();

const parseCsv = (input: string): string[][] => {
  const rows: string[][] = [];
  let row: string[] = [];
  let field = '';
  let inQuotes = false;

  for (let i = 0; i < input.length; i += 1) {
    const char = input[i];
    const next = input[i + 1];

    if (char === '"') {
      if (inQuotes && next === '"') {
        field += '"';
        i += 1;
      } else {
        inQuotes = !inQuotes;
      }
      continue;
    }

    if (!inQuotes && char === ',') {
      row.push(field);
      field = '';
      continue;
    }

    if (!inQuotes && (char === '\n' || char === '\r')) {
      if (char === '\r' && next === '\n') i += 1;
      row.push(field);
      rows.push(row);
      row = [];
      field = '';
      continue;
    }

    field += char;
  }

  row.push(field);
  rows.push(row);
  return rows;
};

const loadMp3MapFromSheet = async () => {
  const mp3BySong = new Map<string, string>();

  try {
    const response = await fetch(SHEET_CSV_URL, { headers: { Accept: 'text/csv' } });
    if (!response.ok) return mp3BySong;
    const csvText = await response.text();
    const rows = parseCsv(csvText);
    if (!rows.length) return mp3BySong;

    let headerRowIndex = -1;
    let songCol = -1;
    let mp3Col = -1;

    for (let i = 0; i < rows.length; i += 1) {
      const row = rows[i].map((cell) => normalizeToken(cell));
      const songIndex = row.findIndex((cell) => cell === 'cancion' || cell.includes('cancion'));
      const mp3Index = row.findIndex((cell) => cell === 'mp3');
      if (songIndex !== -1 && mp3Index !== -1) {
        headerRowIndex = i;
        songCol = songIndex;
        mp3Col = mp3Index;
        break;
      }
    }

    if (headerRowIndex === -1 || songCol === -1 || mp3Col === -1) return mp3BySong;

    for (let i = headerRowIndex + 1; i < rows.length; i += 1) {
      const row = rows[i];
      const songTitle = (row[songCol] || '').trim();
      const mp3Value = (row[mp3Col] || '').trim();
      if (!songTitle || !mp3Value) continue;

      const mp3Norm = normalizeToken(mp3Value);
      if (mp3Norm === 'no esta' || mp3Norm === 'no está') continue;
      mp3BySong.set(normalizeToken(songTitle), mp3Value);
    }
  } catch (error) {
    console.error('No se pudo leer MP3 desde Google Sheet:', error);
  }

  return mp3BySong;
};

let canciones: any[] = [];
const mp3BySong = await loadMp3MapFromSheet();
try {
  const { data, error } = await supabase
    .from('canciones')
    .select('*')
    .order('titulo');
    
  if (error) {
    console.error("Error fetching from Supabase:", error);
  } else if (data) {
    // Solo en este caso mostramos canciones que no estan archivadas.
    canciones = data
      .filter(c => c.estado !== 'Archivada')
      .map((cancion: any) => {
        const dbMp3 = (cancion.mp3 || cancion.MP3 || '').trim();
        if (dbMp3) return cancion;

        const sheetMp3 = mp3BySong.get(normalizeToken(cancion.titulo || '')) || '';
        return sheetMp3 ? { ...cancion, mp3: sheetMp3 } : cancion;
      });
  }
} catch (e) {
  console.error("Fetch failed", e);
}

const temasUnicos = [...new Set(canciones.map((c: any) => c.tema).filter(Boolean))].sort() as string[];
---

<Layout>
