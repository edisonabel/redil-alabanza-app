 todasLasCanciones.forEach((card, index) => {
  card.dataset.originalIndex = String(index);
 });
 let cancionesFiltradas = sortSongsSelectedFirst([...todasLasCanciones]);
 applySongOrder(cancionesFiltradas);
 const limite = 15;
 let indiceActual = Math.min(limite, cancionesFiltradas.length);
 let isLoading = false;

 const initialVisibleCards = new Set(cancionesFiltradas.slice(0, indiceActual));
 todasLasCanciones.forEach((card) => {
  const isInitiallyVisible = initialVisibleCards.has(card);
  card.classList.toggle('cancion-oculta', !isInitiallyVisible);
  card.classList.remove('anim-fade-in-up', 'anim-stagger');
  card.style.removeProperty('--delay');
  card.style.display = isInitiallyVisible ? '' : 'none';
 });
 
 function cargarMasCanciones() {
 if (isLoading) return;
 isLoading = true;

 const fragmento = cancionesFiltradas.slice(indiceActual, indiceActual + limite);
 if (fragmento.length === 0) {
 if (sentinel) sentinel.style.display = 'none';
 isLoading = false;
 return;
 }
 
 fragmento.forEach((card) => {
  card.classList.remove('cancion-oculta');
  card.style.display = '';
  card.classList.remove('anim-fade-in-up', 'anim-stagger');
  card.style.removeProperty('--delay');
 });
 requestAnimationFrame(bindResourceActionHints);
 if (isSelectionMode || document.body.classList.contains('repertorio-compact-list-mode')) {
  scheduleSelectionMarqueeMeasurement();
 }
 indiceActual += limite;
 
 if (sentinel) {
 sentinel.style.display = (indiceActual >= cancionesFiltradas.length) ? 'none' : 'block';
 }

 requestAnimationFrame(() => {
 isLoading = false;
 if (sentinel && sentinel.style.display !== 'none') {
 const rect = sentinel.getBoundingClientRect();
 if (rect.top <= window.innerHeight + 150) {
 cargarMasCanciones();
 }
 }
 });
 }
 
 observer = new IntersectionObserver((entries) => {
 if (entries[0].isIntersecting) cargarMasCanciones();
 }, { root: null, rootMargin: '150px', threshold: 0 });
 
 if (sentinel) observer.observe(sentinel);

const normalizeStr = (str: string) => str ? str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase() : '';

const matchVoz = (vozValue: string, vozFilter: string) => {
 const v = normalizeStr(vozValue);
 const f = normalizeStr(vozFilter);
 if (f === 'todas') return true;

 if (f === 'hombre y mujer') {
 const hasHombre = ['hombre', 'masculino', 'male', 'tenor'].some((alias) => v.includes(alias));
 const hasMujer = ['mujer', 'femenino', 'female', 'soprano', 'alto', 'contralto'].some((alias) => v.includes(alias));
 const hasDuetAlias = ['dueto', 'duo', 'mixta', 'mixto', 'mixed'].some((alias) => v.includes(alias));
 return (hasHombre && hasMujer) || hasDuetAlias;
 }

 if (f === 'hombre') {
 return ['hombre', 'masculino', 'male', 'tenor'].some((alias) => v.includes(alias));
 }

 if (f === 'mujer') {
 return ['mujer', 'femenino', 'female', 'soprano', 'alto', 'contralto'].some((alias) => v.includes(alias));
 }

 return v.includes(f);
};

const matchCategoria = (categoriaValue: string, categoriaFilter: string) => {
 const c = normalizeStr(categoriaValue);
 const f = normalizeStr(categoriaFilter);
 if (f === 'todas') return true;

 if (f.startsWith('rapid')) return c.includes('rapid');
 if (f.startsWith('lent')) return c.includes('lent');
 if (f.startsWith('trans')) return c.includes('trans');

 return c.includes(f);
};

 function debounce<T extends (...args: any[]) => void>(func: T, wait: number) {
 let timeout: ReturnType<typeof setTimeout> | undefined;
 return function(...args: Parameters<T>) {
 clearTimeout(timeout);
 timeout = setTimeout(() => func(...args), wait);
 };
 }

function filterCards() {
 const searchTerm = normalizeStr(searchInput.value).trim();
 const vozTerm = normalizeStr(filterVoz.value);
 const categoriaTerm = normalizeStr(filterCategoria.value);
 const temaTerm = normalizeStr(filterTema.value);
 const estadoTerm = normalizeStr(filterEstado.value);
 syncFilterMenuState();

 todasLasCanciones.forEach((card) => {
  card.classList.add('cancion-oculta');
  card.classList.remove('anim-fade-in-up', 'anim-stagger');
  card.style.removeProperty('--delay');
  card.style.display = 'none';
 });
 indiceActual = 0;
 isLoading = false;

 cancionesFiltradas = todasLasCanciones.filter(card => {
 const titulo = normalizeStr(card.getAttribute('data-titulo') || '');
 const artista = normalizeStr(card.getAttribute('data-artista') || '');
 const voz = normalizeStr(card.getAttribute('data-voz') || '');
 const categoria = normalizeStr(card.getAttribute('data-categoria') || '');
 const tema = normalizeStr(card.getAttribute('data-tema') || '');
 const estado = normalizeStr(card.getAttribute('data-estado') || '');

 const matchesSearch = titulo.includes(searchTerm) || artista.includes(searchTerm);
 const matchesVoz = matchVoz(voz, vozTerm);
 const matchesCategoria = matchCategoria(categoria, categoriaTerm);
 const matchesTema = temaTerm === 'todas' || tema.includes(temaTerm);
 const matchesEstado = estadoTerm === 'todas' || estado.includes(estadoTerm);

 return matchesSearch && matchesVoz && matchesCategoria && matchesTema && matchesEstado;
 });

 cancionesFiltradas = sortSongsSelectedFirst(cancionesFiltradas);
 applySongOrder(cancionesFiltradas);

 cargarMasCanciones();
 requestAnimationFrame(bindResourceActionHints);

 // Show/hide empty state
 if (emptyFilterState && gridCanciones) {
  if (cancionesFiltradas.length === 0) {
   gridCanciones.style.display = 'none';
   emptyFilterState.classList.remove('hidden');
   emptyFilterState.style.opacity = '0';
   emptyFilterState.style.transform = 'scale(0.95) translateY(12px)';
   requestAnimationFrame(() => {
    emptyFilterState.style.transition = 'opacity 400ms cubic-bezier(0.22,1,0.36,1), transform 400ms cubic-bezier(0.22,1,0.36,1)';
    emptyFilterState.style.opacity = '1';
    emptyFilterState.style.transform = 'scale(1) translateY(0)';
   });
  } else {
   gridCanciones.style.display = '';
   emptyFilterState.classList.add('hidden');
   emptyFilterState.style.opacity = '';
   emptyFilterState.style.transform = '';
   emptyFilterState.style.transition = '';
  }
 }
 }

 const debouncedFilterCards = debounce(filterCards, 140);

 // Limpiar filtros button
 if (btnResetFilters) {
  addListener(btnResetFilters, 'click', () => {
   if (searchInput) (searchInput as HTMLInputElement).value = '';
   if (filterVoz) (filterVoz as HTMLSelectElement).value = 'Todas';
   if (filterCategoria) (filterCategoria as HTMLSelectElement).value = 'Todas';
   if (filterTema) (filterTema as HTMLSelectElement).value = 'Todas';
   if (filterEstado) (filterEstado as HTMLSelectElement).value = 'Todas';
   syncMobileFilterDraft();
   setMobileFiltersOpen(false);
   filterCards();
  });
 }

 if(searchInput) addListener(searchInput, 'input', debouncedFilterCards);
 if(filterVoz) addListener(filterVoz, 'change', filterCards);
 if(filterCategoria) addListener(filterCategoria, 'change', filterCards);
 if(filterTema) addListener(filterTema, 'change', filterCards);
 if(filterEstado) addListener(filterEstado, 'change', filterCards);
 syncFilterMenuState();


 }

 if (!repertorioWindow.__REPERTORIO_INIT_BOUND__) {
  document.addEventListener('astro:page-load', initRepertorio);
  repertorioWindow.__REPERTORIO_INIT_BOUND__ = true;
 }

 if (!repertorioWindow.__REPERTORIO_BEFORE_SWAP_BOUND__) {
  document.addEventListener('astro:before-swap', cleanupRepertorioRuntime);
  repertorioWindow.__REPERTORIO_BEFORE_SWAP_BOUND__ = true;
 }

 void initRepertorio();
</script>

