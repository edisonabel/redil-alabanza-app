---
import Layout from '../layouts/Layout.astro';
import CardCancion from '../components/CardCancion.astro';
import BuscadorPredictivo from '../components/BuscadorPredictivo.astro';
import OnboardingRoot from '../components/onboarding/OnboardingRoot';
import { supabase } from '../lib/supabase';

let canciones: any[] = [];
const userId = Astro.locals.user?.id ?? null;
try {
  const { data, error } = await supabase
    .from('canciones')
    .select('*')
    .order('titulo');
    
  if (error) {
    console.error("Error fetching from Supabase:", error);
  } else if (data) {
    canciones = data.filter(c => c.estado !== 'Archivada');
  }
} catch (e) {
  console.error("Fetch failed", e);
}

const temasUnicos = [...new Set(canciones.map((c: any) => c.tema).filter(Boolean))].sort() as string[];
const visibleInitialSongs = canciones.slice(0, 15);
const firstTourCardId = visibleInitialSongs.find(Boolean)?.id ?? null;
const firstTourAudioId = visibleInitialSongs.find((c: any) => typeof c?.mp3 === 'string' && c.mp3.trim() !== '')?.id ?? firstTourCardId;
const firstTourResourcesId =
  visibleInitialSongs.find((c: any) =>
    ['voces', 'link_voces', 'link_acordes', 'link_youtube', 'link_secuencias'].some((key) => {
      const value = c?.[key];
      return typeof value === 'string' && value.trim() !== '';
    }),
  )?.id ?? firstTourAudioId ?? firstTourCardId;
---

<Layout>
 <header class="mb-1.5 mt-2 md:mb-10 md:mt-6 px-2 md:px-4 max-w-7xl mx-auto">
 <div class="text-left flex flex-col justify-center">
 <div class="page-title-row mb-1.5">
  <span class="page-title-icon" aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
  </span>
 <h1 id="mainTitle" class="page-title text-[2.1rem] md:text-[3.5rem]">Repertorio Alabanza</h1>
  </div>
 <p class="page-subtitle text-sm md:text-lg">Administraci&oacute;n de canciones, tonos y recursos.</p>
  </div>
  </header>

 <!-- UI Controles -->
 <section id="searchControls" data-tour="repertorio-search" class="max-w-7xl mx-auto mb-6 bg-surface border border-border rounded-2xl px-2.5 py-3 md:px-4 md:py-4 shadow-lg">
 <div class="grid grid-cols-2 lg:grid-cols-4 gap-2.5 md:gap-3 items-end">
 <div class="col-span-2 md:col-span-1 lg:col-span-1">
 <label for="search-input" class="hidden md:block text-sm font-medium text-content mb-1.5">Buscar</label>
  <BuscadorPredictivo idInput="searchInput" placeholder="Buscar canci&oacute;n o artista..." />
 </div>
 
 <div class="col-span-1">
 <label for="filterVoz" class="block text-xs md:text-sm font-medium text-content mb-1.5">Voz</label>
 <select id="filterVoz" 
 class="w-full h-11 bg-surface border border-border text-content rounded-xl px-3 text-sm md:text-base focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors appearance-none">
 <option value="Todas">Todas</option>
 <option value="Hombre">Hombre</option>
 <option value="Mujer">Mujer</option>
 <option value="Hombre y Mujer">Hombre y Mujer</option>
 </select>
 </div>

 <div class="col-span-1">
 <label for="filterCategoria" class="block text-xs md:text-sm font-medium text-content mb-1.5">Categor&iacute;a</label>
 <select id="filterCategoria" 
 class="w-full h-11 bg-surface border border-border text-content rounded-xl px-3 text-sm md:text-base focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors appearance-none">
 <option value="Todas">Todas</option>
 <option value="Lenta">Lenta</option>
 <option value="R&aacute;pida">R&aacute;pida</option>
 <option value="Transici&oacute;n">Transici&oacute;n</option>
 </select>
 </div>

 <div class="col-span-2 md:col-span-1 lg:col-span-1 mt-0.5 md:mt-0">
 <label for="filterTema" class="block text-xs md:text-sm font-medium text-content mb-1.5">Tema</label>
 <select id="filterTema" 
 class="w-full h-11 bg-surface border border-border text-content rounded-xl px-3 text-sm md:text-base focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors appearance-none">
 <option value="Todas">Todas</option>
 {temasUnicos.map(tema => (
 <option value={tema}>{tema}</option>
 ))}
 </select>
 </div>
 </div>
 </section>

 <!-- Encabezado de Resultados y Vista -->
 <div class="max-w-7xl mx-auto mb-2 md:mb-4 mt-2 md:mt-8 flex justify-between items-center px-2 md:px-0">
 <h3 class="text-xl font-bold text-content mb-2 md:mb-4">Setlist</h3>
 <div id="viewToggleContainer" class="flex bg-surface flex-shrink-0 mb-2 md:mb-4 rounded-lg p-1 border border-border h-fit">
 <button id="btnViewGrid" class="p-1.5 rounded-md bg-surface text-content shadow-sm border border-border transition-all" title="Vista de Cuadr&iacute;cula">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
 </button>
 <button id="btnViewList" class="p-1.5 rounded-md text-content-muted hover:text-content transition-all" title="Vista de Lista">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
 </button>
 </div>
 </div>

 <!-- Grid de Canciones -->
 <div id="gridCanciones" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto">
 {canciones.map((cancion: any, index: number) => (
 <CardCancion 
  cancionId={cancion.id || ''}
  titulo={cancion.titulo || ''}
  cantante={cancion.cantante || cancion.artista || ''}
  tonalidad={cancion.tonalidad || ''}
  bpm={cancion.bpm || 0}
 linkLetra={cancion.link_letras || ''}
  linkAcordes={cancion.link_acordes || ''}
  linkVoces={cancion.voces || cancion.link_voces || ''}
  linkYoutube={cancion.link_youtube || ''}
  linkSecuencias={cancion.link_secuencias || ''}
  linkMp3={cancion.mp3 || ''}
  chordpro={cancion.chordpro || ''}
  categoria={cancion.categoria || ''}
 voz={cancion.voz || cancion.voz_principal || ''}
 tema={cancion.tema || ''}
 estado={cancion.estado || ''}
 oculta={index >= 15}
 tourCard={String(cancion.id) === String(firstTourCardId) ? 'repertorio-card' : undefined}
 tourAudio={String(cancion.id) === String(firstTourAudioId) ? 'repertorio-audio' : undefined}
 tourResources={String(cancion.id) === String(firstTourResourcesId) ? 'repertorio-resources' : undefined}
 />
 ))}
 </div>

 <!-- Centinela para Infinite Scroll -->
 <div id="scroll-sentinel" class="h-4 w-full mt-8"></div>

 <!-- Panel Flotante Setlist (modo normal) -->
<div id="setlistPanel" class="fixed bottom-[calc(env(safe-area-inset-bottom)+5rem)] md:bottom-24 left-3 right-3 md:left-auto md:right-6 bg-background border border-border text-content p-3 md:p-4 rounded-xl md:rounded-2xl shadow-2xl z-50 flex items-center justify-between gap-3 md:gap-4 hidden transition-opacity">
 <div class="font-semibold text-sm md:text-base whitespace-nowrap">
 Setlist: <span id="setlistCount" class="text-action">0</span>
 </div>
 <div class="flex items-center gap-2 shrink-0">
 <button id="btnCopySetlist" class="px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-bold transition-colors shadow-[0_0_14px_rgba(37,99,235,0.45)]">Copiar Enlace</button>
 <button id="btnClearSetlist" class="px-3.5 py-2 bg-neutral/20 text-neutral hover:bg-neutral-300 rounded-lg text-sm font-bold transition-colors">Limpiar</button>
 </div>
 </div>

 <!-- Barra Flotante Playlist (modo seleccion) - Inyeccion modular -->
<div id="playlistBar" class="fixed bottom-[calc(env(safe-area-inset-bottom)+5rem)] md:bottom-[calc(var(--spacing)*21)] left-0 right-0 z-50 bg-surface border-t border-border shadow-[0_-8px_30px_rgba(0,0,0,0.3)] px-4 py-3 hidden">
 <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3 sm:gap-4">
 <div class="flex items-start sm:items-center gap-3 min-w-0">
 <div class="w-10 h-10 rounded-full bg-brand/20 flex items-center justify-center">
 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-action"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
 </div>
 <div class="min-w-0">
 <div class="flex flex-wrap items-center gap-2">
 <span id="playlistCountBadge" class="inline-flex items-center rounded-full bg-action/10 text-action border border-action/30 px-2.5 py-1 text-xs font-bold tracking-wide">
 <span id="playlistCount">0</span>&nbsp;canciones
 </span>
 <button id="btn-clear-playlist-selection" type="button" class="hidden md:inline-flex items-center rounded-full border border-border bg-background/80 px-2.5 py-1 text-[11px] font-bold text-content-muted hover:bg-background hover:text-content transition-colors">
 Limpiar lista
 </button>
 </div>
 <p class="text-content font-bold text-base md:text-lg leading-tight mt-1">Canciones seleccionadas</p>
 <p class="text-content-muted text-sm leading-tight truncate">Toca el + de cada canci&oacute;n para agregar o quitar</p>
 </div>
 </div>
 <div class="flex items-center gap-2">
 <button id="btn-clear-playlist-selection-mobile" class="inline-flex md:hidden px-3 py-2.5 rounded-xl border border-border text-content-muted text-sm font-bold hover:bg-background transition-colors">
 Limpiar
 </button>
 <button id="btn-cancel-playlist" class="flex-1 sm:flex-none px-4 py-2.5 rounded-xl border border-border text-content-muted text-sm font-bold hover:bg-background transition-colors">
 Cancelar
 </button>
 <button id="btn-save-playlist" class="flex-1 sm:flex-none px-5 py-2.5 rounded-xl bg-action text-white text-sm font-bold hover:bg-action/80 transition-all shadow-lg flex items-center justify-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
 Guardar Setlist
 </button>
 </div>
 </div>
</div>

  <OnboardingRoot client:load page="repertorio" userId={userId} />
</Layout>

 <!-- Data bridge eliminado. Supabase renderiza directamente. -->
 <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
 
<script>
import { supabase } from '../lib/supabase';

 type RepertorioWindow = Window & {
  __REPERTORIO_INIT_BOUND__?: boolean;
  __REPERTORIO_BEFORE_SWAP_BOUND__?: boolean;
  __REPERTORIO_CLEANUP__?: (() => void) | null;
  __REPERTORIO_METRONOME__?: {
   intervalId: number | null;
   activeDot: HTMLElement | null;
   audioCtx: AudioContext | null;
  };
 };

 const repertorioWindow = window as RepertorioWindow;

 const cleanupRepertorioRuntime = () => {
  if (typeof repertorioWindow.__REPERTORIO_CLEANUP__ === 'function') {
   repertorioWindow.__REPERTORIO_CLEANUP__();
  }
  repertorioWindow.__REPERTORIO_CLEANUP__ = null;
 };

 async function initRepertorio() {
 cleanupRepertorioRuntime();
 if (!window.location.pathname.startsWith('/repertorio')) return;

 const cleanupFns: Array<() => void> = [];
 const addListener = (
  target: EventTarget | null | undefined,
  type: string,
  handler: EventListenerOrEventListenerObject,
  options: AddEventListenerOptions | boolean = false,
 ) => {
  if (!target) return;
  target.addEventListener(type, handler as EventListener, options as AddEventListenerOptions);
  cleanupFns.push(() => {
   target.removeEventListener(type, handler as EventListener, options as EventListenerOptions);
  });
 };

 let observer: IntersectionObserver | null = null;
 const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
 const metronomeState = repertorioWindow.__REPERTORIO_METRONOME__ || {
  intervalId: null,
  activeDot: null,
  audioCtx: null,
 };
 repertorioWindow.__REPERTORIO_METRONOME__ = metronomeState;

 const getSharedAudioCtx = () => {
  if (!AudioContextClass) return null;
  if (!metronomeState.audioCtx || metronomeState.audioCtx.state === 'closed') {
   metronomeState.audioCtx = new AudioContextClass();
  }
  return metronomeState.audioCtx;
 };

 const stopMetronome = () => {
  if (metronomeState.intervalId) {
   clearInterval(metronomeState.intervalId);
   metronomeState.intervalId = null;
  }
  if (metronomeState.activeDot) {
   metronomeState.activeDot.classList.remove('beat-active');
   metronomeState.activeDot.style.removeProperty('--bpm-duration');
   metronomeState.activeDot = null;
  }
 };

 repertorioWindow.__REPERTORIO_CLEANUP__ = () => {
  cleanupFns.forEach((dispose) => {
   try {
    dispose();
   } catch {
    // no-op
   }
  });
  cleanupFns.length = 0;

  if (observer) {
   observer.disconnect();
   observer = null;
  }

  stopMetronome();

  const anyAudio = document.querySelector('audio') as HTMLAudioElement | null;
  if (anyAudio) {
   try {
    anyAudio.pause();
   } catch {
    // no-op
   }
  }

  const modal = document.getElementById('vocesModal') as HTMLElement | null;
  const backdrop = document.getElementById('vocesBackdrop') as HTMLElement | null;
  const panel = document.getElementById('vocesPanel') as HTMLElement | null;
  if (modal && !modal.classList.contains('hidden')) {
   modal.classList.add('hidden');
   modal.setAttribute('aria-hidden', 'true');
   backdrop?.classList.add('opacity-0');
   panel?.classList.add('opacity-0', 'translate-y-4');
  }

  if (document.body.dataset.vocesModalOpen === 'true') {
   delete document.body.dataset.vocesModalOpen;
   document.body.style.position = '';
   document.body.style.top = '';
   document.body.style.left = '';
   document.body.style.right = '';
   document.body.style.width = '';
   document.body.style.overflow = '';
   document.documentElement.style.overflow = '';
  }
 };

// Puerta Guardiana de Seguridad RLS: Verificar Sesion Activa
const { data: { session }, error: sessionError } = await supabase.auth.getSession();
if (sessionError || !session) {
// Expulsar solicitudes anonimas inmediatamente re-direccionando hacia el tunel de autenticacion
/* window.location.replace('/login'); Movido a Middleware */
 return;
 }
 
 const searchInput = document.getElementById('searchInput') as HTMLInputElement;
 const filterVoz = document.getElementById('filterVoz') as HTMLSelectElement;
 const filterCategoria = document.getElementById('filterCategoria') as HTMLSelectElement;
 const filterTema = document.getElementById('filterTema') as HTMLSelectElement;
 
 const mainTitle = document.getElementById('mainTitle');
 const searchControls = document.getElementById('searchControls');
 const setlistPanel = document.getElementById('setlistPanel');
 const setlistCount = document.getElementById('setlistCount');
 const btnCopySetlist = document.getElementById('btnCopySetlist');
 const btnClearSetlist = document.getElementById('btnClearSetlist');
 
 const btnViewGrid = document.getElementById('btnViewGrid');
 const btnViewList = document.getElementById('btnViewList');
 const gridCanciones = document.getElementById('gridCanciones');
 
 // Obtenemos todos los <article> dentro del grid
 const cards = document.querySelectorAll('#gridCanciones article') as NodeListOf<HTMLElement>;

 // ----- View Toggle Logic -----
 let isListView = false;

 function setGridView() {
 if (!gridCanciones) return;
 isListView = false;
 
 // Switch classes on container
 gridCanciones.className = 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto';
 
 // Remove list mode from all cards
 cards.forEach(card => card.classList.remove('modo-lista', 'expandido'));
 
 // Update button styles
 const updateBtns = (gridBtn: HTMLElement | null, listBtn: HTMLElement | null) => {
 if(!gridBtn || !listBtn) return;
 gridBtn.classList.add('bg-background', 'text-white', 'shadow-sm');
 gridBtn.classList.remove('text-content-muted', 'hover:text-content');
 listBtn.classList.remove('bg-background', 'text-white', 'shadow-sm');
 listBtn.classList.add('text-content-muted', 'hover:text-content');
 };
 
 updateBtns(btnViewGrid, btnViewList);
 void document.body.offsetHeight; // Fuerza un reflow para corregir glitches de repintado en iOS
 }

 function setListView() {
 if (!gridCanciones) return;
 isListView = true;
 
 // Switch classes on container to vertical flow
 gridCanciones.className = 'flex flex-col gap-3 max-w-7xl mx-auto';
 
 // Add list mode to all cards
 cards.forEach(card => card.classList.add('modo-lista'));
 
 // Update button styles
 const updateBtns = (gridBtn: HTMLElement | null, listBtn: HTMLElement | null) => {
 if(!gridBtn || !listBtn) return;
 listBtn.classList.add('bg-background', 'text-white', 'shadow-sm');
 listBtn.classList.remove('text-content-muted', 'hover:text-content');
 gridBtn.classList.remove('bg-background', 'text-white', 'shadow-sm');
 gridBtn.classList.add('text-content-muted', 'hover:text-content');
 };
 
 updateBtns(btnViewGrid, btnViewList);
 void document.body.offsetHeight; // Fuerza un reflow para corregir glitches de repintado en iOS
 }

 if(btnViewGrid) addListener(btnViewGrid, 'click', setGridView);
 if(btnViewList) addListener(btnViewList, 'click', setListView);

 // Accordion logic for list view
 cards.forEach(card => {
 const header = card.querySelector('.card-header');
 if (header) {
 addListener(header, 'click', (e) => {
 // Prevent toggling if user clicked the Add to Setlist button
 if ((e.target as Element).closest('.btn-add-setlist')) return;
 
 if (isListView) {
 card.classList.toggle('expandido');
 }
 });
 }
 });

 
 // =============================================
 // DETECCION DE MODOS DE LA PAGINA (Setlist Semanal vs Playlist vs Normal)
 // =============================================
 const urlParams = new URLSearchParams(window.location.search);
 const seleccionarPara = urlParams.get('seleccionar_para');
 const setlistParam = urlParams.get('setlist');
 const isSelectionMode = !!seleccionarPara;
 const isSetlistSemana = !!setlistParam;

 let selectedSongs = [];
 const playlistBar = document.getElementById('playlistBar');
 const playlistCountEl = document.getElementById('playlistCount');
 const btnClearPlaylistSelection = document.getElementById('btn-clear-playlist-selection');
 const btnClearPlaylistSelectionMobile = document.getElementById('btn-clear-playlist-selection-mobile');

 // Helper local para setlist normal
 let setlist = JSON.parse(localStorage.getItem('setlist') || '[]');

 function updateSetlistUI() {
 if (setlistCount) setlistCount.textContent = setlist.length.toString();
 if (setlistPanel) {
 if (setlist.length > 0) {
 setlistPanel.classList.remove('hidden');
 } else {
 setlistPanel.classList.add('hidden');
 }
 }
 }

 function updatePlaylistCount() {
 if (playlistCountEl) playlistCountEl.textContent = selectedSongs.length.toString();
 }

 function setSelectionButtonState(btn, isSelected) {
  if (!btn) return;
  const iconPlus = btn.querySelector('.setlist-icon-plus');
  const iconCheck = btn.querySelector('.setlist-icon-check');

  if (iconPlus && iconCheck) {
   if (isSelected) {
    iconPlus.classList.add('hidden');
    iconCheck.classList.remove('hidden');
   } else {
    iconPlus.classList.remove('hidden');
    iconCheck.classList.add('hidden');
   }
  }

  // Selected: teal premium look
  btn.classList.toggle('bg-teal-500', Boolean(isSelected));
  btn.classList.toggle('border-teal-500', Boolean(isSelected));
  btn.classList.toggle('text-white', Boolean(isSelected));
  btn.classList.toggle('shadow-md', Boolean(isSelected));
  btn.classList.toggle('dark:bg-teal-500', Boolean(isSelected));
  btn.classList.toggle('dark:border-teal-500', Boolean(isSelected));
  btn.classList.toggle('dark:text-white', Boolean(isSelected));
  // Unselected: restore defaults
  btn.classList.toggle('bg-white', !isSelected);
  btn.classList.toggle('border-zinc-200', !isSelected);
  btn.classList.toggle('text-zinc-400', !isSelected);
  btn.classList.toggle('dark:bg-zinc-900', !isSelected);
  btn.classList.toggle('dark:border-white/10', !isSelected);
  btn.classList.toggle('dark:text-zinc-500', !isSelected);
 }

 function sortSongsSelectedFirst(songCards) {
  if (!isSelectionMode) return [...songCards];

  return [...songCards].sort((a, b) => {
   const aId = String(a.getAttribute('data-id') || '');
   const bId = String(b.getAttribute('data-id') || '');
   const aSeleccionada = selectedSongs.includes(aId);
   const bSeleccionada = selectedSongs.includes(bId);

   if (aSeleccionada && !bSeleccionada) return -1;
   if (!aSeleccionada && bSeleccionada) return 1;

   const aIndex = Number(a.dataset.originalIndex || '0');
   const bIndex = Number(b.dataset.originalIndex || '0');
   return aIndex - bIndex;
  });
 }

 function applySongOrder(songCards) {
  if (!gridCanciones) return;
  songCards.forEach((card) => gridCanciones.appendChild(card));
 }

 function syncSelectionButtons() {
  cards.forEach(card => {
   const btn = card.querySelector('.btn-add-setlist') as HTMLElement | null;
   if (!btn) return;

   const cancionId = btn.getAttribute('data-id') || card.getAttribute('data-id') || '';
   const isSelected = cancionId && selectedSongs.includes(String(cancionId));
   setSelectionButtonState(btn, Boolean(isSelected));
  });
 }

 const dispatchProPlayerEvent = (payload: { url: string; title?: string; artist?: string; isDirectPlayable?: boolean; autoPlay?: boolean }) => {
  const url = (payload?.url || '').trim();
  if (!url) return;
  const proPlayer = (window as any).__REDIL_PRO_PLAYER__;
  if (proPlayer && typeof proPlayer.open === 'function') {
   proPlayer.open({
    url,
    title: payload.title,
    artist: payload.artist,
    autoPlay: payload.autoPlay !== false,
   });
   return;
  }
  window.dispatchEvent(new CustomEvent('play-pro-audio', { detail: payload }));
 };

 // Listener global para abrir modal MP3 desde la tarjeta (debe existir en todos los modos, incluido setlist)
 addListener(document, 'click', async (e) => {
 const mp3Button = (e.target as Element).closest('.btn-open-mp3') as HTMLElement | null;
 if (!mp3Button) return;

 e.preventDefault();
 e.stopPropagation();

 const mp3Url = mp3Button.getAttribute('data-mp3') || '';
 const songTitle = mp3Button.getAttribute('data-title') || mp3Button.getAttribute('data-cancion') || 'Canción';
 const songArtist = mp3Button.getAttribute('data-artist') || '';

 // Llamada al RPC seguro para sumar una reproducción (sin detener la música si falla)
 const cancionId = mp3Button.getAttribute('data-id') || mp3Button.closest('article')?.getAttribute('data-id');
 if (cancionId) {
   try {
     const { error } = await supabase.rpc('incrementar_reproduccion', { 
       cancion_id: cancionId 
     });
     if (error) {
       console.warn('Aviso: No se pudo sumar la reproducción', error.message);
     }
   } catch (err) {
     console.warn('Aviso: Excepción silenciosa en el contador', err);
   }
 }

 dispatchProPlayerEvent({ url: mp3Url, title: songTitle, artist: songArtist, autoPlay: true });
 }, { capture: true });

// ----- Metronomo Interactivo Logic -----

function playClick() {
const audioCtx = getSharedAudioCtx();
if (!audioCtx) return;
if (audioCtx.state === 'suspended') audioCtx.resume();
 
 const osc = audioCtx.createOscillator();
 const gainNode = audioCtx.createGain();
 
 osc.connect(gainNode);
 gainNode.connect(audioCtx.destination);
 
 osc.type = 'sine';
 osc.frequency.setValueAtTime(800, audioCtx.currentTime);
 
 gainNode.gain.setValueAtTime(1, audioCtx.currentTime);
 gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
 
 osc.start(audioCtx.currentTime);
 osc.stop(audioCtx.currentTime + 0.1);
 }
 
 addListener(document, 'click', (e) => {
 const badge = (e.target as Element).closest('.badge-bpm');
 if (badge) {
 const bpmStr = badge.getAttribute('data-bpm');
 if (!bpmStr) return;
 
 const bpmVal = parseInt(bpmStr.replace(/[^0-9]/g, ''), 10);
 if (!bpmVal || bpmVal <= 0) return;
 
 const dot = badge.querySelector('.metronomo-dot') as HTMLElement;
 if (!dot) return;
 
 if (metronomeState.activeDot && metronomeState.activeDot !== dot) {
 stopMetronome();
 }

 if (dot.classList.contains('beat-active')) {
 stopMetronome();
 return;
 }

 stopMetronome();
 const duracionSegundos = 60 / bpmVal;
 dot.style.setProperty('--bpm-duration', `${duracionSegundos}s`);
 dot.classList.add('beat-active');
 metronomeState.activeDot = dot;

 playClick();
 metronomeState.intervalId = window.setInterval(playClick, duracionSegundos * 1000);
 }
});

 // ----- Reference Tone (Pitch Pipe) Logic -----
 const frecuencias: { [key: string]: number } = {
 'C': 261.63, 'C#': 277.18, 'D': 293.66, 'Eb': 311.13, 'E': 329.63, 
 'F': 349.23, 'F#': 369.99, 'G': 392.00, 'G#': 415.30, 'A': 440.00, 
 'Bb': 466.16, 'B': 493.88
 };
 
 addListener(document, 'click', (e) => {
 const badgeTono = (e.target as Element).closest('.badge-tono');
 if (badgeTono) {
 let tono = badgeTono.getAttribute('data-tono');
 if (!tono || tono.trim() === '-' || tono.trim() === '') return;
 
 tono = tono.replace(/m/g, '').trim();
 const frecuencia = frecuencias[tono];
 
 const audioCtx = getSharedAudioCtx();
 if (frecuencia && audioCtx) {
 if (audioCtx.state === 'suspended') audioCtx.resume();
 
 const oscPrincipal = audioCtx.createOscillator();
 oscPrincipal.type = 'triangle';
 oscPrincipal.frequency.value = frecuencia;
 
 const oscBrillo = audioCtx.createOscillator();
 oscBrillo.type = 'sine';
 oscBrillo.frequency.value = frecuencia * 2; 
 
 const gainNode = audioCtx.createGain();
 
 oscPrincipal.connect(gainNode);
 oscBrillo.connect(gainNode);
 gainNode.connect(audioCtx.destination);
 
 const now = audioCtx.currentTime;
 gainNode.gain.setValueAtTime(0, now);
 gainNode.gain.linearRampToValueAtTime(0.8, now + 0.02);
 gainNode.gain.exponentialRampToValueAtTime(0.1, now + 0.5);
 gainNode.gain.exponentialRampToValueAtTime(0.001, now + 3);
 
 oscPrincipal.start(now);
 oscBrillo.start(now);
 oscPrincipal.stop(now + 3);
 oscBrillo.stop(now + 3);
 }
 }
 });

 // =============================================
 // BLOQUE 1: MODO SETLIST DE LA SEMANA (Solo ver, no buscar ni scrollear)
 // =============================================
 if (isSetlistSemana) {
 try {
 const decodedData = decodeURIComponent(atob(setlistParam));
 const setlistArray = JSON.parse(decodedData);
 
 const setlistFechaIso = urlParams.get('fechaIso');
 const setlistTema = urlParams.get('tema');
 const esEnsayo = urlParams.get('esEnsayo') === 'true';
 
 if (searchControls) searchControls.style.display = 'none';
 if (setlistPanel) setlistPanel.style.display = 'none';
 
 if (mainTitle) {
   const headerContainer = mainTitle.parentElement;
   if (headerContainer) {
     if (setlistFechaIso) {
       // Escenario A: Evento Oficial (Datos presentes - Puro Dinamismo y Objeto Date)
       const eventoFechaObj = new Date(setlistFechaIso);
       const diaStr = eventoFechaObj.toLocaleDateString('es-ES', { weekday: 'long' }).toUpperCase();
       const fechaStr = eventoFechaObj.toLocaleDateString('es-ES', { day: 'numeric', month: 'long' });
       
       const titleText = setlistTema && setlistTema !== 'Sin t\u00edtulo' ? setlistTema : 'Sin tema asignado';
       const badgeHTML = esEnsayo ? '<span class="ml-2 md:ml-3 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] md:text-xs font-medium bg-yellow-100 text-yellow-800 tracking-wide align-middle">?? Ensayo</span>' : '';
       
       headerContainer.innerHTML = `
         <p class="text-[11px] md:text-sm font-semibold text-brand uppercase tracking-wider mb-0 md:mb-1">${diaStr}</p>
         <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-content tracking-tight leading-none">${titleText}</h1>
         <h2 class="text-sm md:text-lg font-medium text-content-muted mt-1 md:mt-2">${fechaStr}${badgeHTML}</h2>
       `;
     } else {
       // Escenario B: Setlist Custom / Enlace Manual (Sin datos)
       headerContainer.innerHTML = `
         <h1 class="text-3xl sm:text-4xl font-extrabold text-content tracking-tight">Setlist Personalizada</h1>
       `;
     }
   }
 }

 cards.forEach(card => {
 const cancionTitulo = card.getAttribute('data-cancion') || '';
 
 if (setlistArray.includes(cancionTitulo)) {
 card.classList.remove('cancion-oculta'); // Critical FIX: Remover clase !important
 card.style.display = 'block';
 const addBtn = card.querySelector('.btn-add-setlist');
 if(addBtn) addBtn.style.display = 'none';
 } else {
 card.classList.add('cancion-oculta');
 card.style.display = 'none';
 }
 });
 
 // Iniciar SortableJS para Drag and Drop
 if (typeof window.Sortable !== 'undefined' && gridCanciones) {
   new window.Sortable(gridCanciones, {
     animation: 150,
     ghostClass: 'opacity-50',
     delay: 100, // delay on mobile to prevent accidental dragging during scroll
     delayOnTouchOnly: true,
   });
 }
 
 // Detenemos la ejecucion aqui porque no necesitamos modo infinito ni filtros
 return; 

 } catch (e) {
 console.error("Error validando el link del setlist:", e);
 window.location.href = window.location.pathname;
 return; // Detener ejecucion para evitar bugs de pintado 
 }
 }

 // =============================================
 // BLOQUE 2: PREPARACION DE UI PARA SELECCION O MODO NORMAL
 // =============================================
 if (isSelectionMode) {
 if (mainTitle) mainTitle.innerHTML = 'Seleccionar Setlist';
 if (setlistPanel) setlistPanel.style.display = 'none';
 if (playlistBar) playlistBar.classList.remove('hidden');

const clearPlaylistSelection = () => {
 selectedSongs = [];
  cancionesFiltradas = sortSongsSelectedFirst(cancionesFiltradas);
  applySongOrder(cancionesFiltradas);
  updatePlaylistCount();
  syncSelectionButtons();
 };

 // Pre-cargar canciones de la playlist existente
 (async () => {
 const { data: pl } = await supabase.from('playlists').select('id').eq('evento_id', seleccionarPara).single();
 if (pl) {
 const { data: items } = await supabase.from('playlist_canciones').select('cancion_id').eq('playlist_id', pl.id).order('orden');
 if (items) {
 items.forEach(item => {
 if (item.cancion_id) selectedSongs.push(String(item.cancion_id));
 });
 cancionesFiltradas = sortSongsSelectedFirst(cancionesFiltradas);
 applySongOrder(cancionesFiltradas);
 updatePlaylistCount();
 syncSelectionButtons();
 }
 }
 })();

 // Listeners de Guardar y Cancelar Playlist
 addListener(document.getElementById('btn-cancel-playlist'), 'click', () => { window.location.href = '/programacion'; });
 addListener(btnClearPlaylistSelection, 'click', clearPlaylistSelection);
 addListener(btnClearPlaylistSelectionMobile, 'click', clearPlaylistSelection);
 
 addListener(document.getElementById('btn-save-playlist'), 'click', async () => {
 const btn = document.getElementById('btn-save-playlist');
 btn.disabled = true;
 btn.innerHTML = 'Guardando...';

 try {
 const { data: playlist, error: plErr } = await supabase.from('playlists').upsert({ evento_id: seleccionarPara }, { onConflict: 'evento_id' }).select('id').single();
 if (plErr) throw plErr;

 await supabase.from('playlist_canciones').delete().eq('playlist_id', playlist.id);

 if (selectedSongs.length > 0) {
 const insertPayload = selectedSongs.map((songId, i) => ({ playlist_id: playlist.id, cancion_id: songId, orden: i }));
 if (insertPayload.length > 0) {
 const { error: insErr } = await supabase.from('playlist_canciones').insert(insertPayload);
 if (insErr) throw insErr;
 }
 }
 window.location.href = '/programacion';
 } catch (err) {
 alert('Error al guardar: ' + (err.message || 'Error desconocido'));
 btn.disabled = false;
 btn.innerHTML = 'Guardar Setlist';
 }
 });

 } else {
 // Modo local / Setlist normal temporal
 updateSetlistUI();

 if (btnCopySetlist) {
 addListener(btnCopySetlist, 'click', () => {
 const base64Str = btoa(encodeURIComponent(JSON.stringify(setlist)));
 const url = window.location.origin + window.location.pathname + '?setlist=' + encodeURIComponent(base64Str);
 navigator.clipboard.writeText(url).then(() => {
 alert('\u00A1Setlist copiado y abierto en una nueva pesta\u00F1a!');
 window.open(url, '_blank');
 });
 });
 }

 if (btnClearSetlist) {
 addListener(btnClearSetlist, 'click', () => {
 setlist = [];
 localStorage.removeItem('setlist');
 updateSetlistUI();
 window.location.href = window.location.pathname;
 });
 }
 }

 // Listener Universal para el boton + de las tarjetas
 addListener(document, 'click', (e) => {
 const btn = e.target.closest('.btn-add-setlist');
 if (!btn) return;
 e.preventDefault();
 e.stopPropagation();

 const card = btn.closest('article');
 const cancionId = btn.getAttribute('data-id') || card?.getAttribute('data-id') || '';
 const cancion = btn.getAttribute('data-cancion') || '';
 const svg = btn.querySelector('svg');

 if (isSelectionMode) {
 if (!cancionId) return;
 const idx = selectedSongs.indexOf(String(cancionId));
 if (idx > -1) {
 selectedSongs.splice(idx, 1);
 } else {
 selectedSongs.push(String(cancionId));
 }
 cancionesFiltradas = sortSongsSelectedFirst(cancionesFiltradas);
 applySongOrder(cancionesFiltradas);
 updatePlaylistCount();
 syncSelectionButtons();
 } else {
 if (!cancion) return;
 if (!setlist.includes(cancion)) {
 setlist.push(cancion);
 localStorage.setItem('setlist', JSON.stringify(setlist));
 updateSetlistUI();
 setSelectionButtonState(btn, true);
 }
 }
 }, { capture: true });

 // =============================================
 // BLOQUE 3: INFINITE SCROLL & BUSQUEDA (COMPARTIDO MODO NORMAL Y PLAYLIST)
 // =============================================
 const sentinel = document.getElementById('scroll-sentinel');
 const todasLasCanciones = Array.from(cards);
 todasLasCanciones.forEach((card, index) => {
  card.dataset.originalIndex = String(index);
 });
 let cancionesFiltradas = [...todasLasCanciones];
 let indiceActual = 0;
 const limite = 15;
 let isLoading = false;
 
 function cargarMasCanciones() {
 if (isLoading) return;
 isLoading = true;

 const fragmento = cancionesFiltradas.slice(indiceActual, indiceActual + limite);
 if (fragmento.length === 0) {
 if (sentinel) sentinel.style.display = 'none';
 isLoading = false;
 return;
 }
 
 fragmento.forEach(card => {
 card.classList.remove('cancion-oculta');
 card.style.display = ''; // Resetear el display modificado por el filtrado
 });
 indiceActual += limite;
 
 if (sentinel) {
 sentinel.style.display = (indiceActual >= cancionesFiltradas.length) ? 'none' : 'block';
 }

 requestAnimationFrame(() => {
 isLoading = false;
 if (sentinel && sentinel.style.display !== 'none') {
 const rect = sentinel.getBoundingClientRect();
 if (rect.top <= window.innerHeight + 150) {
 cargarMasCanciones();
 }
 }
 });
 }
 
 observer = new IntersectionObserver((entries) => {
 if (entries[0].isIntersecting) cargarMasCanciones();
 }, { root: null, rootMargin: '150px', threshold: 0 });
 
 if (sentinel) observer.observe(sentinel);

const normalizeStr = (str) => str ? str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase() : '';

const matchVoz = (vozValue, vozFilter) => {
 const v = normalizeStr(vozValue);
 const f = normalizeStr(vozFilter);
 if (f === 'todas') return true;

 if (f === 'hombre y mujer') {
 const hasHombre = ['hombre', 'masculino', 'male', 'tenor'].some((alias) => v.includes(alias));
 const hasMujer = ['mujer', 'femenino', 'female', 'soprano', 'alto', 'contralto'].some((alias) => v.includes(alias));
 const hasDuetAlias = ['dueto', 'duo', 'mixta', 'mixto', 'mixed'].some((alias) => v.includes(alias));
 return (hasHombre && hasMujer) || hasDuetAlias;
 }

 if (f === 'hombre') {
 return ['hombre', 'masculino', 'male', 'tenor'].some((alias) => v.includes(alias));
 }

 if (f === 'mujer') {
 return ['mujer', 'femenino', 'female', 'soprano', 'alto', 'contralto'].some((alias) => v.includes(alias));
 }

 return v.includes(f);
};

const formatTime = (seconds: number) => {
   if (!Number.isFinite(seconds) || seconds < 0) return '00:00';
   const total = Math.floor(seconds);
   const min = Math.floor(total / 60);
   const sec = total % 60;
   return `${String(min).padStart(2, '0')}:${String(sec).padStart(2, '0')}`;
 };

const matchCategoria = (categoriaValue, categoriaFilter) => {
 const c = normalizeStr(categoriaValue);
 const f = normalizeStr(categoriaFilter);
 if (f === 'todas') return true;

 if (f.startsWith('rapid')) return c.includes('rapid');
 if (f.startsWith('lent')) return c.includes('lent');
 if (f.startsWith('trans')) return c.includes('trans');

 return c.includes(f);
};

 function debounce(func, wait) {
 let timeout;
 return function(...args) {
 clearTimeout(timeout);
 timeout = setTimeout(() => func(...args), wait);
 };
 }

function filterCards() {
 const searchTerm = normalizeStr(searchInput.value).trim();
 const vozTerm = normalizeStr(filterVoz.value);
 const categoriaTerm = normalizeStr(filterCategoria.value);
 const temaTerm = normalizeStr(filterTema.value);

 todasLasCanciones.forEach(card => card.classList.add('cancion-oculta'));
 indiceActual = 0;

 cancionesFiltradas = todasLasCanciones.filter(card => {
 const titulo = normalizeStr(card.getAttribute('data-titulo') || '');
 const artista = normalizeStr(card.getAttribute('data-artista') || '');
 const voz = normalizeStr(card.getAttribute('data-voz') || '');
 const categoria = normalizeStr(card.getAttribute('data-categoria') || '');
 const tema = normalizeStr(card.getAttribute('data-tema') || '');

 const matchesSearch = titulo.includes(searchTerm) || artista.includes(searchTerm);
 const matchesVoz = matchVoz(voz, vozTerm);
 const matchesCategoria = matchCategoria(categoria, categoriaTerm);
 const matchesTema = temaTerm === 'todas' || tema.includes(temaTerm);

 return matchesSearch && matchesVoz && matchesCategoria && matchesTema;
 });

 cancionesFiltradas = sortSongsSelectedFirst(cancionesFiltradas);
 applySongOrder(cancionesFiltradas);

 todasLasCanciones.forEach(card => card.style.display = 'none');
 cargarMasCanciones();
 }

 const debouncedFilterCards = debounce(filterCards, 300);

 if(searchInput) addListener(searchInput, 'input', debouncedFilterCards);
 if(filterVoz) addListener(filterVoz, 'change', debouncedFilterCards);
 if(filterCategoria) addListener(filterCategoria, 'change', debouncedFilterCards);
 if(filterTema) addListener(filterTema, 'change', debouncedFilterCards);


 // Helper para Playlist modular
 function updatePlaylistCount() {
 if (playlistCountEl) playlistCountEl.textContent = selectedSongs.length.toString();
 }
 }

 if (!repertorioWindow.__REPERTORIO_INIT_BOUND__) {
  document.addEventListener('astro:page-load', initRepertorio);
  repertorioWindow.__REPERTORIO_INIT_BOUND__ = true;
 }

 if (!repertorioWindow.__REPERTORIO_BEFORE_SWAP_BOUND__) {
  document.addEventListener('astro:before-swap', cleanupRepertorioRuntime);
  repertorioWindow.__REPERTORIO_BEFORE_SWAP_BOUND__ = true;
 }

 void initRepertorio();
</script>

