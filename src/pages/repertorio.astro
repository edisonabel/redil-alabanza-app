 const dispatchProPlayerEvent = (payload: {
  url: string;
  title?: string;
  artist?: string;
  isDirectPlayable?: boolean;
  autoPlay?: boolean;
  songId?: string;
  chordpro?: string;
  sectionMarkers?: any[];
  artworkUrl?: string;
 }) => {
  const url = (payload?.url || '').trim();
  if (!url) return;
  const proPlayer = (window as any).__REDIL_PRO_PLAYER__;
  if (proPlayer && typeof proPlayer.open === 'function') {
   proPlayer.open({
    url,
    title: payload.title,
    artist: payload.artist,
    autoPlay: payload.autoPlay !== false,
    songId: payload.songId,
    chordpro: payload.chordpro,
    sectionMarkers: payload.sectionMarkers,
    artworkUrl: payload.artworkUrl,
   });
   return;
  }
  window.dispatchEvent(new CustomEvent('play-pro-audio', { detail: payload }));
 };

