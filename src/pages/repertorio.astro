 const requestSelectionArtwork = (image: HTMLImageElement) => {
  const source = image.dataset.selectionArtworkSrc || '';
  const shell = image.closest('.selection-artwork');

  const clearArtworkTimeout = () => {
   const timeoutId = selectionArtworkTimeouts.get(image);
   if (timeoutId) window.clearTimeout(timeoutId);
   selectionArtworkTimeouts.delete(image);
  };

  const markArtworkLoaded = () => {
   clearArtworkTimeout();
   shell?.classList.remove('is-loading');
   shell?.classList.remove('is-fallback');
   shell?.classList.add('is-loaded');
  };

  const markArtworkFallback = () => {
   clearArtworkTimeout();
   shell?.classList.remove('is-loading');
   shell?.classList.remove('is-loaded');
   shell?.classList.add('is-fallback');
   image.removeAttribute('src');
  };

  const handleArtworkError = () => {
   const fallbackSource = image.dataset.selectionArtworkFallbackSrc || '';
   if (fallbackSource && image.dataset.selectionArtworkFallbackRequested !== 'true') {
    image.dataset.selectionArtworkFallbackRequested = 'true';
    image.src = fallbackSource;
    return;
   }

   markArtworkFallback();
  };

  if (image.dataset.selectionArtworkListenersBound !== 'true') {
   image.dataset.selectionArtworkListenersBound = 'true';
   addListener(image, 'load', markArtworkLoaded);
   addListener(image, 'error', handleArtworkError);
   cleanupFns.push(() => {
    delete image.dataset.selectionArtworkListenersBound;
   });
  }

  if (!source) {
   markArtworkFallback();
   return;
  }

  if (!shell?.classList.contains('is-loaded')) {
   shell?.classList.remove('is-fallback');
   shell?.classList.add('is-loading');
  }

  clearArtworkTimeout();
  const timeoutId = window.setTimeout(() => {
   if (!shell?.classList.contains('is-loaded')) markArtworkFallback();
  }, 12000);
  selectionArtworkTimeouts.set(image, timeoutId);

  if (image.dataset.selectionArtworkRequested !== 'true') {
   image.dataset.selectionArtworkRequested = 'true';
   image.src = source;
  } else if (!image.getAttribute('src')) {
   const fallbackSource = image.dataset.selectionArtworkFallbackSrc || '';
   image.src = image.dataset.selectionArtworkFallbackRequested === 'true' && fallbackSource
    ? fallbackSource
    : source;
  }

  queueMicrotask(() => {
   if (!image.complete) return;
   if (image.naturalWidth > 0) markArtworkLoaded();
   else handleArtworkError();
  });
 };

 const initializeSelectionArtwork = () => {
  if (selectionArtworkObserver) {
   selectionArtworkObserver.disconnect();
   selectionArtworkObserver = null;
  }
  const images = Array.from(
   document.querySelectorAll<HTMLImageElement>('[data-selection-artwork-src]'),
  );
  if (!images.length) return;

  const priorityCount = Math.min(3, images.length);
  images.slice(0, priorityCount).forEach((image) => {
   image.loading = 'eager';
   image.fetchPriority = 'high';
   requestSelectionArtwork(image);
  });

  const deferredImages = images.slice(priorityCount);
  if (!deferredImages.length) return;

  if (!('IntersectionObserver' in window)) {
   deferredImages.forEach(requestSelectionArtwork);
   return;
  }

  selectionArtworkObserver = new IntersectionObserver((entries) => {
   entries.forEach((entry) => {
    if (!entry.isIntersecting) return;
    const image = entry.target as HTMLImageElement;
    requestSelectionArtwork(image);
    selectionArtworkObserver?.unobserve(image);
   });
  }, { root: null, rootMargin: '320px 0px', threshold: 0.01 });

  deferredImages.forEach((image) => selectionArtworkObserver?.observe(image));
 };

 const measureSelectionMarquees = () => {
  const isMobileCompactList = window.matchMedia('(max-width: 767px)').matches
   && (isSelectionMode || document.body.classList.contains('repertorio-compact-list-mode'));
  const titles = Array.from(document.querySelectorAll<HTMLElement>(
   '#gridCanciones .card-title',
  ));

  titles.forEach((title, index) => {
   const text = title.querySelector<HTMLElement>('.card-title-marquee');
   title.classList.remove('is-overflowing');
   title.style.removeProperty('--marquee-distance');
   title.style.removeProperty('--marquee-duration');
   title.style.removeProperty('--marquee-delay');
   if (!isMobileCompactList || !text || title.clientWidth <= 0) return;

   text.classList.add('is-measuring');
   const naturalWidth = Math.ceil(text.getBoundingClientRect().width);
   text.classList.remove('is-measuring');
   const overflow = naturalWidth - title.clientWidth;
   if (overflow <= 3) return;

   title.style.setProperty('--marquee-distance', `${overflow + 12}px`);
   title.style.setProperty('--marquee-duration', `${Math.min(18, Math.max(11, 9 + overflow / 18)).toFixed(1)}s`);
   title.style.setProperty('--marquee-delay', `${(index % 5) * 0.45}s`);
   title.classList.add('is-overflowing');
  });
 };

 const scheduleSelectionMarqueeMeasurement = () => {
  if (selectionMarqueeFrame) cancelAnimationFrame(selectionMarqueeFrame);
  selectionMarqueeFrame = requestAnimationFrame(() => {
   selectionMarqueeFrame = 0;
   if (!isStaleInit()) measureSelectionMarquees();
  });
 };

 addListener(window, 'resize', () => {
  if (selectionMarqueeResizeTimer) clearTimeout(selectionMarqueeResizeTimer);
  selectionMarqueeResizeTimer = setTimeout(scheduleSelectionMarqueeMeasurement, 120);
 }, { passive: true });

