 </button>
 <button id="btnViewList" class="p-1.5 rounded-md text-content-muted hover:text-content transition-all" title="Vista de Lista">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
 </button>
 </div>
 </div>

 <!-- Grid de Canciones -->
 <div id="gridCanciones" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto">
 {canciones.map((cancion: any, index: number) => (
 <CardCancion 
 titulo={cancion.titulo || ''}
 cantante={cancion.cantante || cancion.artista || ''}
 tonalidad={cancion.tonalidad || ''}
 bpm={cancion.bpm || 0}
 linkLetra={cancion.link_letras || ''}
 linkAcordes={cancion.link_acordes || ''}
 linkVoces={cancion.link_voces || ''}
 linkYoutube={cancion.link_youtube || ''}
 linkSecuencias={cancion.link_secuencias || ''}
 linkMp3={cancion.mp3 || cancion.MP3 || ''}
 chordpro={cancion.chordpro || ''}
 categoria={cancion.categoria || ''}
 voz={cancion.voz || cancion.voz_principal || ''}
 tema={cancion.tema || ''}
 estado={cancion.estado || ''}
 oculta={index >= 15}
 />
 ))}
 </div>

 <!-- Centinela para Infinite Scroll -->
 <div id="scroll-sentinel" class="h-4 w-full mt-8"></div>

 <!-- Panel Flotante Setlist (modo normal) -->
<div id="setlistPanel" class="fixed bottom-[calc(env(safe-area-inset-bottom)+5rem)] md:bottom-24 left-3 right-3 md:left-auto md:right-6 bg-background border border-border text-content p-3 md:p-4 rounded-xl md:rounded-2xl shadow-2xl z-50 flex items-center justify-between gap-3 md:gap-4 hidden transition-opacity">
 <div class="font-semibold text-sm md:text-base whitespace-nowrap">
 Setlist: <span id="setlistCount" class="text-blue-400">0</span>
 </div>
 <div class="flex items-center gap-2 shrink-0">
 <button id="btnCopySetlist" class="px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-bold transition-colors">Copiar Enlace</button>
 <button id="btnClearSetlist" class="px-3.5 py-2 bg-neutral/20 text-neutral hover:bg-neutral-300 rounded-lg text-sm font-bold transition-colors">Limpiar</button>
 </div>
 </div>

 <!-- Barra Flotante Playlist (modo seleccion) - Inyeccion modular -->
<div id="playlistBar" class="fixed bottom-[calc(env(safe-area-inset-bottom)+5rem)] md:bottom-16 left-0 right-0 z-50 bg-surface border-t border-border shadow-[0_-8px_30px_rgba(0,0,0,0.3)] px-4 py-3 hidden">
 <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3 sm:gap-4">
 <div class="flex items-start sm:items-center gap-3">
 <div class="w-10 h-10 rounded-full bg-brand/20 flex items-center justify-center">
 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-teal-400"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
 </div>
 <div>
 <p class="text-content font-bold text-base leading-tight"><span id="playlistCount">0</span> Canciones Seleccionadas</p>
 <p class="text-content-muted text-sm leading-tight">Toca el + de cada canci&oacute;n para agregar o quitar</p>
 </div>
 </div>
 <div class="flex items-center gap-2">
 <button id="btn-cancel-playlist" class="flex-1 sm:flex-none px-4 py-2.5 rounded-xl border border-border text-content-muted text-sm font-bold hover:bg-background transition-colors">
 Cancelar
 </button>
 <button id="btn-save-playlist" class="flex-1 sm:flex-none px-5 py-2.5 rounded-xl bg-gradient-to-r from-teal-600 to-emerald-600 text-white text-sm font-bold hover:opacity-90 transition-all shadow-lg flex items-center justify-center gap-2">
 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
 Guardar Setlist
 </button>
 </div>
 </div>
</div>

<!-- Modal Reproductor MP3 (Modo Ensayo con Loop A-B) -->
<div id="mp3PlayerModal" class="fixed inset-0 z-[130] hidden">
  <div id="mp3PlayerBackdrop" class="absolute inset-0 bg-overlay/70 backdrop-blur-sm"></div>
  <div class="relative z-10 w-full h-full flex items-end md:items-center justify-center p-0 md:p-4">
    <div class="w-full md:max-w-2xl bg-surface border border-border rounded-t-3xl md:rounded-3xl shadow-2xl p-5 md:p-6">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <h3 id="mp3Title" class="text-lg md:text-xl font-black text-content truncate">Canción</h3>
          <p id="mp3Artist" class="text-sm text-content-muted truncate">Artista</p>
        </div>
        <button id="btnMp3Close" type="button" class="w-9 h-9 rounded-xl border border-border bg-background text-content-muted hover:text-content hover:bg-surface transition-colors" aria-label="Cerrar reproductor">✕</button>
      </div>

      <audio id="mp3Audio" class="hidden" preload="metadata"></audio>

      <div class="mt-4 rounded-2xl border border-border bg-background/70 p-4">
        <div class="flex items-center gap-2">
          <button id="btnMp3PlayPause" type="button" class="w-12 h-12 rounded-full bg-action text-white grid place-items-center hover:bg-action/90 transition-colors shadow-lg" aria-label="Reproducir">
            <svg id="mp3PlayIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-6 h-6 fill-current"><path d="M8 5v14l11-7z"></path></svg>
          </button>
          <span id="mp3CurrentTime" class="text-xs font-semibold text-content-muted w-12 text-right">00:00</span>
          <div id="mp3TimelineWrap" class="relative flex-1 h-8 flex items-center">
            <canvas id="mp3Waveform" class="pointer-events-none absolute inset-x-0 top-1/2 -translate-y-1/2 h-8 w-full opacity-80"></canvas>
            <input id="mp3Seek" type="range" min="0" max="100" value="0" class="w-full accent-action" />
            <div id="mp3LoopBracket" class="hidden pointer-events-none absolute inset-x-0 top-1/2 -translate-y-1/2 h-2">
              <div id="mp3LoopRangeFill" class="absolute top-0 h-2 rounded-full bg-brand/35"></div>
              <button id="mp3LoopHandleA" type="button" class="mp3-loop-handle pointer-events-auto absolute top-1/2 -translate-x-1/2 -translate-y-1/2 w-5 h-5 rounded-md bg-surface text-brand border border-brand/70 shadow-sm grid place-items-center text-xs font-black leading-none" aria-label="Bracket A">[</button>
              <button id="mp3LoopHandleB" type="button" class="mp3-loop-handle pointer-events-auto absolute top-1/2 -translate-x-1/2 -translate-y-1/2 w-5 h-5 rounded-md bg-surface text-brand border border-brand/70 shadow-sm grid place-items-center text-xs font-black leading-none" aria-label="Bracket B">]</button>
            </div>
          </div>
          <span id="mp3Duration" class="text-xs font-semibold text-content-muted w-12">00:00</span>
        </div>

        <div class="mt-3 flex items-center justify-between gap-3 flex-wrap">
          <label class="inline-flex items-center gap-2 text-sm font-semibold text-content">
            <input id="chkLoopRange" type="checkbox" class="w-4 h-4 rounded border-border accent-action" />
            Loop [A-B] (ensayo)
          </label>
          <p id="mp3LoopInfo" class="text-xs text-content-muted">[A] 00:00 - [B] 00:00</p>
          <button id="btnClearLoopRange" type="button" class="px-3 py-1.5 rounded-xl border border-border bg-surface text-content text-xs font-bold hover:bg-background transition-colors">Limpiar loop</button>
        </div>
        <p id="mp3Status" class="mt-2 text-xs text-content-muted">Activa el loop y arrastra los brackets A/B sobre la barra.</p>
      </div>
    </div>
  </div>
</div>
</Layout>

 <!-- Data bridge eliminado. Supabase renderiza directamente. -->
 <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
 
 <script>
 import { supabase } from '../lib/supabase';

 document.addEventListener('DOMContentLoaded', async () => {
 // Puerta Guardiana de Seguridad RLS: Verificar Sesion Activa
 const { data: { session }, error: sessionError } = await supabase.auth.getSession();
 if (sessionError || !session) {
 // Expulsar solicitudes anonimas inmediatamente re-direccionando hacia el tunel de autenticacion
 /* window.location.replace('/login'); Movido a Middleware */
 return;
 }
 
 const searchInput = document.getElementById('searchInput') as HTMLInputElement;
 const filterVoz = document.getElementById('filterVoz') as HTMLSelectElement;
 const filterCategoria = document.getElementById('filterCategoria') as HTMLSelectElement;
 const filterTema = document.getElementById('filterTema') as HTMLSelectElement;
 
 const mainTitle = document.getElementById('mainTitle');
 const searchControls = document.getElementById('searchControls');
 const setlistPanel = document.getElementById('setlistPanel');
 const setlistCount = document.getElementById('setlistCount');
 const btnCopySetlist = document.getElementById('btnCopySetlist');
 const btnClearSetlist = document.getElementById('btnClearSetlist');

 const mp3PlayerModal = document.getElementById('mp3PlayerModal') as HTMLElement;
 const mp3PlayerBackdrop = document.getElementById('mp3PlayerBackdrop') as HTMLElement;
 const btnMp3Close = document.getElementById('btnMp3Close') as HTMLButtonElement;
 const mp3Title = document.getElementById('mp3Title') as HTMLElement;
 const mp3Artist = document.getElementById('mp3Artist') as HTMLElement;
 const mp3Status = document.getElementById('mp3Status') as HTMLElement;
 const mp3Audio = document.getElementById('mp3Audio') as HTMLAudioElement;
 const btnMp3PlayPause = document.getElementById('btnMp3PlayPause') as HTMLButtonElement;
 const mp3PlayIcon = document.getElementById('mp3PlayIcon') as SVGElement;
 const mp3TimelineWrap = document.getElementById('mp3TimelineWrap') as HTMLElement;
 const mp3Waveform = document.getElementById('mp3Waveform') as HTMLCanvasElement;
 const mp3Seek = document.getElementById('mp3Seek') as HTMLInputElement;
 const mp3CurrentTime = document.getElementById('mp3CurrentTime') as HTMLElement;
 const mp3Duration = document.getElementById('mp3Duration') as HTMLElement;
 const mp3LoopBracket = document.getElementById('mp3LoopBracket') as HTMLElement;
 const mp3LoopRangeFill = document.getElementById('mp3LoopRangeFill') as HTMLElement;
 const mp3LoopHandleA = document.getElementById('mp3LoopHandleA') as HTMLButtonElement;
 const mp3LoopHandleB = document.getElementById('mp3LoopHandleB') as HTMLButtonElement;
 const btnClearLoopRange = document.getElementById('btnClearLoopRange') as HTMLButtonElement;
 const chkLoopRange = document.getElementById('chkLoopRange') as HTMLInputElement;
 const mp3LoopInfo = document.getElementById('mp3LoopInfo') as HTMLElement;
 
 const btnViewGrid = document.getElementById('btnViewGrid');
 const btnViewList = document.getElementById('btnViewList');
 const gridCanciones = document.getElementById('gridCanciones');
 
 // Obtenemos todos los <article> dentro del grid
 const cards = document.querySelectorAll('#gridCanciones article') as NodeListOf<HTMLElement>;

 // ----- View Toggle Logic -----
 let isListView = false;

 function setGridView() {
 if (!gridCanciones) return;
 isListView = false;
 
 // Switch classes on container
 gridCanciones.className = 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto';
 
 // Remove list mode from all cards
 cards.forEach(card => card.classList.remove('modo-lista', 'expandido'));
 
 // Update button styles
 const updateBtns = (gridBtn: HTMLElement | null, listBtn: HTMLElement | null) => {
 if(!gridBtn || !listBtn) return;
 gridBtn.classList.add('bg-background', 'text-white', 'shadow-sm');
 gridBtn.classList.remove('text-content-muted', 'hover:text-content');
 listBtn.classList.remove('bg-background', 'text-white', 'shadow-sm');
 listBtn.classList.add('text-content-muted', 'hover:text-content');
 };
 
 updateBtns(btnViewGrid, btnViewList);
 void document.body.offsetHeight; // Fuerza un reflow para corregir glitches de repintado en iOS
 }

 function setListView() {
 if (!gridCanciones) return;
 isListView = true;
 
 // Switch classes on container to vertical flow
 gridCanciones.className = 'flex flex-col gap-3 max-w-4xl mx-auto';
 
 // Add list mode to all cards
 cards.forEach(card => card.classList.add('modo-lista'));
 
 // Update button styles
 const updateBtns = (gridBtn: HTMLElement | null, listBtn: HTMLElement | null) => {
 if(!gridBtn || !listBtn) return;
 listBtn.classList.add('bg-background', 'text-white', 'shadow-sm');
 listBtn.classList.remove('text-content-muted', 'hover:text-content');
 gridBtn.classList.remove('bg-background', 'text-white', 'shadow-sm');
 gridBtn.classList.add('text-content-muted', 'hover:text-content');
 };
 
 updateBtns(btnViewGrid, btnViewList);
 void document.body.offsetHeight; // Fuerza un reflow para corregir glitches de repintado en iOS
 }

 if(btnViewGrid) btnViewGrid.addEventListener('click', setGridView);
 if(btnViewList) btnViewList.addEventListener('click', setListView);

 // Accordion logic for list view
 cards.forEach(card => {
 const header = card.querySelector('.card-header');
 if (header) {
 header.addEventListener('click', (e) => {
 // Prevent toggling if user clicked the Add to Setlist button
 if ((e.target as Element).closest('.btn-add-setlist')) return;
 
 if (isListView) {
 card.classList.toggle('expandido');
 }
 });
 }
 });

 
 // =============================================
 // DETECCION DE MODOS DE LA PAGINA (Setlist Semanal vs Playlist vs Normal)
 // =============================================
 const urlParams = new URLSearchParams(window.location.search);
 const seleccionarPara = urlParams.get('seleccionar_para');
 const setlistParam = urlParams.get('setlist');
 const isSelectionMode = !!seleccionarPara;
