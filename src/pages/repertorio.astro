 let resourceHintFrame = 0;
 const updateResourceActionHint = (scroller: HTMLElement) => {
  const shell = scroller.closest('.resource-actions-shell') as HTMLElement | null;
  if (!shell) return;
  const hasOverflow = scroller.scrollWidth - scroller.clientWidth > 8;
  const canScrollBack = hasOverflow && scroller.scrollLeft > 12;
  const isAtEnd = scroller.scrollLeft + scroller.clientWidth >= scroller.scrollWidth - 12;
  const canScrollForward = hasOverflow && !isAtEnd;
  shell.classList.toggle('has-overflow', hasOverflow);
  shell.classList.toggle('has-more', canScrollForward);
  shell.classList.toggle('can-scroll-back', canScrollBack);
  shell.classList.toggle('can-scroll-forward', canScrollForward);
 };

 const syncResourceActionHints = () => {
  resourceHintFrame = 0;
  document.querySelectorAll('.resource-actions').forEach((scroller) => {
   updateResourceActionHint(scroller as HTMLElement);
  });
 };

 const scheduleResourceActionHints = () => {
  if (resourceHintFrame) return;
  resourceHintFrame = window.requestAnimationFrame(syncResourceActionHints);
 };

 const bindResourceActionHints = () => {
  document.querySelectorAll('.resource-actions').forEach((scroller) => {
   const el = scroller as HTMLElement;
   if (el.dataset.resourceHintBound === 'true') return;
   el.dataset.resourceHintBound = 'true';
   addListener(el, 'scroll', scheduleResourceActionHints, { passive: true });
   cleanupFns.push(() => {
    delete el.dataset.resourceHintBound;
   });

   const shell = el.closest('.resource-actions-shell') as HTMLElement | null;
   shell?.querySelectorAll('[data-resource-scroll]').forEach((button) => {
    const control = button as HTMLButtonElement;
    if (control.dataset.resourceScrollBound === 'true') return;
    control.dataset.resourceScrollBound = 'true';
    addListener(control, 'click', (event) => {
     event.preventDefault();
     event.stopPropagation();
     const direction = control.dataset.resourceScroll === 'prev' ? -1 : 1;
     const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
     const distance = Math.max(180, Math.round(el.clientWidth * 0.72));
     el.scrollBy({
      left: direction * distance,
      behavior: reducedMotion ? 'auto' : 'smooth',
     });
     scheduleResourceActionHints();
     window.setTimeout(scheduleResourceActionHints, reducedMotion ? 30 : 320);
    });
    cleanupFns.push(() => {
     delete control.dataset.resourceScrollBound;
    });
   });
  });
  scheduleResourceActionHints();
 };
 requestAnimationFrame(bindResourceActionHints);
 addListener(window, 'resize', scheduleResourceActionHints, { passive: true });

 let lastSearchScrollY = Math.max(window.scrollY, 0);
 let searchScrollTicking = false;
 let searchControlsHidden = false;

 const setSearchControlsHidden = (hidden: boolean) => {
  if (!searchControls || searchControlsHidden === hidden) return;
  searchControlsHidden = hidden;
  searchControls.classList.toggle('is-hidden', hidden);
 };

 const keepSearchControlsVisible = () => {
  lastSearchScrollY = Math.max(window.scrollY, 0);
  setSearchControlsHidden(false);
 };

 const handleSearchControlsScroll = () => {
  if (!searchControls || searchScrollTicking) return;
  searchScrollTicking = true;

  window.requestAnimationFrame(() => {
   const currentScrollY = Math.max(window.scrollY, 0);
   const diff = currentScrollY - lastSearchScrollY;
   const focusedElement = document.activeElement;
   const controlsFocused = Boolean(focusedElement && searchControls.contains(focusedElement));
   const filtersOpen = advancedFilters?.dataset.open === 'true' || Boolean(mobileFiltersDialog?.open);
   const accordionBusy = document.body.classList.contains('repertorio-accordion-busy');

   if (currentScrollY <= 80 || controlsFocused || filtersOpen || accordionBusy) {
    setSearchControlsHidden(false);
    lastSearchScrollY = currentScrollY;
    searchScrollTicking = false;
    return;
   }

   if (Math.abs(diff) >= 8) {
    if (diff > 0 && currentScrollY > 120) {
     setSearchControlsHidden(true);
    } else if (diff < 0) {
     setSearchControlsHidden(false);
    }

    lastSearchScrollY = currentScrollY;
   }

   searchScrollTicking = false;
  });
 };

 addListener(window, 'scroll', handleSearchControlsScroll, { passive: true });
 addListener(searchControls, 'focusin', keepSearchControlsVisible);
