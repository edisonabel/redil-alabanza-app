  <OnboardingRoot client:idle page="repertorio" userId={userId} />
</Layout>

 <!-- Data bridge eliminado. Supabase renderiza directamente. -->
 <!-- SortableJS se carga dinámicamente solo cuando se necesita (modo setlist) -->
 
<script>
import { supabase } from '../lib/supabase';
import { metronomeService } from '../services/MetronomeEngine';
import { safeHtml } from '../lib/client/html-safety.js';

 type RepertorioWindow = Window & {
  __REPERTORIO_INIT_BOUND__?: boolean;
  __REPERTORIO_BEFORE_SWAP_BOUND__?: boolean;
  __REPERTORIO_INIT_RUN_ID__?: number;
  __REPERTORIO_CLEANUP__?: (() => void) | null;
  __REPERTORIO_METRONOME__?: {
   activeDot: HTMLElement | null;
   audioCtx: AudioContext | null;
  };
 };

 const repertorioWindow = window as RepertorioWindow;
 const loadSongRegistry = () => {
  const songRegistryElement = document.getElementById('repertorioSongRegistry');
  try {
   (window as any).__REDIL_SONG_REGISTRY__ = JSON.parse(songRegistryElement?.textContent || '{}');
  } catch (error) {
   console.warn('Repertorio: no se pudo leer el registro local de canciones.', error);
   (window as any).__REDIL_SONG_REGISTRY__ = {};
  }
 };
 const nextRepertorioInitRun = () => {
  repertorioWindow.__REPERTORIO_INIT_RUN_ID__ = (repertorioWindow.__REPERTORIO_INIT_RUN_ID__ ?? 0) + 1;
  return repertorioWindow.__REPERTORIO_INIT_RUN_ID__;
 };

 const cleanupRepertorioRuntime = () => {
  nextRepertorioInitRun();
  if (typeof repertorioWindow.__REPERTORIO_CLEANUP__ === 'function') {
   repertorioWindow.__REPERTORIO_CLEANUP__();
  }
  repertorioWindow.__REPERTORIO_CLEANUP__ = null;
 };

 async function initRepertorio() {
 cleanupRepertorioRuntime();
 if (!window.location.pathname.startsWith('/repertorio')) return;
 loadSongRegistry();
 const initRunId = nextRepertorioInitRun();
 const isStaleInit = () => repertorioWindow.__REPERTORIO_INIT_RUN_ID__ !== initRunId;

 const cleanupFns: Array<() => void> = [];
 const addListener = (
  target: EventTarget | null | undefined,
  type: string,
  handler: EventListenerOrEventListenerObject,
  options: AddEventListenerOptions | boolean = false,
 ) => {
  if (!target) return;
  target.addEventListener(type, handler as EventListener, options as AddEventListenerOptions);
  cleanupFns.push(() => {
   target.removeEventListener(type, handler as EventListener, options as EventListenerOptions);
  });
 };

  let observer: IntersectionObserver | null = null;
  let selectionArtworkObserver: IntersectionObserver | null = null;
  const selectionArtworkTimeouts = new Map<HTMLImageElement, number>();
  let selectionMarqueeFrame = 0;
  let selectionMarqueeResizeTimer: ReturnType<typeof setTimeout> | null = null;
  let accordionBusyTimer: ReturnType<typeof setTimeout> | null = null;
  const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
  const metronomeState = repertorioWindow.__REPERTORIO_METRONOME__ || {
   activeDot: null,
   audioCtx: null,
  };
 repertorioWindow.__REPERTORIO_METRONOME__ = metronomeState;

 const getSharedAudioCtx = () => {
  if (!AudioContextClass) return null;
  if (!metronomeState.audioCtx || metronomeState.audioCtx.state === 'closed') {
   metronomeState.audioCtx = new AudioContextClass();
  }
  return metronomeState.audioCtx;
  };

  const stopMetronome = () => {
   metronomeService.stop();
   if (metronomeState.activeDot) {
    metronomeState.activeDot.classList.remove('beat-active');
    metronomeState.activeDot.style.removeProperty('--bpm-duration');
    metronomeState.activeDot = null;
   }
 };

 repertorioWindow.__REPERTORIO_CLEANUP__ = () => {
  cleanupFns.forEach((dispose) => {
   try {
    dispose();
   } catch {
    // no-op
   }
  });
  cleanupFns.length = 0;

  if (observer) {
   observer.disconnect();
   observer = null;
  }

  if (selectionArtworkObserver) {
   selectionArtworkObserver.disconnect();
   selectionArtworkObserver = null;
  }

  selectionArtworkTimeouts.forEach((timeoutId) => window.clearTimeout(timeoutId));
  selectionArtworkTimeouts.clear();

  if (selectionMarqueeFrame) {
   cancelAnimationFrame(selectionMarqueeFrame);
   selectionMarqueeFrame = 0;
  }
  if (selectionMarqueeResizeTimer) {
   clearTimeout(selectionMarqueeResizeTimer);
   selectionMarqueeResizeTimer = null;
  }
  if (accordionBusyTimer) {
   clearTimeout(accordionBusyTimer);
   accordionBusyTimer = null;
  }

  document.body.classList.remove(
   'repertorio-selection-mode',
   'repertorio-compact-list-mode',
   'repertorio-shared-setlist-mode',
   'repertorio-accordion-busy',
   'mobile-filters-open',
  );

  const mobileFiltersDialog = document.getElementById('mobileFiltersDialog') as HTMLDialogElement | null;
  if (mobileFiltersDialog?.open) mobileFiltersDialog.close();

  stopMetronome();

  const anyAudio = document.querySelector('audio') as HTMLAudioElement | null;
  if (anyAudio) {
   try {
    anyAudio.pause();
   } catch {
    // no-op
   }
  }

  const modal = document.getElementById('vocesModal') as HTMLElement | null;
  const backdrop = document.getElementById('vocesBackdrop') as HTMLElement | null;
  const panel = document.getElementById('vocesPanel') as HTMLElement | null;
  if (modal && !modal.classList.contains('hidden')) {
   modal.classList.add('hidden');
   modal.setAttribute('aria-hidden', 'true');
   backdrop?.classList.add('opacity-0');
   panel?.classList.add('opacity-0', 'translate-y-4');
  }

  if (document.body.dataset.vocesModalOpen === 'true') {
   delete document.body.dataset.vocesModalOpen;
   document.body.style.position = '';
   document.body.style.top = '';
   document.body.style.left = '';
   document.body.style.right = '';
   document.body.style.width = '';
   document.body.style.overflow = '';
   document.documentElement.style.overflow = '';
  }
 };

