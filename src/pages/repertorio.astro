 </div>
 </section>

 <!-- Encabezado de Resultados y Vista -->
 <div class="max-w-7xl mx-auto mb-2 md:mb-4 mt-2 md:mt-8 flex justify-between items-center px-2 md:px-0">
 <h3 class="text-xl font-bold text-content mb-2 md:mb-4">Setlist</h3>
 <div id="viewToggleContainer" class="flex bg-surface flex-shrink-0 mb-2 md:mb-4 rounded-lg p-1 border border-border h-fit">
 <button id="btnViewGrid" class="p-1.5 rounded-md bg-surface text-content shadow-sm border border-border transition-all" title="Vista de Cuadr&iacute;cula">
