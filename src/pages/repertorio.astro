---
import Layout from '../layouts/Layout.astro';
import CardCancion from '../components/CardCancion.astro';
import BuscadorPredictivo from '../components/BuscadorPredictivo.astro';
import OnboardingRoot from '../components/onboarding/OnboardingRoot';
import { createSupabaseUserClient } from '../lib/server/supabase-user-client.js';
import { pickPreferredVoicePayload } from '../utils/voicePayload.js';
import { buildStoredSongArtworkUrl } from '../utils/songArtwork.js';

let canciones: any[] = [];
const userId = Astro.locals.user?.id ?? null;
const accessToken = Astro.locals.accessToken || '';
const supabaseSSR = createSupabaseUserClient(accessToken);
try {
  const { data, error } = await supabaseSSR
    .from('canciones')
    .select(`
      id,
      titulo,
      cantante,
      tonalidad,
      bpm,
      categoria,
      estado,
      tema,
      voz,
      chordpro,
      link_acordes,
      link_letras,
      link_secuencias,
      link_voces,
      link_youtube,
      mp3,
      multitrack_session,
      section_markers,
      voces
    `)
    .order('titulo');

  if (error) {
    console.error("Error fetching from Supabase:", error);
  } else if (data) {
    canciones = data.filter(c => c.estado !== 'Archivada');
  }
} catch (e) {
  console.error("Fetch failed", e);
}

const selectionEventId = String(Astro.url.searchParams.get('seleccionar_para') || '').trim();
let initialPlaylistSongIds: string[] = [];
if (/^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(selectionEventId)) {
  try {
    const { data: playlist, error: playlistError } = await supabaseSSR
      .from('playlists')
      .select('id')
      .eq('evento_id', selectionEventId)
      .maybeSingle();

    if (playlistError) throw playlistError;
    if (playlist?.id) {
      const { data: playlistItems, error: playlistItemsError } = await supabaseSSR
        .from('playlist_canciones')
        .select('cancion_id')
        .eq('playlist_id', playlist.id)
        .order('orden');
      if (playlistItemsError) throw playlistItemsError;
      initialPlaylistSongIds = (playlistItems || [])
        .map((item) => String(item.cancion_id || '').trim())
        .filter(Boolean);
    }
  } catch (error) {
    console.error('[repertorio] SSR playlist preload failed:', error);
  }
}

const temasUnicos = [...new Set(canciones.map((c: any) => c.tema).filter(Boolean))].sort() as string[];
const estadosUnicos = [...new Set(canciones.map((c: any) => c.estado).filter(Boolean))].sort() as string[];
const songRegistry = canciones.reduce((acc: Record<string, any>, cancion: any) => {
  const artwork = cancion.portada || cancion.imagen || cancion.image || cancion.cover || cancion.thumbnail
    || cancion.artwork || cancion.album_art || cancion.albumArt || cancion.caratula || cancion.foto || '';
  const resolvedArtwork = artwork || buildStoredSongArtworkUrl(cancion);
  if (!cancion.chordpro && !resolvedArtwork && !Array.isArray(cancion.section_markers)) return acc;

  const entry: Record<string, any> = {};
  if (cancion.chordpro) entry.c = cancion.chordpro;
  if (Array.isArray(cancion.section_markers) && cancion.section_markers.length) entry.m = cancion.section_markers;
  if (resolvedArtwork) entry.a = resolvedArtwork;
  if (Object.keys(entry).length) acc[String(cancion.id)] = entry;
  return acc;
}, {});
const serializedSongRegistry = JSON.stringify(songRegistry).replace(/</g, '\\u003c');
const visibleInitialSongs = canciones.slice(0, 15);
const firstTourCardId = visibleInitialSongs.find(Boolean)?.id ?? null;
const firstTourAudioId = visibleInitialSongs.find((c: any) => typeof c?.mp3 === 'string' && c.mp3.trim() !== '')?.id ?? firstTourCardId;
const firstTourResourcesId =
  visibleInitialSongs.find((c: any) =>
    ['voces', 'link_voces', 'link_acordes', 'link_youtube', 'link_secuencias'].some((key) => {
      const value = c?.[key];
      return typeof value === 'string' && value.trim() !== '';
    }),
  )?.id ?? firstTourAudioId ?? firstTourCardId;
