---
import Layout from '../layouts/Layout.astro';
import AdminRepertorio from '../components/AdminRepertorio.jsx';
---

<Layout>
  <main class="flex h-full min-h-0 flex-1 flex-col overflow-hidden bg-background">
    <header class="mb-1 w-full shrink-0 px-1 pt-1 sm:px-2 md:mb-2 md:px-3 xl:px-4">
      <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1.5 text-left">
        <a
          href="/repertorio"
          class="ui-no-press inline-flex h-9 w-9 items-center justify-center rounded-xl border border-border bg-surface/90 text-sm font-semibold text-content-muted transition-colors hover:border-brand/25 hover:text-content"
          aria-label="Volver"
          title="Volver"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
            <path d="m15 18-6-6 6-6"></path>
          </svg>
        </a>
        <div class="flex min-w-0 flex-1 flex-wrap items-center gap-x-2 gap-y-1.5">
          <h1 class="text-[1.45rem] font-bold leading-none tracking-[-0.03em] text-content md:text-[2.05rem]">
            Administraci&oacute;n
          </h1>
          <div id="admin-header-actions" class="flex min-w-0 flex-wrap items-center gap-1.5"></div>
        </div>
      </div>
    </header>

    <div class="min-h-0 flex-1 w-full overflow-hidden px-0">
      <AdminRepertorio client:load />
    </div>
  </main>
</Layout>
