---
import Layout from '../layouts/Layout.astro';
import AdminRepertorio from '../components/AdminRepertorio.jsx';
---

<Layout>
  <main class="min-h-screen bg-background">
    <header class="mt-2 mb-2 w-full px-3 md:mt-3 md:mb-3 md:px-5 xl:px-6">
      <div class="text-left">
        <div class="page-title-row mb-1">
          <span class="page-title-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 5v14"></path>
              <path d="M5 12h14"></path>
            </svg>
          </span>
          <h1 class="page-title text-[1.75rem] md:text-[2.75rem]">Administraci&oacute;n de Repertorio</h1>
        </div>
        <p class="page-subtitle text-sm md:text-base">Carga ChordPro, MP3 y tiempos de ensayo sin perder espacio en pantalla.</p>
      </div>
    </header>

    <div class="w-full px-0 md:px-0">
      <AdminRepertorio client:load />
    </div>
  </main>
</Layout>
