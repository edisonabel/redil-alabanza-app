---
import Layout from '../layouts/Layout.astro';
import ModalEvento from '../components/react/ModalEvento.jsx';
import ModalDetalle from '../components/react/ModalDetalle.jsx';
import ModalSerie from '../components/react/ModalSerie.jsx';
import CalendarioGrid from '../components/react/CalendarioGrid.jsx';
import OnboardingRoot from '../components/onboarding/OnboardingRoot';
import { createClient } from '@supabase/supabase-js';
import { getSupabaseServerEnv } from '../lib/server/supabase-env.js';

const INITIAL_MONTH_WINDOW = 2;

const initialFetchFloor = new Date(Date.now() - 12 * 60 * 60 * 1000);
const initialFetchLimit = new Date(initialFetchFloor);
initialFetchLimit.setMonth(initialFetchLimit.getMonth() + INITIAL_MONTH_WINDOW, 0);
initialFetchLimit.setHours(23, 59, 59, 999);

const accessToken = Astro.locals.accessToken || Astro.cookies.get('sb-access-token')?.value || '';
let ssrUser = Astro.locals.user || null;
let ssrRoles: any[] = [];
let ssrEventos: any[] = [];
let ssrAdmin = false;
let ssrCanEditTema = false;
let ssrHasMoreEventos = false;

if (!ssrUser || !accessToken) {
  return Astro.redirect('/login');
}

const { supabaseUrl, supabaseAnonKey } = getSupabaseServerEnv();
const supabaseSSR = createClient(supabaseUrl, supabaseAnonKey, {
  global: {
    headers: {
      Authorization: `Bearer ${accessToken}`,
    },
  },
  auth: {
    persistSession: false,
    autoRefreshToken: false,
  },
});

if (ssrUser) {
  const rolesPromise = supabaseSSR.from('roles').select('id, nombre, codigo').order('nombre');
  const perfilPromise = supabaseSSR.from('perfiles').select('is_admin').eq('id', ssrUser.id).maybeSingle();
  const canEditTemaPromise = supabaseSSR.rpc('has_sermon_edit_role');
  const eventosPromise = perfilPromise.then(({ data: perfil }) => {
    const isAdmin = perfil?.is_admin || false;

    let query = supabaseSSR
      .from('eventos')
      .select('id, titulo, fecha_hora, hora_fin, estado, es_acustico, notas_especiales, tema_predicacion, serie_id, asignaciones(id, rol_id, perfiles(id, nombre, email, avatar_url))')
      .gte('fecha_hora', initialFetchFloor.toISOString())
      .lte('fecha_hora', initialFetchLimit.toISOString())
      .order('fecha_hora', { ascending: true });

    if (!isAdmin) {
      query = query.eq('estado', 'Publicado');
    }

    return query;
  });
  const moreEventosPromise = perfilPromise.then(({ data: perfil }) => {
    const isAdmin = perfil?.is_admin || false;

    let query = supabaseSSR
      .from('eventos')
      .select('id', { count: 'exact', head: true })
      .gt('fecha_hora', initialFetchLimit.toISOString());

    if (!isAdmin) {
      query = query.eq('estado', 'Publicado');
    }

    return query;
  });

  const [
    { data: globalRoles, error: rolesError },
    { data: perfil, error: perfilError },
    { data: eventosDb, error: err },
    { count: moreEventosCount, error: moreEventosError },
    { data: hasSermonRole },
  ] = await Promise.all([rolesPromise, perfilPromise, eventosPromise, moreEventosPromise, canEditTemaPromise]);

  ssrRoles = globalRoles || [];
  ssrAdmin = perfil?.is_admin || false;
  ssrCanEditTema = ssrAdmin || (hasSermonRole === true);
  ssrHasMoreEventos = (moreEventosCount || 0) > 0;
  const queryError = err || perfilError || rolesError || moreEventosError;
  if (queryError) {
    console.error('[programacion] SSR query failed', queryError);
  }
  
  ssrEventos = eventosDb || [];
}
---

<Layout>
  <!-- Global inyecciÃ³n de SesiÃ³n SSR Segura para Vanilla JS Scripts posteriores (si quedan) -->
  <script is:inline define:vars={{ ssrUser }}>
    window.__SSR_USER__ = ssrUser;
  </script>

  <div class="max-w-6xl mx-auto px-4 mt-4 md:mt-8 w-full">
    <!-- Encabezado Maestro -->
    <header class="flex flex-col md:flex-row md:items-center justify-between gap-2 md:gap-4 mb-2 md:mb-6">
      <div>
        <div class="page-title-row">
          <span class="page-title-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
          </span>
          <h1 class="page-title text-[2.1rem] md:text-[3.5rem]">Programaci&oacute;n Mensual</h1>
        </div>
      </div>
    </header>

    <CalendarioGrid
        client:load
        initialEvents={ssrEventos}
        sessionUser={ssrUser}
        initialRoles={ssrRoles}
        isAdmin={ssrAdmin}
        canEditTema={ssrCanEditTema}
        initialLoadUntil={initialFetchLimit.toISOString()}
        hasMoreInitialEvents={ssrHasMoreEventos}
    />
    
    <!-- MODAL DE GESTIÃ“N (FASE 1) -->
    <ModalEvento client:only="react" />
    
    <!-- MODAL VISTA DETALLE COMPLETADO (FASE 1) -->
    <ModalDetalle client:only="react" initialRoles={ssrRoles} sessionUser={ssrUser} isAdmin={ssrAdmin} />

    <!-- MODAL GENERADOR DE SERIES -->
    <ModalSerie client:only="react" sessionUser={ssrUser} />
    <OnboardingRoot client:idle page="programacion" userId={ssrUser?.id ?? null} />
  </div>

  <style is:global>
    /* Ocultar scrollbar horizontal en mÃ³vil (mantiene swipe fluÃ­do snap-x) */
    @media (max-width: 768px) {
      .hide-scrollbar-on-mobile::-webkit-scrollbar {
        display: none;
      }
      .hide-scrollbar-on-mobile {
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
      }
    }
  </style>
</Layout>
