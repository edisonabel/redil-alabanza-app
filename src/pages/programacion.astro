---
import Layout from '../layouts/Layout.astro';
import ModalEvento from '../components/react/ModalEvento.jsx';
import ModalDetalle from '../components/react/ModalDetalle.jsx';
import ModalSerie from '../components/react/ModalSerie.jsx';
import CalendarioGrid from '../components/react/CalendarioGrid.jsx';
import { supabase } from '../lib/supabase';

// SSR Auth Retrieval (runs safely on the server)
const tokenCookie = Astro.cookies.get('sb-access-token');
const token = tokenCookie ? tokenCookie.value : null;
let ssrUser = null;
let ssrRoles = [];
let ssrEventos = [];
let queryError = null;
let ssrAdmin = false;

if (token) {
  const { data: userData } = await supabase.auth.getUser(token);
  ssrUser = userData?.user || null;
  
  if (!ssrUser) {
    Astro.cookies.delete('sb-access-token', { path: '/' });
    Astro.cookies.delete('sb-refresh-token', { path: '/' });
    return Astro.redirect('/login');
  }

  // Fetch inicial Roles globales
  const { data: globalRoles } = await supabase.from('roles').select('*').order('nombre');
  ssrRoles = globalRoles || [];

  // Fetch inicial Eventos filtrados por RBAC
  const { data: perfil } = await supabase.from('perfiles').select('is_admin').eq('id', ssrUser.id).single();
  ssrAdmin = perfil?.is_admin || false;
  
  let query = supabase.from('eventos')
    .select('*, asignaciones(rol_id, perfiles(id, nombre, email, avatar_url))')
    .gte('fecha_hora', new Date(Date.now() - 12 * 60 * 60 * 1000).toISOString())
    .order('fecha_hora', { ascending: true });
    
  if (!ssrAdmin) {
    query = query.eq('estado', 'Publicado');
  }
  
  const { data: eventosDb, error: err } = await query;
  queryError = err;
  
  console.log("=== PROGRAMACION QUERY LOG ===", { 
    error: queryError, 
    rowsCount: eventosDb?.length, 
    sample: eventosDb?.[0] ? {
        id: eventosDb[0].id,
        titulo: eventosDb[0].titulo,
        tema_predicacion: eventosDb[0].tema_predicacion,
        fecha_hora: eventosDb[0].fecha_hora,
        estado: eventosDb[0].estado,
        playlists: eventosDb[0].playlists
    } : null 
  });
  
  ssrEventos = eventosDb || [];
}
---

<Layout>
  <!-- Global inyección de Sesión SSR Segura para Vanilla JS Scripts posteriores (si quedan) -->
  <script is:inline define:vars={{ ssrUser }}>
    window.__SSR_USER__ = ssrUser;
  </script>

  <div class="max-w-6xl mx-auto px-4 mt-4 md:mt-8 w-full">
    <!-- Encabezado Maestro -->
    <header class="flex flex-col md:flex-row md:items-center justify-between gap-2 md:gap-4 mb-2 md:mb-6">
      <div>
        <h1 class="text-[2.5rem] md:text-5xl font-semibold tracking-tight text-neutral-900 flex items-center gap-2">
          Programación <span class="text-teal-400 font-medium tracking-normal -ml-1">Mensual</span>
        </h1>
      </div>
    </header>

    <CalendarioGrid 
        client:load 
        initialEvents={ssrEventos} 
        sessionUser={ssrUser} 
        initialRoles={ssrRoles} 
        ssrError={queryError?.message || null}
        isAdmin={ssrAdmin}
    />
    
    <!-- MODAL DE GESTIÓN (FASE 1) -->
    <ModalEvento client:only="react" />
    
    <!-- MODAL VISTA DETALLE COMPLETADO (FASE 1) -->
    <ModalDetalle client:only="react" initialRoles={ssrRoles} />

    <!-- MODAL GENERADOR DE SERIES -->
    <ModalSerie client:only="react" sessionUser={ssrUser} />
  </div>

  <style is:global>
    /* Ocultar scrollbar horizontal en móvil (mantiene swipe fluído snap-x) */
    @media (max-width: 768px) {
      .hide-scrollbar-on-mobile::-webkit-scrollbar {
        display: none;
      }
      .hide-scrollbar-on-mobile {
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
      }
    }
  </style>
</Layout>
