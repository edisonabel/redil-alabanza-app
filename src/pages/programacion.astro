 modalDetalle?.classList.remove('opacity-0');
 modalDetalleContent?.classList.remove('scale-95');
 modalDetalleContent?.classList.add('scale-100');
 }, 10);
 };

 const closeDetalle = () => {
 modalDetalleContent?.classList.remove('scale-100');
 modalDetalleContent?.classList.add('scale-95');
 modalDetalle?.classList.add('opacity-0');
 setTimeout(() => modalDetalle?.classList.add('hidden'), 300);
 };

 document.getElementById('btn-close-detalle')?.addEventListener('click', closeDetalle);
 modalDetalle?.addEventListener('click', (e) => { if (e.target === modalDetalle) closeDetalle(); }); 

 // ==========================================
 // LÓGICA DE SELECTORES DE VISTA (TABS)
 // ==========================================
 const btnViewCard = document.getElementById('btn-view-card');
 const btnViewList = document.getElementById('btn-view-list');
 const btnViewCalendar = document.getElementById('btn-view-calendar');
 
 const gridView = document.getElementById('agenda-grid');
 const listView = document.getElementById('agenda-list');
 const calendarView = document.getElementById('agenda-calendar');

 const activeClassBg = ['bg-white', 'text-orange-500', 'border-orange-400', 'shadow-sm'];
 const inactiveClassBg = ['bg-white', 'text-neutral-600', 'border-neutral-300', 'hover:bg-neutral-50'];

 const switchView = (targetBtn, targetView) => {
 // Esconder todos
 [gridView, listView, calendarView].forEach(el => el?.classList.add('hidden'));
 // Mostrar target
 targetView?.classList.remove('hidden');
 
 // Resetear clases de todos los botones
 [btnViewCard, btnViewList, btnViewCalendar].forEach(btn => {
 if(!btn) return;
 btn.classList.add(...inactiveClassBg);
 btn.classList.remove(...activeClassBg);
 });
 
 // Activar boton target
 if(targetBtn) {
 targetBtn.classList.remove(...inactiveClassBg);
 targetBtn.classList.add(...activeClassBg);
 }
 };

 btnViewCard?.addEventListener('click', () => switchView(btnViewCard, gridView));
 btnViewList?.addEventListener('click', () => switchView(btnViewList, listView));
 btnViewCalendar?.addEventListener('click', () => switchView(btnViewCalendar, calendarView));


  // ==========================================
  // FASE 2: GENERADOR DE SERIES
  // ==========================================
  const serieModal = document.getElementById('serie-modal');
  const serieFab = document.getElementById('btn-serie-fab');
  const btnCloseSerie = document.getElementById('btn-close-serie');
  const btnCancelSerie = document.getElementById('btn-cancel-serie');
  const btnSubmitSerie = document.getElementById('btn-submit-serie');
  const seriePreview = document.getElementById('serie-preview');
  const serieFechaLimite = document.getElementById('serie-fecha-limite') as HTMLInputElement;


  // Regla del Año en Curso: max = 31 de diciembre del año actual
  if (serieFechaLimite) {
  const maxDate = new Date().getFullYear() + '-12-31';
  serieFechaLimite.setAttribute('max', maxDate);
  serieFechaLimite.addEventListener('change', () => {
  const val = serieFechaLimite.value;
  const currentYear = new Date().getFullYear();
  if (val && new Date(val).getFullYear() > currentYear) {
  alert('La fecha límite no puede pasar del año en curso (' + currentYear + ').');
  serieFechaLimite.value = maxDate;
  }
  });
  }

  // Toggle modal serie
  const toggleSerieModal = (show: boolean) => {
  if (serieModal) {
  if (show) {
  serieModal.classList.remove('hidden');
  // Set defaults
  const today = new Date();
  const todayStr = today.toISOString().slice(0, 10);
  (document.getElementById('serie-fecha-inicio') as HTMLInputElement).value = todayStr;
  if (serieFechaLimite) serieFechaLimite.value = today.getFullYear() + '-12-31';
  } else {
  serieModal.classList.add('hidden');
  }
  }
  };

  serieFab?.addEventListener('click', () => toggleSerieModal(true));
  btnCloseSerie?.addEventListener('click', () => toggleSerieModal(false));
  btnCancelSerie?.addEventListener('click', () => toggleSerieModal(false));
  serieModal?.addEventListener('click', (e) => { if (e.target === serieModal) toggleSerieModal(false); });

  // Preview: mostrar cuántos eventos se generarían
  const updateSeriePreview = () => {
  const diaStr = (document.getElementById('serie-dia') as HTMLSelectElement)?.value;
  const fechaIni = (document.getElementById('serie-fecha-inicio') as HTMLInputElement)?.value;
  const fechaLim = serieFechaLimite?.value;
  if (!diaStr || !fechaIni || !fechaLim || !seriePreview) return;

  const dia = parseInt(diaStr);
  const start = new Date(fechaIni + 'T00:00:00');
  const end = new Date(fechaLim + 'T23:59:59');
  let count = 0;
  const cursor = new Date(start);
  while (cursor <= end) {
  if (cursor.getDay() === dia) count++;
  cursor.setDate(cursor.getDate() + 1);
  }
  if (count > 0) {
  seriePreview.classList.remove('hidden');
  const dias = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  seriePreview.textContent = 'Se generarán ' + count + ' eventos cada ' + dias[dia] + ' desde ' + fechaIni + ' hasta ' + fechaLim;
  } else {
  seriePreview.classList.add('hidden');
  }
  };

  ['serie-dia', 'serie-fecha-inicio', 'serie-fecha-limite'].forEach(id => {
  document.getElementById(id)?.addEventListener('change', updateSeriePreview);
  });

  // Generar Serie
  btnSubmitSerie?.addEventListener('click', async () => {
  const titulo = (document.getElementById('serie-titulo') as HTMLInputElement)?.value?.trim();
  const diaStr = (document.getElementById('serie-dia') as HTMLSelectElement)?.value;
  const horaInicio = (document.getElementById('serie-hora-inicio') as HTMLInputElement)?.value;
  const horaFin = (document.getElementById('serie-hora-fin') as HTMLInputElement)?.value;
  const fechaIni = (document.getElementById('serie-fecha-inicio') as HTMLInputElement)?.value;
  const fechaLim = serieFechaLimite?.value;
  const estado = (document.getElementById('serie-estado') as HTMLSelectElement)?.value || 'Publicado';

  if (!titulo || !diaStr || !horaInicio || !fechaIni || !fechaLim) {
  alert('Completa todos los campos obligatorios.');
  return;
  }

  // Validar año en curso
  const currentYear = new Date().getFullYear();
  if (new Date(fechaLim).getFullYear() > currentYear) {
  alert('La fecha límite no puede pasar del año en curso (' + currentYear + ').');
  return;
  }

  const dia = parseInt(diaStr);
  const uuidSerie = crypto.randomUUID();
  const eventos: any[] = [];

  const start = new Date(fechaIni + 'T00:00:00');
  const end = new Date(fechaLim + 'T23:59:59');
  const cursor = new Date(start);

  while (cursor <= end) {
  if (cursor.getDay() === dia) {
  const fechaHora = new Date(cursor);
  const [h, m] = horaInicio.split(':').map(Number);
  fechaHora.setHours(h, m, 0, 0);

  eventos.push({
  titulo,
  fecha_hora: fechaHora.toISOString(),
  hora_fin: horaFin || null,
  estado,
  created_by: user.id,
  serie_id: uuidSerie
  });
  }
  cursor.setDate(cursor.getDate() + 1);
  }

  if (eventos.length === 0) {
  alert('No se encontraron fechas con el día seleccionado en ese rango.');
  return;
  }

  // Spinner
  const serieSpinner = document.getElementById('serie-spinner');
  const serieSubmitText = btnSubmitSerie.querySelector('span');
  if (serieSpinner) serieSpinner.classList.remove('hidden');
  if (serieSubmitText) serieSubmitText.textContent = 'Generando...';
  (btnSubmitSerie as HTMLButtonElement).disabled = true;

  try {
  // Bulk Insert: insertar en lotes de 50
  for (let i = 0; i < eventos.length; i += 50) {
  const batch = eventos.slice(i, i + 50);
  const { error } = await supabase.from('eventos').insert(batch);
  if (error && !error.message?.includes('No rows returned') && error.code !== '201') throw error;
  }

  toggleSerieModal(false);
  alert('¡Serie creada! Se generaron ' + eventos.length + ' eventos.');
  await fetchAgenda();
  } catch (err: any) {
  console.error('Error generando serie:', err);
  alert('Error al generar serie: ' + (err.message || 'Error desconocido'));
  } finally {
  if (serieSpinner) serieSpinner.classList.add('hidden');
  if (serieSubmitText) serieSubmitText.textContent = 'Generar Serie';
  (btnSubmitSerie as HTMLButtonElement).disabled = false;
  }
  });
 });

</script>
