# Supabase (publico - safe para el cliente)
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX

# Supabase (servidor - nunca exponer al cliente)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXX

# Cloudflare R2 Storage
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_ACCESS_KEY_ID=XXXXXXXXXXXXXXXXXXXX
R2_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXX
PUBLIC_R2_URL=https://pub-XXXXXXXXXXXXXXXXXXXX.r2.dev

# Web Push / Notificaciones
# Generar con: npx web-push generate-vapid-keys
#
# PUBLIC_VAPID_KEY  -> usada en el cliente (BotonNotificaciones.jsx)
# VAPID_PUBLIC_KEY  -> usada en el servidor para firmar
# VAPID_PRIVATE_KEY -> usada solo en el servidor, nunca exponer al cliente
# VAPID_SUBJECT     -> mailto: del administrador
# VAPID_EMAIL       -> alias legacy soportado como fallback
PUBLIC_VAPID_KEY=BPublicVapidKeyXXXXXXXXXXXXXXXXXXXXXXXXX
VAPID_PUBLIC_KEY=BPublicVapidKeyXXXXXXXXXXXXXXXXXXXXXXXXX
VAPID_PRIVATE_KEY=PrivateVapidKeyXXXXXXXXXXXXXXXXXXXXXXXXX
VAPID_SUBJECT=mailto:admin@yourdomain.com
VAPID_EMAIL=mailto:admin@yourdomain.com

# URL publica del sitio (usada en emails y links absolutos)
PUBLIC_SITE_URL=https://yourdomain.com

# Email transaccional (Resend)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
RESEND_FROM=Tu App <noreply@yourdomain.com>

# Secreto interno para invocar Edge Functions de notificaciones desde el servidor.
# Si no se define, el codigo usa SUPABASE_SERVICE_ROLE_KEY como fallback.
NOTIFICATION_FUNCTION_SECRET=change_me_internal_secret

# Registro de usuarios
# Codigo secreto para permitir nuevos registros. Cambiarlo invalida el anterior.
REGISTRATION_CODE=TU_CODIGO_SECRETO

# OpenAI Whisper - Auto-deteccion de section markers
# Solo servidor. Nunca usar prefijo PUBLIC_.

