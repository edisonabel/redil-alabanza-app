  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "serialize-javascript": "^7.0.5",
    "yaml": "^2.8.3"
  }
