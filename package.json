{
  "name": "alabanza",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:lan": "astro dev --host 0.0.0.0 --port 4321",
    "build": "astro build",
    "preview": "astro preview",
    "preview:lan": "astro preview --host 0.0.0.0 --port 4321",
    "local:start": "node scripts/start-local-server.mjs",
    "local:url": "node scripts/print-lan-url.mjs",
    "check": "astro check --minimumFailingSeverity error",
    "test:authorization": "node scripts/test-authorization-boundaries.mjs",
    "test:migrations": "node scripts/check-migration-history.mjs",
    "test:voice-follower": "node scripts/test-voice-lyric-follower.mjs",
    "test:section-alignment": "node --experimental-strip-types scripts/test-global-section-alignment.mjs",
    "test:guide-markers": "node --experimental-strip-types scripts/test-guide-section-markers.mjs",
    "test:audio-routing": "node scripts/test-audio-playback-routing.mjs",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npm run ios:sync && npx cap open ios",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/netlify": "7.0.13",
    "@astrojs/react": "^4.4.2",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@iconify-icons/mdi": "^1.2.48",
    "@iconify/react": "^6.0.2",
    "@sparticuz/chromium": "^143.0.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "2.110.3",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "6.4.8",
    "dotenv": "^17.3.1",
    "driver.js": "^1.4.0",
    "framer-motion": "^12.35.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "mp4box": "^2.3.0",
    "papaparse": "^5.5.3",
    "pg": "^8.19.0",
    "puppeteer": "^24.43.1",
    "puppeteer-core": "^24.43.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rubberband-wasm": "^3.3.0",
    "tailwindcss": "^4.2.1",
    "web-push": "^3.6.7"
